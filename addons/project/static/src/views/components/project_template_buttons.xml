<?xml version="1.0" encoding="utf-8"?>
<templates>
    <t t-name="project.ProjectTemplateButtons">
        <div class="btn-group o_template_icon_group ms-auto d-flex ps-1" t-if="this.isProjectManager">
            <i role="button" t-on-click.stop="this.onEditClick" class="btn btn-link oi oi-filled fs-3" data-icon="edit"></i>
            <i role="button" t-on-click.stop="this.onDeleteClick" class="btn text-danger oi oi-filled fs-3" data-icon="delete"></i>
        </div>
    </t>
</templates>
