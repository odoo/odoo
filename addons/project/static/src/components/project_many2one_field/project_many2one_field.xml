<templates>

    <t t-name="project.ProjectMany2OneField">
        <div class="d-flex align-items-center gap-1">
            <t t-set="isPrivateTask" t-value="this.props.readonly and !this.props.record.data.project_id"/>
            <Many2One t-if="!isPrivateTask" t-props="this.m2oProps"/>
            <span
                t-if="isPrivateTask and !this.props.record.data.is_template"
                class="text-danger fst-italic text-muted"
                t-out="this.labelRegularTask"
            />
            <span
                t-if="isPrivateTask and this.props.record.data.is_template"
                class="text-muted"
                t-out="this.labelTemplateTask"
            />
        </div>
    </t>

</templates>
