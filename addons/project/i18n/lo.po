#. module: project
#: model:mail.template,body_html:project.project_done_email_template
msgid ""
"<div>\n"
"    Dear <t t-out=\"object.partner_id.name or 'customer'\">Brandon Freeman</t>,<br/>\n"
"    It is my pleasure to let you know that we have successfully completed the project \"<strong t-out=\"object.name or ''\">Renovations</strong>\".\n"
"    <t t-if=\"user.signature\" data-o-mail-quote-container=\"1\">\n"
"        <br/>\n"
"        <div data-o-mail-quote=\"1\">--<br data-o-mail-quote=\"1\"/><t t-out=\"user.signature or ''\" data-o-mail-quote=\"1\">Mitchell Admin</t></div>\n"
"    </t>\n"
"</div>\n"
"<br/><span style=\"margin: 0px 0px 0px 0px; font-size: 12px; opacity: 0.5; color: #454748;\" groups=\"project.group_project_stages\">You are receiving this email because your project has been moved to the stage <b t-out=\"object.stage_id.name or ''\">Done</b></span>\n"
"            "
msgstr ""
"<div>\n"
"    ຮຽນ <t t-out=\"object.partner_id.name or 'customer'\">Brandon Freeman</t>"
",<br/>\n"
"    ພວກເຮົາມີຄວາມຍິນດີທີ່ຈະແຈ້ງໃຫ້ທ່ານຊາບວ່າພວກເຮົາໄດ້ເຮັດໂຄງການ \"<strong t-"
"out=\"object.name or ''\">ການປັບປຸງໃໝ່</strong>\" ສຳເລັດແລ້ວ.\n"
"    <t t-if=\"user.signature\" data-o-mail-quote-container=\"1\">\n"
"        <br/>\n"
"        <div data-o-mail-quote=\"1\">--<br data-o-mail-quote=\"1\"/><t t-"
"out=\"user.signature or ''\" data-o-mail-quote=\"1\">Mitchell Admin</t></div>"
"\n"
"    </t>\n"
"</div>\n"
"<br/><span style=\"margin: 0px 0px 0px 0px; font-size: 12px; opacity: 0.5; "
"color: #454748;\" groups=\"project.group_project_stages\">ທ່ານໄດ້ຮັບອີເມລນີ້ຍ້ອນວ່າໂຄ"
