#. module: google_gmail
#. odoo-python
#: code:addons/google_gmail/models/ir_mail_server.py:0
msgid ""
"Incorrect Connection Security for Gmail mail server “%s”. Please set it to "
"\"TLS (STARTTLS)\"."
msgstr ""
"ຄວາມປອດໄພການເຊື່ອມຕໍ່ບໍ່ຖືກຕ້ອງສຳລັບເຊີເວີເມລ Gmail “%s”. ກະລຸນາຕັ້ງຄ່າເປັນ \"TLS (STARTTLS)"
"\"."

#. module: google_gmail
#: model:ir.model,name:google_gmail.model_ir_mail_server
msgid "Mail Server"
msgstr "ເຊີເວີເມລ"

#. module: google_gmail
#. odoo-python
#: code:addons/google_gmail/models/google_gmail_mixin.py:0
msgid "Only the administrator can link a Gmail mail server."
msgstr "ມີພຽງແຕ່ຜູ້ເບິ່ງແຍງລະບົບເທົ່ານັ້ນທີ່ສາມາດເຊື່ອມໂຍງເຊີເວີເມລ Gmail ໄດ້."

#. module: google_gmail
#. odoo-python
#: code:addons/google_gmail/models/google_gmail_mixin.py:0
msgid "Please configure your Gmail credentials."
msgstr "ກະລຸນາຕັ້ງຄ່າຂໍ້ມູນປະຈຳຕົວ Gmail ຂອງທ່ານ."

#. module: google_gmail
#. odoo-python
#: code:addons/google_gmail/models/ir_mail_server.py:0
msgid ""
"Please fill the \"Username\" field with your Gmail username (your email "
"address). This should be the same account as the one used for the Gmail "
"OAuthentication Token."
msgstr ""
"ກະລຸນາຕື່ມຂໍ້ມູນໃສ່ຫ້ອງ \"ຊື່ຜູ້ໃຊ້\" ດ້ວຍຊື່ຜູ້ໃຊ້ Gmail ຂອງທ່ານ (ທີ່ຢູ່ອີເມລຂອງທ່ານ). ນີ້ຄວນເປັນບັນຊີດຽວກັນ"
"ກັບບັນຊີທີ່ໃຊ້ສຳລັບ Gmail OAuthentication Token."

#. module: google_gmail
#. odoo-python
#: code:addons/google_gmail/models/ir_mail_server.py:0
msgid ""
"Please leave the password field empty for Gmail mail server “%s”. The OAuth "
"process does not require it"
msgstr ""
"ກະລຸນາປະຫ້ອງລະຫັດຜ່ານໃຫ້ວ່າງໄວ້ສຳລັບເຊີເວີເມລ Gmail “%s”. ຂະບວນການ OAuth ບໍ່ຈຳເປັນຕ້ອງໃຊ້ລະຫັ"
"ດຜ່ານ"

