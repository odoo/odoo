#. module: google_gmail
#. odoo-python
#: code:addons/google_gmail/models/ir_mail_server.py:0
msgid ""
"Incorrect Connection Security for Gmail mail server “%s”. Please set it to "
"\"TLS (STARTTLS)\"."
msgstr ""
"ລະບົບຄວາມປອດໄພຂອງການເຊື່ອມຕໍ່ບໍ່ຖືກຕ້ອງສຳລັບເຊີເວີເມລ Gmail “%s”. ກະລຸນາຕັ້ງຄ່າໃຫ້ເປັນ \"TLS "
"(STARTTLS)\"."

#. module: google_gmail
#: model:ir.model,name:google_gmail.model_ir_mail_server
