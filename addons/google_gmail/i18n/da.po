#: model:ir.model,name:google_gmail.model_ir_mail_server
msgid "Mail Server"
msgstr "Mailserver"

#. module: google_gmail
#. odoo-python
#: code:addons/google_gmail/models/google_gmail_mixin.py:0
msgid "Only the administrator can link a Gmail mail server."
msgstr "Kun administratoren kan forbinde en Gmail-mailserver."

#. module: google_gmail
#. odoo-python
#: code:addons/google_gmail/models/google_gmail_mixin.py:0
msgid "Please configure your Gmail credentials."
msgstr "Konfigurér venligst dine Gmail-loginoplysninger."

#. module: google_gmail
#. odoo-python
#: code:addons/google_gmail/models/ir_mail_server.py:0
msgid ""
"Please fill the \"Username\" field with your Gmail username (your email "
"address). This should be the same account as the one used for the Gmail "
"OAuthentication Token."
msgstr ""
"Udfyld venligst feltet 'Brugernavn' med dit Gmail-brugernavn (din e-"
"mailadresse). Det skal være den samme konto, som blev brugt til Gmail OAuth-"
"tokenet."

#. module: google_gmail
#. odoo-python
#: code:addons/google_gmail/models/ir_mail_server.py:0
msgid ""
"Please leave the password field empty for Gmail mail server “%s”. The OAuth "
"process does not require it"
msgstr ""
"Lad feltet \"Adgangskode\" være tomt for Gmail-mailserveren \"%s\". OAuth-"
"processen kræver ingen adgangskode"

