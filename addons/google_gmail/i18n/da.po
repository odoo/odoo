#. module: google_gmail
#. odoo-python
#: code:addons/google_gmail/models/ir_mail_server.py:0
msgid ""
"Incorrect Connection Security for Gmail mail server “%s”. Please set it to "
"\"TLS (STARTTLS)\"."
msgstr ""
"Ugyldig forbindelsessikkerhed til Gmail-mailserver \"%s\". Sæt den venligst "
"til \"TLS (STARTTLS)\"."

