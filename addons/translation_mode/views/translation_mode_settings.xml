<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="translation_mode_settings_form" model="ir.ui.view">
        <field name="name">translation_mode.settings.form</field>
        <field name="model">translation_mode.settings</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <label for="language" />
                    <div class="o_input_box">
                        <field name="language" required="1" class="w-100" />
                        <button
                            type="action"
                            name="%(base.action_view_base_language_install)d"
                            class="btn btn-link fa fa-globe o_input_box_overlay_end"
                            groups="base.group_system"
                            aria-label="Add a language"
                            title="Add a language"
                        />
                    </div>
                    <field name="translation_url" />
                </group>
                <footer>
                    <button class="btn btn-primary" type="object" name="save_and_reload" string="Save" />
                    <button special="cancel" />
                </footer>
            </form>
        </field>
    </record>
</odoo>
