msgstr "POS Adyen ຂໍທິບຈາກລູກຄ້າ"

#. module: pos_adyen
#: model:ir.model.fields,help:pos_adyen.field_pos_payment_method__adyen_test_mode
msgid "Run transactions in the test environment."
msgstr "ດຳເນີນທຸລະກຳໃນສະພາບແວດລ້ອມທົດລອງ."

#. module: pos_adyen
#. odoo-python
#: code:addons/pos_adyen/models/pos_payment_method.py:0
msgid ""
"Terminal %(terminal)s is already used in company %(company)s on payment "
"method %(payment_method)s."
msgstr ""
"ເຄື່ອງ %(terminal)s ຖືກນຳໃຊ້ແລ້ວໃນບໍລິສັດ %(company)s ສຳລັບວິທີການຊຳລະເງິນ %"
"(payment_method)s."

#. module: pos_adyen
#. odoo-python
#: code:addons/pos_adyen/models/pos_payment_method.py:0
msgid ""
"Terminal %(terminal)s is already used on payment method %(payment_method)s."
msgstr "ເຄື່ອງ %(terminal)s ຖືກນຳໃຊ້ແລ້ວໃນວິທີການຊຳລະເງິນ %(payment_method)s."

#. module: pos_adyen
#: model:ir.model.fields,help:pos_adyen.field_pos_payment_method__adyen_event_url
msgid "This URL needs to be pasted on Adyen's portal terminal settings."
msgstr ""
"URL ນີ້ຕ້ອງໄດ້ເອົາໄປວາງໄວ້ໃນການຕັ້ງຄ່າເທີມິນອລໃນພໍທັລ (Portal) ຂອງ Adyen."

#. module: pos_adyen
#: model:ir.model.fields,help:pos_adyen.field_pos_payment_method__adyen_api_key
msgid ""
"Used when connecting to Adyen: https://docs.adyen.com/user-management/how-"
"to-get-the-api-key/#description"
msgstr ""
"ໃຊ້ໃນເວລາເຊື່ອມຕໍ່ຫາ Adyen: https://docs.adyen.com/user-management/how-to-get-the-"
"api-key/#description"

#. module: pos_adyen
#: model:ir.model.fields,help:pos_adyen.field_pos_payment_method__adyen_terminal_identifier
msgid "[Terminal model]-[Serial number], for example: P400Plus-123456789"
msgstr "[ລຸ້ນຂອງເຄື່ອງ]-[ໝາຍເລກຊີຣີ], ຕົວຢ່າງ: P400Plus-123456789"
