#. module: pos_adyen
#. odoo-javascript
#: code:addons/pos_adyen/static/src/app/utils/payment/payment_adyen.js:0
msgid "Authentication failed. Please check your Adyen credentials."
msgstr "ການຢືນຢັນຕົວຕົນລົ້ມເຫຼວ. ກະລຸນາກວດສອບຂໍ້ມູນປະຈຳຕົວ Adyen ຂອງທ່ານ."

#. module: pos_adyen
#. odoo-javascript
#: code:addons/pos_adyen/static/src/app/utils/payment/payment_adyen.js:0
msgid ""
"Cancelling the payment failed. Please cancel it manually on the payment "
"terminal."
msgstr ""
"ການຍົກເລີກການຊຳລະເງິນລົ້ມເຫຼວ. ກະລຸນາຍົກເລີກດ້ວຍຕົນເອງຢູ່ທີ່ເຄື່ອງຊຳລະເງິນ."

#. module: pos_adyen
#. odoo-javascript
#: code:addons/pos_adyen/static/src/app/utils/payment/payment_adyen.js:0
msgid "Cannot process transactions with negative amount."
msgstr "ບໍ່ສາມາດປະມວນຜົນທຸລະກຳທີ່ມີຈຳນວນເງິນຕິດລົບໄດ້."

#. module: pos_adyen
#: model:ir.model,name:pos_adyen.model_res_config_settings
