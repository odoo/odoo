#. module: pos_adyen
#. odoo-python
#: code:addons/pos_adyen/models/pos_config.py:0
msgid ""
"Please configure a tip product for POS %s to support tipping with Adyen."
msgstr "ກະລຸນາກຳນົດຄ່າສິນຄ້າທິບສຳລັບ POS %s ເພື່ອຮອງຮັບການໃຫ້ທິບດ້ວຍ Adyen."

#. module: pos_adyen
#: model:ir.model,name:pos_adyen.model_pos_config
msgid "Point of Sale Configuration"
msgstr "ການກຳນົດຄ່າຈຸດຂາຍ"

#. module: pos_adyen
#: model:ir.model,name:pos_adyen.model_pos_payment_method
msgid "Point of Sale Payment Methods"
msgstr "ວິທີການຊຳລະເງິນຂອງຈຸດຂາຍ"

#. module: pos_adyen
#: model:ir.model.fields,field_description:pos_adyen.field_res_config_settings__pos_adyen_ask_customer_for_tip
