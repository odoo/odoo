<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="hr_work_entry.ExportWorkEntriesCogMenu">
        <div t-if="is_actionmenu">
            <button type="button" class="btn btn-secondary" t-on-click="this.exportWorkEntries">
                <i class="fa fa-users me-1"/>
                Export Time Entries
            </button>
        </div>
        <DropdownItem t-else="" onSelected.bind="this.exportWorkEntries">
            <i class="fa fa-users me-1"/>
            Export Time Entries
        </DropdownItem>
    </t>

</templates>
