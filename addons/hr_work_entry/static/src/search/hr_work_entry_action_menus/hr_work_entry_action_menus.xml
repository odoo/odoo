<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="hr_work_entry.actionmenu" t-inherit="hr.actionmenu" t-inherit-mode="extension">
        <xpath expr="//div[@t-if='props.items.print?.length']" position="before">
            <t t-if="hasAvailableExports" class="d-inline-block">
                <t t-call="hr_work_entry.ExportCogMenu">
                    <t t-set="is_actionmenu" t-value="'True'"/>
                </t>
            </t>
        </xpath>
    </t>
</templates>
