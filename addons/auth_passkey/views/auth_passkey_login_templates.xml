<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template priority="32" id="auth_passkey_login" inherit_id="web.login">
        <xpath expr="//div[hasclass('o_login_auth')]" position="attributes">
            <attribute name="t-if">true</attribute>
        </xpath>
        <xpath expr="//div[hasclass('o_login_auth')]/div" position="inside">
            <button class="passkey_login_link list-group-item list-group-item-action py-2" type="button">
                <i class="fa fa-qrcode" role="presentation"/>
                Use a Passkey
            </button>
        </xpath>
        <xpath expr="//input[@name='redirect']" position="before">
            <input type="hidden" name="webauthn_response"/>
        </xpath>
    </template>
</odoo>
