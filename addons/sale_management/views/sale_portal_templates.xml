<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="sale_order_portal_optional_product_quantity" name="Order Quantity">
        <div t-if="line._can_be_edited_on_portal()" class="d-inline-flex align-items-center gap-1">
            <div class="input-group js_quantity_container d-inline-flex border rounded w-auto">
                <a
                    title="Remove one"
                    aria-label="Remove one"
                    href="#"
                    t-att-class="'btn btn-link pe-2 border-0 opacity-50' if line.product_uom_qty == 0 else 'btn btn-link pe-2 border-0 js_update_line_json'"
                    t-att-data-line-id="line.id"
                    t-att-data-remove="True"
                >
                    <i class="oi oi-minus text-600"/>
                </a>
                <input
                    type="text"
                    size="3"
                    class="js_quantity form-control text-center border-0"
                    style="min-width: 2rem; field-sizing: content"
                    t-att-data-line-id="line.id"
                    t-att-value="int(line.product_uom_qty) or '0'"
                />
                <a
                    title="Add one"
                    aria-label="Add one"
                    class="btn btn-link ps-2 border-0 js_update_line_json"
                    href="#"
                    t-att-data-line-id="line.id"
                >
                    <i class="oi oi-plus text-600"/>
                </a>
            </div>
            <span class="align-self-center" t-field="line.product_uom_id"/>
        </div>
        <div t-else="">
            <span t-field="line.product_uom_qty"/>
            <span t-field="line.product_uom_id"/>
        </div>
    </template>

    <template id="sale_order_portal_content_inherit_sale_management" name="Order Options" inherit_id="sale.sale_order_portal_content">
        <xpath expr="//tr[@name='tr_product']" position="attributes">
            <attribute name="class" add="align-middle" separator=" "/>
        </xpath>
        <xpath expr="//td[@name='td_product_quantity']/div[@id='quote_qty']" position="replace">
            <t t-call="sale_management.sale_order_portal_optional_product_quantity"/>
        </xpath>
        <xpath expr="//td[@name='td_combo_quantity']/div[@id='quote_qty']" position="replace">
            <t t-call="sale_management.sale_order_portal_optional_product_quantity"/>
        </xpath>
        <xpath expr="//div[hasclass('d-lg-none')]//span[@name='span_qty_uom']" position="replace">
            <t t-call="sale_management.sale_order_portal_optional_product_quantity"/>
        </xpath>
    </template>

</odoo>
