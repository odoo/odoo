<?xml version="1.0" encoding="UTF-8"?>

<templates>
    <t t-inherit="account.SectionDropdown" t-inherit-mode="extension">
        <t t-name="composition_button" position="after">
            <DropdownItem
                t-if="'is_optional' in this.props.section"
                onSelected="() => this.toggleFieldOfSection('is_optional')"
                attrs="{ 'class': this.disableOptionalButton() ? 'disabled' : '' }"
            >
                <i class="me-1 fa fa-fw fa-dot-circle-o"/>
                <span t-if="this.props.section.is_optional">Unset Optional</span>
                <span t-else="">Set Optional</span>
            </DropdownItem>
        </t>
    </t>
</templates>
