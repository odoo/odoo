<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Privilege for WooCommerce groups -->
        <record id="privilege_woocommerce" model="res.groups.privilege">
            <field name="name">WooCommerce</field>
            <field name="category_id" ref="channel_base.module_channel_base"/>
        </record>

        <record id="group_woocommerce_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="privilege_woocommerce"/>
            <field name="implied_ids" eval="[Command.link(ref('channel_base.group_channel_user'))]"/>
            <field name="comment">Can view WooCommerce backends and sync logs.</field>
        </record>

        <record id="group_woocommerce_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="privilege_woocommerce"/>
            <field name="implied_ids" eval="[Command.link(ref('group_woocommerce_user')), Command.link(ref('channel_base.group_channel_manager'))]"/>
            <field name="comment">Can configure WooCommerce backends, credentials, and trigger syncs.</field>
        </record>

    </data>
</odoo>
