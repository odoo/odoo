<!-- Tutor Availability Views -->
<record id="view_tutor_availability_list" model="ir.ui.view">
<field name="name">tutor.availability.list</field>
<field name="model">tutor.availability</field>
<field name="arch" type="xml">
<list string="Tutor Availability">
<field name="tutor_id"/>
<field name="availability_type"/>
<field name="start_time_display"/>
<field name="end_time_display"/>
<field name="timezone"/>
<field name="active"/>
</list>
</field>
</record>

<record id="view_tutor_availability_form" model="ir.ui.view">
<field name="name">tutor.availability.form</field>
<field name="model">tutor.availability</field>
<field name="arch" type="xml">
<form string="Tutor Availability">
<sheet>
<group>
<field name="tutor_id"/>
<field name="availability_type"/>
<field name="timezone"/>
<field name="active"/>
</group>

<group string="Time Slot">
<group>
<div style="display: flex; align-items: center; gap: 8px; margin-bottom: 12px;">
<span style="font-weight: bold; min-width: 80px;">Start Time</span>
<field name="start_hour" nolabel="1" style="width: 50px;"/>
<span>:</span>
<field name="start_minute" nolabel="1" style="width: 50px;"/>
</div>
<div style="display: flex; align-items: center; gap: 8px; margin-bottom: 12px;">
<span style="font-weight: bold; min-width: 80px;">End Time</span>
<field name="end_hour" nolabel="1" style="width: 50px;"/>
<span>:</span>
<field name="end_minute" nolabel="1" style="width: 50px;"/>
</div>
</group>
</group>

<group string="Days of Availability">
<field name="monday"/>
<field name="tuesday"/>
<field name="wednesday"/>
<field name="thursday"/>
<field name="friday"/>
<field name="saturday"/>
<field name="sunday"/>
</group>

<group string="Notes">
<field name="notes" nolabel="1"/>
</group>
</sheet>
</form>
</field>
</record>

