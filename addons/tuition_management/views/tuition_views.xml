<!-- Enquiry Views -->
<record id="view_enquiry_form" model="ir.ui.view">
<field name="name">enquiry.form</field>
<field name="model">enquiry</field>
<field name="arch" type="xml">
<form string="Enquiry">
<header>
<button name="action_convert_to_student" type="object" string="Convert to Student" class="btn-secondary"/>
<button name="action_convert_to_parent" type="object" string="Convert to Parent" class="btn-secondary"/>
</header>
<div class="alert alert-info" role="status">
<field name="status" nolabel="1" widget="statusbar" options="{'clickable': True}"/>
</div>
<sheet>
<group string="Enquiry Information">
<field name="enquiry_name"/>
<field name="enquiry_date"/>
</group>
<group string="Personal Information">
<field name="first_name"/>
<field name="middle_name"/>
<field name="last_name"/>
<field name="name" readonly="1"/>
<field name="student_name"/>
<field name="email"/>
<field name="phone"/>
<field name="partner_id"/>
</group>
<group string="Academic Information">
<field name="subject_id"/>
<field name="grade_id"/>
</group>
<group string="Demo Sessions">
<field name="demo_session_ids"/>
</group>
<group string="Notes">
<field name="notes" nolabel="1"/>
</group>
</sheet>
</form>
</field>
</record>

