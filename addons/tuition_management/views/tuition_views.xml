<field name="phone"/>
</group>
<group string="Address">
<field name="address_line_1" placeholder="Address Line 1"/>
<field name="address_line_2" placeholder="Address Line 2"/>
<field name="address_line_3" placeholder="Address Line 3"/>
<field name="address_line_4" placeholder="Address Line 4"/>
<field name="zip_code"/>
