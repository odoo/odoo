  <!-- Tutor Portal: My Courses Taught -->
  <template id="portal_my_courses_taught" name="My Courses Taught">
    <t t-call="portal.portal_layout">
      <div class="container">
        <h2>My Courses</h2>
        <t t-if="courses">
          <table class="table table-striped">
            <thead>
              <tr>
                <th>Course</th>
                <th>Subject</th>
              </tr>
            </thead>
            <tbody>
              <tr t-foreach="courses" t-as="course">
                <td><t t-esc="course.name"/></td>
                <td><t t-esc="course.subject_id.name"/></td>
              </tr>
            </tbody>
          </table>
        </t>
        <t t-else="">
          <p class="alert alert-info">You are not teaching any courses yet.</p>
        </t>
      </div>
    </t>
  </template>

