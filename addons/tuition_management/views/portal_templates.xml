                <th>Time</th>
              </tr>
            </thead>
            <tbody>
              <tr t-foreach="schedules" t-as="schedule">
                <td><t t-esc="schedule.name"/></td>
                <td><t t-esc="schedule.schedule_type"/></td>
                <td><t t-esc="schedule.schedule_time"/></td>
              </tr>
            </tbody>
          </table>
        </t>
        <t t-else="">
          <p class="alert alert-info">No teaching schedules found.</p>
        </t>
      </div>
    </t>
  </template>

  <!-- Tutor Portal: Student Attendance Management -->
  <template id="portal_student_attendance" name="Student Attendance">
    <t t-call="portal.portal_layout">
      <div class="container">
        <h2>Attendance</h2>
        <t t-if="attendance_records">
          <table class="table table-striped">
            <thead>
              <tr>
                <th>Student</th>
                <th>Date</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <tr t-foreach="attendance_records" t-as="record">
                <td><t t-esc="record.student_id.first_name"/></td>
