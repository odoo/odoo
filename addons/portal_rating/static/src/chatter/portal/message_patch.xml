<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="mail.Message" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o-mail-Message-core')]" position="attributes">
            <attribute name="t-att-class">{ 'o-review-Message-core': this.displayRating }</attribute>
        </xpath>
        <xpath expr="//div[hasclass('o-mail-Message-sidebar')]" position="attributes">
            <attribute name="t-att-class">{ 'align-items-start': !this.isAlignedRight, 'o-inChatWindow': this.env.inChatWindow, 'o-review-Message-sidebar me-2': this.displayRating }</attribute>
        </xpath>
        <xpath expr="//*[@t-custom-ref='messageContent']" position="attributes">
            <attribute name="t-att-class">{ 'flex-grow-1': this.isEditing, 'o-review-Message-content': this.displayRating }</attribute>
        </xpath>
        <div name="header" position="inside">
            <div t-if="this.ratingValue" class="w-100 mt-1">
                <t t-call="portal_rating.rating_stars_static" val="this.ratingValue"/>
            </div>
        </div>
        <xpath expr="//div[hasclass('o-mail-Message-richBody')]" position="after">
            <button
                t-if="this.displayRating and this.ratingValue and this.state.isBodyClamped"
                type="button"
                class="btn btn-link p-0 mt-1"
                t-on-click="this.toggleBodyExpand"
            >
                <t t-if="this.state.showFullBody">Show less</t>
                <t t-else="">Show more</t>
            </button>
        </xpath>
        <xpath expr="//*[@t-custom-ref='messageContent']" position="inside">
            <!--Only possible if a rating is link to the message, for now we can't comment if no rating
                is link to the message (because publisher comment data
                is on the rating.rating model - one comment max) -->
            <div t-if="this.message.rating_id and this.message.rating_id.id" class="o_wrating_publisher_container">
                <button t-if="this.store.self.is_user_publisher"
                    t-attf-class="btn px-2 my-2 mb-0 btn-sm border o_wrating_js_publisher_comment_btn {{ this.message.rating_id.publisher_comment !== '' ? 'd-none' : '' }}"
                    t-on-click="this.onClikEditComment">
                    <i class="fa fa-comment-o text-muted me-1"/>Comment
                </button>
                <div t-if="this.state.editRating" class="mt-2">
                    <Composer autofocus="true" composer="this.message.composer" onDiscardCallback.bind="this.exitEditCommentMode" onPostCallback.bind="this.exitEditCommentMode" mode="'compact'"/>
                </div>
                <div t-if="this.message.rating_id.publisher_comment and !this.state.editRating" class="o_wrating_publisher_comment my-2 ms-4">
                    <div class="o-mail-Message-core position-relative d-flex flex-shrink-0">
                        <div class="o-mail-Message-sidebar flex-basis-auto d-flex flex-shrink-0 me-2">
                            <div class="o-mail-Message-avatarContainer position-relative">
                                <img class="o-mail-Message-avatar w-100 h-100 rounded"
                                     t-att-src="this.message.rating_id.publisher_avatar" t-att-class="this.authorAvatarAttClass"/>
                            </div>
                        </div>
                        <div class="w-100 min-w-0">
                            <div class="o-mail-Message-header d-flex flex-wrap align-items-baseline lh-1">
                                <strong class="me-1 text-truncate smaller"><t t-out="this.message.rating_id.publisher_name"/></strong>
                                <span class="o-mail-Message-date o-xsmaller">Published on <t t-out="this.message.rating_id.publisher_datetime"/></span>
                                <div t-if="this.store.self.is_user_publisher" class="d-flex rounded-0">
                                    <Dropdown>
                                        <button class="bg-transparent border-0">
                                            <i class="btn px-1 py-0 oi oi-ellipsis-v"/>
                                        </button>
                                        <t t-set-slot="content">
                                            <DropdownItem class="'o_wrating_js_publisher_comment_edit'" onSelected="() => this.onClikEditComment()">
                                                <i class="fa fa-fw fa-pencil me-1"/>Edit
                                            </DropdownItem>
                                            <DropdownItem class="'o_wrating_js_publisher_comment_delete'" onSelected="() => this.deleteComment()">
                                                <i class="fa fa-fw fa-trash-o me-1"/>Delete
                                            </DropdownItem>
                                        </t>
                                    </Dropdown>
                                </div>
                            </div>
                            <div class="position-relative d-flex">
                                <div class="min-w-0 position-relative d-flex overflow-x-auto d-inline-block">
                                    <div class="o-mail-Message-bubble rounded-bottom-3 position-absolute top-0 start-0 w-100 h-100 opacity-25 rounded-end-3"/>
                                    <div class="o-mail-Message-body o-mail-Message-body-wrating position-relative text-break px-0 mb-0 align-self-start">
                                        <p><t t-out="this.message.rating_id.publisher_comment"/></p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </t>
</templates>
