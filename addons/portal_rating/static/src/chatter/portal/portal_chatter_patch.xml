<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="portal.Chatter" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o-mail-Chatter-top')]/*[1]" position="before">
            <div t-if="this.portalChatterPlugin?.displayRating() and this.ratingStats and this.ratingStats.total" class="my-2" t-att-class="{ 'mb-4':this.twoColumns() }">
                <t t-call="portal_rating.rating_card"
                    two_columns="this.twoColumns()"
                    rating_stats="this.ratingStats"
                    selected_rating="this.state.thread?.selectedRating"/>
            </div>
        </xpath>
    </t>
</templates>
