<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_self_order.KioskProductListPage">
        <div class="o_kiosk_product_list_page d-flex flex-column vh-100 overflow-hidden bg-secondary">

            <!-- Categories -->
            <div class="category_container d-flex flex-nowrap flex-column w-100 bg-white border-bottom border-light user-select-none">
                <div class="category_list d-flex mx-auto px-4 py-4 gap-3 overflow-x-auto overflow-y-hidden mw-100" t-ref="category_list">
                    <t t-foreach="state.topCategories" t-as="category" t-key="category.id">
                        <t t-set="isSelectedCategory" t-value="category === topSelectedCategory"/>
                        <button t-on-click="() => this.selectCategory(category)"
                            role="button" class="category_btn d-flex flex-column align-items-center bg-white border-0"
                            t-att-class="{'selected': isSelectedCategory}">
                        <img class="object-cover mb-2 rounded-pill bg-secondary transition-base "
                             t-attf-src="/web/image/pos.category/#{category.id}/image_128?unique=#{category.write_date}"
                             t-att-class="{'border-primary': isSelectedCategory}"  draggable="false"/>
                        <span class="fs-3 text-nowrap" t-att-class="{'fw-bold': isSelectedCategory}"
                              t-esc="category.name"/>
                        </button>
                    </t>
                </div>
            </div>

            <div class="sub_category_container d-flex flex-shrink-0" t-ref="sub_cat_container" t-att-class="{'show': state.subCategories?.length > 0}">
                <div t-if="state.subCategories?.length > 0"  class="d-flex flex-nowrap flex-column w-100 bg-white border-bottom border-light user-select-none">
                    <div class="category_list flex-shrink-0 d-flex mx-auto py-3 px-4 gap-3 overflow-x-auto overflow-y-hidden mw-100" t-ref="sub_category_list">
                        <t t-set="isAllSelected" t-value="!selectedCategory.parent_id "/>
                        <button t-on-click="() => this.selectCategory(topSelectedCategory)"
                             role="button" class="child_category_btn d-flex align-items-center border-1 px-4 rounded-pill bg-secondary justify-content-center"
                             t-att-class="{'border-primary': isAllSelected, 'border-transparent': !isAllSelected}" style="min-width: 120px">
                            <span class="fs-3 text-nowrap">All</span>
                        </button>
                        <t t-foreach="state.subCategories" t-as="child_category" t-key="child_category.id">
                            <t t-set="isSelectedChildCategory" t-value="child_category === selectedCategory "/>
                            <button t-on-click="() => this.selectCategory(child_category)"
                                 role="button" class="child_category_btn d-flex align-items-center border-1 px-4 rounded-pill bg-secondary"
                                 t-att-class="{'border-primary': isSelectedChildCategory, 'border-transparent': !isSelectedChildCategory}">
                                <img class="object-cover me-2 flex-shrink-0" t-attf-src="/web/image/pos.category/#{child_category.id}/image_128?unique=#{child_category.write_date}" draggable="false"/>
                                <span class="fs-3 text-nowrap"  t-esc="child_category.name"/>
                            </button>
                        </t>
                    </div>
                </div>
            </div>

            <!-- Products -->
            <t t-set="productList" t-value="products"/>
            <div class="d-flex flex-grow-1 justify-content-center position-relative overflow-y-auto  align-items-start"  >
                <div class="product_list d-flex flex-wrap justify-content-center px-4 w-100" t-att-class="{'product_list_small': productList.length &lt; 5}">
                    <div class="spacer"></div>
                    <button t-foreach="productList" t-as="product" t-key="product.id" t-on-click="(evt) => this.selectProduct(product, evt.target)"
                            role="button" class="o_kiosk_product_box d-flex flex-column align-items-center bg-white position-relative p-4"
                            t-att-class="{'opacity-50' : !product.self_order_available || !isProductAvailable(product)}">
                        <img class="object-fit-contain mb-3"  t-attf-src="/web/image/product.template/#{product.id}/image_512?unique=#{product.write_date}" loading="lazy"/>
                        <span t-esc="product.name" class="fs-2  fw-bold m-0 text-break"/>
                        <span t-esc="selfOrder.formatMonetary(selfOrder.getProductDisplayPrice(product))"
                              class="o-so-tabular-nums mt-1 fs-2 fw-bold text-muted "/>
                        <div class="text-center mt-2 fs-lighter">
                            <div t-if="!product.self_order_available"  class="fs-lighter bg-secondary rounded p-1 px-3">Out of stock</div>
                            <div t-elif="!isProductAvailable(product)" class="fs-lighter bg-secondary rounded p-1 px-3">Unavailable</div>
                        </div>
                        <t t-set="qty" t-value="state.quantityByProductTmplId[product.id]" />
                        <span t-if="qty" t-esc="qty" class="position-absolute top-0 end-0 px-3 py-1 m-3 rounded-pill bg-black text-white fs-5 fw-bold"/>
                    </button>
                    <div class="spacer"></div>
                </div>
            </div>
            <OrderWidget t-if="this.selfOrder.ordering" action.bind="review"/>
        </div>
    </t>
</templates>
