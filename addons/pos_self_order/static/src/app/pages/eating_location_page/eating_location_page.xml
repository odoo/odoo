<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve" >
    <t t-name="pos_self_order.EatingLocationPage">
        <t t-if="selfOrder.kioskMode">
            <div class="o_kiosk_eating_location_box d-flex flex-column flex-grow-1 bg-secondary overflow-y-auto"
                 t-attf-style="background-image:#{selfOrder.kioskBackgroundImage};background-size: cover; background-position: center;">
                <div class="d-flex flex-column flex-grow-1 justify-content-center  ">
                    <h1 class="mx-4 m-0 mb-4 mt-4 mb-md-5 pb-md-5 fw-bold header text-center">Where do you want<br/>to eat?</h1>
                    <div class="d-flex flex-wrap align-items-stretch justify-content-center gap-5">
                        <button t-foreach="presets"
                                t-as="preset" t-key="preset.id"
                                t-on-click="() => this.selectPreset(preset)"
                                role="button"
                                class="preset_btn bg-white border p-0 d-flex flex-column border-light "
                                t-att-class="{'justify-content-center': !preset.has_image}">
                            <t t-if="preset.has_image">
                                <div class="img_container w-100 ratio ratio-1x1">
                                    <img class="w-100 h-100 object-fit-cover" t-attf-src="/web/image/pos.preset/#{preset.id}/image_512?unique=#{preset.write_date} "/>
                                </div>
                                <h1 t-esc="preset.name" class="px-1 m-0 flex-grow-1"/>
                            </t>
                            <t t-else="">
                                <h1 t-esc="preset.name" class="px-1 m-0"/>
                            </t>
                        </button>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center position-relative mx-4 mt-4 mb-5 ">
                    <button class="btn btn-lg bg-white btn-back" t-on-click="()=>this.onClickBack()">
                         <i class="oi oi-chevron-left d-md-none" />
                         <span class="d-none d-md-inline">Back</span>
                    </button>
                    <div></div>
                    <KioskLanguageSelector extraClass="'position-absolute start-50 translate-middle-x'"/>
                </div>
            </div>
        </t>
        <t t-else="">
            <div class="o_self_eating_location d-flex flex-column align-items-center flex-grow-1 bg-300 bg-gradient overflow-y-auto text-center">
                <h1 class="pt-3 m-0">Choose your eating location</h1>
                <div class="container d-flex flex-wrap align-items-center justify-content-center gap-3 my-auto">
                    <button t-foreach="presets"
                        t-as="preset" t-key="preset.id"
                        t-on-click="() => this.selectPreset(preset)"
                        role="button"
                        class="o_self_eating_location_box btn btn-light">
                        <img t-if="preset.image_128" t-att-src="'data:image/png;base64,' + preset.image_128" />
                        <h3 t-esc="preset.name"/>
                    </button>
                </div>
            </div>
            <div class="page-buttons shadow-sm p-3 bg-view border-top text-center">
                <button class="btn btn-secondary btn-lg" t-on-click="()=>this.onClickBack()">
                    <i class="oi oi-chevron-left"/>
                    Back
                </button>
            </div>
        </t>
    </t>
</templates>
