<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_self_order.ProductCard">
        <t t-set="product" t-value="this.props.product" />
        <t t-set="snoozed" t-value="this.isProductSnoozed" />
        <t t-set="productTmpl" t-value="this.productTmpl" />
        <article
            class="o_self_product_card position-relative d-flex flex-row-reverse flex-lg-column align-items-start cursor-pointer"
            t-on-click="(evt) => this.selectProduct(evt.target)"
            t-att-class="{'opacity-25' : snoozed}"
            t-attf-class="{{this.props.class}}"
            role="button"
        >
            <div t-att-class="{'d-none d-lg-block': !product.showProductImageInSelf}" class="product_img ratio ratio-1x1 w-lg-100 flex-shrink-0 ms-2 ms-lg-0">
                <img class="o_self_product_card_img object-fit-scale rounded-4" t-attf-src="/web/image/product.template/#{productTmpl.id}/image_512?unique=#{productTmpl.write_date}" loading="lazy"/>
            </div>
            <div class="d-flex flex-column w-100 mt-lg-2 mt-kiosk-p-3 gap-lg-1 text-lg-center align-items-lg-center flex-grow-1">
                <!-- Product Name -->
                <div class="self_order_product_name d-inline-block">
                    <span t-out="this.formatProductName(product)" class="align-middle fs-4 fw-bold text-break"/>
                    <div t-if="product.public_description or product.product_tag_ids.length > 0"
                            class="product_info_icon d-inline-flex justify-content-center align-items-center border border-dark rounded-circle text-center"
                            t-on-click.stop="()=>this.displayProductInfo()">
                        <i class="fa fa-info "/>
                    </div>
                </div>
                <t t-call-slot="default"/>
                <div t-if="snoozed" class="badge my-1 rounded-pill text-bg-danger w-auto me-auto mx-lg-auto">Out of stock</div>
                <span t-if="!this.props.hidePrice" t-out="this.selfOrder.formatMonetary(this.selfOrder.getProductDisplayPrice(product))" class="o-so-tabular-nums fs-4 fw-bold text-primary"/>
                <div class="product_descr o_line_clamp d-lg-none mt-1 text-muted small" t-if="product.public_description" t-out="product.productDescriptionMarkup"/>
            </div>
            <span t-if="this.props.qty" t-out="this.props.qty" class="badge position-absolute top-0 end-0 m-0 m-lg-2 rounded-4 fs-5 text-bg-primary fw-bold"/>
        </article>
    </t>
</templates>
