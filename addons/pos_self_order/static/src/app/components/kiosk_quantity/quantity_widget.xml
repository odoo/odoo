<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_self_order.KioskQuantityWidget">
      <div class="o_kiosk_quantity_widget btn-group user-select-none" role="group" aria-label="Quantity select">
         <button type="button"
                 t-on-click="() => this.props.onQtyDown()"
                 t-attf-class="{{ props.value &gt; 1 ? '' : 'disabled' }} btn btn-outline-primary btn-lg rounded"><i class="fa fa-minus"/></button>
          <div class="o-so-tabular-nums d-flex align-items-center px-4 fs-2 fw-bold" t-esc="props.value"/>
          <button type="button"
                  t-on-click="() => this.props.onQtyUp()"
                  class="btn btn-outline-primary btn-lg rounded "><i class="fa fa-plus"/></button>
      </div>
    </t>
</templates>
