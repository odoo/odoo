<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_self_order.OrderWidget">
        <div
            class="page-buttons bg-view z-1"
            t-att-class="{'border-top' : !this.props.removeTopClasses}">
            <div class="o_self_footer container o_self_container px-kiosk-p-4 d-flex justify-content-between flex-nowrap py-3 gap-2 gap-sm-4">
                <div class="d-flex flex-nowrap align-items-center justify-content-start overflow-hidden gap-2" style="min-width: fit-content;">
                    <t t-foreach="this.getButtons('left')" t-as="button" t-key="button.label">
                        <button
                            t-if="button.icon"
                            role="button"
                            t-attf-class="btn btn-{{button.severity}} {{button.disabled ? 'disabled' : ''}} {{button.extraClasses}} btn-lg d-sm-none {{button.icon}} opacity-75"
                            t-on-click="button.onClick" />
                        <button
                            role="button"
                            t-attf-class="btn btn-{{button.severity}} {{button.disabled ? 'disabled' : ''}} {{button.extraClasses}} btn-lg {{button.icon ? 'd-none d-sm-inline': ''}}"
                            t-on-click="button.onClick"
                            t-out="button.label"/>
                    </t>
                </div>

                <div class="d-flex flex-nowrap align-items-center justify-content-end overflow-hidden gap-2 gap-md-4">
                    <div t-if="this.props.total" class="d-flex align-items-center flex-shrink-0 me-2 me-sm-4" >
                        <div class="to-order d-flex flex-column align-items-start justify-content-center h-100 rounded-4" role="button" t-on-click="this.props.total.onClick">
                            <h4 class="d-none d-sm-block text-muted opacity-75">Total</h4>
                            <div class="d-flex align-items-center">
                                <div class="fs-4 fw-bold o-so-tabular-nums rounded-pill py-1 px-3 px-md-4 text-bg-secondary" t-out="this.props.total.count"/>
                                <div class="fs-2 fw-bold o-so-tabular-nums mx-2 text-primary">
                                    <t t-out="this.selfOrder.formatMonetary(this.props.total.price)"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <t t-foreach="this.getButtons('right')" t-as="button" t-key="button.label">
                        <button
                            t-if="button.icon"
                            role="button"
                            t-attf-class="btn btn-{{button.severity}} {{button.disabled ? 'disabled' : ''}} {{button.extraClasses}} btn-lg d-sm-none {{button.icon}} opacity-75"
                            t-on-click="button.onClick" />
                        <button
                            role="button"
                            t-attf-class="btn btn-{{button.severity}} {{button.disabled ? 'disabled' : ''}} {{button.extraClasses}} btn-lg text-truncate {{button.icon ? 'd-none d-sm-inline': ''}}"
                            t-on-click="button.onClick"
                            t-out="button.label"/>
                    </t>
                </div>
            </div>
        </div>
    </t>
</templates>
