<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_self_order.KioskLanguageSelector">
        <button t-if="languages.length > 1" t-on-click="openLanguages"
                class="kiosk_language_selector d-flex align-items-center border-0 rounded py-3 px-4 bg-white" t-attf-class="{{ props.extraClass }}">
            <img class="rounded" t-attf-src="{{currentLanguage.flag_image_url}}"/>
            <span t-esc="currentLanguage.display_name" class="ms-3"></span>
        </button>
    </t>
</templates>
