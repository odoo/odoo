<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_self_order.PresetInfoPopup">
        <Dialog header="false"
            contentClass="'w-100 m-0 position-absolute self_order_pills_selection_popup_dialog preset_info_popup_dialog'"
            bodyClass="'p-4 pb-3 m-0'"
            title="this.props.title">
            <div class="select_popup_preset_info w-100 d-flex flex-column h-100 overflow-hidden">
                <div class="d-flex justify-content-between align-items-center px-2 mt-2 mb-4">
                    <h2 class="mb-0">We need more info</h2>
                    <button class="btn-close" aria-label="close" t-on-click="this.close"/>
                </div>
                <div class="d-flex flex-column gap-3 overflow-y-auto overflow-x-hidden flex-grow-1">
                    <input t-if="this.preset.needsName || this.preset.needsPartner"
                        t-ref="autofocus"
                        type="text"
                        class="form-control form-control-lg"
                        placeholder="Name"
                        t-custom-model="state.name"/>
                    <input t-if="this.preset.needsEmail || this.preset.needsPartner"
                        type="text"
                        class="form-control form-control-lg"
                        placeholder="Email"
                        t-custom-model="state.email"/>
                    <t t-if="this.preset.needsName || this.preset.needsPartner">
                        <div class="input-group">
                            <div class="position-relative w-25 me-3">
                                <div class="form-control form-control-lg d-flex align-items-center gap-1 pe-none">
                                    <t t-out="this.flagEmoji(this.selectedCountry?.code || '')"/>
                                    <span>+<t t-out="state.phoneCode"/></span>
                                </div>
                                <select class="position-absolute top-0 start-0 w-100 h-100 opacity-0"
                                        t-custom-model.number="state.phoneCode">
                                    <option t-foreach="this.selfOrder.models['res.country'].getAll()" t-as="c" t-key="c.id" t-att-value="c.phone_code">
                                        <t t-out="this.flagEmoji(c.code)"/> +<t t-out="c.phone_code"/> <t t-out="c.name"/>
                                    </option>
                                </select>
                            </div>
                            <input type="tel"
                                class="form-control form-control-lg"
                                placeholder="Phone"
                                t-custom-model="state.phoneLocal" />
                        </div>
                        <p t-if="!this.checkPhoneFormat()" class="text-danger">Enter a valid phone number</p>
                    </t>
                    <t t-if="this.preset.needsPartner">
                        <div t-att-class="'o_field_widget o_field_google_address_autocomplete' + (state.validationError?.type === 'delivery' ? ' address-delivery-error' : '')">
                            <AddressAutoComplete t-props="this.addressAutoCompleteProps" />
                            <div class="d-flex justify-content-end mt-1">
                                <img src="/google_address_autocomplete/static/src/img/powered_by_google_on_white.png"
                                    alt="Powered by Google"
                                    style="height: 18px;"/>
                            </div>
                        </div>
                        <t t-if="state.validationError">
                            <p class="text-danger mb-0" t-esc="state.validationError.message"/>
                            <div t-if="state.validationError.type === 'delivery' and this.otherPresets.length" class="d-flex gap-2 flex-wrap justify-content-center">
                                <button t-foreach="this.otherPresets" t-as="altPreset" t-key="altPreset.id"
                                    type="button"
                                    class="btn btn-light btn-sm"
                                    t-on-click="() => this.selectPreset(altPreset)"
                                    t-out="altPreset.name"
                                />
                            </div>
                        </t>
                    </t>
                </div>
                <div class="w-100 d-flex mt-3">
                    <button class="btn btn-secondary flex-grow-1 me-1"
                        t-on-click="this.props.close">
                        Cancel
                    </button>
                    <button class="btn btn-primary flex-grow-1 ms-1"
                        t-on-click="this.setInformations"
                        t-att-disabled="!this.validSelection || state.isSubmitting">
                        <t t-if="state.isSubmitting">
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true" />
                            Validating...
                        </t>
                        <t t-else="">
                            Continue
                        </t>
                    </button>
                </div>
            </div>
        </Dialog>
    </t>
</templates>
