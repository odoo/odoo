<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_self_order.OrderTrackerDropdown" t-inherit="point_of_sale.OrderTrackerDropdown" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('form-switch')]" position="attributes">
            <attribute name="t-if" separator=" and " add="!externalOrder.counter"/>
        </xpath>
        <xpath expr="//div[hasclass('form-switch')]" position="after">
            <div t-if="externalOrder.counter" class="px-2 py-1 ms-2 text-bg-warning rounded fw-bold medium" t-on-click="() => this.snoozeSelfOrdering()">
                <t t-out="externalOrder.counter"/>
            </div>
        </xpath>
    </t>
</templates>
