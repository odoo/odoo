<?xml version="1.0" encoding="utf-8"?>
<odoo>
   <record id="view_pos_self_order_config_form" model="ir.ui.view">
        <field name="name">pos.self.order.config.form</field>
        <field name="model">pos.self.order.config</field>
        <field name="arch" type="xml">
            <form string="Self-Order Configuration">
                <header>
                    <button name="preview_self_order_app" class="oe_highlight" type="object" string="Preview Web interface"/>
                    <button name="generate_qr_codes_page" type="object" string="Print QR Codes" invisible="not ordering_mode in ['consultation', 'mobile']"/>
                    <button name="generate_qr_codes_zip" type="object" string="Download QR Codes" invisible="not ordering_mode in ['consultation', 'mobile']"/>
                    <button name="get_pos_qr_stands" type="object" string="Free Metal / Wood Stands" invisible="not ordering_mode in ['consultation', 'mobile']"/>
                    <button groups="base.group_no_one" name="update_access_tokens" type="object" string="Reset QR Codes" invisible="not ordering_mode in ['consultation', 'mobile']"/>
                </header>
                <sheet>
                    <div class="oe_title mb-2">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="My Awesome Self-ordering service"/>
                        </h1>
                    </div>
                    <group class="w-100" name="Configuration">
                        <group>
                            <field name="pos_config_id" />
                            <field name="ordering_mode" />
                            <field name="service_mode" />
                        </group>
                        <group>
                            <field name="pay_after" />
                            <field name="available_category_ids" widget="many2many_tags" placeholder="Empty = Point of Sale categories" />
                            <field name="url" widget="CopyClipboardChar" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Presets" name="preset">
                            <field name="available_preset_ids" context="{'list_view_ref': 'pos_self_order.view_pos_preset_self_order_list'}" />
                        </page>
                        <page string="Custom links" name="custom_links">
                            <field name="available_custom_link_ids" />
                        </page>
                        <page string="Personalization" name="personalization">
                            <group>
                                <group>
                                    <field name="default_language_id" />
                                    <field name="available_language_ids" widget="many2many_tags" />
                                    <field name="primary_color" widget="color"/>
                                </group>
                                <group class="d-block">
                                    <div class="alert alert-info" role="alert">
                                        Personalize your splash screen by adding one or multiple
                                        images to create a slideshow
                                    </div>
                                    <field name="image_background_ids" widget="many2many_binary" nolabel="1" />
                                    <field name="image_home_ids" widget="many2many_binary" nolabel="1" />
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pos_self_order_config_list" model="ir.ui.view">
        <field name="name">pos.self.order.config.list</field>
        <field name="model">pos.self.order.config</field>
        <field name="arch" type="xml">
            <list string="Self-Order Configurations">
                <field name="name" />
                <field name="pos_config_id" />
            </list>
        </field>
    </record>

    <record id="action_pos_self_order_config" model="ir.actions.act_window">
        <field name="name">Self-Order Configurations</field>
        <field name="res_model">pos.self.order.config</field>
        <field name="view_mode">list,form</field>
        <field name="target">current</field>
    </record>
</odoo>
