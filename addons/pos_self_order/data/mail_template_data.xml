<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="takeout_email_template" model="mail.template">
            <field name="name">Takeout: Confirmation order for self</field>
            <field name="description">Sent to customers with the receipt in attachment</field>
            <field name="model_id" ref="pos_self_order.model_pos_order"/>
            <field name="subject">Your {{ object.config_id.name }} receipt</field>
            <field name="email_from">{{ (object.company_id.email_formatted or object.user_id.email_formatted)}}</field>
            <field name="email_to" eval="False"/>
            <field name="partner_to" eval="False"/>
            <field name="use_default_to" eval="False"/>
            <field name="lang">{{ object.partner_id.lang or user.lang }}</field>
            <field name="auto_delete" eval="False"/>
            <field name="body_html" type="html">
                <div style="margin: 0; padding: 0; font-size: 14px;">
                    <t t-set="store_name" t-value="object.config_id.name"/>
                    <t t-set="tz" t-value="object.company_id.partner_id.tz"/>
                    <t t-set="lg" t-value="object.partner_id.lang or user.lang"/>
                    <div>
                        <t t-if="client_name">Hello <t t-out="client_name">Client name</t>,</t>
                        <t t-else="">Hello,</t>
                    </div>
                    <br/>
                    <div>Your order <t t-out="object.tracking_number">...</t> amounting in <t t-out="format_amount(object.amount_total,object.currency_id)">$xx.xx</t> has been confirmed. <span t-if="object.preset_time">It will be ready at <t t-out="format_time(time=object.preset_time, tz=tz, time_format='short', lang_code=lg)">12:00 pm</t></span></div>
                    <br/>
                    <div>Thank you,</div>
                    <br/>
                    <div t-if="object.state == 'paid'">
                        <div>Attached, you will find your receipt</div>
                        <br/>
                    </div>
                    <t t-out="store_name">Store name</t>
                </div>
            </field>
        </record>

        <record id="delivery_email_template" model="mail.template">
            <field name="name">Delivery: Confirmation order for self</field>
            <field name="description">Sent to customers with the receipt in attachment</field>
            <field name="model_id" ref="pos_self_order.model_pos_order"/>
            <field name="subject">Your {{ object.config_id.name }} receipt</field>
            <field name="email_from">{{ (object.company_id.email_formatted or object.user_id.email_formatted)}}</field>
            <field name="email_to" eval="False"/>
            <field name="partner_to" eval="False"/>
            <field name="use_default_to" eval="False"/>
            <field name="lang">{{ object.partner_id.lang or user.lang }}</field>
            <field name="auto_delete" eval="False"/>
            <field name="body_html" type="html">
                <div style="margin: 0; padding: 0; font-size: 14px;">
                    <t t-set="client_name" t-value="object.partner_id.name"/>
                    <t t-set="config" t-value="object.config_id"/>
                    <t t-set="company" t-value="config.company_id"/>
                    <t t-set="street" t-value="company.street or ''"/>
                    <t t-set="state" t-value="company.state_id.name or ''"/>
                    <t t-set="city" t-value="company.city or ''"/>
                    <t t-set="country" t-value="company.country_id.name or ''"/>
                    <t t-set="store_name" t-value="config.name"/>
                    <t t-set="tz" t-value="object.company_id.partner_id.tz"/>
                    <t t-set="lg" t-value="object.partner_id.lang or user.lang"/>
                    <h1 style="font-size: 18px; font-weight: bold; color: #374151;">
                            Order confirmed!
                    </h1>
                    <div>
                        <t t-if="client_name">Dear <t t-out="client_name">Client name</t>,</t>
                        <t t-else="">Hello,</t>
                    </div>
                    <br/>
                    <div>Your order has been confirmed. You'll find your receipt attached to this email.</div>
                    <div>Thank you for shopping with us!</div>
                    <br/>
                    <t t-out="store_name">Store name</t>
                    <table style="margin-top:20px; font-size: 14px;">
                        <tr align="left" style="color: #0000ff">
                            <th>
                                Order details
                            </th>
                            <th style="font-size: 1px; width: 25px;">&amp;nbsp;</th>
                            <th>
                                Pick-up details
                            </th>
                        </tr>
                        <tr valign="top">
                            <td>
                                Order <t t-out="object.name">orderRef</t> (<t t-out="format_amount(object.amount_total,object.currency_id)">$xx.xx</t>)
                            </td>
                            <td style="font-size: 1px; width: 25px;">&amp;nbsp;</td>
                            <td>
                                Ready <span t-if="object.preset_time">at <t t-out="format_time(time=object.preset_time, tz=tz, time_format='short', lang_code=lg)">12:00 pm</t></span><br/>
                                <t t-if="config.use_custom_receipt_info and config.custom_receipt_address">
                                    <t t-out="config.receipt_address"/><br/>
                                </t>
                                <t t-else="">
                                    <t t-out="street">street</t><br/>
                                    <t t-out="state">state</t> <t t-out="company.zip or ''">zip</t><br/>
                                    <t t-out="city">city</t><br/>
                                    <t t-out="country">country</t><br/>
                                </t>
                                <a target="_blank" t-attf-href="http://maps.google.com/maps?oi=map&amp;q={{config.receipt_address}}" style="font-size: 12px; color: #008f8c; text-decoration: underline;">View Map</a>
                            </td>
                        </tr>
                    </table>
                </div>
            </field>
        </record>
    </data>
</odoo>
