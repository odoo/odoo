<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="mysubscription.SubscriptionSection" owl="1">
        <h1 class="text-primary mb-3">My Subscription</h1>
        <div class="row gx-5 mb-3">
            <div class="col-lg-3">
                <div class="d-flex flex-column mb-2">
                    <div t-attf-class="d-flex fw-bold {{this.dashboardState.hasSubscription ? '' : 'text-danger'}}"
                    >
                        <t t-out="this.expirationDate"/>
                    </div>

                    <div class="d-flex text-muted">
                        <span>License Key: <t t-out="this.dashboardState.enterpriseCode"/></span>
                    </div>
                </div>

            </div>
        </div>

        <div class="row gx-5 mb-3">
            <DashboardBlock subtitle.translate="Invoices">
                <div>Check your invoices </div>
                <t t-set-slot="content">
                    <a
                        class="btn btn-outline-secondary px-4 py-2"
                        href="https://www.odoo.com/my/addresses"
                        target="_blank"
                    >
                        Edit Address
                    </a>
                    <a
                        class="btn btn-outline-secondary px-4 py-2"
                        href="https://www.odoo.com/my/invoices"
                        target="_blank"
                    >
                        View Invoices
                    </a>
                </t>
            </DashboardBlock>
        </div>
    </t>

</templates>
