<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="mysubscription.SubscriptionSection" owl="1">
        <h1 class="text-primary mb-3">My Subscription</h1>
        <div class="row gx-5 mb-3">
            <div class="col-lg-3">
                <div class="d-flex flex-column mb-2">
                    <div t-attf-class="d-flex fw-bold {{this.dashboardState.hasSubscription ? '' : 'text-danger'}}"
                    >
                        <t t-out="this.expirationDate"/>
                    </div>

                    <div class="d-flex text-muted">
                        <span>Monthly subscription (*)</span>
                    </div>

                    <div class="d-flex text-muted">
                        <span>License Key: <t t-out="this.dashboardState.enterpriseCode"/></span>
                    </div>
                </div>

                <h4 class="text-primary mb-1 fw-bold">Your Odoo Contact</h4>
                <div class="d-flex align-items-center mb-2">
                    <div>
                        <div>Ada Lovelace (*)</div>
                        <div><i class="fa fa-phone me-2"/>+32 111 11 11 (*)</div>
                        <div><i class="fa fa-envelope me-2"/>adlo@odoo.com (*)</div>
                    </div>
                </div>
            </div>

            <div class="col-lg-9">
                <div class="align-items-start">
                    <div class="card-body mb-3">
                        <div class="bg-light border rounded-3 p-5 text-center text-muted d-flex align-items-center justify-content-center" style="min-height: 250px;">
                            <div>
                                <h4>Table Placeholder</h4>
                                <p>Sub data could go there?</p>
                            </div>
                        </div>
                    </div>
                    <div>
                        <a
                            t-att-href="'https://accounts.odoo.com/my/home'"
                            class="btn btn-outline-secondary px-4 py-2"
                            target="_blank"
                        >
                            Manage Subscription
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </t>

</templates>
