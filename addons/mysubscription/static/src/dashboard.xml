<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="mysubscription.Dashboard" owl="1">
        <div class="o_action_manager bg-view position-relative h-100 overflow-auto">
            <div class="container-fluid py-4 px-5">

                <t t-if="this.showSubscriptionSection">
                    <SubscriptionSection/>
                    <hr class="my-4 text-muted opacity-25"/>

                    <AddressSection/>
                    <hr class="my-4 text-muted opacity-25"/>
                </t>

                <PlanSection hasSubscription="this.state.hasSubscription"/>
                <hr class="my-4 text-muted opacity-25"/>

                <IapSection/>
                <hr class="my-4 text-muted opacity-25"/>

                <DatabaseSection baseUrl="this.state.baseUrl"/>

                <hr class="my-2 text-info"/>
                <span class="text-info">
                    This section is for testing purposes.
                </span>
                <hr class="my-2 text-info"/>
                <button
                    class="btn btn-info px-4 py-2"
                    t-on-click="() => this.state.showSub = !this.state.showSub"
                >
                    with/without subscription
                </button>
                (*) : Temporary data

            </div>
        </div>
    </t>

</templates>
