<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="mysubscription.DashboardBlock">
        <div class="col-12 col-sm-5 col-md-4 col-lg-3 mb-4">
            <h3 class="text-primary mb-1 fw-bold" t-out="this.props.subtitle"/>
            <div class="mb-2">
                <t t-call-slot="default"/>
            </div>
        </div>
        <div class="col-12 col-sm-7 col-md-8 col-lg-9 mb-4">
            <div class="d-flex align-items-start gap-3">
                <t t-call-slot="content"/>
            </div>
        </div>
    </t>

</templates>
