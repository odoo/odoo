<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="mysubscription.PlanSection" owl="1">
        <h1 class="text-primary mb-3">Current Plan</h1>
        <div class="row gx-5 mb-3">
            <div class="col-lg-3">
                <h4 class="text-primary mb-1 fw-bold">Switch Plan</h4>
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>Flexible; change at any time</div>
                </div>

                <h4 class="text-primary mb-1 fw-bold">Need Help?</h4>
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>Contact your dedicated account manager or the support</div>
                </div>
            </div>

            <div class="col-lg-9">
                <div class="row g-4">
                    <PlanBox data="this.communityPlan"/>
                    <PlanBox data="this.enterprisePlan"/>
                </div>
            </div>
        </div>

        <div class="row gx-5 mb-3" t-if="this.showSubscriptionCode()">
            <DashboardBlock subtitle.translate="Subscription Code">
                <input type="text" class="o_input w-auto mx-2 mb-2 mb-sm-0" t-ref="this.inputRef"
                    placeholder="Paste code here"
                    title="Your subscription code"
                />

                <t t-set-slot="content">
                    <button class="btn btn-primary px-4 py-2" t-on-click.prevent="this.onCodeSubmit"><t t-out="this.state.buttonText"/></button>
                </t>
            </DashboardBlock>
        </div>
    </t>

</templates>
