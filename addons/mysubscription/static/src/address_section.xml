<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="mysubscription.AddressSection" owl="1">
        <div class="row gx-5 mb-3">
            <DashboardBlock subtitle.translate="Invoicing Address">
                <div>120 chemin de Martignon (*)</div>
                <div>73299 Plancherine (*)</div>
                <div>France (*)</div>

                <t t-set-slot="buttons">
                    <button class="btn btn-outline-secondary px-4 py-2" t-on-click="this.onEditAddress">
                        Edit Address (*)
                    </button>
                    <button class="btn btn-outline-secondary px-4 py-2" t-on-click="this.onViewInvoices">
                        View Invoices (*)
                    </button>
                </t>
            </DashboardBlock>
        </div>
    </t>

</templates>
