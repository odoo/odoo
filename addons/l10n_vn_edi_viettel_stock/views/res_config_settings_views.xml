<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_l10n_vn_edi_viettel_stock" model="ir.ui.view">
        <field name="name">res.config.settings.form.inherit.l10n_vn_edi_viettel_stock</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='operations_setting_container']" position="inside">
                <setting help="Enable sending transfer notes to SInvoice for Vietnam company." invisible="country_code != 'VN'"
                title="Used for all Internal deliveries unless a specific symbol is defined in each Warehouse.">
                    <field name="l10n_vn_edi_send_transfer_note" string="Send Transfer Note to SInvoice"/>
                    <div class="content-group mt16" invisible="not l10n_vn_edi_send_transfer_note">
                        <div class="row">
                            <label for="l10n_vn_edi_stock_default_sinvoice_symbol_id" string="Default Symbol" class="col-lg-3 o_light_label"
                            title="Used for all Internal deliveries unless a specific symbol is defined in each Warehouse."/>
                            <field name="l10n_vn_edi_stock_default_sinvoice_symbol_id" options="{'no_open': True, 'no_create': True}"/>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
