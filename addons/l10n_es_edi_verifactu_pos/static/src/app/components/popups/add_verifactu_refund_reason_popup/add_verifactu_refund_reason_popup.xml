<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="l10n_es_edi_verifactu_pos.AddVerifactuRefundReasonPopup">
        <Dialog title.translate="Additional Refund Information">
            <div class="mb-3">
                <label for="verifactu_invoice_type" class="form-label">Veri*Factu Refund Reason: </label>
                <select class="detail form-select" id="verifactu_invoice_type" name="l10n_es_invoice_type"
                        t-custom-model="this.state.l10n_es_invoice_type">
                    <t t-foreach="this.pos.config._verifactu_invoice_types" t-as="invoice_type" t-key="invoice_type.value">
                        <option t-att-value="invoice_type.value"
                                t-att-selected="invoice_type.value === this.state.l10n_es_invoice_type ? 'selected' : undefined">
                            <t t-out="invoice_type.name"/>
                        </option>
                    </t>
                </select>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-primary o-default-button" t-on-click="this.confirm">Ok</button>
            </t>
        </Dialog>
    </t>

</templates>
