#. module: website_cf_turnstile
#. odoo-javascript
#: code:addons/website_cf_turnstile/static/src/interactions/error_handler.js:0
msgid ""
"Please make sure your credentials for this service are properly set up.\\n"
msgstr ""
"ກະລຸນາກວດສອບໃຫ້ແນ່ໃຈວ່າຂໍ້ມູນການເຂົ້າໃຊ້ຂອງທ່ານສຳລັບບໍລິການນີ້ໄດ້ຖືກຕັ້ງຄ່າຢ່າງຖືກຕ້ອງແລ້ວ.\\n"

#. module: website_cf_turnstile
#. odoo-python
#: code:addons/website_cf_turnstile/models/ir_http.py:0
msgid "Suspicious activity detected by Turnstile CAPTCHA."
msgstr "ກວດພົບກິດຈະກຳທີ່ໜ້າສົງໄສໂດຍ Turnstile CAPTCHA."

#. module: website_cf_turnstile
#. odoo-python
#: code:addons/website_cf_turnstile/models/ir_http.py:0
msgid "The CloudFlare human validation failed."
msgstr "ການຢືນຢັນຕົວຕົນຂອງ CloudFlare ບໍ່ສຳເລັດ."

#. module: website_cf_turnstile
#. odoo-python
#: code:addons/website_cf_turnstile/models/ir_http.py:0
msgid "The Cloudflare turnstile private key is invalid."
msgstr "ລະຫັດສ່ວນຕົວ Cloudflare turnstile ບໍ່ຖືກຕ້ອງ."

#. module: website_cf_turnstile
#. odoo-javascript
#: code:addons/website_cf_turnstile/static/src/interactions/error_handler.js:0
msgid "The error code is: %s.\\n"
msgstr "ລະຫັດຂໍ້ຜິດພາດແມ່ນ: %s.\\n"

#. module: website_cf_turnstile
#. odoo-python
#: code:addons/website_cf_turnstile/models/ir_http.py:0
msgid "The request is invalid or malformed."
msgstr "ການຮ້ອງຂໍບໍ່ຖືກຕ້ອງ ຫຼື ຜິດຮູບແບບ."

#. module: website_cf_turnstile
#. odoo-javascript
#: code:addons/website_cf_turnstile/static/src/interactions/error_handler.js:0
msgid "There was an error with Cloudflare Turnstile, the captcha system.\\n"
msgstr "ມີຂໍ້ຜິດພາດເກີດຂຶ້ນກັບ Cloudflare Turnstile, ເຊິ່ງເປັນລະບົບ captcha.\\n"

#. module: website_cf_turnstile
#. odoo-javascript
#: code:addons/website_cf_turnstile/static/src/interactions/error_handler.js:0
msgid ""
"You can find more information about this error code here: "
"https://developers.cloudflare.com/turnstile/reference/errors."
msgstr ""
"ທ່ານສາມາດຊອກຫາຂໍ້ມູນເພີ່ມເຕີມກ່ຽວກັບລະຫັດຂໍ້ຜິດພາດນີ້ໄດ້ທີ່ນີ້: https://"
"developers.cloudflare.com/turnstile/reference/errors."

#. module: website_cf_turnstile
#. odoo-python
#: code:addons/website_cf_turnstile/models/ir_http.py:0
msgid "Your request has timed out, please retry."
msgstr "ການຮ້ອງຂໍຂອງທ່ານໝົດເວລາ, ກະລຸນາລອງໃໝ່ອີກຄັ້ງ."
