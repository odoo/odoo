<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_stock.DatePickerPopup">
        <Dialog title="this.props.title" size="'sm'">
            <div class="mb-3 w-100 d-flex flex-column flex-sm-row align-items-center">
                <div class="flex-grow-1 w-100 shipping-date-selector">
                    <DateTimeInput
                        type="'date'"
                        value="this.state.shippingDate"
                        onChange.bind="this.onDateChange"
                        minDate="'today'"
                    />
                </div>
            </div>
            <t t-set-slot="footer">
                <button
                    class="btn btn-primary w-100"
                    t-on-click="this.confirm"
                    t-out="this.props.confirmLabel"
                />
            </t>
        </Dialog>
    </t>
</templates>
