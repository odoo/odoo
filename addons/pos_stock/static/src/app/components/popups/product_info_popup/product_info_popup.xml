<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_stock.ProductInfoPopup" t-inherit="point_of_sale.ProductInfoPopup" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('section-inventory')]//h3" position="inside">
            <t t-if="this.pos.session.update_stock_at_closing"> (as of opening)</t>
        </xpath>
        <div class="section-inventory-body" position="replace">
            <div class="section-inventory-body">
                <t t-foreach="this.props.info.productInfo.warehouses" t-as="warehouse" t-key="warehouse.name">
                    <div t-attf-class="row align-items-center my-3 {{ this.ui.isSmall ? 'text-center' : 'text-start' }}">
                        <div t-attf-class="{{ this.ui.isSmall ? 'col-12 mb-2' : 'col-3 mb-0' }} text-start fw-bold text-break">
                            <t t-out="warehouse.name"/> <t t-if="!this.ui.isSmall">:</t>
                        </div>
                        <div t-attf-class="{{ this.ui.isSmall ? 'col-4 flex-column' : 'col flex-row' }} d-flex align-items-center">
                            <span t-if="this.ui.isSmall" class="text-muted mb-1">On hand</span>
                            <div>
                                <i t-attf-class="fa fa-circle text-{{ warehouse.available_quantity &gt; 0 ? 'success' : 'danger' }} me-1"></i>
                                <span class="fw-bolder on-hand"><t t-out="warehouse.available_quantity"/></span>
                                <span class="ms-1"><t t-out="warehouse.uom"/></span>
                                <span t-if="!this.ui.isSmall" class="ms-1">on hand</span>
                            </div>
                        </div>
                        <div t-attf-class="{{ this.ui.isSmall ? 'col-4 flex-column' : 'col flex-row' }} d-flex align-items-center border-start border-end">
                            <span t-if="this.ui.isSmall" class="text-muted mb-1">Available</span>
                            <div>
                                <span class="fw-bolder"><t t-out="warehouse.free_qty"/></span>
                                <span class="ms-1"><t t-out="warehouse.uom"/></span>
                                <span t-if="!this.ui.isSmall" class="ms-1">available</span>
                            </div>
                        </div>
                        <div t-attf-class="{{ this.ui.isSmall ? 'col-4 flex-column' : 'col flex-row' }} d-flex align-items-center">
                            <span t-if="this.ui.isSmall" class="text-muted mb-1">Forecasted</span>
                            <div>
                                <span class="fw-bolder"><t t-out="warehouse.forecasted_quantity"/></span>
                                <span class="ms-1"><t t-out="warehouse.uom"/></span>
                                <span t-if="!this.ui.isSmall" class="ms-1">forecasted</span>
                            </div>
                        </div>
                    </div>
                </t>
            </div>
        </div>
    </t>
</templates>
