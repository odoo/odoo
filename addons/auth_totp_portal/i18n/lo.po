#. module: auth_totp_portal
#. odoo-javascript
#: code:addons/auth_totp_portal/static/src/js/totp_frontend.js:0
msgid " Copy"
msgstr " ສຳເນົາ"

#. module: auth_totp_portal
#: model_terms:ir.ui.view,arch_db:auth_totp_portal.totp_portal_hook
msgid "(Disable two-factor authentication)"
msgstr "(ປິດການຢືນຢັນຕົວຕົນແບບສອງຂັ້ນຕອນ)"

#. module: auth_totp_portal
#: model_terms:ir.ui.view,arch_db:auth_totp_portal.totp_portal_hook
msgid ""
"<i class=\"fa fa-warning\"/>\n"
"                        Two-factor authentication not enabled"
msgstr ""
"<i class=\"fa fa-warning\"/>\n"
"                        ການຢືນຢັນຕົວຕົນແບບສອງຂັ້ນຕອນຍັງບໍ່ທັນໄດ້ເປີດໃຊ້ງານ"

#. module: auth_totp_portal
#: model_terms:ir.ui.view,arch_db:auth_totp_portal.totp_portal_hook
msgid "<i title=\"Documentation\" class=\"fa fa-fw o_button_icon fa-info-circle\"/>"
msgstr ""
"<i title=\"ເອກະສານອ້າງອີງ\" class=\"fa fa-fw o_button_icon fa-info-circle\"/>"

#. module: auth_totp_portal
#: model_terms:ir.ui.view,arch_db:auth_totp_portal.totp_portal_hook
msgid ""
"<span class=\"text-success\">\n"
"                        <i class=\"fa fa-check-circle\"/>\n"
"                        Two-factor authentication enabled\n"
"                    </span>"
msgstr ""
"<span class=\"text-success\">\n"
"                        <i class=\"fa fa-check-circle\"/>\n"
"                        ເປີດໃຊ້ງານການຢືນຢັນຕົວຕົນແບບສອງຂັ້ນຕອນແລ້ວ\n"
"                    </span>"

#. module: auth_totp_portal
#: model_terms:ir.ui.view,arch_db:auth_totp_portal.totp_portal_hook
msgid "<strong>Added On</strong>"
msgstr "<strong>ເພີ່ມເມື່ອ</strong>"

#. module: auth_totp_portal
#: model_terms:ir.ui.view,arch_db:auth_totp_portal.totp_portal_hook
msgid "<strong>Trusted Device</strong>"
msgstr "<strong>ອຸປະກອນທີ່ເຊື່ອຖືໄດ້</strong>"

#. module: auth_totp_portal
#. odoo-javascript
#: code:addons/auth_totp_portal/static/src/js/totp_frontend.js:0
msgid "Activate"
msgstr "ເປີດໃຊ້ງານ"

#. module: auth_totp_portal
#. odoo-javascript
#: code:addons/auth_totp_portal/static/src/components/totp_confirmation_dialog.js:0
msgid "Copied!"
msgstr "ສຳເນົາແລ້ວ!"

#. module: auth_totp_portal
#: model_terms:ir.ui.view,arch_db:auth_totp_portal.totp_portal_hook
msgid "Enable two-factor authentication"
msgstr "ເປີດໃຊ້ງານການຢືນຢັນຕົວຕົນແບບສອງຂັ້ນຕອນ"

#. module: auth_totp_portal
#. odoo-javascript
#: code:addons/auth_totp_portal/static/src/js/totp_frontend.js:0
msgid "Operation failed for unknown reason."
msgstr "ການດຳເນີນງານຫຼົ້ມເຫຼວໂດຍບໍ່ຮູ້ສາເຫດ."

#. module: auth_totp_portal
#: model_terms:ir.ui.view,arch_db:auth_totp_portal.totp_portal_hook
msgid "Revoke All"
msgstr "ຖອນສິດທັງໝົດ"

#. module: auth_totp_portal
#: model_terms:ir.ui.view,arch_db:auth_totp_portal.totp_portal_hook
msgid "Two-factor authentication"
msgstr "ການຢືນຢັນຕົວຕົນແບບສອງຂັ້ນຕອນ"

#. module: auth_totp_portal
