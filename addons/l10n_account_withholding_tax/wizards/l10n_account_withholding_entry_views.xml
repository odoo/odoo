<odoo>
    <record id="l10n_account_withholding_entry_form_action" model="ir.actions.act_window">
        <field name="name">Create Withholding Entry</field>
        <field name="res_model">l10n.account.withholding.entry</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="l10n_account_withholding_wizard_entry_view_form" model="ir.ui.view">
        <field name="name">l10n.account.withholding.wizard.view.form</field>
        <field name="model">l10n.account.withholding.entry</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="reference"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="journal_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Withholding lines">
                            <field name="withholding_line_ids" nolabel="1" colspan="2">
                                <list editable="bottom" no_open="1">
                                    <field name="source_base_amount_currency" column_invisible="True"/> <!-- Needed for taxes computation -->
                                    <field name="source_base_amount" column_invisible="True"/> <!-- Needed for taxes computation -->
                                    <field name="source_tax_amount_currency" column_invisible="True"/> <!-- Needed for taxes computation -->
                                    <field name="source_tax_amount" column_invisible="True"/> <!-- Needed for taxes computation -->
                                    <field name="source_currency_id" column_invisible="True"/> <!-- Needed for taxes computation -->
                                    <field name="comodel_currency_id" column_invisible="True"/> <!-- Needed for taxes computation -->
                                    <field name="placeholder_value" column_invisible="True"/> <!-- Needed for the placeholder widget -->
                                    <field name="name"
                                        string="Sequence Number"
                                        required="not withholding_sequence_id"
                                        widget="char_with_placeholder_field"
                                        options="{'placeholder_field': 'placeholder_value'}"
                                        width="92px"/>
                                    <field name="tax_id"
                                        options="{'no_open': True, 'no_create': True}"
                                        string="Tax"
                                        width="92px"/>
                                    <field name="base_amount"/>
                                    <field name="analytic_distribution" widget="analytic_distribution" groups="analytic.group_analytic_accounting"/>
                                    <field name="amount" string="Withheld Amount" sum="Total Withheld Amount"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button string="Create and Post" name="action_create_and_post_withhold" type="object" class="oe_highlight"/>
                    <button string="Discard" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
