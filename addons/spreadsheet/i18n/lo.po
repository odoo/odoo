msgstr "A"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"A boolean indicating whether to use A1 style notation (TRUE) or R1C1 style "
"notation (FALSE)."
msgstr ""
"ຄ່າບູລີນທີ່ລະບຸວ່າຈະໃຊ້ຮູບແບບການອ້າງອີງແບບ A1 (TRUE) ຫຼື ແບບ R1C1 (FALSE)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"A boolean indicating whether to use A1 style notation or R1C1 style "
"notation."
msgstr "ຄ່າບູລີນທີ່ລະບຸວ່າຈະໃຊ້ຮູບແບບການອ້າງອີງແບບ A1 ຫຼື ແບບ R1C1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"A boolean; if TRUE, empty cells selected in the text arguments won't be "
"included in the result."
msgstr ""
"ຄ່າບູລີນ; ຫາກເປັນ TRUE, ຫ້ອງຫວ່າງທີ່ຖືກເລືອກໃນສ່ວນຂອງຂໍ້ຄວາມຈະບໍ່ຖືກລວມເຂົ້າໃນຜົນຮັບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"A column or row containing true or false values corresponding to the first "
"column or row of range."
msgstr ""
"ຖັນ ຫຼື ແຖວທີ່ມີຄ່າຈິງ (true) ຫຼື ເທັດ (false) ເຊິ່ງກົງກັບຖັນ ຫຼື ແຖວທຳອິດຂອງຊ່ວງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A conditional count across a range."
msgstr "ການນັບແບບມີເງື່ອນໄຂໃນຊ່ວງທີ່ກຳນົດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A conditional sum across a range."
msgstr "ການລວມຍອດແບບມີເງື່ອນໄຂໃນຊ່ວງທີ່ກຳນົດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A flag specifying whether to compute the intercept or not."
msgstr "ຕົວບົ່ງຊີ້ທີ່ລະບຸວ່າຈະໃຫ້ຄຳນວນຄ່າຈຸດຕັດແກນ (intercept) ຫຼື ບໍ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A flag specifying whether to compute the slope or not"
msgstr "ຕົວບົ່ງຊີ້ທີ່ລະບຸວ່າຈະໃຫ້ຄຳນວນຄ່າຄວາມຊັນ (slope) ຫຼື ບໍ່"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"A flag specifying whether to return additional regression statistics or only"
" the linear coefficients and the y-intercept"
msgstr ""
"ຕົວບົ່ງຊີ້ທີ່ລະບຸວ່າຈະໃຫ້ສົ່ງຄືນຄ່າສະຖິຕິການຖົດຖອຍເພີ່ມເຕີມ ຫຼື ພຽງແຕ່ຄ່າສຳປະສິດເສັ້ນຊື່ ແລະ ຈຸດຕັດແກນ y"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
