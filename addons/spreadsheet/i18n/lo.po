msgstr "ບໍ່ສາມາດຂະຫຍາຍຜົນລັບໂດຍອັດຕະໂນມັດໄດ້. ກະລຸນາແຊກຄໍລຳ ແລະ ແຖວເພີ່ມເຕີມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Result couldn't be automatically expanded. Please insert more columns."
msgstr "ບໍ່ສາມາດຂະຫຍາຍຜົນລັບໂດຍອັດຕະໂນມັດໄດ້. ກະລຸນາແຊກຄໍລຳເພີ່ມເຕີມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Result couldn't be automatically expanded. Please insert more rows."
msgstr "ບໍ່ສາມາດຂະຫຍາຍຜົນລັບໂດຍອັດຕະໂນມັດໄດ້. ກະລຸນາແຊກແຖວເພີ່ມເຕີມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Result of multiplying a series of numbers together."
msgstr "ຜົນລັບຂອງການຄູນຕົວເລກຊຸດໜຶ່ງເຂົ້າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Return a whole number or a decimal value."
msgstr "ສົ່ງຄືນຄ່າເປັນເລກຖ້ວນ ຫຼື ເລກທົດສະນິຍົມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Return every distinct item"
msgstr "ສົ່ງຄືນທຸກລາຍການທີ່ແຕກຕ່າງກັນ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Return items that appear exactly once"
msgstr "ສົ່ງຄືນລາຍການທີ່ປະກົດຂຶ້ນພຽງຄັ້ງດຽວ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/pivot/pivot_functions.js:0
msgid "Return the current value of a spreadsheet filter."
msgstr "ສົ່ງຄືນຄ່າປັດຈຸບັນຂອງຕົວຕອງສະເປຣດຊີດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Return unique columns"
msgstr "ສົ່ງຄືນຄໍລຳທີ່ເປັນເອກະລັກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Return unique rows"
msgstr "ສົ່ງຄືນແຖວທີ່ເປັນເອກະລັກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns a cell reference as a string. "
msgstr "ສົ່ງຄືນການອ້າງອີງຫ້ອງເປັນຂໍ້ຄວາມ. "

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Returns a filtered version of the source range, returning only rows or "
"columns that meet the specified conditions."
msgstr ""
"ສົ່ງຄືນຊ່ວງຂໍ້ມູນທີ່ຖືກຕອງແລ້ວ, ໂດຍສົ່ງຄືນສະເພາະແຖວ ຫຼື ຄໍລຳທີ່ກົງກັບເງື່ອນໄຂທີ່ລະບຸ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns a grid of random numbers between 0 inclusive and 1 exclusive."
msgstr "ສົ່ງຄືນຕາຕະລາງຕົວເລກສຸ່ມລະຫວ່າງ 0 (ຮວມ) ຫາ 1 (ບໍ່ຮວມ)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns a n x n unit matrix, where n is the input dimension."
msgstr "ສົ່ງຄືນເມທຣິກຊ໌ເອກະລັກຂະໜາດ n x n, ໂດຍ n ແມ່ນມິຕິທີ່ລະບຸ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Returns a range reference shifted by a specified number of rows and columns "
"from a starting cell reference."
msgstr ""
"ສົ່ງຄືນການອ້າງອີງຊ່ວງຂໍ້ມູນທີ່ຖືກຍ້າຍໄປຕາມຈຳນວນແຖວ ແລະ ຄໍລຳທີ່ລະບຸ ຈາກຫ້ອງເລີ່ມຕົ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns a result array constrained to a specific width and height."
msgstr "ສົ່ງຄືນອາເຣຜົນລັບທີ່ຖືກຈຳກັດຄວາມກວ້າງ ແລະ ຄວາມສູງຕາມທີ່ລະບຸ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns a sequence of numbers."
msgstr "ສົ່ງຄືນລຳດັບຂອງຕົວເລກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Returns a subtotal for a vertical range of cells using a specified "
"aggregation function."
msgstr "ສົ່ງຄືນຜົນຮວມຍ່ອຍສຳລັບຊ່ວງຫ້ອງໃນແນວຕັ້ງ ໂດຍໃຊ້ຟັງຊັນການຮວມກຸ່ມທີ່ລະບຸ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns a value by comparing cases to an expression."
msgstr "ສົ່ງຄືນຄ່າໂດຍການປຽບທຽບກໍລະນີຕ່າງໆກັບສຳນວນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns a value depending on multiple logical expressions."
msgstr "ສົ່ງຄືນຄ່າໂດຍຂຶ້ນກັບຫຼາຍສຳນວນໂລຊິກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Returns an absolute reference as plain text of the top left cell in "
"reference."
msgstr ""
"ສົ່ງຄືນການອ້າງອີງແບບສົມບູນເປັນຂໍ້ຄວາມທຳມະດາຂອງຫ້ອງເທິງຊ້າຍສຸດໃນການອ້າງອີງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns opposite of provided logical value."
msgstr "ສົ່ງຄືນຄ່າທີ່ກົງກັນຂ້າມກັບຄ່າໂລຊິກທີ່ລະບຸ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns text that occurs after a given substring or delimiter."
msgstr "ສົ່ງຄືນຂໍ້ຄວາມທີ່ຢູ່ຫຼັງຂໍ້ຄວາມຍ່ອຍ ຫຼື ຕົວຂັ້ນທີ່ລະບຸ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns text that occurs before a given substring or delimiter."
msgstr "ສົ່ງຄືນຂໍ້ຄວາມທີ່ຢູ່ກ່ອນຂໍ້ຄວາມຍ່ອຍ ຫຼື ຕົວຂັ້ນທີ່ລະບຸ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns the column number of the cell in reference."
msgstr "ສົ່ງຄືນໝາຍເລກຄໍລຳຂອງຫ້ອງທີ່ອ້າງອີງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns the content of a cell, specified by a string."
msgstr "ສົ່ງຄືນເນື້ອໃນຂອງຫ້ອງ ທີ່ລະບຸໂດຍສະຕຣິງ (String)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns the content of a cell, specified by row and column offset."
msgstr "ສົ່ງຄືນເນື້ອໃນຂອງຫ້ອງ ທີ່ລະບຸໂດຍໄລຍະຫ່າງ (offset) ຂອງແຖວ ແລະ ຄໍລຳ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns the error value #N/A."
msgstr "ສົ່ງຄືນຄ່າຂໍ້ຜິດພາດ #N/A."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns the first n items in a data set after performing a sort."
msgstr "ສົ່ງຄືນ n ລາຍການທຳອິດໃນຊຸດຂໍ້ມູນຫຼັງຈາກຈັດລຽງແລ້ວ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns the format of the top left cell in reference."
msgstr "ສົ່ງຄືນຮູບແບບຂອງຫ້ອງເທິງຊ້າຍສຸດໃນການອ້າງອີງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns the interest paid at a particular period of an investment."
msgstr "ສົ່ງຄືນດອກເບ້ຍທີ່ຈ່າຍໃນງວດໃດໜຶ່ງຂອງການລົງທຶນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns the matrix determinant of a square matrix."
msgstr "ສົ່ງຄືນຄ່າດີເທີມີແນນ (Determinant) ຂອງເມທຣິກຊ໌ຈະຕຸລັດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Returns the maximum value in a range of cells, filtered by a set of "
"criteria."
msgstr "ສົ່ງຄືນຄ່າສູງສຸດໃນຊ່ວງຫ້ອງ ທີ່ຖືກຕອງໂດຍກຸ່ມເງື່ອນໄຂ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Returns the minimum value in a range of cells, filtered by a set of "
"criteria."
msgstr "ສົ່ງຄືນຄ່າຕໍ່າສຸດໃນຊ່ວງຫ້ອງ ທີ່ຖືກຕອງໂດຍກຸ່ມເງື່ອນໄຂ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns the multiplicative inverse of a square matrix."
msgstr "ສົ່ງຄືນຕົວປີ້ນການຄູນ (Inverse) ຂອງເມທຣິກຊ໌ຈະຕຸລັດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns the rank of a specified value in a dataset."
msgstr "ສົ່ງຄືນອັນດັບຂອງຄ່າທີ່ລະບຸໃນຊຸດຂໍ້ມູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns the row number of the top left cell in reference."
msgstr "ສົ່ງຄືນໝາຍເລກແຖວຂອງຫ້ອງເທິງຊ້າຍສຸດໃນການອ້າງອີງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Returns the type of data in the cell in reference. The following values are "
"returned: \"b\" for a blank cell, \"l\" (for label) if the cell contains "
"plain text, and \"v\" (for value) if the cell contains any other type of "
"data."
msgstr ""
"ສົ່ງຄືນປະເພດຂໍ້ມູນໃນຫ້ອງທີ່ອ້າງອີງ. ຄ່າທີ່ຈະສົ່ງຄືນມີດັ່ງນີ້: \"b\" ສຳລັບຫ້ອງຫວ່າງ, \"l\" (label) ຖ້າຫ້ອ"
"ງມີຂໍ້ຄວາມທຳມະດາ, ແລະ \"v\" (value) ຖ້າຫ້ອງມີຂໍ້ມູນປະເພດອື່ນໆ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns the value contained in the top left cell in reference."
msgstr "ສົ່ງຄືນຄ່າທີ່ມີຢູ່ໃນຫ້ອງເທິງຊ້າຍສຸດໃນການອ້າງອີງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Returns value depending on logical expression."
msgstr "ສົ່ງຄືນຄ່າໂດຍຂຶ້ນກັບສຳນວນໂລຊິກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.xml:0
msgid "Reverse icons"
msgstr "ກັບດ້ານໄອຄອນ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.xml:0
msgid "Right"
msgstr "ຂວາ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Right axis"
msgstr "ແກນຂວາ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Rounds a number according to standard rules."
msgstr "ປັດຕົວເລກຕາມກົດເກນມາດຕະຖານ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Rounds a number down to the nearest integer that is less than or equal to "
"it."
msgstr ""
"ປັດຕົວເລກລົງໃຫ້ເປັນເລກຖ້ວນທີ່ໃກ້ຄຽງທີ່ສຸດເຊິ່ງໜ້ອຍກວ່າ ຫຼື ເທົ່າກັບຕົວເລກນັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Rounds a number up to the nearest odd integer."
msgstr "ປັດຕົວເລກຂຶ້ນໃຫ້ເປັນເລກຄີກທີ່ໃກ້ຄຽງທີ່ສຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Rounds down a number."
msgstr "ປັດຕົວເລກລົງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Rounds number down to nearest multiple of factor."
msgstr "ປັດຕົວເລກລົງໃຫ້ເປັນຄ່າທະວີຄູນທີ່ໃກ້ຄຽງທີ່ສຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Rounds number up to nearest multiple of factor."
msgstr "ປັດຕົວເລກຂຶ້ນໃຫ້ເປັນຄ່າທະວີຄູນທີ່ໃກ້ຄຽງທີ່ສຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Rounds up a number."
msgstr "ປັດຕົວເລກຂຶ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Row above"
msgstr "ແຖວດ້ານເທິງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Row below"
msgstr "ແຖວດ້ານລຸ່ມ"

#. module: spreadsheet
#. odoo-javascript
