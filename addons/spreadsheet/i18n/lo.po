#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Variance of sample (text as 0)."
msgstr "ຄ່າຜັນປ່ຽນຂອງກຸ່ມຕົວຢ່າງ (ຖືວ່າຂໍ້ຄວາມເປັນ 0)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Variance."
msgstr "ຄ່າຜັນປ່ຽນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Vertical align"
msgstr "ການຈັດແນວຕັ້ງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
