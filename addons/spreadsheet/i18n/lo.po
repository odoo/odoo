#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to use for padding empty cells."
msgstr "ຄ່າທີ່ຈະໃຊ້ເພື່ອຕື່ມໃສ່ຫ້ອງທີ່ວ່າງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
