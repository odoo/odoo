msgstr "ຄ່າສົມບູນຂອງຕົວເລກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/actions/spreadsheet_download_action.js:0
msgid "Access Error"
msgstr "ຂໍ້ຜິດພາດໃນການເຂົ້າເຖິງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Access to the clipboard denied by the browser. Please enable clipboard "
"permission for this page in your browser settings."
msgstr ""
"ການເຂົ້າເຖິງ Clipboard ຖືກປະຕິເສດໂດຍບຣາວເຊີ. ກະລຸນາເປີດການອະນຸຍາດ Clipboard ສຳລັບໜ້ານີ້ໃນກ"
"ານຕັ້ງຄ່າບຣາວເຊີຂອງທ່ານ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Accounting"
msgstr "ການບັນຊີ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.xml:0
msgid "Accounting format"
msgstr "ຮູບແບບການບັນຊີ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Accrued interest of security paying at maturity."
msgstr "ດອກເບ້ຍຄ້າງຮັບຂອງຫຼັກຊັບທີ່ຈະຈ່າຍເມື່ອຄົບກຳນົດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/global_filters/plugins/global_filters_ui_plugin.js:0
msgid "Active Filters"
msgstr "ຕົວຕອງທີ່ໃຊ້ງານຢູ່"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.xml:0
msgid "Add"
msgstr "ເພີ່ມ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.xml:0
msgid "Add a title"
msgstr "ເພີ່ມຫົວຂໍ້"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.xml:0
msgid "Add another item"
msgstr "ເພີ່ມລາຍການອື່ນ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.xml:0
msgid "Add any characters or symbol"
msgstr "ເພີ່ມຕົວອັກສອນ ຫຼື ສັນຍະລັກໃດໆ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.xml:0
msgid "Add calculated measure"
msgstr "ເພີ່ມການວັດແທກທີ່ຄຳນວນແລ້ວ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Add filters"
msgstr "ເພີ່ມຕົວຕອງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.xml:0
msgid "Add new columns to avoid overwriting cells"
msgstr "ເພີ່ມຖັນໃໝ່ເພື່ອຫຼີກເວັ້ນການຂຽນທັບຫ້ອງທີ່ມີຂໍ້ມູນ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.xml:0
msgid "Add range"
msgstr "ເພີ່ມຊ່ວງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Additional column or row containing true or false values."
msgstr "ຖັນ ຫຼື ແຖວ ເພີ່ມເຕີມທີ່ມີຄ່າ true ຫຼື false."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Additional conditions to be evaluated if the previous ones are FALSE."
msgstr "ເງື່ອນໄຂເພີ່ມເຕີມທີ່ຈະຖືກປະເມີນ ຖ້າເງື່ອນໄຂກ່ອນໜ້ານີ້ເປັນ ເທັດ (FALSE)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Additional criteria to check."
msgstr "ເງື່ອນໄຂເພີ່ມເຕີມເພື່ອທົດສອບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Additional criteria_range and criterion to check."
msgstr "ຊ່ວງເງື່ອນໄຂ ແລະ ເງື່ອນໄຂເພີ່ມເຕີມເພື່ອທົດສອບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Additional future cash flows."
msgstr "ກະແສເງິນສົດໃນອະນາຄົດເພີ່ມເຕີມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Additional numbers or ranges to add to value1."
msgstr "ຕົວເລກ ຫຼື ຊ່ວງເພີ່ມເຕີມທີ່ຈະເພີ່ມເຂົ້າໃນ value1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Additional ranges over which to evaluate the additional criteria. The "
"filtered set will be the intersection of the sets produced by each "
"criterion-range pair."
msgstr ""
"ຊ່ວງເພີ່ມເຕີມສຳລັບປະເມີນເງື່ອນໄຂເສີມ. ຊຸດຂໍ້ມູນທີ່ກອງໄດ້ຈະເປັນສ່ວນທີ່ຄືກັນ ຂອງແຕ່ລະຄູ່ຊ່ວງເງື່ອນໄຂ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Additional ranges to add to range1."
msgstr "ຊ່ວງເພີ່ມເຕີມທີ່ຈະເພີ່ມເຂົ້າໃນ range1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Additional ranges to check."
msgstr "ຊ່ວງເພີ່ມເຕີມເພື່ອທົດສອບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Additional ranges to flatten."
msgstr "ຊ່ວງເພີ່ມເຕີມທີ່ຈະເຮັດໃຫ້ເປັນແຖວດຽວ (flatten)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Additional text item(s)."
msgstr "ລາຍການຂໍ້ຄວາມເພີ່ມເຕີມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Additional values or ranges in which to count the number of blanks."
msgstr "ຄ່າ ຫຼື ຊ່ວງເພີ່ມເຕີມທີ່ຈະໃຊ້ນັບຈຳນວນຫ້ອງຫວ່າງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Additional values or ranges to consider for uniqueness."
msgstr "ຄ່າ ຫຼື ຊ່ວງເພີ່ມເຕີມທີ່ຈະພິຈາລະນາຄວາມບໍ່ຊໍ້າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Additional values or ranges to consider when calculating the average value."
msgstr "ຄ່າ ຫຼື ຊ່ວງເພີ່ມເຕີມທີ່ຈະພິຈາລະນາໃນການຄຳນວນຄ່າສະເລ່ຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Additional values or ranges to consider when calculating the maximum value."
msgstr "ຄ່າ ຫຼື ຊ່ວງເພີ່ມເຕີມທີ່ຈະພິຈາລະນາໃນການຄຳນວນຄ່າສູງສຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Additional values or ranges to consider when calculating the median value."
msgstr "ຄ່າ ຫຼື ຊ່ວງເພີ່ມເຕີມທີ່ຈະພິຈາລະນາໃນການຄຳນວນຄ່າມາດທະຍະຖານ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
