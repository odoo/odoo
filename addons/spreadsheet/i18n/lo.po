#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Calculated measure 1"
msgstr "ການວັດແທກທີ່ຄຳນວນແລ້ວ 1"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Calculates effective interest rate."
msgstr "ຄຳນວນອັດຕາດອກເບ້ຍທີ່ແທ້ຈິງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Calculates the expected y-value for a specified x based on a linear "
"regression of a dataset."
msgstr ""
"ຄຳນວນຄ່າ y ທີ່ຄາດໄວ້ສຳລັບຄ່າ x ທີ່ລະບຸ ໂດຍອີງໃສ່ການຖົດຖອຍແບບເສັ້ນຊື່ຂອງຊຸດຂໍ້ມູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Calculates the frequency distribution of a range."
msgstr "ຄຳນວນການແຈກຢາຍຄວາມຖີ່ຂອງຊ່ວງຂໍ້ມູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Calculates the matrix product of two matrices."
msgstr "ຄຳນວນຜົນຄູນເມທຣິກຂອງສອງເມທຣິກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Calculates the number of days, months, or years between two dates."
msgstr "ຄຳນວນຈຳນວນວັນ, ເດືອນ, ຫຼື ປີ ລະຫວ່າງວັນທີສອງວັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Calculates the price of a security paying interest at maturity, based on "
"expected yield."
msgstr ""
"ຄຳນວນລາຄາຂອງຫຼັກຊັບທີ່ຈ່າຍດອກເບ້ຍເມື່ອຄົບກຳນົດ, ໂດຍອີງໃສ່ຜົນຕອບແທນທີ່ຄາດໄວ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Calculates the standard error of the predicted y-value for each x in the "
"regression of a dataset."
msgstr ""
"ຄຳນວນຄ່າຄວາມຜິດພາດມາດຕະຖານຂອງຄ່າ y ທີ່ທຳນາຍໄວ້ສຳລັບແຕ່ລະຄ່າ x ໃນການຖົດຖອຍຂອງຊຸດຂໍ້ມູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Calculates the sum of squares of the differences of values in two array."
msgstr "ຄຳນວນຜົນບວກກຳລັງສອງຂອງຄ່າຄວາມແຕກຕ່າງໃນສອງອາເຣ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Calculates the sum of the difference of the squares of the values in two "
"array."
msgstr "ຄຳນວນຜົນບວກຂອງຄ່າຄວາມແຕກຕ່າງກຳລັງສອງໃນສອງອາເຣ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Calculates the sum of the products of corresponding entries in equal-sized "
"ranges."
msgstr "ຄຳນວນຜົນບວກຂອງຜົນຄູນຂອງລາຍການທີ່ກົງກັນໃນຊ່ວງຂໍ້ມູນທີ່ມີຂະໜາດເທົ່າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Calculates the sum of the sum of the squares of the values in two array."
msgstr "ຄຳນວນຜົນບວກຂອງຜົນບວກກຳລັງສອງຂອງຄ່າຕ່າງໆໃນສອງອາເຣ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Calculates the value as a percentage for successive items in the Base field "
"that are displayed as a running total."
msgstr ""
"ຄຳນວນຄ່າເປັນເປີເຊັນສຳລັບລາຍການທີ່ຕໍ່ເນື່ອງກັນໃນຟິວຫຼັກ ທີ່ສະແດງເປັນຍອດລວມສະສົມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Calculates values as follows:\n"
"((value in cell) x (Grand Total of Grand Totals)) / ((Grand Row Total) x (Grand Column Total))"
msgstr ""
"ຄຳນວນຄ່າດັ່ງນີ້:\n"
"((ຄ່າໃນຫ້ອງ) x (ຍອດລວມທັງໝົດຂອງຍອດລວມທັງໝົດ)) / ((ຍອດລວມແຖວທັງໝົດ) x (ຍອດລວມຖັນທັງໝົດ))"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Calculates values as follows:\n"
"(value for the item) / (value for the parent item of the selected Base field)"
msgstr ""
"ຄຳນວນຄ່າດັ່ງນີ້:\n"
"(ຄ່າຂອງລາຍການ) / (ຄ່າຂອງລາຍການຫຼັກຂອງຟິວຫຼັກທີ່ເລືອກ)"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Calculates values as follows:\n"
"(value for the item) / (value for the parent item on columns)"
msgstr ""
"ຄຳນວນຄ່າດັ່ງນີ້:\n"
"(ຄ່າຂອງລາຍການ) / (ຄ່າຂອງລາຍການຫຼັກໃນຖັນ)"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Calculates values as follows:\n"
"(value for the item) / (value for the parent item on rows)"
msgstr ""
"ຄຳນວນຄ່າດັ່ງນີ້:\n"
"(ຄ່າຂອງລາຍການ) / (ຄ່າຂອງລາຍການຫຼັກໃນແຖວ)"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.xml:0
msgid "Cancel"
msgstr "ຍົກເລີກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Cannot do a special paste of a figure."
msgstr "ບໍ່ສາມາດວາງຮູບແບບພິເສດສຳລັບຮູບພາບໄດ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Cannot duplicate a pivot in error."
msgstr "ບໍ່ສາມາດສຳເນົາ Pivot ທີ່ເກີດຂໍ້ຜິດພາດໄດ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Cannot find workbook relations file"
msgstr "ບໍ່ພົບໄຟລ໌ຄວາມສຳພັນຂອງວຽກງານ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Cannot have filters without a header row"
msgstr "ບໍ່ສາມາດມີຕົວຕອງໄດ້ໂດຍບໍ່ມີແຖວຫົວຂໍ້"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Cannot hide all the columns of a sheet."
msgstr "ບໍ່ສາມາດເຊື່ອງຖັນທັງໝົດຂອງແຜ່ນງານໄດ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Cannot hide all the rows of a sheet."
msgstr "ບໍ່ສາມາດເຊື່ອງແຖວທັງໝົດຂອງແຜ່ນງານໄດ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Cannot open the link because the linked sheet is hidden."
msgstr "ບໍ່ສາມາດເປີດລິ້ງໄດ້ ເພາະແຜ່ນງານທີ່ເຊື່ອມຕໍ່ນັ້ນຖືກເຊື່ອງໄວ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Cannot remove duplicates for an unknown reason"
msgstr "ບໍ່ສາມາດລຶບລາຍການທີ່ຊ້ຳກັນໄດ້ ຍ້ອນເຫດຜົນທີ່ບໍ່ຊາບໄດ້"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Cannot sort a zone with array formulas."
msgstr "ບໍ່ສາມາດລຽງລຳດັບພື້ນທີ່ທີ່ມີສູດອາເຣໄດ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Cannot sort. To sort, select only cells or only merges that have the same "
"size."
msgstr ""
"ບໍ່ສາມາດລຽງລຳດັບໄດ້. ເພື່ອລຽງລຳດັບ, ກະລຸນາເລືອກສະເພາະຫ້ອງ ຫຼື ຫ້ອງທີ່ປະສານກັນທີ່ມີຂະໜາດເທົ່າກັນເທົ່ານັ້"
"ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Cannot split the selection for an unknown reason"
msgstr "ບໍ່ສາມາດແຍກສ່ວນທີ່ເລືອກໄດ້ ຍ້ອນເຫດຜົນທີ່ບໍ່ຊາບໄດ້"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/pivot/pivot_model.js:0
msgid "Cannot use custom pivot groups with \"Count Distinct\" measure"
msgstr "ບໍ່ສາມາດໃຊ້ກຸ່ມ Pivot ທີ່ກຳນົດເອງກັບການວັດແທກແບບ \"Count Distinct\" ໄດ້"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Capitalizes each word in a specified string."
msgstr "ປ່ຽນຕົວອັກສອນທຳອິດຂອງແຕ່ລະຄຳໃນຂໍ້ຄວາມໃຫ້ເປັນຕົວພິມໃຫຍ່."

#. module: spreadsheet
