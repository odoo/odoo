#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"A boolean indicating whether to use A1 style notation (TRUE) or R1C1 style "
"notation (FALSE)."
msgstr "ຄ່າ Boolean ທີ່ລະບຸວ່າຈະໃຊ້ຮູບແບບ A1 (TRUE) ຫຼື ຮູບແບບ R1C1 (FALSE)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"A boolean; if TRUE, empty cells selected in the text arguments won't be "
"included in the result."
msgstr ""
"ຄ່າ Boolean; ຖ້າເປັນ TRUE, ຫ້ອງທີ່ຫວ່າງເປົ່າຈະບໍ່ຖືກລວມເຂົ້າໃນຜົນໄດ້ຮັບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"A column or row containing true or false values corresponding to the first "
"column or row of range."
msgstr "ຖັນ ຫຼື ແຖວ ທີ່ມີຄ່າ true ຫຼື false ເຊິ່ງກົງກັບຖັນ ຫຼື ແຖວທຳອິດຂອງຊ່ວງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A conditional count across a range."
msgstr "ການນັບແບບມີເງື່ອນໄຂໃນທົ່ວຊ່ວງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A conditional sum across a range."
msgstr "ການລວມແບບມີເງື່ອນໄຂໃນທົ່ວຊ່ວງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A flag specifying wheter to compute the slope or not"
msgstr "ເຄື່ອງໝາຍລະບຸວ່າຈະຄຳນວນຫາຄ່າຄວາມຊັນ (slope) ຫຼື ບໍ່"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A flag specifying whether to compute the intercept or not."
msgstr "ເຄື່ອງໝາຍລະບຸວ່າຈະຄຳນວນຫາຈຸດຕັດ (intercept) ຫຼື ບໍ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"A flag specifying whether to return additional regression statistics or only"
" the linear coefficients and the y-intercept"
msgstr ""
"ເຄື່ອງໝາຍລະບຸວ່າຈະໃຫ້ສົ່ງຄືນສະຖິຕິການຖົດຖອຍເພີ່ມເຕີມ ຫຼື ສະເພາະຄ່າສຳປະສິດເສັ້ນຊື່ ແລະ ຈຸດຕັດແກນ y"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A maximum range limit value is needed"
msgstr "ຕ້ອງການຄ່າກຳນົດຊ່ວງສູງສຸດ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A minimum range limit value is needed"
msgstr "ຕ້ອງການຄ່າກຳນົດຊ່ວງຕ່ຳສຸດ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"A number indicating which numbering system to use to represent weekdays. By "
"default, counts starting with Sunday = 1."
msgstr "ຕົວເລກລະບຸລະບົບການນັບວັນໃນອາທິດ. ໂດຍເລີ່ມຕົ້ນແມ່ນ ວັນອາທິດ = 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"A number or string representing which days of the week are considered "
"weekends."
msgstr "ຕົວເລກ ຫຼື ຂໍ້ຄວາມ ທີ່ລະບຸວ່າວັນໃດໃນອາທິດແມ່ນວັນຢຸດທ້າຍອາທິດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A number raised to a power."
msgstr "ຕົວເລກທີ່ຍົກກຳລັງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A number representing the day that a week starts on. Sunday = 1."
msgstr "ຕົວເລກແທນວັນທີ່ເລີ່ມຕົ້ນອາທິດ. ວັນອາທິດ = 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A number representing the way to display ties."
msgstr "ຕົວເລກແທນວິທີການສະແດງຄ່າທີ່ສະເໝີກັນ (ties)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A number with the sign reversed."
msgstr "ຕົວເລກທີ່ມີເຄື່ອງໝາຍກົງກັນຂ້າມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A random number between 0 inclusive and 1 exclusive."
msgstr "ຕົວເລກສຸ່ມລະຫວ່າງ 0 (ລວມ) ຫາ 1 (ບໍ່ລວມ)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"A range containing the income or payments associated with the investment. "
"The array should contain bot payments and incomes."
msgstr ""
"ຊ່ວງທີ່ມີລາຍຮັບ ຫຼື ລາຍຈ່າຍທີ່ກ່ຽວຂ້ອງກັບການລົງທຶນ. ອາເຣ (Array) ຄວນມີທັງລາຍຈ່າຍ ແລະ ລາຍຮັບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A range needs to be defined"
msgstr "ຕ້ອງໄດ້ກຳນົດຊ່ວງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"A range or array constant containing the date serial numbers to consider "
"holidays."
msgstr "ຊ່ວງ ຫຼື ຄ່າຄົງທີ່ອາເຣ ທີ່ມີຕົວເລກລຳດັບວັນທີເພື່ອພິຈາລະນາເປັນວັນຢຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"A range or array constant containing the dates to consider as holidays."
msgstr "ຊ່ວງ ຫຼື ຄ່າຄົງທີ່ອາເຣ ທີ່ມີວັນທີເພື່ອພິຈາລະນາເປັນວັນຢຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A range or array constant containing the dates to consider holidays."
msgstr "ຊ່ວງ ຫຼື ຄ່າຄົງທີ່ອາເຣ ທີ່ມີວັນທີສຳລັບວັນຢຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A segment of a string."
msgstr "ສ່ວນໜຶ່ງຂອງຂໍ້ຄວາມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A series of interest rates to compound against the principal."
msgstr "ຊຸດຂອງອັດຕາດອກເບ້ຍເພື່ອຄິດໄລ່ດອກເບ້ຍທົບຕົ້ນກັບເງິນຕົ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A sheet with the name %s already exists. Please select another name."
msgstr "ມີແຜ່ນງານທີ່ມີຊື່ %s ຢູ່ແລ້ວ. ກະລຸນາເລືອກຊື່ອື່ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A specified number, unchanged."
msgstr "ຕົວເລກທີ່ລະບຸ, ບໍ່ມີການປ່ຽນແປງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"A string indicating the name of the sheet into which the address points."
msgstr "ຂໍ້ຄວາມທີ່ລະບຸຊື່ຂອງແຜ່ນງານທີ່ທີ່ຢູ່ນັ້ນອ້າງອີງເຖິງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A substring from the end of a specified string."
msgstr "ຂໍ້ຄວາມຍ່ອຍຈາກຕອນທ້າຍຂອງຂໍ້ຄວາມທີ່ລະບຸ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "A table can only be created on a continuous selection."
msgstr "ສາມາດສ້າງຕາຕະລາງໄດ້ສະເພາະກັບພື້ນທີ່ທີ່ເລືອກແບບຕໍ່ເນື່ອງເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"A text abbreviation for unit of time. Accepted values are \"Y\" (the number "
"of whole years between start_date and end_date), \"M\" (the number of whole "
"months between start_date and end_date), \"D\" (the number of days between "
"start_date and end_date), \"MD\" (the number of days between start_date and "
"end_date after subtracting whole months), \"YM\" (the number of whole months"
" between start_date and end_date after subtracting whole years), \"YD\" (the"
" number of days between start_date and end_date, assuming start_date and "
"end_date were no more than one year apart)."
msgstr ""
"ຕົວຫຍໍ້ສຳລັບຫົວໜ່ວຍເວລາ. ຄ່າທີ່ຍອມຮັບແມ່ນ \"Y\" (ຈຳນວນປີ), \"M\" (ຈຳນວນເດືອນ), \"D\" (ຈຳນວ"
"ນວັນ), \"MD\" (ຈຳນວນວັນຫຼັງຫັກເດືອນ), \"YM\" (ຈຳນວນເດືອນຫຼັງຫັກປີ), \"YD\" (ຈຳນວນວັນໃນຮອບ"
"ໜຶ່ງປີ)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.xml:0
msgid "ABOUT"
msgstr "ກ່ຽວກັບ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
