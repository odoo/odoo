#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The amount of initial capital or value to compound against."
msgstr "ຈຳນວນເງິນທຶນເລີ່ມຕົ້ນ ຫຼື ມູນຄ່າທີ່ຈະນຳມາຄິດດອກເບ້ຍທົບຕົ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The amount per period to be paid."
msgstr "ຈຳນວນເງິນທີ່ຈະຕ້ອງຊຳລະໃນແຕ່ລະງວດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The amount to be received at maturity."
msgstr "ຈຳນວນເງິນທີ່ຈະໄດ້ຮັບເມື່ອຄົບກຳນົດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The amount to increment each value in the sequence"
msgstr "ຈຳນວນທີ່ຈະເພີ່ມຂຶ້ນໃນແຕ່ລະຄ່າຂອງລໍາດັບ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The angle to convert from radians to degrees."
msgstr "ມຸມທີ່ຈະແປງຈາກເຣດຽນເປັນອົງສາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The angle to find the cosecant of, in radians."
msgstr "ມຸມທີ່ຈະຫາຄ່າໂຄເຊແຄນ (Cosecant), ເປັນເຣດຽນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The angle to find the cosine of, in radians."
msgstr "ມຸມທີ່ຈະຫາຄ່າໂຄຊາຍ (Cosine), ເປັນເຣດຽນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The angle to find the cotangent of, in radians."
msgstr "ມຸມທີ່ຈະຫາຄ່າໂຄຕັງແຊນ (Cotangent), ເປັນເຣດຽນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The angle to find the secant of, in radians."
msgstr "ມຸມທີ່ຈະຫາຄ່າເຊແຄນ (Secant), ເປັນເຣດຽນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The angle to find the sine of, in radians."
msgstr "ມຸມທີ່ຈະຫາຄ່າຊາຍ (Sine), ເປັນເຣດຽນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The angle to find the tangent of, in radians."
msgstr "ມຸມທີ່ຈະຫາຄ່າຕັງແຊນ (Tangent), ເປັນເຣດຽນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The annualized rate of interest."
msgstr "ອັດຕາດອກເບ້ຍລາຍປີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The argument %s is not a valid measure. Here are the measures: %s"
msgstr ""
"ອາຄິວເມັ້ນ (argument) %s ບໍ່ແມ່ນຄ່າວັດແທກທີ່ຖືກຕ້ອງ. ນີ້ຄືຄ່າວັດແທກທັງໝົດ: %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The argument dimension must be positive"
msgstr "ມິຕິຂອງອາຄິວເມັ້ນຕ້ອງເປັນຄ່າບວກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The argument is missing. Please provide a value"
msgstr "ອາຄິວເມັ້ນຂາດຫາຍໄປ. ກະລຸນາລະບຸຄ່າ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The argument square_matrix must have the same number of columns and rows."
msgstr "ອາຄິວເມັ້ນ square_matrix ຕ້ອງມີຈຳນວນຖັນ ແລະ ແຖວເທົ່າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The arguments array_x and array_y must contain at least one pair of numbers."
msgstr "ອາຄິວເມັ້ນ array_x ແລະ array_y ຕ້ອງມີຕົວເລກຢ່າງໜ້ອຍໜຶ່ງຄູ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The arguments array_x and array_y must have the same dimensions."
msgstr "ອາຄິວເມັ້ນ array_x ແລະ array_y ຕ້ອງມີມິຕິເທົ່າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The arguments condition must be a single column or row."
msgstr "ເງື່ອນໄຂຂອງອາຄິວເມັ້ນຕ້ອງເປັນຖັນດຽວ ຫຼື ແຖວດຽວ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The arguments conditions must have the same dimensions."
msgstr "ເງື່ອນໄຂຂອງອາຄິວເມັ້ນຕ້ອງມີມິຕິເທົ່າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The array of ranges containing the values to be counted."
msgstr "ອາເຣຂອງຂອບເຂດທີ່ມີຄ່າທີ່ຈະຖືກນັບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The array or range containing dependent (y) values that are already known, "
"used to curve fit an ideal exponential growth curve."
msgstr ""
"ອາເຣ ຫຼື ຂອບເຂດທີ່ມີຄ່າຕາມ (y) ທີ່ຮູ້ແລ້ວ, ໃຊ້ເພື່ອຫາເສັ້ນໂຄ້ງການເຕີບໂຕແບບເອັກສະໂປເນນຊຽວທີ່ເໝາະສົມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The array or range containing dependent (y) values that are already known, "
"used to curve fit an ideal linear trend."
msgstr ""
"ອາເຣ ຫຼື ຂອບເຂດທີ່ມີຄ່າຕາມ (y) ທີ່ຮູ້ແລ້ວ, ໃຊ້ເພື່ອຫາເສັ້ນທ່າອ່ຽງແບບເສັ້ນຊື່ທີ່ເໝາະສົມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The array or range containing the data to consider, structured in such a way"
" that the first row contains the labels for each column's values."
msgstr ""
"ອາເຣ ຫຼື ຂອບເຂດທີ່ມີຂໍ້ມູນທີ່ຈະພິຈາລະນາ, ຈັດໂຄງສ້າງໃຫ້ແຖວທຳອິດເປັນປ້າຍຊື່ສຳລັບຄ່າໃນແຕ່ລະຖັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The array or range containing the dataset to consider."
msgstr "ອາເຣ ຫຼື ຂອບເຂດທີ່ມີຊຸດຂໍ້ມູນທີ່ຈະພິຈາລະນາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The array or range of values that will be reduced by corresponding entries "
"in array_y, squared, and added together."
msgstr ""
"ອາເຣ ຫຼື ຂອບເຂດຂອງຄ່າທີ່ຈະຖືກລົບດ້ວຍຄ່າທີ່ກົງກັນໃນ array_y, ແລ້ວຍົກກຳລັງສອງ, ແລະ ເອົາມາລວມກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The array or range of values that will be subtracted from corresponding "
"entries in array_x, the result squared, and all such results added together."
msgstr ""
"ອາເຣ ຫຼື ຂອບເຂດຂອງຄ່າທີ່ຈະຖືກນຳໄປລົບອອກຈາກຄ່າທີ່ກົງກັນໃນ array_x, ແລ້ວຜົນລົບຍົກກຳລັງສອງ, ແລະ ເ"
"ອົາຜົນໄດ້ຮັບທັງໝົດມາລວມກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The array or range of values whose squares will be added to the squares of "
"corresponding entries in array_x and added together."
msgstr ""
"ອາເຣ ຫຼື ຂອບເຂດຂອງຄ່າທີ່ກຳລັງສອງຂອງມັນຈະຖືກບວກເຂົ້າກັບກຳລັງສອງຂອງຄ່າທີ່ກົງກັນໃນ array_x ແລະ ລວ"
"ມເຂົ້າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The array or range of values whose squares will be added to the squares of "
"corresponding entries in array_y and added together."
msgstr ""
"ອາເຣ ຫຼື ຂອບເຂດຂອງຄ່າທີ່ກຳລັງສອງຂອງມັນຈະຖືກບວກເຂົ້າກັບກຳລັງສອງຂອງຄ່າທີ່ກົງກັນໃນ array_y ແລະ ລວ"
"ມເຂົ້າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The array or range of values whose squares will be reduced by the squares of"
" corresponding entries in array_y and added together."
msgstr ""
"ອາເຣ ຫຼື ຂອບເຂດຂອງຄ່າທີ່ກຳລັງສອງຂອງມັນຈະຖືກລົບດ້ວຍກຳລັງສອງຂອງຄ່າທີ່ກົງກັນໃນ array_y ແລະ ລວມເຂົ້"
"າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The array or range of values whose squares will be subtracted from the "
"squares of corresponding entries in array_x and added together."
msgstr ""
"ອາເຣ ຫຼື ຂອບເຂດຂອງຄ່າທີ່ກຳລັງສອງຂອງມັນຈະຖືກນຳໄປລົບອອກຈາກກຳລັງສອງຂອງຄ່າທີ່ກົງກັນໃນ array_x ແລ"
"ະ ລວມເຂົ້າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The array that contains the columns to be returned."
msgstr "ອາເຣທີ່ມີບັນດາຖັນທີ່ຈະຖືກສົ່ງຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The array that contains the rows to be returned."
msgstr "ອາເຣທີ່ມີບັນດາແຖວທີ່ຈະຖືກສົ່ງຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The array to expand."
msgstr "ອາເຣທີ່ຈະຂະຫຍາຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The array which will be transformed."
msgstr "ອາເຣທີ່ຈະຖືກແປງຮູບຮ່າງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The base (%s) must be between 2 and 36 inclusive."
msgstr "ຖານ (%s) ຕ້ອງຢູ່ລະຫວ່າງ 2 ຫາ 36."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The base (%s) must be strictly positive."
msgstr "ຖານ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The base must be different from 1."
msgstr "ຖານຕ້ອງຕ່າງຈາກ 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The base of the logarithm."
msgstr "ຖານຂອງໂລກາລິດ (logarithm)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The base to convert the value from."
msgstr "ຖານທີ່ຈະໃຊ້ແປງຄ່າອອກມາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The baseline value is invalid"
msgstr "ຄ່າເສັ້ນພື້ນຖານ (baseline) ບໍ່ຖືກຕ້ອງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The case-sensitive format of the result, enclosed in quotation marks. "
"Examples: \"0.00\" rounded to 2 decimal places, \"hh:mm:ss\" for "
"hour:minutes:seconds."
msgstr ""
"ຮູບແບບຂອງຜົນໄດ້ຮັບ (ກວດສອບຕົວພິມໃຫຍ່-ນ້ອຍ), ໃສ່ໃນເຄື່ອງໝາຍຄຳເວົ້າ. ຕົວຢ່າງ: \"0.00\" ປັດເປັນທົດ"
"ສະນິຍົມ 2 ຕຳແໜ່ງ, \"hh:mm:ss\" ສຳລັບ ຊົ່ວໂມງ:ນາທີ:ວິນາທີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The case_sensitivity (%s) must be 0 or 1."
msgstr "ການກວດສອບຕົວພິມໃຫຍ່-ນ້ອຍ (case_sensitivity) (%s) ຕ້ອງເປັນ 0 ຫຼື 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The cashflow_amounts and cashflow_dates ranges must have the same "
"dimensions."
msgstr "ຂອບເຂດ cashflow_amounts ແລະ cashflow_dates ຕ້ອງມີມິຕິເທົ່າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The cell whose column number will be returned. Column A corresponds to 1. By"
" default, the function use the cell in which the formula is entered."
msgstr ""
"ເຊລທີ່ຈະຖືກສົ່ງຄືນເລກຖັນ. ຖັນ A ເທົ່າກັບ 1. ໂດຍເລີ່ມຕົ້ນ, ຟັງຊັນຈະໃຊ້ເຊລທີ່ພິມສູດນັ້ນລົງໄປ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The cell whose row number will be returned. By default, this function uses "
"the cell in which the formula is entered."
msgstr ""
"ເຊລທີ່ຈະຖືກສົ່ງຄືນເລກແຖວ. ໂດຍເລີ່ມຕົ້ນ, ຟັງຊັນຈະໃຊ້ເຊລທີ່ພິມສູດນັ້ນລົງໄປ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The cell you are trying to edit has been deleted."
msgstr "ເຊລທີ່ທ່ານກຳລັງພະຍາຍາມແກ້ໄຂໄດ້ຖືກລຶບໄປແລ້ວ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The character or characters to use to split text."
msgstr "ຕົວອັກສອນ ຫຼື ກຸ່ມຕົວອັກສອນທີ່ຈະໃຊ້ແຍກຂໍ້ຄວາມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The character or string to place between each concatenated value."
msgstr "ຕົວອັກສອນ ຫຼື ຂໍ້ຄວາມທີ່ຈະໃສ່ລະຫວ່າງແຕ່ລະຄ່າທີ່ນຳມາຕໍ່ກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The character within text_to_search at which to start the search."
msgstr "ຕຳແໜ່ງຕົວອັກສອນໃນ text_to_search ທີ່ຈະເລີ່ມຕົ້ນການຄົ້ນຫາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The chart definition is invalid for an unknown reason"
msgstr "ຄຳນິຍາມແຜນພູມບໍ່ຖືກຕ້ອງຍ້ອນເຫດຜົນທີ່ບໍ່ຮູ້ຈັກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The column index of the value to be returned, where the first column in "
"range is numbered 1."
msgstr "ດັດຊະນີຖັນຂອງຄ່າທີ່ຈະສົ່ງຄືນ, ໂດຍຖັນທຳອິດໃນຂອບເຂດຈະເປັນໝາຍເລກ 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The column number (not name) of the cell reference. A is column number 1. "
msgstr "ເລກຖັນ (ບໍ່ແມ່ນຊື່) ຂອງການອ້າງອີງເຊລ. A ແມ່ນຖັນໝາຍເລກ 1. "

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The columns argument (%s) must be strictly positive."
msgstr "ອາຄິວເມັ້ນຖັນ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The columns arguments (%s) must be greater or equal than the number of "
"columns of the array."
msgstr "ອາຄິວເມັ້ນຖັນ (%s) ຕ້ອງຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ ຈຳນວນຖັນຂອງອາເຣ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The columns arguments must be between -%s and %s (got %s), excluding 0."
msgstr "ອາຄິວເມັ້ນຖັນຕ້ອງຢູ່ລະຫວ່າງ -%s ຫາ %s (ໄດ້ຮັບ %s), ຍົກເວັ້ນ 0."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The columns indexes of the columns to be returned."
msgstr "ດັດຊະນີຖັນຂອງບັນດາຖັນທີ່ຈະຖືກສົ່ງຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/currency/formulas.js:0
msgid "The company to take the exchange rate from."
msgstr "ບໍລິສັດທີ່ຈະດຶງເອົາອັດຕາແລກປ່ຽນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The corresponding value to be returned if case1 matches expression."
msgstr "ຄ່າທີ່ກົງກັນທີ່ຈະສົ່ງຄືນ ຖ້າ case1 ກົງກັບນິພົດ (expression)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The cost (%s) must be positive or null."
msgstr "ຕົ້ນທຶນ (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The cost (%s) must be strictly positive."
msgstr "ຕົ້ນທຶນ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The covariance of a dataset."
msgstr "ຄ່າຄວາມແປປວນຮ່ວມ (covariance) ຂອງຊຸດຂໍ້ມູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The criteria range contains %s row, it must be at least 2 rows."
msgstr "ຂອບເຂດເງື່ອນໄຂມີ %s ແຖວ, ມັນຕ້ອງມີຢ່າງໜ້ອຍ 2 ແຖວ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The current value of the annuity."
msgstr "ມູນຄ່າປັດຈຸບັນຂອງເງິນງວດ (annuity)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The current window is too small to display this sheet properly. Consider "
"resizing your browser window or adjusting frozen rows and columns."
msgstr ""
"ໜ້າຕ່າງປັດຈຸບັນນ້ອຍເກີນໄປທີ່ຈະສະແດງແຜ່ນງານນີ້ໄດ້ຢ່າງຖືກຕ້ອງ. ກະລຸນາປັບຂະໜາດໜ້າຕ່າງບຣາວເຊີ ຫຼື ປັບປ່ຽນກ"
"ານຄຶງແຖວ ແລະ ຖັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The data points to return the y values for on the ideal curve fit."
msgstr "ຈຸດຂໍ້ມູນທີ່ຈະສົ່ງຄືນຄ່າ y ສຳລັບເສັ້ນໂຄ້ງທີ່ເໝາະສົມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The data range is invalid"
msgstr "ຂອບເຂດຂໍ້ມູນບໍ່ຖືກຕ້ອງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The data to be filtered."
msgstr "ຂໍ້ມູນທີ່ຈະຖືກຕອງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The data to be sorted."
msgstr "ຂໍ້ມູນທີ່ຈະຖືກລຽງລໍາດັບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The data to filter by unique entries."
msgstr "ຂໍ້ມູນທີ່ຈະຕອງເອົາສະເພາະຄ່າທີ່ບໍ່ຊ້ຳກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The data view makes the carousel transparent, revealing the data underneath."
msgstr "ມຸມມອງຂໍ້ມູນເຮັດໃຫ້ carousel ໂປ່ງໃສ ເພື່ອໃຫ້ເຫັນຂໍ້ມູນທີ່ຢູ່ທາງລຸ່ມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The data you entered in %s violates the data validation rule set on the cell:\n"
"%s"
msgstr ""
"ຂໍ້ມູນທີ່ທ່ານປ້ອນໃນ %s ບໍ່ຖືກຕ້ອງຕາມກົດການກວດສອບຂໍ້ມູນທີ່ຕັ້ງໄວ້ໃນເຊລ:\n"
"%s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The dataset is invalid"
msgstr "ຊຸດຂໍ້ມູນບໍ່ຖືກຕ້ອງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The date for which to determine the ISO week number. Must be a reference to "
"a cell containing a date, a function returning a date type, or a number."
msgstr ""
"ວັນທີທີ່ຈະໃຊ້ກຳນົດເລກອາທິດຕາມ ISO. ຕ້ອງເປັນການອ້າງອີງເຊລທີ່ມີວັນທີ, ຟັງຊັນທີ່ສົ່ງຄືນຄ່າວັນທີ, ຫຼື ຕົວເລກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The date for which to determine the day of the week. Must be a reference to "
"a cell containing a date, a function returning a date type, or a number."
msgstr ""
"ວັນທີທີ່ຈະໃຊ້ກຳນົດວັນໃນອາທິດ. ຕ້ອງເປັນການອ້າງອີງເຊລທີ່ມີວັນທີ, ຟັງຊັນທີ່ສົ່ງຄືນຄ່າວັນທີ, ຫຼື ຕົວເລກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The date for which to determine the week number. Must be a reference to a "
"cell containing a date, a function returning a date type, or a number."
msgstr ""
"ວັນທີທີ່ຈະໃຊ້ກຳນົດເລກອາທິດ. ຕ້ອງເປັນການອ້າງອີງເຊລທີ່ມີວັນທີ, ຟັງຊັນທີ່ສົ່ງຄືນຄ່າວັນທີ, ຫຼື ຕົວເລກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date from which to begin counting."
msgstr "ວັນທີທີ່ຈະເລີ່ມຕົ້ນການນັບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date from which to calculate the end of quarter."
msgstr "ວັນທີທີ່ຈະໃຊ້ຄຳນວນມື້ສຸດທ້າຍຂອງໄຕມາດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date from which to calculate the end of the year."
msgstr "ວັນທີທີ່ຈະໃຊ້ຄຳນວນມື້ສຸດທ້າຍຂອງປີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date from which to calculate the result."
msgstr "ວັນທີທີ່ຈະໃຊ້ຄຳນວນຜົນໄດ້ຮັບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date from which to calculate the start of quarter."
msgstr "ວັນທີທີ່ຈະໃຊ້ຄຳນວນມື້ເລີ່ມຕົ້ນຂອງໄຕມາດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date from which to calculate the start of the year."
msgstr "ວັນທີທີ່ຈະໃຊ້ຄຳນວນມື້ເລີ່ມຕົ້ນຂອງປີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date from which to extract the day."
msgstr "ວັນທີທີ່ຈະໃຊ້ດຶງເອົາຄ່າຂອງວັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date from which to extract the month."
msgstr "ວັນທີທີ່ຈະໃຊ້ດຶງເອົາຄ່າຂອງເດືອນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date from which to extract the quarter."
msgstr "ວັນທີທີ່ຈະໃຊ້ດຶງເອົາຄ່າຂອງໄຕມາດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date from which to extract the year."
msgstr "ວັນທີທີ່ຈະໃຊ້ດຶງເອົາຄ່າຂອງປີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date the asset was purchased."
msgstr "ວັນທີທີ່ຊື້ຊັບສິນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date the first period ended."
msgstr "ວັນທີທີ່ສິ້ນສຸດງວດທຳອິດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date the security was initially issued."
msgstr "ວັນທີທີ່ອອກຫຼັກຊັບໃນຕອນທຳອິດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date_string (%s) cannot be parsed to date/time."
msgstr "ຂໍ້ຄວາມວັນທີ (date_string) (%s) ບໍ່ສາມາດແປງເປັນ ວັນທີ/ເວລາ ໄດ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The day component of the date."
msgstr "ສ່ວນປະກອບຂອງວັນໃນວັນທີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The day_count_convention (%s) must be between 0 and 4 inclusive."
msgstr "ວິທີການນັບວັນ (day_count_convention) (%s) ຕ້ອງຢູ່ລະຫວ່າງ 0 ຫາ 4."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The delimiter (%s) must be not be empty."
msgstr "ຕົວຂັ້ນ (%s) ຕ້ອງບໍ່ວ່າງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The delimiters cannot be empty values."
msgstr "ຕົວຂັ້ນບໍ່ສາມາດເປັນຄ່າວ່າງໄດ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The deprecation rate."
msgstr "ອັດຕາຄ່າເສື່ອມລາຄາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The depreciation factor (%s) must be strictly positive."
msgstr "ປັດໄຈຄ່າເສື່ອມລາຄາ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The desired instance of the delimiter after which we extract the text. A "
"negative number searches from the end."
msgstr ""
"ຕຳແໜ່ງຂອງຕົວຂັ້ນທີ່ຕ້ອງການ ເພື່ອຈະດຶງຂໍ້ຄວາມຫຼັງຈາກນັ້ນ. ຕົວເລກລົບຈະຄົ້ນຫາຈາກທ້າຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The desired instance of the delimiter before which we extract the text. A "
"negative number searches from the end."
msgstr ""
"ຕຳແໜ່ງຂອງຕົວຂັ້ນທີ່ຕ້ອງການ ເພື່ອຈະດຶງຂໍ້ຄວາມກ່ອນໜ້ານັ້ນ. ຕົວເລກລົບຈະຄົ້ນຫາຈາກທ້າຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The discount (%s) must be different from -1."
msgstr "ສ່ວນຫຼຸດ (%s) ຕ້ອງຕ່າງຈາກ -1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The discount (%s) must be smaller than 1."
msgstr "ສ່ວນຫຼຸດ (%s) ຕ້ອງນ້ອຍກວ່າ 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The discount (%s) must be strictly positive."
msgstr "ສ່ວນຫຼຸດ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The discount rate of the bill at time of purchase."
msgstr "ອັດຕາສ່ວນຫຼຸດຂອງບິນໃນເວລາທີ່ຊື້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The discount rate of the investment over one period."
msgstr "ອັດຕາສ່ວນຫຼຸດຂອງການລົງທຶນໃນໜຶ່ງງວດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The discount rate of the security at time of purchase."
msgstr "ອັດຕາສ່ວນຫຼຸດຂອງຫຼັກຊັບໃນເວລາທີ່ຊື້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The discount rate of the security invested in."
msgstr "ອັດຕາສ່ວນຫຼຸດຂອງຫຼັກຊັບທີ່ລົງທຶນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The divisor must be different from 0."
msgstr "ຕົວຫານຕ້ອງຕ່າງຈາກ 0."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The divisor must be different from zero."
msgstr "ຕົວຫານຕ້ອງຕ່າງຈາກສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The effective interest rate per year."
msgstr "ອັດຕາດອກເບ້ຍທີ່ແທ້ຈິງຕໍ່ປີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The effective_rate (%s) must be strictly positive."
msgstr "ອັດຕາທີ່ແທ້ຈິງ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The end date of the period from which to calculate the number of net working"
" days."
msgstr "ວັນທີສິ້ນສຸດຂອງໄລຍະເວລາທີ່ຈະໃຊ້ຄຳນວນຈຳນວນມື້ເຮັດວຽກສຸດທິ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The end date to consider in the calculation."
msgstr "ວັນທີສິ້ນສຸດທີ່ຈະນຳມາພິຈາລະນາໃນການຄຳນວນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The end date to consider in the calculation. Must be a reference to a cell "
"containing a DATE, a function returning a DATE type, or a number."
msgstr ""
"ວັນທີສິ້ນສຸດທີ່ຈະນຳມາພິຈາລະນາໃນການຄຳນວນ. ຕ້ອງເປັນການອ້າງອີງເຊລທີ່ມີວັນທີ, ຟັງຊັນທີ່ສົ່ງຄືນຄ່າວັນທີ, ຫຼື ຕົວ"
"ເລກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The end date to consider in the calculation. Must be a reference to a cell "
"containing a date, a function returning a date type, or a number."
msgstr ""
"ວັນທີສິ້ນສຸດທີ່ຈະນຳມາພິຈາລະນາໃນການຄຳນວນ. ຕ້ອງເປັນການອ້າງອີງເຊລທີ່ມີວັນທີ, ຟັງຊັນທີ່ສົ່ງຄືນຄ່າວັນທີ, ຫຼື ຕົວ"
"ເລກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The end of the date range."
msgstr "ມື້ສິ້ນສຸດຂອງຂອບເຂດວັນທີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The end_date (%s) must be positive or null."
msgstr "ວັນທີສິ້ນສຸດ (end_date) (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The end_period (%(end)s) must be smaller or equal to the life (%(life)s)."
msgstr ""
"ງວດສິ້ນສຸດ (%(end)s) ຕ້ອງນ້ອຍກວ່າ ຫຼື ເທົ່າກັບ ອາຍຸການໃຊ້ງານ (%(life)s)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The end_period (%s) must be positive or null."
msgstr "ງວດສິ້ນສຸດ (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The expected annual yield of the security."
msgstr "ຜົນຕອບແທນລາຍປີທີ່ຄາດຫວັງຂອງຫຼັກຊັບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The exponent (%s) must be an integer when the base is negative."
msgstr "ເລກກຳລັງ (%s) ຕ້ອງເປັນເລກຖ້ວນ ເມື່ອຖານເປັນຄ່າລົບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The exponent to raise base to."
msgstr "ເລກກຳລັງທີ່ຈະໃຊ້ຍົກຖານຂຶ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The exponent to raise e."
msgstr "ເລກກຳລັງທີ່ຈະໃຊ້ຍົກ e ຂຶ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The extract_length argument (%s) must be positive or null."
msgstr "ອາຄິວເມັ້ນຄວາມຍາວທີ່ຈະດຶງ (extract_length) (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The factor (%s) must be positive when the value (%s) is positive."
msgstr "ປັດໄຈ (%s) ຕ້ອງເປັນຄ່າບວກ ເມື່ອຄ່າ (%s) ເປັນຄ່າບວກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The factor by which depreciation decreases."
msgstr "ປັດໄຈທີ່ເຮັດໃຫ້ຄ່າເສື່ອມລາຄາຫຼຸດລົງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/list/list_data_source.js:0
msgid "The field %s does not exist or you do not have access to that field"
msgstr "ຟີວ %s ບໍ່ມີຢູ່ ຫຼື ທ່ານບໍ່ມີສິດເຂົ້າເຖິງຟີວນັ້ນ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The field (%(fieldValue)s) must be one of %(dimRowDB)s or must be a number "
"between 1 and %s inclusive."
msgstr ""
"ຟີວ (%(fieldValue)s) ຕ້ອງແມ່ນໜຶ່ງໃນ %(dimRowDB)s ຫຼື ຕ້ອງເປັນຕົວເລກລະຫວ່າງ 1 ຫາ %s."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The field (%s) must be one of %s."
msgstr "ຟີວ (%s) ຕ້ອງແມ່ນໜຶ່ງໃນ %s."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The field must be a number or a string"
msgstr "ຟີວຕ້ອງເປັນຕົວເລກ ຫຼື ຂໍ້ຄວາມ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/list/list_functions.js:0
msgid "The field name should not be empty."
msgstr "ຊື່ຟີວບໍ່ຄວນວ່າງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The file you are trying to copy is too large (>%sMB).\n"
"It will not be added to your OS clipboard.\n"
"You can download it directly instead."
msgstr ""
"ໄຟລ໌ທີ່ທ່ານພະຍາຍາມສຳເນົາໃຫຍ່ເກີນໄປ (>%sMB).\n"
"ມັນຈະບໍ່ຖືກເພີ່ມໃສ່ຄລິບບອດຂອງລະບົບ.\n"
"ທ່ານສາມາດດາວໂຫຼດມັນໂດຍກົງແທນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first addend."
msgstr "ຕົວຕັ້ງບວກທຳອິດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The first and second arguments of [[FUNCTION_NAME]] must be non-empty "
"matrices."
msgstr ""
"ອາຄິວເມັ້ນທຳອິດ ແລະ ທີສອງຂອງ [[FUNCTION_NAME]] ຕ້ອງເປັນມາຕຣິກ (matrices) ທີ່ບໍ່ວ່າງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first case to be checked against expression."
msgstr "ກໍລະນີທຳອິດທີ່ຈະກວດສອບກັບນິພົດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first column index of the columns to be returned."
msgstr "ດັດຊະນີຖັນທຳອິດຂອງບັນດາຖັນທີ່ຈະຖືກສົ່ງຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The first condition to be evaluated. This can be a boolean, a number, an "
"array, or a reference to any of those."
msgstr ""
"ເງື່ອນໄຂທຳອິດທີ່ຈະຖືກປະເມີນ. ສາມາດເປັນຄ່າບູລີນ, ຕົວເລກ, ອາເຣ ຫຼື ການອ້າງອີງໃສ່ຄ່າເຫຼົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first future cash flow."
msgstr "ກະແສເງິນສົດໃນອະນາຄົດທຳອິດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first matrix in the matrix multiplication operation."
msgstr "ມາຕຣິກທຳອິດໃນການດຳເນີນການຄູນມາຕຣິກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first multiplicand."
msgstr "ຕົວຕັ້ງຄູນທຳອິດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first number in the sequence"
msgstr "ຕົວເລກທຳອິດໃນລໍາດັບ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first number or range to add together."
msgstr "ຕົວເລກ ຫຼື ຂອບເຂດທຳອິດທີ່ຈະນຳມາບວກກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first number or range to calculate for the product."
msgstr "ຕົວເລກ ຫຼື ຂອບເຂດທຳອິດທີ່ຈະນຳມາຄຳນວນຫາຜົນຄູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first number to compare."
msgstr "ຕົວເລກທຳອິດທີ່ຈະນຳມາປຽບທຽບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first range to be appended."
msgstr "ຂອບເຂດທຳອິດທີ່ຈະນຳມາຕໍ່ທ້າຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first range to flatten."
msgstr "ຂອບເຂດທຳອິດທີ່ຈະເຮັດໃຫ້ເປັນມິຕິດຽວ (flatten)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The first range whose entries will be multiplied with corresponding entries "
"in the other ranges."
msgstr "ຂອບເຂດທຳອິດທີ່ຄ່າໃນນັ້ນຈະຖືກຄູນດ້ວຍຄ່າທີ່ກົງກັນໃນຂອບເຂດອື່ນໆ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first row index of the rows to be returned."
msgstr "ດັດຊະນີແຖວທຳອິດຂອງບັນດາແຖວທີ່ຈະຖືກສົ່ງຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first string to compare."
msgstr "ຂໍ້ຄວາມທຳອິດທີ່ຈະນຳມາປຽບທຽບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first value must be a number"
msgstr "ຄ່າທຳອິດຕ້ອງເປັນຕົວເລກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first value or range in which to count the number of blanks."
msgstr "ຄ່າ ຫຼື ຂອບເຂດທຳອິດທີ່ຈະໃຊ້ນັບຈຳນວນເຊລວ່າງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first value or range of the population."
msgstr "ຄ່າ ຫຼື ຂອບເຂດທຳອິດຂອງປະຊາກອນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first value or range of the sample."
msgstr "ຄ່າ ຫຼື ຂອບເຂດທຳອິດຂອງກຸ່ມຕົວຢ່າງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first value or range to consider for uniqueness."
msgstr "ຄ່າ ຫຼື ຂອບເຂດທຳອິດທີ່ຈະພິຈາລະນາຄວາມບໍ່ຊ້ຳກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The first value or range to consider when calculating the average value."
msgstr "ຄ່າ ຫຼື ຂອບເຂດທຳອິດທີ່ຈະພິຈາລະນາເມື່ອຄຳນວນຄ່າສະເລ່ຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The first value or range to consider when calculating the maximum value."
msgstr "ຄ່າ ຫຼື ຂອບເຂດທຳອິດທີ່ຈະພິຈາລະນາເມື່ອຄຳນວນຄ່າສູງສຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The first value or range to consider when calculating the median value."
msgstr "ຄ່າ ຫຼື ຂອບເຂດທຳອິດທີ່ຈະພິຈາລະນາເມື່ອຄຳນວນຄ່າມັດທະຍະຖານ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The first value or range to consider when calculating the minimum value."
msgstr "ຄ່າ ຫຼື ຂອບເຂດທຳອິດທີ່ຈະພິຈາລະນາເມື່ອຄຳນວນຄ່າຕ່ຳສຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first value or range to consider when counting."
msgstr "ຄ່າ ຫຼື ຂອບເຂດທຳອິດທີ່ຈະພິຈາລະນາເມື່ອນັບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first value."
msgstr "ຄ່າທຳອິດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The first_period (%(first)s) must be smaller or equal to the last_period "
"(%(last)s)."
msgstr "ງວດທຳອິດ (%(first)s) ຕ້ອງນ້ອຍກວ່າ ຫຼື ເທົ່າກັບ ງວດສຸດທ້າຍ (%(last)s)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first_period (%s) must be strictly positive."
msgstr "ງວດທຳອິດ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The formatting unit should be 'k', 'm' or 'b'."
msgstr "ຫົວໜ່ວຍຮູບແບບຄວນເປັນ 'k' (ພັນ), 'm' (ລ້ານ) ຫຼື 'b' (ຕື້)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The formatting unit. Use 'k', 'm', or 'b' to force the unit"
msgstr "ຫົວໜ່ວຍຮູບແບບ. ໃຊ້ 'k', 'm' ຫຼື 'b' ເພື່ອບັງຄັບຫົວໜ່ວຍ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The formula must be valid"
msgstr "ສູດຕ້ອງຖືກຕ້ອງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The frequency (%s) must be one of %s"
msgstr "ຄວາມຖີ່ (%s) ຕ້ອງແມ່ນໜຶ່ງໃນ %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The full URL of the link enclosed in quotation marks."
msgstr "URL ເຕັມຂອງລິ້ງ ທີ່ໃສ່ໃນເຄື່ອງໝາຍຄຳເວົ້າ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The function [[FUNCTION_NAME]] expects a boolean value, but '%s' is a text, "
"and cannot be coerced to a boolean."
msgstr ""
"ຟັງຊັນ [[FUNCTION_NAME]] ຕ້ອງການຄ່າບູລີນ, ແຕ່ '%s' ເປັນຂໍ້ຄວາມ ແລະ ບໍ່ສາມາດແປງເປັນບູລີນໄດ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The function [[FUNCTION_NAME]] expects a number value between %s and %s "
"inclusive, but receives %s."
msgstr ""
"ຟັງຊັນ [[FUNCTION_NAME]] ຕ້ອງການຄ່າຕົວເລກລະຫວ່າງ %s ຫາ %s, ແຕ່ໄດ້ຮັບ %s."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The function [[FUNCTION_NAME]] expects a number value to be greater than or "
"equal to 1, but receives %s."
msgstr ""
"ຟັງຊັນ [[FUNCTION_NAME]] ຕ້ອງການຄ່າຕົວເລກທີ່ຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ 1, ແຕ່ໄດ້ຮັບ %s."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The function [[FUNCTION_NAME]] expects a number value, but '%s' is a string,"
" and cannot be coerced to a number."
msgstr ""
"ຟັງຊັນ [[FUNCTION_NAME]] ຕ້ອງການຄ່າຕົວເລກ, ແຕ່ '%s' ເປັນຂໍ້ຄວາມ ແລະ ບໍ່ສາມາດແປງເປັນຕົວເລກໄ"
"ດ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The function [[FUNCTION_NAME]] has an argument with value '%s'. It should be"
" one of: %s."
msgstr ""
"ຟັງຊັນ [[FUNCTION_NAME]] ມີອາຄິວເມັ້ນທີ່ມີຄ່າ '%s'. ມັນຄວນຈະແມ່ນໜຶ່ງໃນ: %s."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The function [[FUNCTION_NAME]] result cannot be negative"
msgstr "ຜົນໄດ້ຮັບຂອງຟັງຊັນ [[FUNCTION_NAME]] ບໍ່ສາມາດເປັນຄ່າລົບໄດ້"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The function [[FUNCTION_NAME]] result must be greater than or equal "
"01/01/1900."
msgstr ""
"ຜົນໄດ້ຮັບຂອງຟັງຊັນ [[FUNCTION_NAME]] ຕ້ອງຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ 01/01/1900."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The function code (%s) must be between 1 to 11 or 101 to 111."
msgstr "ລະຫັດຟັງຊັນ (%s) ຕ້ອງຢູ່ລະຫວ່າງ 1 ຫາ 11 ຫຼື 101 ຫາ 111."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The function to use in subtotal aggregation."
msgstr "ຟັງຊັນທີ່ຈະໃຊ້ໃນການລວມຍ່ອຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The future value of the investment."
msgstr "ມູນຄ່າໃນອະນາຄົດຂອງການລົງທຶນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The future value remaining after the final payment has been made."
msgstr "ມູນຄ່າໃນອະນາຄົດທີ່ເຫຼືອຫຼັງຈາກການຊຳລະງວດສຸດທ້າຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The future_value (%s) must be strictly positive."
msgstr "ມູນຄ່າໃນອະນາຄົດ (future_value) (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The header row of a table can't be moved."
msgstr "ແຖວສ່ວນຫົວຂອງຕາຕະລາງບໍ່ສາມາດຍ້າຍໄດ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The high (%s) must be greater than or equal to the low (%s)."
msgstr "ຄ່າສູງສຸດ (%s) ຕ້ອງຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ ຄ່າຕ່ຳສຸດ (%s)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The high end of the random range."
msgstr "ຂອບເຂດສູງສຸດຂອງການສຸ່ມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The hour component of the time."
msgstr "ສ່ວນປະກອບຂອງຊົ່ວໂມງໃນເວລາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The index from the left of string from which to begin extracting. The first "
"character in string has the index 1."
msgstr ""
"ດັດຊະນີຈາກເບື້ອງຊ້າຍຂອງຂໍ້ຄວາມທີ່ຈະເລີ່ມດຶງອອກມາ. ຕົວອັກສອນທຳອິດມີດັດຊະນີແມ່ນ 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The index of the column in range or a range outside of range containing the "
"values by which to sort."
msgstr "ດັດຊະນີຂອງຖັນໃນຂອບເຂດ ຫຼື ຂອບເຂດພາຍນອກທີ່ມີຄ່າທີ່ຈະໃຊ້ລຽງລໍາດັບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The index of the column to be returned from within the reference range of "
"cells."
msgstr "ດັດຊະນີຂອງຖັນທີ່ຈະຖືກສົ່ງຄືນຈາກພາຍໃນຂອບເຂດການອ້າງອີງຂອງເຊລ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The index of the row to be returned from within the reference range of "
"cells."
msgstr "ດັດຊະນີຂອງແຖວທີ່ຈະຖືກສົ່ງຄືນຈາກພາຍໃນຂອບເຂດການອ້າງອີງຂອງເຊລ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The info_type should be one of %s."
msgstr "ປະເພດຂໍ້ມູນ (info_type) ຄວນແມ່ນໜຶ່ງໃນ %s."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The initial cost of the asset."
msgstr "ຕົ້ນທຶນເລີ່ມຕົ້ນຂອງຊັບສິນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The initial string."
msgstr "ຂໍ້ຄວາມເລີ່ມຕົ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The instance of search_for within text_to_search to replace with "
"replace_with. By default, all occurrences of search_for are replaced; "
"however, if occurrence_number is specified, only the indicated instance of "
"search_for is replaced."
msgstr ""
"ຕຳແໜ່ງຂອງ search_for ໃນ text_to_search ທີ່ຈະແທນທີ່ດ້ວຍ replace_with. ໂດຍເລີ່ມຕົ້ນ, ຈະແທ"
"ນທີ່ທຸກໆຈຸດທີ່ພົບ; ແຕ່ຖ້າລະບຸ occurrence_number, ຈະແທນທີ່ສະເພາະຕຳແໜ່ງນັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The instance_num (%s) must not be zero."
msgstr "ລໍາດັບທີ່ພົບ (instance_num) (%s) ຕ້ອງບໍ່ເປັນສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The interest rate paid on funds invested."
msgstr "ອັດຕາດອກເບ້ຍທີ່ຈ່າຍໃຫ້ກັບເງິນທີ່ລົງທຶນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The interest rate."
msgstr "ອັດຕາດອກເບ້ຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The investment (%s) must be strictly positive."
msgstr "ເງິນລົງທຶນ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The investment's current value."
msgstr "ມູນຄ່າປັດຈຸບັນຂອງການລົງທຶນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The investment's desired future value."
msgstr "ມູນຄ່າໃນອະນາຄົດທີ່ຕ້ອງການຂອງການລົງທຶນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The issue (%s) must be positive or null."
msgstr "ວັນທີອອກ (issue) (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The key value is invalid"
msgstr "ຄ່າຄີ (key) ບໍ່ຖືກຕ້ອງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/pivot/pivot_functions.js:0
msgid "The label of the filter whose value to return."
msgstr "ປ້າຍຊື່ຂອງຕົວຕອງທີ່ຈະສົ່ງຄືນຄ່າ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The last_period (%(last)s) must be smaller or equal to the number_of_periods"
" (%(nPeriods)s)."
msgstr ""
"ງວດສຸດທ້າຍ (%(last)s) ຕ້ອງນ້ອຍກວ່າ ຫຼື ເທົ່າກັບ ຈຳນວນງວດທັງໝົດ (%(nPeriods)s)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The last_period (%s) must be strictly positive."
msgstr "ງວດສຸດທ້າຍ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The length of the segment to extract."
msgstr "ຄວາມຍາວຂອງສ່ວນຂໍ້ຄວາມທີ່ຈະດຶງອອກມາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The life (%s) must be strictly positive."
msgstr "ອາຍຸການໃຊ້ງານ (life) (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The logarithm of a number, base e (euler's number)."
msgstr "ໂລກາລິດຂອງຕົວເລກ, ຖານ e (ຕົວເລກຂອງ Euler)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The logarithm of a number, for a given base."
msgstr "ໂລກາລິດຂອງຕົວເລກ, ສຳລັບຖານທີ່ກຳນົດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The low end of the random range."
msgstr "ຂອບເຂດຕ່ຳສຸດຂອງການສຸ່ມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The lower inflection point value must be a number"
msgstr "ຄ່າຂອງຈຸດປ່ຽນໂຄ້ງລຸ່ມ (lower inflection point) ຕ້ອງເປັນຕົວເລກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The matrix is not invertible."
msgstr "ມາຕຣິກນີ້ບໍ່ສາມາດຫາຕົວປ່ຽນຜັນ (inverse) ໄດ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The maturity (%(maturity)s) must be strictly greater than the settlement "
"(%(settlement)s)."
msgstr ""
"ມື້ຄົບກຳນົດ (%(maturity)s) ຕ້ອງຫຼາຍກວ່າ ມື້ຊຳລະເງິນ (%(settlement)s) ເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The maturity date of the security."
msgstr "ວັນທີຄົບກຳນົດຂອງຫຼັກຊັບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The maturity or end date of the security, when it can be redeemed at face, "
"or par value."
msgstr ""
"ວັນທີຄົບກຳນົດ ຫຼື ວັນທີສິ້ນສຸດຂອງຫຼັກຊັບ, ເມື່ອສາມາດໄຖ່ຖອນໄດ້ຕາມມູນຄ່າໜ້າຕາ ຫຼື ມູນຄ່າທີ່ກຳນົດໄວ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The maximum (%s) and minimum (%s) must be integers when whole_number is "
"TRUE."
msgstr ""
"ຄ່າສູງສຸດ (%s) ແລະ ຕ່ຳສຸດ (%s) ຕ້ອງເປັນເລກຖ້ວນ ເມື່ອ whole_number ເປັນ TRUE."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The maximum (%s) must be greater than or equal to the minimum (%s)."
msgstr "ຄ່າສູງສຸດ (%s) ຕ້ອງຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ ຄ່າຕ່ຳສຸດ (%s)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The maximum number of cells for each column, rounded down to the nearest "
"whole number."
msgstr "ຈຳນວນເຊລສູງສຸດໃນແຕ່ລະຖັນ, ປັດລົງເປັນເລກຖ້ວນທີ່ໃກ້ຄຽງທີ່ສຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The maximum number of cells for each row, rounded down to the nearest whole "
"number."
msgstr "ຈຳນວນເຊລສູງສຸດໃນແຕ່ລະແຖວ, ປັດລົງເປັນເລກຖ້ວນທີ່ໃກ້ຄຽງທີ່ສຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The maximum number you would like returned."
msgstr "ຕົວເລກສູງສຸດທີ່ທ່ານຕ້ອງການໃຫ້ສົ່ງຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The maximum range limit value must be a number"
msgstr "ຄ່າຈຳກັດສູງສຸດຂອງຂອບເຂດຕ້ອງເປັນຕົວເລກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The maxpoint must be a number"
msgstr "ຈຸດສູງສຸດ (maxpoint) ຕ້ອງເປັນຕົວເລກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/chart/odoo_chart/odoo_chart_helpers.js:0
msgid ""
"The menu linked to this chart doesn't have an corresponding action. Please "
"link the chart to another menu."
msgstr ""
"ເມນູທີ່ເຊື່ອມຕໍ່ກັບແຜນພູມນີ້ບໍ່ມີການດຳເນີນການ (action) ທີ່ກ່ຽວຂ້ອງ. ກະລຸນາເຊື່ອມຕໍ່ແຜນພູມກັບເມນູອື່ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The midpoint must be a number"
msgstr "ຈຸດກາງ (midpoint) ຕ້ອງເປັນຕົວເລກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The minimum number you would like returned."
msgstr "ຕົວເລກຕ່ຳສຸດທີ່ທ່ານຕ້ອງການໃຫ້ສົ່ງຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The minimum range limit value must be a number"
msgstr "ຄ່າຈຳກັດຕ່ຳສຸດຂອງຂອບເຂດຕ້ອງເປັນຕົວເລກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The minpoint must be a number"
msgstr "ຈຸດຕ່ຳສຸດ (minpoint) ຕ້ອງເປັນຕົວເລກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The minuend, or number to be subtracted from."
msgstr "ຕົວຕັ້ງລົບ, ຫຼື ຕົວເລກທີ່ຈະຖືກລົບອອກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The minute component of the time."
msgstr "ສ່ວນປະກອບຂອງນາທີໃນເວລາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/data_sources/data_source.js:0
#: code:addons/spreadsheet/static/src/pivot/odoo_pivot_loader.js:0
msgid "The model \"%(model)s\" does not exist."
msgstr "ໂມເດວ \"%(model)s\" ບໍ່ມີຢູ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/global_filters/components/filter_value/filter_value.js:0
msgid ""
"The model (%(model)s) of this global filter is not valid (it may have been "
"renamed/deleted)."
msgstr ""
"ໂມເດວ (%(model)s) ຂອງຕົວຕອງທົ່ວໂລກນີ້ບໍ່ຖືກຕ້ອງ (ມັນອາດຈະຖືກປ່ຽນຊື່ ຫຼື ລຶບໄປແລ້ວ)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The month (%s) must be between 1 and 12 inclusive."
msgstr "ເດືອນ (%s) ຕ້ອງຢູ່ລະຫວ່າງ 1 ຫາ 12."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The month component of the date."
msgstr "ສ່ວນປະກອບຂອງເດືອນໃນວັນທີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The net present value of an investment based on a series of periodic cash "
"flows and a discount rate."
msgstr ""
"ມູນຄ່າປັດຈຸບັນສຸດທິ (NPV) ຂອງການລົງທຶນ ອີງຕາມຊຸດຂອງກະແສເງິນສົດເປັນງວດ ແລະ ອັດຕາສ່ວນຫຼຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The nominal interest rate per year."
msgstr "ອັດຕາດອກເບ້ຍຕາມກຳນົດຕໍ່ປີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The nominal_rate (%s) must be strictly positive."
msgstr "ອັດຕາຕາມກຳນົດ (nominal_rate) (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number for which to calculate the positive square root."
msgstr "ຕົວເລກທີ່ຈະໃຊ້ຄຳນວນຫາຮາກຂັ້ນສອງທີ່ເປັນຄ່າບວກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of characters in the text to be replaced."
msgstr "ຈຳນວນຕົວອັກສອນໃນຂໍ້ຄວາມທີ່ຈະຖືກແທນທີ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of characters to return from the left side of string."
msgstr "ຈຳນວນຕົວອັກສອນທີ່ຈະສົ່ງຄືນຈາກເບື້ອງຊ້າຍຂອງຂໍ້ຄວາມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of characters to return from the right side of string."
msgstr "ຈຳນວນຕົວອັກສອນທີ່ຈະສົ່ງຄືນຈາກເບື້ອງຂວາຂອງຂໍ້ຄວາມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of columns (%s) must be positive."
msgstr "ຈຳນວນຖັນ (%s) ຕ້ອງເປັນຄ່າບວກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of columns in the constrained array."
msgstr "ຈຳນວນຖັນໃນອາເຣທີ່ຖືກຈຳກັດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number of columns in the expanded array. If missing, columns will not be"
" expanded."
msgstr "ຈຳນວນຖັນໃນອາເຣທີ່ຂະຫຍາຍ. ຖ້າບໍ່ລະບຸ, ຖັນຈະບໍ່ຖືກຂະຫຍາຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of columns must be positive."
msgstr "ຈຳນວນຖັນຕ້ອງເປັນຄ່າບວກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number of columns of the range to return starting at the offset target."
msgstr "ຈຳນວນຖັນຂອງຂອບເຂດທີ່ຈະສົ່ງຄືນ ໂດຍເລີ່ມຈາກເປົ້າໝາຍ offset."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of columns to be returned."
msgstr "ຈຳນວນຖັນທີ່ຈະຖືກສົ່ງຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of columns to offset by."
msgstr "ຈຳນວນຖັນທີ່ຈະໃຊ້ໃນການ offset."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of columns to return"
msgstr "ຈຳນວນຖັນທີ່ຈະສົ່ງຄືນ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of compounding periods per year."
msgstr "ຈຳນວນງວດຂອງການຄິດດອກເບ້ຍທົບຕົ້ນຕໍ່ປີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of days between start_date and end_date"
msgstr "ຈຳນວນມື້ລະຫວ່າງ start_date ແລະ end_date"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number of days between start_date and end_date after subtracting whole "
"months"
msgstr "ຈຳນວນມື້ລະຫວ່າງ start_date ແລະ end_date ຫຼັງຈາກລົບເດືອນເຕັມອອກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number of days between start_date and end_date, assuming start_date and "
"end_date were no more than one year apart"
msgstr ""
"ຈຳນວນມື້ລະຫວ່າງ start_date ແລະ end_date, ໂດຍສົມມຸດວ່າ start_date ແລະ end_date ຫ່າງກັນ"
"ບໍ່ເກີນໜຶ່ງປີ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of decimal places to which to round."
msgstr "ຈຳນວນຕຳແໜ່ງທົດສະນິຍົມທີ່ຈະປັດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of interest or coupon payments per year (1, 2, or 4)."
msgstr "ຈຳນວນການຈ່າຍດອກເບ້ຍ ຫຼື ຄູປອງຕໍ່ປີ (1, 2 ຫຼື 4)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of items to return."
msgstr "ຈຳນວນລາຍການທີ່ຈະສົ່ງຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number of months before (negative) or after (positive) 'start_date' to "
"calculate."
msgstr "ຈຳນວນເດືອນກ່ອນ (ຄ່າລົບ) ຫຼື ຫຼັງ (ຄ່າບວກ) ຈາກ 'start_date' ທີ່ຈະຄຳນວນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number of months before (negative) or after (positive) 'start_date' to "
"consider."
msgstr ""
"ຈຳນວນເດືອນກ່ອນ (ຄ່າລົບ) ຫຼື ຫຼັງ (ຄ່າບວກ) ຈາກ 'start_date' ທີ່ຈະພິຈາລະນາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of months in the first year of depreciation."
msgstr "ຈຳນວນເດືອນໃນປີທຳອິດຂອງການຄິດຄ່າເສື່ອມລາຄາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of numeric values in dataset."
msgstr "ຈຳນວນຄ່າຕົວເລກໃນຊຸດຂໍ້ມູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of payments to be made."
msgstr "ຈຳນວນງວດທີ່ຈະຕ້ອງຊຳລະ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of periods over which the asset is depreciated."
msgstr "ຈຳນວນງວດທີ່ຊັບສິນຈະຖືກຄິດຄ່າເສື່ອມລາຄາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of periods."
msgstr "ຈຳນວນງວດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of rows (%s) must be positive."
msgstr "ຈຳນວນແຖວ (%s) ຕ້ອງເປັນຄ່າບວກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of rows in the constrained array."
msgstr "ຈຳນວນແຖວໃນອາເຣທີ່ຖືກຈຳກັດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number of rows in the expanded array. If missing, rows will not be "
"expanded."
msgstr "ຈຳນວນແຖວໃນອາເຣທີ່ຂະຫຍາຍ. ຖ້າບໍ່ລະບຸ, ແຖວຈະບໍ່ຖືກຂະຫຍາຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of rows must be positive."
msgstr "ຈຳນວນແຖວຕ້ອງເປັນຄ່າບວກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number of rows of the range to return starting at the offset target."
msgstr "ຈຳນວນແຖວຂອງຂອບເຂດທີ່ຈະສົ່ງຄືນ ໂດຍເລີ່ມຈາກເປົ້າໝາຍ offset."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of rows to be returned."
msgstr "ຈຳນວນແຖວທີ່ຈະຖືກສົ່ງຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of rows to offset by."
msgstr "ຈຳນວນແຖວທີ່ຈະໃຊ້ໃນການ offset."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of rows to return"
msgstr "ຈຳນວນແຖວທີ່ຈະສົ່ງຄືນ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number of significant digits to the right of the decimal point to "
"retain."
msgstr "ຈຳນວນຕົວເລກທີ່ມີໄນສຳຄັນທາງເບື້ອງຂວາຂອງຈຸດທົດສະນິຍົມທີ່ຈະເກັບໄວ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number of the character to look up from the current Unicode table in "
"decimal format."
msgstr ""
"ໝາຍເລກຂອງຕົວອັກສອນທີ່ຈະຄົ້ນຫາຈາກຕາຕະລາງ Unicode ປັດຈຸບັນ ໃນຮູບແບບເລກຖານສິບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of the payment period to begin the cumulative calculation."
msgstr "ໝາຍເລກຂອງງວດການຊຳລະທີ່ຈະເລີ່ມຄຳນວນແບບສະສົມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of the payment period to end the cumulative calculation."
msgstr "ໝາຍເລກຂອງງວດການຊຳລະທີ່ຈະສິ້ນສຸດການຄຳນວນແບບສະສົມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of values in a dataset."
msgstr "ຈຳນວນຄ່າໃນຊຸດຂໍ້ມູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of which to return the absolute value."
msgstr "ຕົວເລກທີ່ຈະສົ່ງຄືນຄ່າສຳບູນ (absolute value)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of whole months between start_date and end_date"
msgstr "ຈຳນວນເດືອນເຕັມລະຫວ່າງ start_date ແລະ end_date"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number of whole months between start_date and end_date after subtracting"
" whole years"
msgstr ""
"ຈຳນວນເດືອນເຕັມລະຫວ່າງ start_date ແລະ end_date ຫຼັງຈາກຫັກຈຳນວນປີເຕັມອອກແລ້ວ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of whole years between start_date and end_date"
msgstr "ຈຳນວນປີເຕັມລະຫວ່າງ start_date ແລະ end_date"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number of working days to advance from start_date. If negative, counts "
"backwards."
msgstr ""
"ຈຳນວນມື້ເຮັດວຽກທີ່ຈະເພີ່ມຂຶ້ນຈາກ start_date. ຖ້າເປັນຄ່າລົບ, ຈະນັບຖອຍຫຼັງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number pi."
msgstr "ຄ່າຂອງໄພ (pi)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number to be divided to find the remainder."
msgstr "ຕົວເລກທີ່ຈະຖືກຫານເພື່ອຫາສ່ວນທີ່ເຫຼືອ (remainder)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number to be divided."
msgstr "ຕົວເລກທີ່ຈະຖືກຫານ (ຕົວຕັ້ງຫານ)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number to convert."
msgstr "ຕົວເລກທີ່ຈະແປງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number to divide by."
msgstr "ຕົວເລກທີ່ຈະນຳມາຫານ (ຕົວຫານ)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number to have its sign reversed. Equivalently, the number to multiply "
"by -1."
msgstr ""
"ຕົວເລກທີ່ຈະຖືກກັບເຄື່ອງໝາຍ. ຫຼື ເວົ້າອີກຢ່າງແມ່ນ ຕົວເລກທີ່ຈະນຳມາຄູນດ້ວຍ -1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number to raise to the exponent power."
msgstr "ຕົວເລກທີ່ຈະຖືກຍົກກຳລັງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number to return."
msgstr "ຕົວເລກທີ່ຈະສົ່ງຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number to round down to the nearest integer."
msgstr "ຕົວເລກທີ່ຈະປັດລົງເປັນເລກຖ້ວນທີ່ໃກ້ຄຽງທີ່ສຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number to whose multiples number will be rounded."
msgstr "ຕົວເລກທີ່ຈະຖືກປັດໃຫ້ເປັນຄ່າທະວີຄູນຂອງຕົວເລກນີ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number to whose multiples number will be rounded. The sign of "
"significance will be ignored."
msgstr ""
"ຕົວເລກທີ່ຈະຖືກປັດໃຫ້ເປັນຄ່າທະວີຄູນຂອງຕົວເລກນີ້. ເຄື່ອງໝາຍຂອງຄ່າໄນສຳຄັນຈະຖືກລະເວັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number to whose multiples value will be rounded."
msgstr "ຕົວເລກທີ່ຈະຖືກປັດໃຫ້ເປັນຄ່າທະວີຄູນຂອງຄ່ານີ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number, date or time to format."
msgstr "ຕົວເລກ, ວັນທີ ຫຼື ເວລາທີ່ຈະຈັດຮູບແບບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number."
msgstr "ຕົວເລກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number_of_characters (%s) must be positive or null."
msgstr "ຈຳນວນຕົວອັກສອນ (number_of_characters) (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number_of_periods (%s) must be different from zero."
msgstr "ຈຳນວນງວດ (number_of_periods) (%s) ຕ້ອງຕ່າງຈາກສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number_of_periods (%s) must be strictly positive."
msgstr "ຈຳນວນງວດ (number_of_periods) (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The occurrenceNumber (%s) must be positive or null."
msgstr "ລໍາດັບທີ່ພົບ (occurrenceNumber) (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The one-dimensional array to be searched."
msgstr "ອາເຣໜຶ່ງມິຕິທີ່ຈະຄົ້ນຫາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The order of the polynomial to fit the data, between 1 and 6."
msgstr ""
"ອັນດັບຂອງພະຫຸນາມ (polynomial) ເພື່ອປັບໃຫ້ເຂົ້າກັບຂໍ້ມູນ, ລະຫວ່າງ 1 ຫາ 6."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The other range whose entries will be multiplied with corresponding entries "
"in the other ranges."
msgstr "ຂອບເຂດອື່ນໆທີ່ຄ່າໃນນັ້ນຈະຖືກຄູນດ້ວຍຄ່າທີ່ກົງກັນໃນຂອບເຂດອື່ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pattern or test to apply to criteria_range."
msgstr "ຮູບແບບ ຫຼື ການທົດສອບທີ່ຈະໃຊ້ກັບ criteria_range."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The pattern or test to apply to criteria_range1, such that each cell that "
"evaluates to TRUE will be included in the filtered set."
msgstr ""
"ຮູບແບບ ຫຼື ການທົດສອບທີ່ຈະໃຊ້ກັບ criteria_range1, ເຊິ່ງເຊລທີ່ມີຄ່າເປັນ TRUE ຈະຖືກລວມເຂົ້າໃນຊຸດຂໍ້ມູນ"
"ທີ່ຕອງແລ້ວ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pattern or test to apply to criteria_range1."
msgstr "ຮູບແບບ ຫຼື ການທົດສອບທີ່ຈະໃຊ້ກັບ criteria_range1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pattern or test to apply to criteria_range2."
msgstr "ຮູບແບບ ຫຼື ການທົດສອບທີ່ຈະໃຊ້ກັບ criteria_range2."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pattern or test to apply to range."
msgstr "ຮູບແບບ ຫຼື ການທົດສອບທີ່ຈະໃຊ້ກັບຂອບເຂດ (range)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The percentile whose value within data will be calculated and returned."
msgstr "ເປີເຊັນໄທ (percentile) ທີ່ຄ່າຂອງມັນໃນຂໍ້ມູນຈະຖືກຄຳນວນ ແລະ ສົ່ງຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The percentile, exclusive of 0 and 1, whose value within 'data' will be "
"calculated and returned."
msgstr ""
"ເປີເຊັນໄທ (percentile), ບໍ່ລວມ 0 ແລະ 1, ທີ່ຄ່າຂອງມັນໃນ 'ຂໍ້ມູນ' ຈະຖືກຄຳນວນ ແລະ ສົ່ງຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The period (%(period)s) must be less than or equal life (%(life)s)."
msgstr "ງວດ (%(period)s) ຕ້ອງນ້ອຍກວ່າ ຫຼື ເທົ່າກັບ ອາຍຸການໃຊ້ງານ (%(life)s)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The period (%(period)s) must be less than or equal to %(lifeLimit)s."
msgstr "ງວດ (%(period)s) ຕ້ອງນ້ອຍກວ່າ ຫຼື ເທົ່າກັບ %(lifeLimit)s."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The period (%s) must be positive or null."
msgstr "ງວດ (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The period (%s) must be strictly positive."
msgstr "ງວດ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The period for which you want to view the interest payment."
msgstr "ງວດທີ່ທ່ານຕ້ອງການເບິ່ງການຊຳລະດອກເບ້ຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The period must be between 1 and number_of_periods (%s)"
msgstr "ງວດຕ້ອງຢູ່ລະຫວ່າງ 1 ຫາ ຈຳນວນງວດທັງໝົດ (%s)"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The periods_by_year (%s) must be strictly positive."
msgstr "ຈຳນວນງວດຕໍ່ປີ (periods_by_year) (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pivot cannot be created because cell %s contains a reserved value"
msgstr "ບໍ່ສາມາດສ້າງ Pivot ໄດ້ ເພາະເຊລ %s ມີຄ່າທີ່ສະຫງວນໄວ້"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pivot cannot be created because cell %s contains an error"
msgstr "ບໍ່ສາມາດສ້າງ Pivot ໄດ້ ເພາະເຊລ %s ມີຂໍ້ຜິດພາດ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pivot cannot be created because cell %s is empty"
msgstr "ບໍ່ສາມາດສ້າງ Pivot ໄດ້ ເພາະເຊລ %s ວ່າງເປົ່າ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pivot cannot be created because the dataset is missing."
msgstr "ບໍ່ສາມາດສ້າງ Pivot ໄດ້ ເພາະບໍ່ພົບຊຸດຂໍ້ມູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The position (%s) must be greater than or equal to 1."
msgstr "ຕຳແໜ່ງ (%s) ຕ້ອງຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The position where the replacement will begin (starting from 1)."
msgstr "ຕຳແໜ່ງທີ່ຈະເລີ່ມການແທນທີ່ (ເລີ່ມຈາກ 1)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The present value of the investment."
msgstr "ມູນຄ່າປັດຈຸບັນຂອງການລົງທຶນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The present_value (%s) must be strictly positive."
msgstr "ມູນຄ່າປັດຈຸບັນ (present_value) (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The price (%s) must be strictly positive."
msgstr "ລາຄາ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The price at which the security is bought per 100 face value."
msgstr "ລາຄາທີ່ຊື້ຫຼັກຊັບຕໍ່ມູນຄ່າໜ້າຕາ 100."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The price at which the security is bought."
msgstr "ລາຄາທີ່ຊື້ຫຼັກຊັບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The price quotation given as a decimal value."
msgstr "ລາຄາອ້າງອີງທີ່ລະບຸເປັນຄ່າທົດສະນິຍົມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The price quotation given using fractional decimal conventions."
msgstr "ລາຄາອ້າງອີງທີ່ລະບຸໂດຍໃຊ້ຮູບແບບທົດສະນິຍົມແບບເສດສ່ວນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The purchase_date (%(purchaseDate)s) must be before the first_period_end "
"(%(firstPeriodEnd)s)."
msgstr ""
"ວັນທີຊື້ (%(purchaseDate)s) ຕ້ອງມາກ່ອນ ມື້ສິ້ນສຸດງວດທຳອິດ (%(firstPeriodEnd)s)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The purchase_date (%s) must be positive or null."
msgstr "ວັນທີຊື້ (purchase_date) (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range containing the dataset to consider."
msgstr "ຂອບເຂດທີ່ມີຊຸດຂໍ້ມູນທີ່ຈະພິຈາລະນາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The range containing the return value. Should have the same dimensions as "
"lookup_range."
msgstr "ຂອບເຂດທີ່ມີຄ່າທີ່ຈະສົ່ງຄືນ. ຄວນມີມິຕິດຽວກັບ lookup_range."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range containing the set of classes."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ບັນຈຸຊຸດຂອງຄລາສ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The range from which to return a result. The value returned corresponds to "
"the location where search_key is found in search_range. This range must be "
"only a single row or column and should not be used if using the "
"search_result_array method."
msgstr ""
"ຊ່ວງຂໍ້ມູນທີ່ຈະສົ່ງຄືນຜົນລັບ. ຄ່າທີ່ສົ່ງຄືນຈະກົງກັບຕຳແໜ່ງທີ່ພົບ search_key ໃນ search_range. ຊ່ວງຂໍ້ມູນນີ້ຕ້"
"ອງເປັນແຖວດຽວ ຫຼື ຖັນດຽວເທົ່ານັ້ນ ແລະ ບໍ່ຄວນໃຊ້ຫາກໃຊ້ວິທີ search_result_array."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range is invalid"
msgstr "ຊ່ວງຂໍ້ມູນບໍ່ຖືກຕ້ອງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range is invalid."
msgstr "ຊ່ວງຂໍ້ມູນບໍ່ຖືກຕ້ອງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range is out of bounds."
msgstr "ຊ່ວງຂໍ້ມູນຢູ່ນອກຂອບເຂດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range is out of the sheet"
msgstr "ຊ່ວງຂໍ້ມູນຢູ່ນອກຊີດ (sheet)"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range must be a single row or a single column."
msgstr "ຊ່ວງຂໍ້ມູນຕ້ອງເປັນແຖວດຽວ ຫຼື ຖັນດຽວ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range of cells from which the maximum will be determined."
msgstr "ຊ່ວງຂອງຫ້ອງທີ່ຈະໃຊ້ກຳນົດຄ່າສູງສຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range of cells from which the minimum will be determined."
msgstr "ຊ່ວງຂອງຫ້ອງທີ່ຈະໃຊ້ກຳນົດຄ່າຕ່ຳສຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The range of cells from which the number of unique values will be counted."
msgstr "ຊ່ວງຂອງຫ້ອງທີ່ຈະໃຊ້ນັບຈຳນວນຄ່າທີ່ບໍ່ຊ້ຳກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range of cells from which the values are returned."
msgstr "ຊ່ວງຂອງຫ້ອງທີ່ຈະສົ່ງຄືນຄ່າ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range of cells over which to evaluate criterion1."
msgstr "ຊ່ວງຂອງຫ້ອງທີ່ຈະໃຊ້ປະເມີນເງື່ອນໄຂທີ 1 (criterion1)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range or reference for which you want the subtotal."
msgstr "ຊ່ວງຂໍ້ມູນ ຫຼື ການອ້າງອີງທີ່ທ່ານຕ້ອງການຫາຜົນລວມຍ່ອຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range representing the array or matrix of dependent data."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ສະແດງເຖິງອາເຣ ຫຼື ມາທຣິກຂອງຂໍ້ມູນທີ່ຂຶ້ນຕໍ່ກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range representing the array or matrix of independent data."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ສະແດງເຖິງອາເຣ ຫຼື ມາທຣິກຂອງຂໍ້ມູນທີ່ເປັນອິດສະຫຼະ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range representing the array or matrix of observed data."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ສະແດງເຖິງອາເຣ ຫຼື ມາທຣິກຂອງຂໍ້ມູນທີ່ສັງເກດໄດ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range representing the array or matrix of predicted data."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ສະແດງເຖິງອາເຣ ຫຼື ມາທຣິກຂອງຂໍ້ມູນທີ່ຄາດການໄວ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range that is tested against criterion."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະຖືກທົດສອບກັບເງື່ອນໄຂ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to average."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະຫາຄ່າສະເລ່ຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The range to average. If not included, criteria_range is used for the "
"average instead."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະຫາຄ່າສະເລ່ຍ. ຫາກບໍ່ໄດ້ລະບຸ, ຈະໃຊ້ criteria_range ແທນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to be summed, if different from range."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະລວມເຂົ້າກັນ, ຫາກແຕກຕ່າງຈາກຊ່ວງຂໍ້ມູນທີ່ກຳນົດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to be transposed."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະສະຫຼັບແຖວເປັນຖັນ (transpose)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to check against criterion."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະກວດສອບກັບເງື່ອນໄຂ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to check against criterion1."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະກວດສອບກັບເງື່ອນໄຂທີ 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The range to consider for the search. Should be a single column or a single "
"row."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະພິຈາລະນາໃນການຄົ້ນຫາ. ຄວນເປັນຖັນດຽວ ຫຼື ແຖວດຽວ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The range to consider for the search. The first column in the range is "
"searched for the key specified in search_key."
msgstr ""
"ຊ່ວງຂໍ້ມູນທີ່ຈະພິຈາລະນາໃນການຄົ້ນຫາ. ຖັນທຳອິດໃນຊ່ວງຂໍ້ມູນຈະຖືກຄົ້ນຫາຕາມຄີທີ່ລະບຸໄວ້ໃນ search_key."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The range to consider for the search. The first row in the range is searched"
" for the key specified in search_key."
msgstr ""
"ຊ່ວງຂໍ້ມູນທີ່ຈະພິຈາລະນາໃນການຄົ້ນຫາ. ແຖວທຳອິດໃນຊ່ວງຂໍ້ມູນຈະຖືກຄົ້ນຫາຕາມຄີທີ່ລະບຸໄວ້ໃນ search_key."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to constrain."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະຈຳກັດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to sum."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະຫາຜົນລວມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to wrap."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະຈັດຮູບແບບການຕັດຂໍ້ຄວາມ (wrap)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range which is tested against criterion."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະຖືກທົດສອບກັບເງື່ອນໄຂ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range whose column count will be returned."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະສົ່ງຄືນຈຳນວນຖັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range whose row count will be returned."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະສົ່ງຄືນຈຳນວນແຖວ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rank from largest to smallest of the element to return."
msgstr "ລຳດັບຈາກໃຫຍ່ຫາໜ້ອຍຂອງອົງປະກອບທີ່ຈະສົ່ງຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rank from smallest to largest of the element to return."
msgstr "ລຳດັບຈາກໜ້ອຍຫາໃຫຍ່ຂອງອົງປະກອບທີ່ຈະສົ່ງຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rate (%s) must be positive or null."
msgstr "ອັດຕາ (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ເປັນສູນ (null)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rate (%s) must be strictly positive."
msgstr "ອັດຕາ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rate at which the investment grows each period."
msgstr "ອັດຕາການເຕີບໂຕຂອງການລົງທຶນໃນແຕ່ລະງວດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rate_guess (%s) must be strictly greater than -1."
msgstr "ຄ່າຄາດຄະເນອັດຕາ (rate_guess) (%s) ຕ້ອງຫຼາຍກວ່າ -1 ເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The redemption (%s) must be strictly positive."
msgstr "ຄ່າໄຖ່ຖອນ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The redemption amount per 100 face value, or par."
msgstr "ຈຳນວນເງິນໄຖ່ຖອນຕໍ່ມູນຄ່າໜ້າປັດ 100 ຫຼື ລາຄາທີ່ກຳນົດ (par)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The reference to the cell."
msgstr "ການອ້າງອີງເຖິງຫ້ອງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The regular expression pattern to match against the text."
msgstr "ຮູບແບບ Regular Expression ເພື່ອໃຊ້ຈັບຄູ່ກັບຂໍ້ຄວາມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The result_range must be a single row or a single column."
msgstr "result_range ຕ້ອງເປັນແຖວດຽວ ຫຼື ຖັນດຽວ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The return (as a percentage) earned on reinvestment of income received from "
"the investment."
msgstr ""
"ຜົນຕອບແທນ (ເປັນເປີເຊັນ) ທີ່ໄດ້ຈາກການລົງທຶນຄືນຂອງລາຍໄດ້ທີ່ໄດ້ຮັບຈາກການລົງທຶນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The return_mode (%s) must be 0, 1 or 2."
msgstr "return_mode (%s) ຕ້ອງເປັນ 0, 1 ຫຼື 2."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The returned value if condition1 is TRUE."
msgstr "ຄ່າທີ່ຈະສົ່ງຄືນຫາກເງື່ອນໄຂທີ 1 ເປັນຈິງ (TRUE)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The row index of the value to be returned, where the first row in range is "
"numbered 1."
msgstr "ດັດຊະນີແຖວຂອງຄ່າທີ່ຈະສົ່ງຄືນ, ໂດຍທີ່ແຖວທຳອິດໃນຊ່ວງຂໍ້ມູນແມ່ນເລກ 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The row number of the cell reference. "
msgstr "ໝາຍເລກແຖວຂອງການອ້າງອີງຫ້ອງ. "

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rows argument (%s) must be strictly positive."
msgstr "ອາຄິວເມນແຖວ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The rows arguments (%s) must be greater or equal than the number of rows of "
"the array."
msgstr "ອາຄິວເມນແຖວ (%s) ຕ້ອງຫຼາຍກວ່າ ຫຼື ເທົ່າກັບຈຳນວນແຖວຂອງອາເຣ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rows arguments must be between -%s and %s (got %s), excluding 0."
msgstr "ອາຄິວເມນແຖວຕ້ອງຢູ່ລະຫວ່າງ -%s ແລະ %s (ໄດ້ຮັບ %s), ຍົກເວັ້ນ 0."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rows indexes of the rows to be returned."
msgstr "ດັດຊະນີແຖວຂອງແຖວທີ່ຈະສົ່ງຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rule is invalid for an unknown reason"
msgstr "ກົດລະບຽບບໍ່ຖືກຕ້ອງດ້ວຍເຫດຜົນທີ່ບໍ່ຮູ້ຈັກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rule is invalid for an unknown reason."
msgstr "ກົດລະບຽບບໍ່ຖືກຕ້ອງດ້ວຍເຫດຜົນທີ່ບໍ່ຮູ້ຈັກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The salvage (%(salvage)s) must be smaller or equal than the cost (%(cost)s)."
msgstr "ມູນຄ່າຊາກ (%(salvage)s) ຕ້ອງນ້ອຍກວ່າ ຫຼື ເທົ່າກັບຕົ້ນທຶນ (%(cost)s)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The salvage (%s) must be positive or null."
msgstr "ມູນຄ່າຊາກ (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ເປັນສູນ (null)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The sample covariance of a dataset."
msgstr "ຄ່າຄວາມແປປວນຮ່ວມ (covariance) ຂອງຕົວຢ່າງຈາກຊຸດຂໍ້ມູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The search and match mode combination is not supported for XLOOKUP "
"evaluation."
msgstr ""
"ການປະສົມປະສານຮູບແບບການຄົ້ນຫາ ແລະ ການຈັບຄູ່ບໍ່ຖືກຮອງຮັບໃນການປະເມີນ XLOOKUP."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The search method is a number 1, 0 or -1 indicating which value to return. 1"
" finds the largest value less than or equal to search_key when range is "
"sorted in ascending order. 0 finds the exact value when range is unsorted. "
"-1 finds the smallest value greater than or equal to search_key when range "
"is sorted in descending order."
msgstr ""
"ວິທີການຄົ້ນຫາແມ່ນຕົວເລກ 1, 0 ຫຼື -1 ເພື່ອລະບຸວ່າຈະສົ່ງຄືນຄ່າໃດ. 1 ຈະຫາຄ່າທີ່ໃຫຍ່ທີ່ສຸດທີ່ນ້ອຍກວ່າ ຫຼື ເທົ່າກັ"
"ບ search_key ເມື່ອຊ່ວງຂໍ້ມູນຖືກຈັດລຽງແບບນ້ອຍຫາໃຫຍ່. 0 ຈະຫາຄ່າທີ່ກົງກັນພໍດີເມື່ອຊ່ວງຂໍ້ມູນບໍ່ໄດ້ຈັດລຽງ. -"
"1 ຈະຫາຄ່າທີ່ນ້ອຍທີ່ສຸດທີ່ໃຫຍ່ກວ່າ ຫຼື ເທົ່າກັບ search_key ເມື່ອຊ່ວງຂໍ້ມູນຖືກຈັດລຽງແບບໃຫຍ່ຫາໜ້ອຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The second addend."
msgstr "ຕົວບວກທີສອງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The second argument is missing. Please provide a value"
msgstr "ອາຄິວເມນທີສອງຫາຍໄປ. ກະລຸນາລະບຸຄ່າ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The second component of the time."
msgstr "ສ່ວນປະກອບທີສອງຂອງເວລາ (ວິນາທີ)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The second matrix in the matrix multiplication operation."
msgstr "ມາທຣິກທີສອງໃນການຄູນມາທຣິກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The second multiplicand."
msgstr "ຕົວຄູນທີສອງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The second number to compare."
msgstr "ຕົວເລກທີສອງທີ່ຈະປຽບທຽບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The second string to compare."
msgstr "ຂໍ້ຄວາມທີສອງທີ່ຈະປຽບທຽບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The second value must be a number"
msgstr "ຄ່າທີສອງຕ້ອງເປັນຕົວເລກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The second value."
msgstr "ຄ່າທີສອງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The settlement date (%(settlement)s) must at most one year after the "
"maturity date (%(maturity)s)."
msgstr ""
"ວັນທີຊຳລະເງິນ (%(settlement)s) ຕ້ອງບໍ່ເກີນໜຶ່ງປີຫຼັງຈາກວັນຄົບກຳນົດ (%(maturity)s)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The settlement date (%(settlement)s) must be greater or equal to the issue "
"date (%(issue)s)."
msgstr ""
"ວັນທີຊຳລະເງິນ (%(settlement)s) ຕ້ອງຫຼາຍກວ່າ ຫຼື ເທົ່າກັບວັນທີອອກ (%(issue)s)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The settlement date (%(settlement)s) must be strictly greater than the issue"
" date (%(issue)s)."
msgstr ""
"ວັນທີຊຳລະເງິນ (%(settlement)s) ຕ້ອງຫຼາຍກວ່າວັນທີອອກ (%(issue)s) ເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The settlement date of the security, the date after issuance when the "
"security is delivered to the buyer."
msgstr ""
"ວັນທີຊຳລະເງິນຂອງຫຼັກຊັບ, ເຊິ່ງແມ່ນວັນທີຫຼັງການອອກຫຼັກຊັບເມື່ອມີການສົ່ງມອບຫຼັກຊັບໃຫ້ຜູ້ຊື້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The sheet name cannot be empty."
msgstr "ຊື່ຊີດບໍ່ສາມາດວ່າງໄດ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The single period within life for which to calculate depreciation."
msgstr "ງວດດຽວພາຍໃນອາຍຸການໃຊ້ງານທີ່ຈະໃຊ້ຄິດໄລ່ຄ່າເສື່ອມລາຄາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The source text."
msgstr "ຂໍ້ຄວາມຕົ້ນສະບັບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The start date of the period from which to calculate the number of net "
"working days."
msgstr "ວັນທີເລີ່ມຕົ້ນຂອງງວດທີ່ຈະໃຊ້ຄິດໄລ່ຈຳນວນມື້ເຮັດວຽກສຸດທິ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The start date to consider in the calculation."
msgstr "ວັນທີເລີ່ມຕົ້ນທີ່ຈະພິຈາລະນາໃນການຄິດໄລ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The start date to consider in the calculation. Must be a reference to a cell"
" containing a DATE, a function returning a DATE type, or a number."
msgstr ""
"ວັນທີເລີ່ມຕົ້ນທີ່ຈະພິຈາລະນາໃນການຄິດໄລ່. ຕ້ອງເປັນການອ້າງອີງເຖິງຫ້ອງທີ່ມີວັນທີ (DATE), ຟັງຊັນທີ່ສົ່ງຄືນປະເພດ"
"ວັນທີ, ຫຼື ຕົວເລກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The start date to consider in the calculation. Must be a reference to a cell"
" containing a date, a function returning a date type, or a number."
msgstr ""
"ວັນທີເລີ່ມຕົ້ນທີ່ຈະພິຈາລະນາໃນການຄິດໄລ່. ຕ້ອງເປັນການອ້າງອີງເຖິງຫ້ອງທີ່ມີວັນທີ, ຟັງຊັນທີ່ສົ່ງຄືນປະເພດວັນທີ, ຫຼື "
"ຕົວເລກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The start of the date range."
msgstr "ຈຸດເລີ່ມຕົ້ນຂອງຊ່ວງວັນທີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The start_date (%s) must be positive or null."
msgstr "ວັນທີເລີ່ມຕົ້ນ (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ເປັນສູນ (null)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The start_period (%(start)s) must be smaller or equal to the end_period "
"(%(end)s)."
msgstr "ງວດເລີ່ມຕົ້ນ (%(start)s) ຕ້ອງນ້ອຍກວ່າ ຫຼື ເທົ່າກັບງວດສິ້ນສຸດ (%(end)s)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The start_period (%s) must be positive or null."
msgstr "ງວດເລີ່ມຕົ້ນ (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ເປັນສູນ (null)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The starting point from which to count the offset rows and columns."
msgstr "ຈຸດເລີ່ມຕົ້ນທີ່ຈະໃຊ້ນັບແຖວ ແລະ ຖັນທີ່ເຍື້ອງໄປ (offset)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The starting unit, the unit currently assigned to value"
msgstr "ຫົວໜ່ວຍເລີ່ມຕົ້ນ, ຫົວໜ່ວຍທີ່ກຳນົດໃຫ້ຄ່າໃນປັດຈຸບັນ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The starting_at (%s) must be greater than or equal to 1."
msgstr "starting_at (%s) ຕ້ອງຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The starting_at argument (%s) must be positive greater than one."
msgstr "ອາຄິວເມນ starting_at (%s) ຕ້ອງເປັນຄ່າບວກທີ່ຫຼາຍກວ່າໜຶ່ງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string from which the left portion will be returned."
msgstr "ຂໍ້ຄວາມທີ່ຈະສົ່ງຄືນສ່ວນທາງຊ້າຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string from which the right portion will be returned."
msgstr "ຂໍ້ຄວາມທີ່ຈະສົ່ງຄືນສ່ວນທາງຂວາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string on which you want to extract text."
msgstr "ຂໍ້ຄວາມທີ່ທ່ານຕ້ອງການດຶງຂໍ້ຄວາມອອກມາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string representing the date."
msgstr "ຂໍ້ຄວາມທີ່ສະແດງເຖິງວັນທີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string that holds the time representation."
msgstr "ຂໍ້ຄວາມທີ່ສະແດງເຖິງເວລາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string that will replace search_for."
msgstr "ຂໍ້ຄວາມທີ່ຈະໄປແທນທີ່ search_for."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string to convert to lowercase."
msgstr "ຂໍ້ຄວາມທີ່ຈະປ່ຽນເປັນຕົວພິມນ້ອຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string to convert to uppercase."
msgstr "ຂໍ້ຄວາມທີ່ຈະປ່ຽນເປັນຕົວພິມໃຫຍ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string to extract a segment from."
msgstr "ຂໍ້ຄວາມທີ່ຈະດຶງບາງສ່ວນອອກມາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string to look for within text_to_search."
msgstr "ຂໍ້ຄວາມທີ່ຈະຄົ້ນຫາພາຍໃນ text_to_search."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string to search for within text_to_search."
msgstr "ຂໍ້ຄວາມທີ່ຈະຄົ້ນຫາພາຍໃນ text_to_search."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string whose length will be returned."
msgstr "ຂໍ້ຄວາມທີ່ຈະສົ່ງຄືນຄວາມຍາວ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The substring after which text will be returned."
msgstr "ຂໍ້ຄວາມຍ່ອຍ ຫຼັງຈາກນັ້ນຂໍ້ຄວາມຈະຖືກສົ່ງຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The subtrahend, or number to subtract from value1."
msgstr "ຕົວລົບ ຫຼື ຕົວເລກທີ່ຈະລົບອອກຈາກ value1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The table zone is invalid for an unknown reason"
msgstr "ເຂດຕາຕະລາງບໍ່ຖືກຕ້ອງດ້ວຍເຫດຜົນທີ່ບໍ່ຮູ້ຈັກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The table_number (%s) is out of range."
msgstr "ໝາຍເລກຕາຕະລາງ (%s) ຢູ່ນອກຂອບເຂດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The text or reference to a cell containing text to be trimmed."
msgstr "ຂໍ້ຄວາມ ຫຼື ການອ້າງອີງຫ້ອງທີ່ມີຂໍ້ຄວາມທີ່ຈະຖືກຕັດຊ່ອງວ່າງ (trim)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The text to display in the cell, enclosed in quotation marks."
msgstr "ຂໍ້ຄວາມທີ່ຈະສະແດງໃນຫ້ອງ, ເຊິ່ງຢູ່ໃນເຄື່ອງໝາຍຄຳເວົ້າ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The text to divide."
msgstr "ຂໍ້ຄວາມທີ່ຈະແບ່ງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The text to search for the first occurrence of search_for."
msgstr "ຂໍ້ຄວາມທີ່ຈະຄົ້ນຫາການປະກົດຕົວຄັ້ງທຳອິດຂອງ search_for."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The text to split."
msgstr "ຂໍ້ຄວາມທີ່ຈະແຍກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The text which will be inserted into the original text."
msgstr "ຂໍ້ຄວາມທີ່ຈະຖືກແຊກເຂົ້າໄປໃນຂໍ້ຄວາມເດີມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The text which will be returned with the first letter of each word in "
"uppercase and all other letters in lowercase."
msgstr ""
"ຂໍ້ຄວາມທີ່ຈະຖືກສົ່ງຄືນໂດຍມີຕົວອັກສອນທຳອິດຂອງແຕ່ລະຄຳເປັນຕົວພິມໃຫຍ່ ແລະ ຕົວອັກສອນອື່ນໆເປັນຕົວພິມນ້ອຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The text whose non-printable characters are to be removed."
msgstr "ຂໍ້ຄວາມທີ່ຕ້ອງການເອົາຕົວອັກສອນທີ່ພິມບໍ່ໄດ້ອອກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The text within which to search and replace."
msgstr "ຂໍ້ຄວາມທີ່ຈະໃຊ້ຄົ້ນຫາ ແລະ ແທນທີ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The text, a part of which will be replaced."
msgstr "ຂໍ້ຄວາມ, ເຊິ່ງບາງສ່ວນຈະຖືກແທນທີ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The text_to_search must be non-empty."
msgstr "text_to_search ຕ້ອງບໍ່ວ່າງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The time from which to calculate the hour component."
msgstr "ເວລາທີ່ຈະໃຊ້ຄິດໄລ່ສ່ວນປະກອບຂອງຊົ່ວໂມງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The time from which to calculate the minute component."
msgstr "ເວລາທີ່ຈະໃຊ້ຄິດໄລ່ສ່ວນປະກອບຂອງນາທີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The time from which to calculate the second component."
msgstr "ເວລາທີ່ຈະໃຊ້ຄິດໄລ່ສ່ວນປະກອບຂອງວິນາທີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The time_string (%s) cannot be parsed to date/time."
msgstr "time_string (%s) ບໍ່ສາມາດແປງເປັນ ວັນທີ/ເວລາ ໄດ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The timing of the payment payments are due for each period."
msgstr "ກຳນົດເວລາຂອງການຊຳລະເງິນທີ່ຄົບກຳນົດໃນແຕ່ລະງວດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The type (%s) is out of range."
msgstr "ປະເພດ (%s) ຢູ່ນອກຂອບເຂດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The type (%s) must be between 1 and 3 or between 11 and 17."
msgstr "ປະເພດ (%s) ຕ້ອງຢູ່ລະຫວ່າງ 1 ຫາ 3 ຫຼື ລະຫວ່າງ 11 ຫາ 17."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The type of information requested."
msgstr "ປະເພດຂອງຂໍ້ມູນທີ່ຮ້ອງຂໍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The unit (%s) must be strictly positive."
msgstr "ຫົວໜ່ວຍ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The unit of measure into which to convert value"
msgstr "ຫົວໜ່ວຍວັດແທກທີ່ຈະແປງຄ່າໄປໃສ່"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The units of the desired fraction, e.g. 8 for 1/8ths or 32 for 1/32nds."
msgstr "ຫົວໜ່ວຍຂອງເສດສ່ວນທີ່ຕ້ອງການ, ເຊັ່ນ: 8 ສຳລັບ 1/8 ຫຼື 32 ສຳລັບ 1/32."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The units of the fraction, e.g. 8 for 1/8ths or 32 for 1/32nds."
msgstr "ຫົວໜ່ວຍຂອງເສດສ່ວນ, ເຊັ່ນ: 8 ສຳລັບ 1/8 ຫຼື 32 ສຳລັບ 1/32."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The upper inflection point value must be a number"
msgstr "ຄ່າຈຸດປ່ຽນໂຄ້ງດ້ານເທິງຕ້ອງເປັນຕົວເລກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value (%s) cannot be between -1 and 1 inclusive."
msgstr "ຄ່າ (%s) ບໍ່ສາມາດຢູ່ລະຫວ່າງ -1 ແລະ 1 ໄດ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value (%s) must be a valid base %s representation."
msgstr "ຄ່າ (%s) ຕ້ອງເປັນການສະແດງຖານ %s ທີ່ຖືກຕ້ອງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value (%s) must be between -1 and 1 exclusive."
msgstr "ຄ່າ (%s) ຕ້ອງຢູ່ລະຫວ່າງ -1 ແລະ 1 (ບໍ່ລວມ)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value (%s) must be between -1 and 1 inclusive."
msgstr "ຄ່າ (%s) ຕ້ອງຢູ່ລະຫວ່າງ -1 ແລະ 1 (ລວມ)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value (%s) must be greater than or equal to 1."
msgstr "ຄ່າ (%s) ຕ້ອງຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value (%s) must be positive or null."
msgstr "ຄ່າ (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ເປັນສູນ (null)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value (%s) must be strictly positive."
msgstr "ຄ່າ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value does not match the custom formula data validation rule"
msgstr "ຄ່າບໍ່ກົງກັບກົດການກວດສອບຂໍ້ມູນສູດແບບກຳນົດເອງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The value for which to calculate the inverse cosine. Must be between -1 and "
"1, inclusive."
msgstr ""
"ຄ່າທີ່ຈະໃຊ້ຄິດໄລ່ cosine ປີ້ນ (inverse cosine). ຕ້ອງຢູ່ລະຫວ່າງ -1 ແລະ 1 (ລວມ)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value for which to calculate the inverse cotangent."
msgstr "ຄ່າທີ່ຈະໃຊ້ຄິດໄລ່ cotangent ປີ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The value for which to calculate the inverse hyperbolic cosine. Must be "
"greater than or equal to 1."
msgstr "ຄ່າທີ່ຈະໃຊ້ຄິດໄລ່ hyperbolic cosine ປີ້ນ. ຕ້ອງຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The value for which to calculate the inverse hyperbolic cotangent. Must not "
"be between -1 and 1, inclusive."
msgstr ""
"ຄ່າທີ່ຈະໃຊ້ຄິດໄລ່ hyperbolic cotangent ປີ້ນ. ຕ້ອງບໍ່ຢູ່ລະຫວ່າງ -1 ແລະ 1 (ລວມ)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value for which to calculate the inverse hyperbolic sine."
msgstr "ຄ່າທີ່ຈະໃຊ້ຄິດໄລ່ hyperbolic sine ປີ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The value for which to calculate the inverse hyperbolic tangent. Must be "
"between -1 and 1, exclusive."
msgstr ""
"ຄ່າທີ່ຈະໃຊ້ຄິດໄລ່ hyperbolic tangent ປີ້ນ. ຕ້ອງຢູ່ລະຫວ່າງ -1 ແລະ 1 (ບໍ່ລວມ)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The value for which to calculate the inverse sine. Must be between -1 and 1,"
" inclusive."
msgstr "ຄ່າທີ່ຈະໃຊ້ຄິດໄລ່ sine ປີ້ນ. ຕ້ອງຢູ່ລະຫວ່າງ -1 ແລະ 1 (ລວມ)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value for which to calculate the inverse tangent."
msgstr "ຄ່າທີ່ຈະໃຊ້ຄິດໄລ່ tangent ປີ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value for which to calculate the logarithm, base e."
msgstr "ຄ່າທີ່ຈະໃຊ້ຄິດໄລ່ ໂລກາຣິດ ຖານ e."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value for which to calculate the logarithm."
msgstr "ຄ່າທີ່ຈະໃຊ້ຄິດໄລ່ ໂລກາຣິດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be %s"
msgstr "ຄ່າຕ້ອງແມ່ນ %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be a boolean"
msgstr "ຄ່າຕ້ອງເປັນບູລີນ (boolean)"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be a date"
msgstr "ຄ່າຕ້ອງເປັນວັນທີ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be a date after %s"
msgstr "ຄ່າຕ້ອງເປັນວັນທີຫຼັງຈາກ %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be a date before %s"
msgstr "ຄ່າຕ້ອງເປັນວັນທີກ່ອນ %s"

#. module: spreadsheet
#. odoo-javascript
