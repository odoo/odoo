#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The angle to find the cotangent of, in radians."
msgstr "ມຸມທີ່ຈະຫາຄ່າໂຄແທນເຈັນ, ເປັນເຣດຽນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The angle to find the secant of, in radians."
msgstr "ມຸມທີ່ຈະຫາຄ່າຊີກັງ, ເປັນເຣດຽນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The angle to find the sine of, in radians."
msgstr "ມຸມທີ່ຈະຫາຄ່າຊິນ, ເປັນເຣດຽນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The angle to find the tangent of, in radians."
msgstr "ມຸມທີ່ຈະຫາຄ່າແທນເຈັນ, ເປັນເຣດຽນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The annualized rate of interest."
msgstr "ອັດຕາດອກເບ້ຍລາຍປີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The argument %s is not a valid measure. Here are the measures: %s"
msgstr "ອາກິວເມນ %s ບໍ່ແມ່ນຄ່າວັດແທກທີ່ຖືກຕ້ອງ. ນີ້ແມ່ນຄ່າວັດແທກທັງໝົດ: %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The argument dimension must be positive"
msgstr "ຂະໜາດຂອງອາກິວເມນຕ້ອງເປັນຄ່າບວກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The argument is missing. Please provide a value"
msgstr "ອາກິວເມນຂາດຫາຍໄປ. ກະລຸນາລະບຸຄ່າ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The argument square_matrix must have the same number of columns and rows."
msgstr "ອາກິວເມນ square_matrix ຕ້ອງມີຈຳນວນຖັນ ແລະ ແຖວເທົ່າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The arguments array_x and array_y must contain at least one pair of numbers."
msgstr "ອາກິວເມນ array_x ແລະ array_y ຕ້ອງມີຕົວເລກຢ່າງໜ້ອຍໜຶ່ງຄູ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The arguments condition must be a single column or row."
msgstr "ອາກິວເມນເງື່ອນໄຂ (condition) ຕ້ອງເປັນຖັນດຽວ ຫຼື ແຖວດຽວ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The arguments conditions must have the same dimensions."
msgstr "ອາກິວເມນເງື່ອນໄຂຕ່າງໆຕ້ອງມີຂະໜາດເທົ່າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The array of ranges containing the values to be counted."
msgstr "ອາເຣຂອງຂອບເຂດທີ່ມີຄ່າທີ່ຈະນັບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The array or range containing dependent (y) values that are already known, "
"used to curve fit an ideal exponential growth curve."
msgstr ""
"ອາເຣ ຫຼື ຂອບເຂດທີ່ມີຄ່າຜັນແປ (y) ທີ່ຮູ້ແລ້ວ, ໃຊ້ເພື່ອສ້າງເສັ້ນສະແດງການເຕີບໂຕແບບເອັກໂປເນນຊຽວທີ່ເໝາະສົ"
"ມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The array or range containing dependent (y) values that are already known, "
"used to curve fit an ideal linear trend."
msgstr ""
"ອາເຣ ຫຼື ຂອບເຂດທີ່ມີຄ່າຜັນແປ (y) ທີ່ຮູ້ແລ້ວ, ໃຊ້ເພື່ອສ້າງເສັ້ນແນວໂນ້ມເສັ້ນຊື່ທີ່ເໝາະສົມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The array or range containing the data to consider, structured in such a way"
" that the first row contains the labels for each column's values."
msgstr ""
"ອາເຣ ຫຼື ຂອບເຂດທີ່ມີຂໍ້ມູນທີ່ຈະພິຈາລະນາ, ເຊິ່ງຈັດຮູບແບບໃຫ້ແຖວທຳອິດມີປ້າຍຊື່ສຳລັບຄ່າຂອງແຕ່ລະຖັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The array or range containing the dataset to consider."
msgstr "ອາເຣ ຫຼື ຂອບເຂດທີ່ມີຊຸດຂໍ້ມູນທີ່ຈະພິຈາລະນາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The array or range of values that will be reduced by corresponding entries "
"in array_y, squared, and added together."
msgstr ""
"ອາເຣ ຫຼື ຂອບເຂດຂອງຄ່າທີ່ຈະຖືກລົບດ້ວຍຄ່າທີ່ກົງກັນໃນ array_y, ແລ້ວຍົກກຳລັງສອງ ແລະ ບວກເຂົ້າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The array or range of values that will be subtracted from corresponding "
"entries in array_x, the result squared, and all such results added together."
msgstr ""
"ອາເຣ ຫຼື ຂອບເຂດຂອງຄ່າທີ່ຈະຖືກລົບອອກຈາກຄ່າທີ່ກົງກັນໃນ array_x, ແລ້ວເອົາຜົນລັບມາຍົກກຳລັງສອງ ແລະ ບ"
"ວກຜົນລັບທັງໝົດເຂົ້າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The array or range of values whose squares will be added to the squares of "
"corresponding entries in array_x and added together."
msgstr ""
"ອາເຣ ຫຼື ຂອບເຂດຂອງຄ່າທີ່ກຳລັງສອງຂອງພວກມັນຈະຖືກບວກໃສ່ກັບກຳລັງສອງຂອງຄ່າທີ່ກົງກັນໃນ array_x ແລະ "
"ບວກເຂົ້າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The array or range of values whose squares will be added to the squares of "
"corresponding entries in array_y and added together."
msgstr ""
"ອາເຣ ຫຼື ຂອບເຂດຂອງຄ່າທີ່ກຳລັງສອງຂອງພວກມັນຈະຖືກບວກໃສ່ກັບກຳລັງສອງຂອງຄ່າທີ່ກົງກັນໃນ array_y ແລະ "
"ບວກເຂົ້າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The array or range of values whose squares will be reduced by the squares of"
" corresponding entries in array_y and added together."
msgstr ""
"ອາເຣ ຫຼື ຂອບເຂດຂອງຄ່າທີ່ກຳລັງສອງຂອງພວກມັນຈະຖືກລົບດ້ວຍກຳລັງສອງຂອງຄ່າທີ່ກົງກັນໃນ array_y ແລະ ບວ"
"ກເຂົ້າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The array or range of values whose squares will be subtracted from the "
"squares of corresponding entries in array_x and added together."
msgstr ""
"ອາເຣ ຫຼື ຂອບເຂດຂອງຄ່າທີ່ກຳລັງສອງຂອງພວກມັນຈະຖືກລົບອອກຈາກກຳລັງສອງຂອງຄ່າທີ່ກົງກັນໃນ array_x ແລ"
"ະ ບວກເຂົ້າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The array that contains the columns to be returned."
msgstr "ອາເຣທີ່ມີຖັນທີ່ຈະສົ່ງຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The array that contains the rows to be returned."
msgstr "ອາເຣທີ່ມີແຖວທີ່ຈະສົ່ງຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The array to expand."
msgstr "ອາເຣທີ່ຈະຂະຫຍາຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The array which will be transformed."
msgstr "ອາເຣທີ່ຈະຖືກແປງຮູບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The base (%s) must be between 2 and 36 inclusive."
msgstr "ເລກຖານ (%s) ຕ້ອງຢູ່ລະຫວ່າງ 2 ຫາ 36."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The base (%s) must be strictly positive."
msgstr "ເລກຖານ (%s) ຕ້ອງເປັນຄ່າບວກຢ່າງແນ່ນອນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The base must be different from 1."
msgstr "ເລກຖານຕ້ອງບໍ່ແມ່ນ 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The base of the logarithm."
msgstr "ຖານຂອງໂລກາຣິດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The base to convert the value from."
msgstr "ຖານທີ່ຈະແປງຄ່າອອກມາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The baseline value is invalid"
msgstr "ຄ່າເສັ້ນພື້ນຖານ (Baseline) ບໍ່ຖືກຕ້ອງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The cashflow_amounts and cashflow_dates ranges must have the same "
"dimensions."
msgstr "ຂອບເຂດ cashflow_amounts ແລະ cashflow_dates ຕ້ອງມີຂະໜາດເທົ່າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The cashflow_amounts must include negative and positive values."
msgstr "cashflow_amounts ຕ້ອງມີທັງຄ່າລົບ ແລະ ຄ່າບວກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The cell whose column number will be returned. Column A corresponds to 1. By"
" default, the function use the cell in which the formula is entered."
msgstr ""
"ຫ້ອງທີ່ຈະສົ່ງຄືນເລກຖັນ. ຖັນ A ກົງກັບ 1. ໂດຍເລີ່ມຕົ້ນ, ຟັງຊັນຈະໃຊ້ຫ້ອງທີ່ປ້ອນສູດລົງໄປ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The cell whose row number will be returned. By default, this function uses "
"the cell in which the formula is entered."
msgstr ""
"ຫ້ອງທີ່ຈະສົ່ງຄືນເລກແຖວ. ໂດຍເລີ່ມຕົ້ນ, ຟັງຊັນນີ້ຈະໃຊ້ຫ້ອງທີ່ປ້ອນສູດລົງໄປ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The cell you are trying to edit has been deleted."
msgstr "ຫ້ອງທີ່ທ່ານກຳລັງພະຍາຍາມແກ້ໄຂໄດ້ຖືກລຶບໄປແລ້ວ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The character or characters to use to split text."
msgstr "ຕົວອັກສອນທີ່ຈະໃຊ້ເພື່ອແຍກຂໍ້ຄວາມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The character or string to place between each concatenated value."
msgstr "ຕົວອັກສອນ ຫຼື ຂໍ້ຄວາມທີ່ຈະໃສ່ລະຫວ່າງແຕ່ລະຄ່າທີ່ເຊື່ອມຕໍ່ກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The character within text_to_search at which to start the search."
msgstr "ຕົວອັກສອນພາຍໃນ text_to_search ທີ່ຈະເລີ່ມຕົ້ນການຄົ້ນຫາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The chart definition is invalid for an unknown reason"
msgstr "ການກຳນົດຄ່າແຜນພູມບໍ່ຖືກຕ້ອງຍ້ອນສາເຫດທີ່ບໍ່ຮູ້ແນ່ຊັດ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The column index of the value to be returned, where the first column in "
"range is numbered 1."
msgstr "ດັດຊະນີຖັນຂອງຄ່າທີ່ຈະສົ່ງຄືນ, ໂດຍທີ່ຖັນທຳອິດໃນຂອບເຂດແມ່ນເລກ 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The column number (not name) of the cell reference. A is column number 1. "
msgstr "ເລກຖັນ (ບໍ່ແມ່ນຊື່) ຂອງການອ້າງອີງຫ້ອງ. A ແມ່ນຖັນເລກ 1. "

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The columns argument (%s) must be strictly positive."
msgstr "ອາກິວເມນຖັນ (%s) ຕ້ອງເປັນຄ່າບວກຢ່າງແນ່ນອນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The columns arguments (%s) must be greater or equal than the number of "
"columns of the array."
msgstr "ອາກິວເມນຖັນ (%s) ຕ້ອງໃຫຍ່ກວ່າ ຫຼື ເທົ່າກັບຈຳນວນຖັນຂອງອາເຣ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The columns arguments must be between -%s and %s (got %s), excluding 0."
msgstr "ອາກິວເມນຖັນຕ້ອງຢູ່ລະຫວ່າງ -%s ຫາ %s (ໄດ້ຮັບ %s), ຍົກເວັ້ນ 0."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The columns indexes of the columns to be returned."
msgstr "ດັດຊະນີຖັນຂອງຖັນທີ່ຈະສົ່ງຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/currency/formulas.js:0
msgid "The company to take the exchange rate from."
msgstr "ບໍລິສັດທີ່ຈະດຶງເອົາອັດຕາແລກປ່ຽນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The control to ignore blanks and errors. 0 (default) is to keep all values, "
"1 is to ignore blanks, 2 is to ignore errors, and 3 is to ignore blanks and "
"errors."
msgstr ""
"ການຄວບຄຸມເພື່ອຂ້າມຫ້ອງວ່າງ ແລະ ຂໍ້ຜິດພາດ. 0 (ຄ່າເລີ່ມຕົ້ນ) ແມ່ນເກັບທຸກຄ່າໄວ້, 1 ແມ່ນຂ້າມຫ້ອງວ່າງ, 2 "
"ແມ່ນຂ້າມຂໍ້ຜິດພາດ, ແລະ 3 ແມ່ນຂ້າມທັງຫ້ອງວ່າງ ແລະ ຂໍ້ຜິດພາດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The cost (%s) must be positive or null."
msgstr "ຕົ້ນທຶນ (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ເປັນສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The cost (%s) must be strictly positive."
msgstr "ຕົ້ນທຶນ (%s) ຕ້ອງເປັນຄ່າບວກຢ່າງແນ່ນອນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The covariance of a dataset."
msgstr "ຄ່າຄວາມແປປວນຮ່ວມ (Covariance) ຂອງຊຸດຂໍ້ມູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The criteria range contains %s row, it must be at least 2 rows."
msgstr "ຂອບເຂດເງື່ອນໄຂມີ %s ແຖວ, ມັນຕ້ອງມີຢ່າງໜ້ອຍ 2 ແຖວ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The current value of the annuity."
msgstr "ມູນຄ່າປັດຈຸບັນຂອງເງິນລາຍປີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The current window is too small to display this sheet properly. Consider "
"resizing your browser window or adjusting frozen rows and columns."
msgstr ""
"ໜ້າຕ່າງປັດຈຸບັນນ້ອຍເກີນໄປທີ່ຈະສະແດງແຜ່ນງານນີ້ຢ່າງຖືກຕ້ອງ. ກະລຸນາປັບຂະໜາດໜ້າຕ່າງເບຣົາເຊີຂອງທ່ານ ຫຼື ປັບ"
"ປ່ຽນແຖວ ແລະ ຖັນທີ່ຄຶງໄວ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The data points to return the y values for on the ideal curve fit."
msgstr "ຈຸດຂໍ້ມູນທີ່ຈະສົ່ງຄືນຄ່າ y ສຳລັບເສັ້ນສະແດງທີ່ເໝາະສົມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The data range is invalid"
msgstr "ຂອບເຂດຂໍ້ມູນບໍ່ຖືກຕ້ອງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The data to be filtered."
msgstr "ຂໍ້ມູນທີ່ຈະຖືກຕອງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The data to be sorted."
msgstr "ຂໍ້ມູນທີ່ຈະຖືກຈັດລຽງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The data to filter by unique entries."
msgstr "ຂໍ້ມູນເພື່ອໃຊ້ກັ່ນຕອງຫາລາຍການທີ່ບໍ່ຊໍ້າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The data you entered in %s violates the data validation rule set on the cell:\n"
"%s"
msgstr ""
"ຂໍ້ມູນທີ່ທ່ານປ້ອນເຂົ້າໃນ %s ແມ່ນລະເມີດກົດການກວດສອບຄວາມຖືກຕ້ອງຂອງຂໍ້ມູນທີ່ຕັ້ງໄວ້ໃນເຊວ:\n"
"%s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The dataset is invalid"
msgstr "ຊຸດຂໍ້ມູນບໍ່ຖືກຕ້ອງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The date for which to determine the ISO week number. Must be a reference to "
"a cell containing a date, a function returning a date type, or a number."
msgstr ""
"ວັນທີທີ່ຈະໃຊ້ກຳນົດເລກລຳດັບອາທິດ ISO. ຕ້ອງເປັນການອ້າງອີງໃສ່ເຊວທີ່ມີວັນທີ, ຟັງຊັນທີ່ສົ່ງຄ່າເປັນປະເພດວັນທີ, "
"ຫຼື ຕົວເລກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The date for which to determine the day of the week. Must be a reference to "
"a cell containing a date, a function returning a date type, or a number."
msgstr ""
"ວັນທີທີ່ຈະໃຊ້ກຳນົດມື້ຂອງອາທິດ. ຕ້ອງເປັນການອ້າງອີງໃສ່ເຊວທີ່ມີວັນທີ, ຟັງຊັນທີ່ສົ່ງຄ່າເປັນປະເພດວັນທີ, ຫຼື ຕົວເລ"
"ກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The date for which to determine the week number. Must be a reference to a "
"cell containing a date, a function returning a date type, or a number."
msgstr ""
"ວັນທີທີ່ຈະໃຊ້ກຳນົດເລກລຳດັບອາທິດ. ຕ້ອງເປັນການອ້າງອີງໃສ່ເຊວທີ່ມີວັນທີ, ຟັງຊັນທີ່ສົ່ງຄ່າເປັນປະເພດວັນທີ, ຫຼື ຕົວ"
"ເລກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date from which to begin counting."
msgstr "ວັນທີທີ່ຈະເລີ່ມຕົ້ນການນັບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date from which to calculate the end of quarter."
msgstr "ວັນທີທີ່ຈະໃຊ້ຄິດໄລ່ມື້ສິ້ນສຸດຂອງໄຕມາດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date from which to calculate the end of the year."
msgstr "ວັນທີທີ່ຈະໃຊ້ຄິດໄລ່ມື້ສິ້ນສຸດຂອງປີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date from which to calculate the result."
msgstr "ວັນທີທີ່ຈະໃຊ້ເພື່ອຄິດໄລ່ຜົນລັດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date from which to calculate the start of quarter."
msgstr "ວັນທີທີ່ຈະໃຊ້ຄິດໄລ່ມື້ເລີ່ມຕົ້ນຂອງໄຕມາດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date from which to calculate the start of the year."
msgstr "ວັນທີທີ່ຈະໃຊ້ຄິດໄລ່ມື້ເລີ່ມຕົ້ນຂອງປີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date from which to extract the day."
msgstr "ວັນທີທີ່ຈະໃຊ້ແຍກເອົາຂໍ້ມູນມື້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date from which to extract the month."
msgstr "ວັນທີທີ່ຈະໃຊ້ແຍກເອົາຂໍ້ມູນເດືອນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date from which to extract the quarter."
msgstr "ວັນທີທີ່ຈະໃຊ້ແຍກເອົາຂໍ້ມູນໄຕມາດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date from which to extract the year."
msgstr "ວັນທີທີ່ຈະໃຊ້ແຍກເອົາຂໍ້ມູນປີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date the asset was purchased."
msgstr "ວັນທີທີ່ໄດ້ຊື້ສິນຊັບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date the first period ended."
msgstr "ວັນທີທີ່ງວດທຳອິດສິ້ນສຸດລົງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date the security was initially issued."
msgstr "ວັນທີທີ່ຫຼັກຊັບຖືກອອກເປັນຄັ້ງທຳອິດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The date_string (%s) cannot be parsed to date/time."
msgstr "ຂໍ້ຄວາມວັນທີ (%s) ບໍ່ສາມາດແປງເປັນ ວັນທີ/ເວລາ ໄດ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The day component of the date."
msgstr "ສ່ວນປະກອບຂອງມື້ໃນວັນທີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The day_count_convention (%s) must be between 0 and 4 inclusive."
msgstr "ຮູບແບບການນັບມື້ (%s) ຕ້ອງຢູ່ລະຫວ່າງ 0 ຫາ 4."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The deprecation rate."
msgstr "ອັດຕາຄ່າຫຼຸ້ຍຫ້ຽນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The depreciation factor (%s) must be strictly positive."
msgstr "ຄ່າປັດໄຈການຫຼຸ້ຍຫ້ຽນ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The discount (%s) must be different from -1."
msgstr "ສ່ວນຫຼຸດ (%s) ຕ້ອງບໍ່ເທົ່າກັບ -1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The discount (%s) must be smaller than 1."
msgstr "ສ່ວນຫຼຸດ (%s) ຕ້ອງນ້ອຍກວ່າ 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The discount (%s) must be strictly positive."
msgstr "ສ່ວນຫຼຸດ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The discount rate of the bill at time of purchase."
msgstr "ອັດຕາສ່ວນຫຼຸດຂອງໃບບິນໃນເວລາທີ່ຊື້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The discount rate of the investment over one period."
msgstr "ອັດຕາສ່ວນຫຼຸດຂອງການລົງທຶນໃນໜຶ່ງງວດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The discount rate of the security at time of purchase."
msgstr "ອັດຕາສ່ວນຫຼຸດຂອງຫຼັກຊັບໃນເວລາທີ່ຊື້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The discount rate of the security invested in."
msgstr "ອັດຕາສ່ວນຫຼຸດຂອງຫຼັກຊັບທີ່ໄດ້ລົງທຶນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The divisor must be different from 0."
msgstr "ຕົວຫານຕ້ອງບໍ່ເທົ່າກັບ 0."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The divisor must be different from zero."
msgstr "ຕົວຫານຕ້ອງບໍ່ແມ່ນສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The effective interest rate per year."
msgstr "ອັດຕາດອກເບ້ຍທີ່ແທ້ຈິງຕໍ່ປີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The effective rate (%s) must must strictly greater than 0."
msgstr "ອັດຕາທີ່ແທ້ຈິງ (%s) ຕ້ອງຫຼາຍກວ່າ 0 ເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The end date of the period from which to calculate the number of net working"
" days."
msgstr "ວັນທີສິ້ນສຸດຂອງງວດທີ່ຈະໃຊ້ຄິດໄລ່ຈຳນວນມື້ເຮັດວຽກຕົວຈິງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The end date to consider in the calculation."
msgstr "ວັນທີສິ້ນສຸດທີ່ຈະພິຈາລະນາໃນການຄິດໄລ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The end date to consider in the calculation. Must be a reference to a cell "
"containing a DATE, a function returning a DATE type, or a number."
msgstr ""
"ວັນທີສິ້ນສຸດທີ່ຈະພິຈາລະນາໃນການຄິດໄລ່. ຕ້ອງເປັນການອ້າງອີງໃສ່ເຊວທີ່ມີ DATE, ຟັງຊັນທີ່ສົ່ງຄ່າເປັນປະເພດ "
"DATE, ຫຼື ຕົວເລກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The end date to consider in the calculation. Must be a reference to a cell "
"containing a date, a function returning a date type, or a number."
msgstr ""
"ວັນທີສິ້ນສຸດທີ່ຈະພິຈາລະນາໃນການຄິດໄລ່. ຕ້ອງເປັນການອ້າງອີງໃສ່ເຊວທີ່ມີວັນທີ, ຟັງຊັນທີ່ສົ່ງຄ່າເປັນປະເພດວັນທີ, "
"ຫຼື ຕົວເລກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The end of the date range."
msgstr "ຈຸດສິ້ນສຸດຂອງຊ່ວງວັນທີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The end_date (%s) must be positive or null."
msgstr "ວັນທີສິ້ນສຸດ (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ເປັນສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The end_period (%s) must be greater or equal than 0."
msgstr "ງວດສິ້ນສຸດ (%s) ຕ້ອງຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ 0."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The end_period (%s) must be smaller or equal to the life (%s)."
msgstr "ງວດສິ້ນສຸດ (%s) ຕ້ອງນ້ອຍກວ່າ ຫຼື ເທົ່າກັບ ອາຍຸການໃຊ້ງານ (%s)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The expected annual yield of the security."
msgstr "ຜົນຕອບແທນປະຈຳປີທີ່ຄາດຫວັງຂອງຫຼັກຊັບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The exponent (%s) must be an integer when the base is negative."
msgstr "ຕົວເລກກຳລັງ (%s) ຕ້ອງເປັນເລກຖ້ວນ ເມື່ອຕົວເລກພື້ນຖານເປັນຄ່າລົບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The exponent to raise base to."
msgstr "ຕົວເລກກຳລັງທີ່ຈະໃຊ້ຍົກກຳລັງຕົວເລກພື້ນຖານ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The exponent to raise e."
msgstr "ຕົວເລກກຳລັງທີ່ຈະໃຊ້ຍົກກຳລັງ e."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The extract_length argument (%s) must be positive or null."
msgstr "ຄ່າອາກິວເມນ extract_length (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ເປັນສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The factor (%s) must be positive when the value (%s) is positive."
msgstr "ຕົວຄູນ (%s) ຕ້ອງເປັນຄ່າບວກ ເມື່ອຄ່າ (%s) ເປັນຄ່າບວກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The factor by which depreciation decreases."
msgstr "ປັດໄຈທີ່ເຮັດໃຫ້ຄ່າຫຼຸ້ຍຫ້ຽນຫຼຸດລົງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/list/list_data_source.js:0
msgid "The field %s does not exist or you do not have access to that field"
msgstr "ຟິວ %s ບໍ່ມີຢູ່ ຫຼື ທ່ານບໍ່ມີສິດເຂົ້າເຖິງຟິວດັ່ງກ່າວ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The field (%(fieldValue)s) must be one of %(dimRowDB)s or must be a number "
"between 1 and %s inclusive."
msgstr ""
"ຟິວ (%(fieldValue)s) ຕ້ອງແມ່ນໜຶ່ງໃນ %(dimRowDB)s ຫຼື ຕ້ອງເປັນຕົວເລກລະຫວ່າງ 1 ຫາ %s."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The field (%s) must be one of %s."
msgstr "ຟິວ (%s) ຕ້ອງແມ່ນໜຶ່ງໃນ %s."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The field must be a number or a string"
msgstr "ຟິວຕ້ອງເປັນຕົວເລກ ຫຼື ຂໍ້ຄວາມ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first addend."
msgstr "ຕົວເລກທຳອິດທີ່ຈະນຳມາບວກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The first and second arguments of [[FUNCTION_NAME]] must be non-empty "
"matrices."
msgstr ""
"ອາກິວເມນທີໜຶ່ງ ແລະ ທີສອງຂອງ [[FUNCTION_NAME]] ຕ້ອງເປັນມາທຣິກ (matrix) ທີ່ມີຂໍ້ມູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first column index of the columns to be returned."
msgstr "ດັດຊະນີຖັນທຳອິດຂອງຖັນທີ່ຈະສົ່ງຄ່າກັບມາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The first condition to be evaluated. This can be a boolean, a number, an "
"array, or a reference to any of those."
msgstr ""
"ເງື່ອນໄຂທຳອິດທີ່ຈະປະເມີນ. ນີ້ສາມາດເປັນຄ່າບູລີນ (boolean), ຕົວເລກ, ອາເຣ (array), ຫຼື ການອ້າງອີງ"
"ໃສ່ຄ່າເຫຼົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first future cash flow."
msgstr "ກະແສເງິນສົດໃນອະນາຄົດງວດທຳອິດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first matrix in the matrix multiplication operation."
msgstr "ມາທຣິກ (matrix) ທຳອິດໃນການຄິດໄລ່ການຄູນມາທຣິກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first multiplicand."
msgstr "ຕົວຕັ້ງຄູນທຳອິດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first number in the sequence"
msgstr "ຕົວເລກທຳອິດໃນລຳດັບ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first number or range to add together."
msgstr "ຕົວເລກ ຫຼື ຊ່ວງທຳອິດທີ່ຈະນຳມາບວກເຂົ້າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first number or range to calculate for the product."
msgstr "ຕົວເລກ ຫຼື ຊ່ວງທຳອິດທີ່ຈະຄິດໄລ່ຫາຜົນຄູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first number to compare."
msgstr "ຕົວເລກທຳອິດທີ່ຈະປຽບທຽບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first range to be appended."
msgstr "ຊ່ວງຂໍ້ມູນທຳອິດທີ່ຈະນຳມາຕໍ່ທ້າຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first range to flatten."
msgstr "ຊ່ວງຂໍ້ມູນທຳອິດທີ່ຈະເຮັດໃຫ້ເປັນແຖວດຽວ (flatten)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The first range whose entries will be multiplied with corresponding entries "
"in the other ranges."
msgstr ""
"ຊ່ວງຂໍ້ມູນທຳອິດທີ່ແຕ່ລະລາຍການຈະຖືກຄູນກັບລາຍການທີ່ກົງກັນໃນຊ່ວງຂໍ້ມູນອື່ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first row index of the rows to be returned."
msgstr "ດັດຊະນີແຖວທຳອິດຂອງແຖວທີ່ຈະສົ່ງຄ່າກັບມາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first string to compare."
msgstr "ຂໍ້ຄວາມທຳອິດທີ່ຈະປຽບທຽບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first value must be a number"
msgstr "ຄ່າທຳອິດ must be ຕ້ອງເປັນຕົວເລກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first value or range in which to count the number of blanks."
msgstr "ຄ່າ ຫຼື ຊ່ວງຂໍ້ມູນທຳອິດທີ່ຈະໃຊ້ນັບຈຳນວນຫ້ອງວ່າງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first value or range of the population."
msgstr "ຄ່າ ຫຼື ຊ່ວງຂໍ້ມູນທຳອິດຂອງປະຊາກອນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first value or range of the sample."
msgstr "ຄ່າ ຫຼື ຊ່ວງຂໍ້ມູນທຳອິດຂອງກຸ່ມຕົວຢ່າງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first value or range to consider for uniqueness."
msgstr "ຄ່າ ຫຼື ຊ່ວງຂໍ້ມູນທຳອິດທີ່ຈະພິຈາລະນາຫາຄ່າທີ່ບໍ່ຊໍ້າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The first value or range to consider when calculating the average value."
msgstr "ຄ່າ ຫຼື ຊ່ວງຂໍ້ມູນທຳອິດທີ່ຈະພິຈາລະນາເມື່ອຄິດໄລ່ຄ່າສະເລ່ຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The first value or range to consider when calculating the maximum value."
msgstr "ຄ່າ ຫຼື ຊ່ວງຂໍ້ມູນທຳອິດທີ່ຈະພິຈາລະນາເມື່ອຄິດໄລ່ຄ່າສູງສຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The first value or range to consider when calculating the median value."
msgstr "ຄ່າ ຫຼື ຊ່ວງຂໍ້ມູນທຳອິດທີ່ຈະພິຈາລະນາເມື່ອຄິດໄລ່ຄ່າມັດທະຍະຖານ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The first value or range to consider when calculating the minimum value."
msgstr "ຄ່າ ຫຼື ຊ່ວງຂໍ້ມູນທຳອິດທີ່ຈະພິຈາລະນາເມື່ອຄິດໄລ່ຄ່າຕ່ຳສຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first value or range to consider when counting."
msgstr "ຄ່າ ຫຼື ຊ່ວງຂໍ້ມູນທຳອິດທີ່ຈະພິຈາລະນາເມື່ອນັບຈຳນວນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first value."
msgstr "ຄ່າທຳອິດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The first_period (%s) must be smaller or equal to the last_period (%s)."
msgstr "ງວດທຳອິດ (%s) ຕ້ອງນ້ອຍກວ່າ ຫຼື ເທົ່າກັບ ງວດສຸດທ້າຍ (%s)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The first_period (%s) must be strictly positive."
msgstr "ງວດທຳອິດ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The formatting unit should be 'k', 'm' or 'b'."
msgstr "ຫົວໜ່ວຍຮູບແບບຄວນເປັນ 'k' (ພັນ), 'm' (ລ້ານ) ຫຼື 'b' (ຕື້)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The formatting unit. Use 'k', 'm', or 'b' to force the unit"
msgstr "ຫົວໜ່ວຍຮູບແບບ. ໃຊ້ 'k', 'm', ຫຼື 'b' ເພື່ອບັງຄັບຫົວໜ່ວຍ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The frequency (%s) must be one of %s"
msgstr "ຄວາມຖີ່ (%s) ຕ້ອງແມ່ນໜຶ່ງໃນ %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The full URL of the link enclosed in quotation marks."
msgstr "URL ເຕັມຂອງລິ້ງທີ່ຢູ່ໃນເຄື່ອງໝາຍວົງຢືມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The function [[FUNCTION_NAME]] expects a boolean value, but '%s' is a text, "
"and cannot be coerced to a boolean."
msgstr ""
"ຟັງຊັນ [[FUNCTION_NAME]] ຕ້ອງການຄ່າບູລີນ, ແຕ່ '%s' ເປັນຂໍ້ຄວາມ ແລະ ບໍ່ສາມາດປ່ຽນເປັນບູລີນໄດ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The function [[FUNCTION_NAME]] expects a number value between %s and %s "
"inclusive, but receives %s."
msgstr ""
"ຟັງຊັນ [[FUNCTION_NAME]] ຕ້ອງການຄ່າຕົວເລກລະຫວ່າງ %s ຫາ %s, ແຕ່ໄດ້ຮັບ %s."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The function [[FUNCTION_NAME]] expects a number value to be greater than or "
"equal to 1, but receives %s."
msgstr ""
"ຟັງຊັນ [[FUNCTION_NAME]] ຕ້ອງການຄ່າຕົວເລກທີ່ຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ 1, ແຕ່ໄດ້ຮັບ %s."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The function [[FUNCTION_NAME]] expects a number value, but '%s' is a string,"
" and cannot be coerced to a number."
msgstr ""
"ຟັງຊັນ [[FUNCTION_NAME]] ຕ້ອງການຄ່າຕົວເລກ, ແຕ່ '%s' ເປັນຂໍ້ຄວາມ ແລະ ບໍ່ສາມາດປ່ຽນເປັນຕົວເລກໄ"
"ດ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The function [[FUNCTION_NAME]] has an argument with value '%s'. It should be"
" one of: %s."
msgstr ""
"ຟັງຊັນ [[FUNCTION_NAME]] ມີອາກິວເມນທີ່ມີຄ່າເປັນ '%s'. ມັນຄວນຈະເປັນໜຶ່ງໃນ: %s."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The function [[FUNCTION_NAME]] result cannot be negative"
msgstr "ຜົນລັດຂອງຟັງຊັນ [[FUNCTION_NAME]] ບໍ່ສາມາດເປັນຄ່າລົບໄດ້"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The function [[FUNCTION_NAME]] result must be greater than or equal "
"01/01/1900."
msgstr "ຜົນລັດຂອງຟັງຊັນ [[FUNCTION_NAME]] ຕ້ອງຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ 01/01/1900."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The future value of the investment."
msgstr "ມູນຄ່າໃນອະນາຄົດຂອງການລົງທຶນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The future value remaining after the final payment has been made."
msgstr "ມູນຄ່າໃນອະນາຄົດທີ່ຍັງເຫຼືອຫຼັງຈາກການຊຳລະງວດສຸດທ້າຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The future_value (%s) must be strictly positive."
msgstr "ມູນຄ່າໃນອະນາຄົດ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The header row of a table can't be moved."
msgstr "ແຖວຫົວຂໍ້ຂອງຕາຕະລາງບໍ່ສາມາດຍ້າຍໄດ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The high (%s) must be greater than or equal to the low (%s)."
msgstr "ຄ່າສູງສຸດ (%s) ຕ້ອງຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ ຄ່າຕ່ຳສຸດ (%s)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The high end of the random range."
msgstr "ຂອບເຂດສູງສຸດຂອງການສຸ່ມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The hour component of the time."
msgstr "ສ່ວນປະກອບຂອງຊົ່ວໂມງໃນເວລາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The index from the left of string from which to begin extracting. The first "
"character in string has the index 1."
msgstr ""
"ດັດຊະນີນັບຈາກເບື້ອງຊ້າຍຂອງຂໍ້ຄວາມທີ່ຈະເລີ່ມແຍກອອກ. ຕົວອັກສອນທຳອິດໃນຂໍ້ຄວາມມີດັດຊະນີແມ່ນ 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The index of the column in range or a range outside of range containing the "
"values by which to sort."
msgstr "ດັດຊະນີຂອງຖັນໃນຊ່ວງຂໍ້ມູນ ຫຼື ຊ່ວງຂໍ້ມູນນອກທີ່ມີຄ່າທີ່ໃຊ້ໃນການຈັດລຽງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The index of the column to be returned from within the reference range of "
"cells."
msgstr "ດັດຊະນີຂອງຖັນທີ່ຈະສົ່ງຄ່າກັບມາຈາກພາຍໃນຊ່ວງການອ້າງອີງຂອງເຊວ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The index of the row to be returned from within the reference range of "
"cells."
msgstr "ດັດຊະນີຂອງແຖວທີ່ຈະສົ່ງຄ່າກັບມາຈາກພາຍໃນຊ່ວງການອ້າງອີງຂອງເຊວ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The info_type should be one of %s."
msgstr "ຄ່າ info_type ຄວນເປັນໜຶ່ງໃນ %s."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The initial cost of the asset."
msgstr "ຕົ້ນທຶນທຳອິດຂອງສິນຊັບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The initial string."
msgstr "ຂໍ້ຄວາມເລີ່ມຕົ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The instance of search_for within text_to_search to replace with "
"replace_with. By default, all occurrences of search_for are replaced; "
"however, if occurrence_number is specified, only the indicated instance of "
"search_for is replaced."
msgstr ""
"ຕຳແໜ່ງຂອງ search_for ພາຍໃນ text_to_search ທີ່ຈະແທນທີ່ດ້ວຍ replace_with. ໂດຍປົກກະຕິ, ທຸ"
"ກໆບ່ອນທີ່ພົບ search_for ຈະຖືກແທນທີ່; ແຕ່ຖ້າມີການກຳນົດ occurrence_number, ຈະແທນທີ່ສະເພາະຕຳແ"
"ໜ່ງທີ່ລະບຸໄວ້ເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The interest rate paid on funds invested."
msgstr "ອັດຕາດອກເບ້ຍທີ່ຈ່າຍໃຫ້ກັບເງິນລົງທຶນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The interest rate."
msgstr "ອັດຕາດອກເບ້ຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The investment (%s) must be strictly positive."
msgstr "ເງິນລົງທຶນ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The investment's current value."
msgstr "ມູນຄ່າປັດຈຸບັນຂອງການລົງທຶນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The investment's desired future value."
msgstr "ມູນຄ່າໃນອະນາຄົດທີ່ຕ້ອງການຂອງການລົງທຶນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The issue (%s) must be positive or null."
msgstr "ວັນທີອອກ (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ເປັນສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The key value is invalid"
msgstr "ຄ່າຫຼັກ (key value) ບໍ່ຖືກຕ້ອງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/pivot/pivot_functions.js:0
msgid "The label of the filter whose value to return."
msgstr "ປ້າຍຊື່ຂອງຕົວແຍກກັ່ນຕອງທີ່ຈະສົ່ງຄ່າຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The last_period (%s) must be smaller or equal to the number_of_periods (%s)."
msgstr "ງວດສຸດທ້າຍ (%s) ຕ້ອງນ້ອຍກວ່າ ຫຼື ເທົ່າກັບ ຈຳນວນງວດທັງໝົດ (%s)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The last_period (%s) must be strictly positive."
msgstr "ງວດສຸດທ້າຍ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The length of the segment to extract."
msgstr "ຄວາມຍາວຂອງຂໍ້ຄວາມທີ່ຈະແຍກອອກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The life (%s) must be strictly positive."
msgstr "ອາຍຸການໃຊ້ງານ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The logarithm of a number, base e (euler's number)."
msgstr "ຄ່າໂລກາຣິດຂອງຕົວເລກ, ຖານ e (ຕົວເລກຂອງ Euler)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The logarithm of a number, for a given base."
msgstr "ຄ່າໂລກາຣິດຂອງຕົວເລກ, ຕາມຖານທີ່ກຳນົດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The low end of the random range."
msgstr "ຂອບເຂດຕ່ຳສຸດຂອງການສຸ່ມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The lower inflection point value must be a number"
msgstr "ຄ່າຂອງຈຸດປ່ຽນຄວາມໂຄ້ງລຸ່ມຕ້ອງເປັນຕົວເລກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The matrix is not invertible."
msgstr "ມາທຣິກບໍ່ສາມາດຫາຕົວປິ້ນ (inverse) ໄດ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The maturity (%s) must be strictly greater than the settlement (%s)."
msgstr "ວັນຄົບກຳນົດ (%s) ຕ້ອງຫຼາຍກວ່າ ວັນຊຳລະສະສາງ (%s) ເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The maturity date of the security."
msgstr "ວັນຄົບກຳນົດຂອງຫຼັກຊັບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The maturity or end date of the security, when it can be redeemed at face, "
"or par value."
msgstr ""
"ວັນຄົບກຳນົດ ຫຼື ວັນທີສິ້ນສຸດຂອງຫຼັກຊັບ, ເມື່ອສາມາດໄຖ່ຖອນໄດ້ຕາມມູນຄ່າທີ່ກຳນົດໄວ້ ຫຼື ມູນຄ່າຕາມລາຄາທີ່ຕັ້ງໄວ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The maximum (%s) and minimum (%s) must be integers when whole_number is "
"TRUE."
msgstr ""
"ຄ່າສູງສຸດ (%s) ແລະ ຄ່າຕ່ຳສຸດ (%s) ຕ້ອງເປັນເລກຖ້ວນ ເມື່ອ whole_number ເປັນ TRUE."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The maximum (%s) must be greater than or equal to the minimum (%s)."
msgstr "ຄ່າສູງສຸດ (%s) ຕ້ອງຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ ຄ່າຕ່ຳສຸດ (%s)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The maximum number of cells for each column, rounded down to the nearest "
"whole number."
msgstr "ຈຳນວນເຊວສູງສຸດສຳລັບແຕ່ລະຖັນ, ໂດຍປັດລົງເປັນເລກຖ້ວນທີ່ໃກ້ທີ່ສຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The maximum number of cells for each row, rounded down to the nearest whole "
"number."
msgstr "ຈຳນວນເຊວສູງສຸດສຳລັບແຕ່ລະແຖວ, ໂດຍປັດລົງເປັນເລກຖ້ວນທີ່ໃກ້ທີ່ສຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The maximum number you would like returned."
msgstr "ຈຳນວນສູງສຸດທີ່ທ່ານຕ້ອງການໃຫ້ສົ່ງຄ່າກັບມາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The maximum range limit value must be a number"
msgstr "ຄ່າຂີດຈຳກັດຊ່ວງສູງສຸດຕ້ອງເປັນຕົວເລກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The maxpoint must be a number"
msgstr "ຄ່າຈຸດສູງສຸດຕ້ອງເປັນຕົວເລກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/helpers/helpers.js:0
msgid ""
"The menu linked to this chart doesn't have an corresponding action. Please "
"link the chart to another menu."
msgstr ""
"ເມນູທີ່ເຊື່ອມຕໍ່ກັບແຜນພູມນີ້ບໍ່ມີການເຮັດວຽກທີ່ກົງກັນ. ກະລຸນາເຊື່ອມຕໍ່ແຜນພູມກັບເມນູອື່ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The midpoint must be a number"
msgstr "ຄ່າຈຸດເຄິ່ງກາງຕ້ອງເປັນຕົວເລກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The minimum number you would like returned."
msgstr "ຈຳນວນຕ່ຳສຸດທີ່ທ່ານຕ້ອງການໃຫ້ສົ່ງຄ່າກັບມາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The minimum range limit value must be a number"
msgstr "ຄ່າຂີດຈຳກັດຊ່ວງຕ່ຳສຸດຕ້ອງເປັນຕົວເລກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The minpoint must be a number"
msgstr "ຄ່າຈຸດຕ່ຳສຸດຕ້ອງເປັນຕົວເລກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The minuend, or number to be subtracted from."
msgstr "ຕົວຕັ້ງລົບ, ຫຼື ຕົວເລກທີ່ຈະຖືກລົບອອກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The minute component of the time."
msgstr "ສ່ວນປະກອບຂອງນາທີໃນເວລາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/data_sources/data_source.js:0
#: code:addons/spreadsheet/static/src/pivot/odoo_pivot_loader.js:0
msgid "The model \"%(model)s\" does not exist."
msgstr "ໂມເດວ \"%(model)s\" ບໍ່ມີຢູ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/global_filters/components/filter_value/filter_value.js:0
msgid ""
"The model (%(model)s) of this global filter is not valid (it may have been "
"renamed/deleted)."
msgstr ""
"ໂມເດວ (%(model)s) ຂອງຕົວແຍກກັ່ນຕອງສາກົນນີ້ບໍ່ຖືກຕ້ອງ (ມັນອາດຈະຖືກປ່ຽນຊື່ ຫຼື ຖືກລຶບໄປແລ້ວ)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The month (%s) must be between 1 and 12 inclusive."
msgstr "ເດືອນ (%s) ຕ້ອງຢູ່ລະຫວ່າງ 1 ຫາ 12."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The month component of the date."
msgstr "ສ່ວນປະກອບຂອງເດືອນໃນວັນທີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The net present value of an investment based on a series of periodic cash "
"flows and a discount rate."
msgstr ""
"ມູນຄ່າປັດຈຸບັນສຸດທິ (NPV) ຂອງການລົງທຶນ ໂດຍອີງໃສ່ກະແສເງິນສົດເປັນງວດ ແລະ ອັດຕາສ່ວນຫຼຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The nominal interest rate per year."
msgstr "ອັດຕາດອກເບ້ຍຕາມກຳນົດຕໍ່ປີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The nominal rate (%s) must be strictly greater than 0."
msgstr "ອັດຕາຕາມກຳນົດ (%s) ຕ້ອງຫຼາຍກວ່າ 0 ເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number for which to calculate the positive square root."
msgstr "ຕົວເລກທີ່ຈະໃຊ້ຄິດໄລ່ຮາກຂັ້ນສອງຄ່າບວກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of characters in the text to be replaced."
msgstr "ຈຳນວນຕົວອັກສອນໃນຂໍ້ຄວາມທີ່ຈະຖືກແທນທີ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of characters to return from the left side of string."
msgstr "ຈຳນວນຕົວອັກສອນທີ່ຈະສົ່ງຄ່າຈາກເບື້ອງຊ້າຍຂອງຂໍ້ຄວາມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of characters to return from the right side of string."
msgstr "ຈຳນວນຕົວອັກສອນທີ່ຈະສົ່ງຄ່າຈາກເບື້ອງຂວາຂອງຂໍ້ຄວາມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of columns (%s) must be positive."
msgstr "ຈຳນວນຖັນ (%s) ຕ້ອງເປັນຄ່າບວກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of columns in the constrained array."
msgstr "ຈຳນວນຖັນໃນອາເຣທີ່ຖືກຈຳກັດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number of columns in the expanded array. If missing, columns will not be"
" expanded."
msgstr "ຈຳນວນຖັນໃນອາເຣທີ່ຂະຫຍາຍອອກ. ຖ້າບໍ່ລະບຸ, ຖັນຈະບໍ່ຖືກຂະຫຍາຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of columns must be positive."
msgstr "ຈຳນວນຖັນຕ້ອງເປັນຄ່າບວກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number of columns of the range to return starting at the offset target."
msgstr ""
"ຈຳນວນຖັນຂອງຊ່ວງຂໍ້ມູນທີ່ຈະສົ່ງຄ່າຄືນ ໂດຍເລີ່ມຕົ້ນຈາກເປົ້າໝາຍການເລື່ອນ (offset)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of columns to be returned."
msgstr "ຈຳນວນຖັນທີ່ຈະສົ່ງຄ່າກັບມາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of columns to offset by."
msgstr "ຈຳນວນຖັນທີ່ຈະເລື່ອນອອກໄປ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of columns to return"
msgstr "ຈຳນວນຖັນທີ່ຈະສົ່ງຄ່າຄືນ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of compounding periods per year."
msgstr "ຈຳນວນງວດຂອງການຄິດໄລ່ດອກເບ້ຍທົບຕົ້ນຕໍ່ປີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of decimal places to which to round."
msgstr "ຈຳນວນຕຳແໜ່ງທົດສະນິຍົມທີ່ຈະປັດເລກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of interest or coupon payments per year (1, 2, or 4)."
msgstr "ຈຳນວນຄັ້ງຂອງການຈ່າຍດອກເບ້ຍ ຫຼື ຄູປອງຕໍ່ປີ (1, 2, ຫຼື 4)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of items to return."
msgstr "ຈຳນວນລາຍການທີ່ຈະສົ່ງຄ່າກັບມາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number of months before (negative) or after (positive) 'start_date' to "
"calculate."
msgstr ""
"ຈຳນວນເດືອນກ່ອນ (ຄ່າລົບ) ຫຼື ຫຼັງ (ຄ່າບວກ) ຈາກ 'ວັນທີເລີ່ມຕົ້ນ' ທີ່ຈະໃຊ້ຄິດໄລ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number of months before (negative) or after (positive) 'start_date' to "
"consider."
msgstr ""
"ຈຳນວນເດືອນກ່ອນ (ຄ່າລົບ) ຫຼື ຫຼັງ (ຄ່າບວກ) ຈາກ 'ວັນທີເລີ່ມຕົ້ນ' ທີ່ຈະພິຈາລະນາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of months in the first year of depreciation."
msgstr "ຈຳນວນເດືອນໃນປີທຳອິດຂອງການຄິດໄລ່ຄ່າຫຼຸ້ຍຫ້ຽນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of numeric values in dataset."
msgstr "ຈຳນວນຄ່າຕົວເລກໃນຊຸດຂໍ້ມູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of payments to be made."
msgstr "ຈຳນວນງວດທີ່ຈະຕ້ອງຊຳລະ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of periods by year (%s) must strictly greater than 0."
msgstr "ຈຳນວນງວດຕໍ່ປີ (%s) ຕ້ອງຫຼາຍກວ່າ 0 ເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of periods must be different than 0."
msgstr "ຈຳນວນງວດຕ້ອງບໍ່ເທົ່າກັບ 0."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of periods over which the asset is depreciated."
msgstr "ຈຳນວນງວດທັງໝົດທີ່ສິນຊັບຖືກຄິດໄລ່ຄ່າຫຼຸ້ຍຫ້ຽນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of periods."
msgstr "ຈຳນວນງວດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of rows (%s) must be positive."
msgstr "ຈຳນວນແຖວ (%s) ຕ້ອງເປັນຄ່າບວກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of rows in the constrained array."
msgstr "ຈຳນວນແຖວໃນອາເຣທີ່ຖືກຈຳກັດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number of rows in the expanded array. If missing, rows will not be "
"expanded."
msgstr "ຈຳນວນແຖວໃນອາເຣທີ່ຂະຫຍາຍອອກ. ຖ້າບໍ່ລະບຸ, ແຖວຈະບໍ່ຖືກຂະຫຍາຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of rows must be positive."
msgstr "ຈຳນວນແຖວຕ້ອງເປັນຄ່າບວກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number of rows of the range to return starting at the offset target."
msgstr ""
"ຈຳນວນແຖວຂອງຊ່ວງຂໍ້ມູນທີ່ຈະສົ່ງຄ່າຄືນ ໂດຍເລີ່ມຕົ້ນຈາກເປົ້າໝາຍການເລື່ອນ (offset)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of rows to be returned."
msgstr "ຈຳນວນແຖວທີ່ຈະສົ່ງຄ່າກັບມາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of rows to offset by."
msgstr "ຈຳນວນແຖວທີ່ຈະເລື່ອນອອກໄປ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of rows to return"
msgstr "ຈຳນວນແຖວທີ່ຈະສົ່ງຄ່າຄືນ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number of significant digits to the right of the decimal point to "
"retain."
msgstr "ຈຳນວນຕົວເລກສຳຄັນຫຼັງຈຸດທົດສະນິຍົມທີ່ຈະເກັບຮັກສາໄວ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number of the character to look up from the current Unicode table in "
"decimal format."
msgstr "ເລກລະຫັດຂອງຕົວອັກສອນທີ່ຈະຄົ້ນຫາຈາກຕາຕະລາງ Unicode ໃນຮູບແບບເລກຖານສິບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of the payment period to begin the cumulative calculation."
msgstr "ເລກລຳດັບຂອງງວດການຊຳລະທີ່ຈະເລີ່ມຕົ້ນການຄິດໄລ່ສະສົມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of the payment period to end the cumulative calculation."
msgstr "ເລກລຳດັບຂອງງວດການຊຳລະທີ່ຈະສິ້ນສຸດການຄິດໄລ່ສະສົມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of values in a dataset."
msgstr "ຈຳນວນຄ່າທັງໝົດໃນຊຸດຂໍ້ມູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number of which to return the absolute value."
msgstr "ຕົວເລກທີ່ຈະສົ່ງຄ່າສຳບູນ (absolute value) ກັບມາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number of working days to advance from start_date. If negative, counts "
"backwards."
msgstr ""
"ຈຳນວນມື້ເຮັດວຽກທີ່ຈະນັບໄປຂ້າງໜ້າຈາກ 'ວັນທີເລີ່ມຕົ້ນ'. ຖ້າເປັນຄ່າລົບ, ຈະນັບຖອຍຫຼັງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number pi."
msgstr "ຄ່າຕົວເລກໄພ (pi)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number to be divided to find the remainder."
msgstr "ຕົວເລກທີ່ຈະຖືກຫານເພື່ອຊອກຫາຕົວເສດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number to be divided."
msgstr "ຕົວເລກທີ່ຈະຖືກຫານ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number to convert."
msgstr "ຕົວເລກທີ່ຈະແປງຄ່າ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number to divide by."
msgstr "ຕົວເລກທີ່ຈະນຳມາຫານ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number to have its sign reversed. Equivalently, the number to multiply "
"by -1."
msgstr "ຕົວເລກທີ່ຈະກັບເຄື່ອງໝາຍ. ຫຼື ທຽບເທົ່າກັບການຄູນຕົວເລກດ້ວຍ -1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number to raise to the exponent power."
msgstr "ຕົວເລກທີ່ຈະນຳມາຍົກກຳລັງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number to return."
msgstr "ຕົວເລກທີ່ຈະສົ່ງຄ່າຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number to round down to the nearest integer."
msgstr "ຕົວເລກທີ່ຈະປັດລົງເປັນເລກຖ້ວນທີ່ໃກ້ທີ່ສຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number to whose multiples number will be rounded."
msgstr "ຕົວເລກທີ່ຈະຖືກປັດໃຫ້ເປັນຄູນຂອງຕົວເລກທີ່ກຳນົດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The number to whose multiples number will be rounded. The sign of "
"significance will be ignored."
msgstr ""
"ຕົວເລກທີ່ຈະຖືກປັດໃຫ້ເປັນຄູນຂອງຕົວເລກທີ່ກຳນົດ. ເຄື່ອງໝາຍຂອງຕົວປັດຈະຖືກລະເວັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number to whose multiples value will be rounded."
msgstr "ຕົວເລກທີ່ຈະຖືກປັດຄ່າໃຫ້ເປັນຕົວຄູນທີ່ກຳນົດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number, date or time to format."
msgstr "ຕົວເລກ, ວັນທີ ຫຼື ເວລາທີ່ຈະຈັດຮູບແບບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number."
msgstr "ຕົວເລກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number_of_characters (%s) must be positive or null."
msgstr "ຈຳນວນຕົວອັກສອນ (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ເປັນສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The number_of_periods (%s) must be greater than 0."
msgstr "ຈຳນວນງວດ (%s) ຕ້ອງຫຼາຍກວ່າ 0."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The occurrenceNumber (%s) must be positive or null."
msgstr "ລຳດັບການເກີດຂຶ້ນ (occurrenceNumber) (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ເປັນສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The one-dimensional array to be searched."
msgstr "ອາເຣໜຶ່ງມິຕິທີ່ຈະໃຊ້ໃນການຄົ້ນຫາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The order of the polynomial to fit the data, between 1 and 6."
msgstr "ລຳດັບຂອງພະຫຸນາມທີ່ຈະໃຊ້ປັບໃຫ້ເຂົ້າກັບຂໍ້ມູນ, ລະຫວ່າງ 1 ຫາ 6."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The other range whose entries will be multiplied with corresponding entries "
"in the other ranges."
msgstr ""
"ຊ່ວງຂໍ້ມູນອື່ນທີ່ແຕ່ລະລາຍການຈະຖືກຄູນກັບລາຍການທີ່ກົງກັນໃນຊ່ວງຂໍ້ມູນອື່ນໆ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The pattern by which to format the number, enclosed in quotation marks."
msgstr "ຮູບແບບທີ່ຈະໃຊ້ຈັດຮູບແບບຕົວເລກ, ຕ້ອງຢູ່ໃນເຄື່ອງໝາຍວົງຢືມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pattern or test to apply to criteria_range."
msgstr "ຮູບແບບ ຫຼື ການທົດສອບທີ່ຈະໃຊ້ກັບ criteria_range."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The pattern or test to apply to criteria_range1, such that each cell that "
"evaluates to TRUE will be included in the filtered set."
msgstr ""
"ຮູບແບບ ຫຼື ການທົດສອບທີ່ຈະໃຊ້ກັບ criteria_range1, ເຊິ່ງເຊວໃດທີ່ມີຄ່າເປັນ TRUE ຈະຖືກລວມເຂົ້າໃນຊຸດຂໍ້"
"ມູນທີ່ກັ່ນຕອງແລ້ວ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pattern or test to apply to criteria_range1."
msgstr "ຮູບແບບ ຫຼື ການທົດສອບທີ່ຈະໃຊ້ກັບ criteria_range1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pattern or test to apply to criteria_range2."
msgstr "ຮູບແບບ ຫຼື ການທົດສອບທີ່ຈະໃຊ້ກັບ criteria_range2."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pattern or test to apply to range."
msgstr "ຮູບແບບ ຫຼື ການທົດສອບທີ່ຈະໃຊ້ກັບຊ່ວງຂໍ້ມູນ (range)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The percentile whose value within data will be calculated and returned."
msgstr "ຄ່າເປີເຊັນທາຍ (percentile) ທີ່ຈະຄິດໄລ່ ແລະ ສົ່ງຄ່າຈາກຂໍ້ມູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The percentile, exclusive of 0 and 1, whose value within 'data' will be "
"calculated and returned."
msgstr "ຄ່າເປີເຊັນທາຍ (ບໍ່ລວມ 0 ແລະ 1) ທີ່ຈະຄິດໄລ່ ແລະ ສົ່ງຄ່າຈາກ 'ຂໍ້ມູນ'."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The period (%s) must be less than or equal life (%s)."
msgstr "ງວດ (%s) ຕ້ອງນ້ອຍກວ່າ ຫຼື ເທົ່າກັບ ອາຍຸການໃຊ້ງານ (%s)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The period (%s) must be less than or equal to %s."
msgstr "ງວດ (%s) ຕ້ອງນ້ອຍກວ່າ ຫຼື ເທົ່າກັບ %s."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The period (%s) must be positive or null."
msgstr "ງວດ (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ເປັນສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The period (%s) must be strictly positive."
msgstr "ງວດ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The period for which you want to view the interest payment."
msgstr "ງວດທີ່ທ່ານຕ້ອງການເບິ່ງການຈ່າຍດອກເບ້ຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The period must be between 1 and number_of_periods (%s)"
msgstr "ງວດຕ້ອງຢູ່ລະຫວ່າງ 1 ຫາ ຈຳນວນງວດທັງໝົດ (%s)"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pivot cannot be created because cell %s contains a reserved value"
msgstr "ບໍ່ສາມາດສ້າງ Pivot ໄດ້ ເພາະເຊວ %s ມີຄ່າທີ່ສະຫງວນໄວ້"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pivot cannot be created because cell %s contains an error"
msgstr "ບໍ່ສາມາດສ້າງ Pivot ໄດ້ ເພາະເຊວ %s ມີຂໍ້ຜິດພາດ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pivot cannot be created because cell %s is empty"
msgstr "ບໍ່ສາມາດສ້າງ Pivot ໄດ້ ເພາະເຊວ %s ເປັນຫ້ອງວ່າງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pivot cannot be created because the dataset is missing."
msgstr "ບໍ່ສາມາດສ້າງ Pivot ໄດ້ ເພາະບໍ່ພົບຊຸດຂໍ້ມູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The position (%s) must be greater than or equal to 1."
msgstr "ຕຳແໜ່ງ (%s) ຕ້ອງຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The position where the replacement will begin (starting from 1)."
msgstr "ຕຳແໜ່ງທີ່ຈະເລີ່ມການແທນທີ່ (ເລີ່ມຈາກ 1)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The present value (%s) must be strictly positive."
msgstr "ມູນຄ່າປັດຈຸບັນ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The present value of the investment."
msgstr "ມູນຄ່າປັດຈຸບັນຂອງການລົງທຶນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The present_value (%s) must be strictly positive."
msgstr "ມູນຄ່າປັດຈຸບັນ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The price (%s) must be strictly positive."
msgstr "ລາຄາ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The price at which the security is bought per 100 face value."
msgstr "ລາຄາທີ່ຊື້ຫຼັກຊັບຕໍ່ມູນຄ່າທີ່ກຳນົດໄວ້ 100."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The price at which the security is bought."
msgstr "ລາຄາທີ່ຊື້ຫຼັກຊັບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The price quotation given as a decimal value."
msgstr "ການສະເໜີລາຄາທີ່ໃຫ້ມາເປັນຄ່າທົດສະນິຍົມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The price quotation given using fractional decimal conventions."
msgstr "ການສະເໜີລາຄາທີ່ໃຫ້ມາໂດຍໃຊ້ຮູບແບບເສດສ່ວນທົດສະນິຍົມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The provided anchor is invalid. The cell must be part of the zone."
msgstr "ຈຸດຍຶດ (anchor) ທີ່ລະບຸບໍ່ຖືກຕ້ອງ. ເຊວຕ້ອງເປັນສ່ວນໜຶ່ງຂອງເຂດຂໍ້ມູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The purchase_date (%s) must be before the first_period_end (%s)."
msgstr "ວັນທີຊື້ (%s) ຕ້ອງມາກ່ອນ ວັນທີສິ້ນສຸດງວດທຳອິດ (%s)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The purchase_date (%s) must be positive or null."
msgstr "ວັນທີຊື້ (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ເປັນສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range containing the dataset to consider."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ມີຊຸດຂໍ້ມູນທີ່ຈະພິຈາລະນາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The range containing the return value. Should have the same dimensions as "
"lookup_range."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ມີຄ່າທີ່ຈະສົ່ງຄືນ. ຄວນມີຂະໜາດດຽວກັບ lookup_range."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range containing the set of classes."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ມີຊຸດຂອງຊັ້ນຮຽນ (classes)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The range from which to return a result. The value returned corresponds to "
"the location where search_key is found in search_range. This range must be "
"only a single row or column and should not be used if using the "
"search_result_array method."
msgstr ""
"ຊ່ວງຂໍ້ມູນທີ່ຈະສົ່ງຜົນລັດຄືນ. ຄ່າທີ່ສົ່ງຄືນຈະກົງກັບຕຳແໜ່ງທີ່ພົບ search_key ໃນ search_range. ຊ່ວງນີ້ຕ້ອງເ"
"ປັນພຽງແຖວດຽວ ຫຼື ຖັນດຽວ ແລະ ບໍ່ຄວນໃຊ້ຖ້າໃຊ້ວິທີ search_result_array."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range is invalid"
msgstr "ຊ່ວງຂໍ້ມູນບໍ່ຖືກຕ້ອງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range is out of the sheet"
msgstr "ຊ່ວງຂໍ້ມູນຢູ່ນອກແຜ່ນງານ (sheet)"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range must be a single row or a single column."
msgstr "ຊ່ວງຂໍ້ມູນຕ້ອງເປັນແຖວດຽວ ຫຼື ຖັນດຽວ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range of cells from which the maximum will be determined."
msgstr "ຊ່ວງຂອງເຊວທີ່ຈະໃຊ້ເພື່ອຊອກຫາຄ່າສູງສຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range of cells from which the minimum will be determined."
msgstr "ຊ່ວງຂອງເຊວທີ່ຈະໃຊ້ເພື່ອຊອກຫາຄ່າຕ່ຳສຸດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The range of cells from which the number of unique values will be counted."
msgstr "ຊ່ວງຂອງເຊວທີ່ຈະໃຊ້ນັບຈຳນວນຄ່າທີ່ບໍ່ຊໍ້າກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range of cells from which the values are returned."
msgstr "ຊ່ວງຂອງເຊວທີ່ຈະສົ່ງຄ່າຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range of cells over which to evaluate criterion1."
msgstr "ຊ່ວງຂອງເຊວທີ່ຈະໃຊ້ປະເມີນເງື່ອນໄຂທີ 1 (criterion1)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range representing the array or matrix of dependent data."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ສະແດງເຖິງອາເຣ ຫຼື ມາທຣິກຂອງຂໍ້ມູນທີ່ຂຶ້ນຕໍ່ກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range representing the array or matrix of independent data."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ສະແດງເຖິງອາເຣ ຫຼື ມາທຣິກຂອງຂໍ້ມູນທີ່ເປັນອິດສະຫຼະ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range representing the array or matrix of observed data."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ສະແດງເຖິງອາເຣ ຫຼື ມາທຣິກຂອງຂໍ້ມູນທີ່ສັງເກດການ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range representing the array or matrix of predicted data."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ສະແດງເຖິງອາເຣ ຫຼື ມາທຣິກຂອງຂໍ້ມູນທີ່ຄາດການ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range that is tested against criterion."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະຖືກທົດສອບກັບເງື່ອນໄຂ (criterion)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to average."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະຫາຄ່າສະເລ່ຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The range to average. If not included, criteria_range is used for the "
"average instead."
msgstr ""
"ຊ່ວງຂໍ້ມູນທີ່ຈະຫາຄ່າສະເລ່ຍ. ຖ້າບໍ່ລະບຸ, ຈະໃຊ້ criteria_range ໃນການຫາຄ່າສະເລ່ຍແທນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to be summed, if different from range."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະລວມ (sum), ຖ້າຫາກແຕກຕ່າງຈາກຊ່ວງຂໍ້ມູນປົກກະຕິ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to be transposed."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະເຮັດການສະຫຼັບແຖວເປັນຖັນ (transpose)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to check against criterion."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະກວດສອບກັບເງື່ອນໄຂ (criterion)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to check against criterion1."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະກວດສອບກັບເງື່ອນໄຂທີ 1 (criterion1)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The range to consider for the search. Should be a single column or a single "
"row."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະພິຈາລະນາໃນການຄົ້ນຫາ. ຄວນເປັນພຽງແຖວດຽວ ຫຼື ຖັນດຽວ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The range to consider for the search. The first column in the range is "
"searched for the key specified in search_key."
msgstr ""
"ຊ່ວງຂໍ້ມູນທີ່ຈະພິຈາລະນາໃນການຄົ້ນຫາ. ຖັນທຳອິດໃນຊ່ວງຂໍ້ມູນຈະຖືກໃຊ້ຄົ້ນຫາຄີ (key) ທີ່ລະບຸໃນ search_key."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The range to consider for the search. The first row in the range is searched"
" for the key specified in search_key."
msgstr ""
"ຊ່ວງຂໍ້ມູນທີ່ຈະພິຈາລະນາໃນການຄົ້ນຫາ. ແຖວທຳອິດໃນຊ່ວງຂໍ້ມູນຈະຖືກໃຊ້ຄົ້ນຫາຄີ (key) ທີ່ລະບຸໃນ "
"search_key."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to constrain."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະຈຳກັດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to sum."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະລວມ (sum)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to wrap."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະຕັດຂຶ້ນແຖວໃໝ່ (wrap)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range which is tested against criterion."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະຖືກທົດສອບກັບເງື່ອນໄຂ (criterion)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range whose column count will be returned."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະຖືກນັບຈຳນວນຖັນ ແລະ ສົ່ງຄ່າຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range whose row count will be returned."
msgstr "ຊ່ວງຂໍ້ມູນທີ່ຈະຖືກນັບຈຳນວນແຖວ ແລະ ສົ່ງຄ່າຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rank from largest to smallest of the element to return."
msgstr "ລຳດັບຈາກໃຫຍ່ຫາຕ່ຳຂອງອົງປະກອບທີ່ຈະສົ່ງຄ່າຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rank from smallest to largest of the element to return."
msgstr "ລຳດັບຈາກຕ່ຳຫາໃຫຍ່ຂອງອົງປະກອບທີ່ຈະສົ່ງຄ່າຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rate (%s) must be positive or null."
msgstr "ອັດຕາ (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ເປັນສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rate (%s) must be strictly positive."
msgstr "ອັດຕາ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rate at which the investment grows each period."
msgstr "ອັດຕາການເຕີບໂຕຂອງການລົງທຶນໃນແຕ່ລະງວດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rate_guess (%s) must be strictly greater than -1."
msgstr "ຄ່າຄາດຄະເນອັດຕາ (rate_guess) (%s) ຕ້ອງຫຼາຍກວ່າ -1 ເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The redemption (%s) must be strictly positive."
msgstr "ມູນຄ່າໄຖ່ຖອນ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The redemption amount per 100 face value, or par."
msgstr "ມູນຄ່າໄຖ່ຖອນຕໍ່ມູນຄ່າທີ່ກຳນົດໄວ້ 100 ຫຼື ມູນຄ່າຕາມລາຄາທີ່ຕັ້ງໄວ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The reference to the cell."
msgstr "ການອ້າງອີງໃສ່ເຊວ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The result_range must be a single row or a single column."
msgstr "ຊ່ວງຜົນລັດ (result_range) ຕ້ອງເປັນແຖວດຽວ ຫຼື ຖັນດຽວ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The return (as a percentage) earned on reinvestment of income received from "
"the investment."
msgstr "ຜົນຕອບແທນ (ເປັນເປີເຊັນ) ທີ່ໄດ້ຮັບຈາກການນຳລາຍຮັບຈາກການລົງທຶນໄປລົງທຶນຕໍ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The returned value if condition1 is TRUE."
msgstr "ຄ່າທີ່ຈະສົ່ງຄືນຖ້າເງື່ອນໄຂທີ 1 (condition1) ເປັນ TRUE."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The row index of the value to be returned, where the first row in range is "
"numbered 1."
msgstr "ດັດຊະນີແຖວຂອງຄ່າທີ່ຈະສົ່ງຄືນ, ເຊິ່ງແຖວທຳອິດໃນຊ່ວງຂໍ້ມູນຈະຖືກນັບເປັນ 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The row number of the cell reference. "
msgstr "ເລກລຳດັບແຖວຂອງການອ້າງອີງເຊວ. "

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rows argument (%s) must be strictly positive."
msgstr "ຄ່າອາກິວເມນແຖວ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The rows arguments (%s) must be greater or equal than the number of rows of "
"the array."
msgstr "ຄ່າອາກິວເມນແຖວ (%s) ຕ້ອງຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ ຈຳນວນແຖວຂອງອາເຣ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rows arguments must be between -%s and %s (got %s), excluding 0."
msgstr "ຄ່າອາກິວເມນແຖວຕ້ອງຢູ່ລະຫວ່າງ -%s ຫາ %s (ໄດ້ຮັບ %s), ແລະ ບໍ່ລວມ 0."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rows indexes of the rows to be returned."
msgstr "ດັດຊະນີແຖວຂອງແຖວທັງໝົດທີ່ຈະສົ່ງຄ່າຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rule is invalid for an unknown reason"
msgstr "ກົດບໍ່ຖືກຕ້ອງເນື່ອງຈາກສາເຫດທີ່ບໍ່ຮູ້ຈັກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The salvage (%s) must be positive or null."
msgstr "ມູນຄ່າຊາກ (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ເປັນສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The salvage (%s) must be smaller or equal than the cost (%s)."
msgstr "ມູນຄ່າຊາກ (%s) ຕ້ອງນ້ອຍກວ່າ ຫຼື ເທົ່າກັບ ຕົ້ນທຶນ (%s)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The sample covariance of a dataset."
msgstr "ຄ່າຄວາມແປປວນຮ່ວມ (covariance) ຂອງກຸ່ມຕົວຢ່າງໃນຊຸດຂໍ້ມູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The search method. 1 (default) finds the largest value less than or equal to"
" search_key when range is sorted in ascending order. 0 finds the exact value"
" when range is unsorted. -1 finds the smallest value greater than or equal "
"to search_key when range is sorted in descending order."
msgstr ""
"ວິທີການຄົ້ນຫາ. 1 (ຄ່າເລີ່ມຕົ້ນ) ຈະຫາຄ່າທີ່ໃຫຍ່ທີ່ສຸດທີ່ນ້ອຍກວ່າ ຫຼື ເທົ່າກັບ search_key ເມື່ອຊ່ວງຂໍ້ມູນຖືກຈັດລ"
"ຽງຈາກນ້ອຍຫາໃຫຍ່. 0 ຈະຫາຄ່າທີ່ກົງກັນພໍດີເມື່ອຂໍ້ມູນບໍ່ໄດ້ຈັດລຽງ. -1 ຈະຫາຄ່າທີ່ນ້ອຍທີ່ສຸດທີ່ຫຼາຍກວ່າ ຫຼື ເທົ່າກັ"
"ບ search_key ເມື່ອຊ່ວງຂໍ້ມູນຖືກຈັດລຽງຈາກໃຫຍ່ຫານ້ອຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The second addend."
msgstr "ຕົວເລກທີສອງທີ່ຈະນຳມາບວກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The second argument is missing. Please provide a value"
msgstr "ບໍ່ພົບອາກິວເມນທີສອງ. ກະລຸນາລະບຸຄ່າໃສ່"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The second component of the time."
msgstr "ສ່ວນປະກອບທີສອງຂອງເວລາ (ວິນາທີ)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The second matrix in the matrix multiplication operation."
msgstr "ມາທຣິກທີສອງໃນການຄິດໄລ່ການຄູນມາທຣິກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The second multiplicand."
msgstr "ຕົວຄູນທີສອງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The second number to compare."
msgstr "ຕົວເລກທີສອງທີ່ຈະປຽບທຽບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The second string to compare."
msgstr "ຂໍ້ຄວາມທີສອງທີ່ຈະປຽບທຽບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The second value must be a number"
msgstr "ຄ່າທີສອງຕ້ອງເປັນຕົວເລກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The second value."
msgstr "ຄ່າທີສອງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The settlement (%s) must be greater than or equal to the issue (%s)."
msgstr "ວັນຊຳລະສະສາງ (%s) ຕ້ອງຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ ວັນທີອອກ (%s)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The settlement date (%s) must at most one year after the maturity date (%s)."
msgstr "ວັນຊຳລະສະສາງ (%s) ຕ້ອງຫ່າງຈາກວັນຄົບກຳນົດ (%s) ບໍ່ເກີນໜຶ່ງປີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The settlement date (%s) must be strictly greater than the issue date (%s)."
msgstr "ວັນຊຳລະສະສາງ (%s) ຕ້ອງຫຼາຍກວ່າ ວັນທີອອກ (%s) ເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The settlement date of the security, the date after issuance when the "
"security is delivered to the buyer."
msgstr ""
"ວັນຊຳລະສະສາງຂອງຫຼັກຊັບ, ເຊິ່ງແມ່ນວັນທີຫຼັງການອອກຫຼັກຊັບເມື່ອມີການສົ່ງມອບຫຼັກຊັບໃຫ້ກັບຜູ້ຊື້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The sheet name cannot be empty."
msgstr "ຊື່ແຜ່ນງານບໍ່ສາມາດວ່າງໄດ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The single period within life for which to calculate depreciation."
msgstr "ງວດດຽວພາຍໃນອາຍຸການໃຊ້ງານທີ່ຈະໃຊ້ຄິດໄລ່ຄ່າຫຼຸ້ຍຫ້ຽນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The start date of the period from which to calculate the number of net "
"working days."
msgstr "ວັນທີເລີ່ມຕົ້ນຂອງງວດທີ່ຈະໃຊ້ຄິດໄລ່ຈຳນວນມື້ເຮັດວຽກຕົວຈິງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The start date to consider in the calculation."
msgstr "ວັນທີເລີ່ມຕົ້ນທີ່ຈະພິຈາລະນາໃນການຄິດໄລ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The start date to consider in the calculation. Must be a reference to a cell"
" containing a DATE, a function returning a DATE type, or a number."
msgstr ""
"ວັນທີເລີ່ມຕົ້ນທີ່ຈະພິຈາລະນາໃນການຄິດໄລ່. ຕ້ອງເປັນການອ້າງອີງໃສ່ເຊວທີ່ມີ DATE, ຟັງຊັນທີ່ສົ່ງຄ່າເປັນປະເພດ "
"DATE, ຫຼື ຕົວເລກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The start date to consider in the calculation. Must be a reference to a cell"
" containing a date, a function returning a date type, or a number."
msgstr ""
"ວັນທີເລີ່ມຕົ້ນທີ່ຈະພິຈາລະນາໃນການຄິດໄລ່. ຕ້ອງເປັນການອ້າງອີງໃສ່ເຊວທີ່ມີວັນທີ, ຟັງຊັນທີ່ສົ່ງຄ່າເປັນປະເພດວັນທີ, "
"ຫຼື ຕົວເລກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The start of the date range."
msgstr "ຈຸດເລີ່ມຕົ້ນຂອງຊ່ວງວັນທີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The start_date (%s) must be positive or null."
msgstr "ວັນທີເລີ່ມຕົ້ນ (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ເປັນສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The start_period (%s) must be greater or equal than 0."
msgstr "ງວດເລີ່ມຕົ້ນ (%s) ຕ້ອງຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ 0."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The start_period (%s) must be smaller or equal to the end_period (%s)."
msgstr "ງວດເລີ່ມຕົ້ນ (%s) ຕ້ອງນ້ອຍກວ່າ ຫຼື ເທົ່າກັບ ງວດສິ້ນສຸດ (%s)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The starting point from which to count the offset rows and columns."
msgstr "ຈຸດເລີ່ມຕົ້ນທີ່ຈະໃຊ້ນັບແຖວ ແລະ ຖັນທີ່ຈະເລື່ອນອອກໄປ (offset)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The starting unit, the unit currently assigned to value"
msgstr "ຫົວໜ່ວຍເລີ່ມຕົ້ນ, ແມ່ນຫົວໜ່ວຍທີ່ຖືກກຳນົດໃຫ້ກັບຄ່າໃນປັດຈຸບັນ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The starting_at (%s) must be greater than or equal to 1."
msgstr "ຄ່າ starting_at (%s) ຕ້ອງຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The starting_at argument (%s) must be positive greater than one."
msgstr "ຄ່າອາກິວເມນ starting_at (%s) ຕ້ອງເປັນຄ່າບວກທີ່ຫຼາຍກວ່າໜຶ່ງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string from which the left portion will be returned."
msgstr "ຂໍ້ຄວາມທີ່ຈະຖືກແຍກສ່ວນເບື້ອງຊ້າຍອອກມາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string from which the right portion will be returned."
msgstr "ຂໍ້ຄວາມທີ່ຈະຖືກແຍກສ່ວນເບື້ອງຂວາອອກມາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string representing the date."
msgstr "ຂໍ້ຄວາມທີ່ສະແດງເຖິງວັນທີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string that holds the time representation."
msgstr "ຂໍ້ຄວາມທີ່ສະແດງເຖິງເວລາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string that will replace search_for."
msgstr "ຂໍ້ຄວາມທີ່ຈະນຳມາແທນທີ່ search_for."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string to convert to lowercase."
msgstr "ຂໍ້ຄວາມທີ່ຈະແປງເປັນຕົວພິມນ້ອຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string to convert to uppercase."
msgstr "ຂໍ້ຄວາມທີ່ຈະແປງເປັນຕົວພິມໃຫຍ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string to extract a segment from."
msgstr "ຂໍ້ຄວາມທີ່ຈະແຍກເອົາບາງສ່ວນອອກມາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string to look for within text_to_search."
msgstr "ຂໍ້ຄວາມທີ່ຈະຄົ້ນຫາພາຍໃນ text_to_search."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string to search for within text_to_search."
msgstr "ຂໍ້ຄວາມທີ່ຈະຄົ້ນຫາພາຍໃນ text_to_search."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The string whose length will be returned."
msgstr "ຂໍ້ຄວາມທີ່ຈະຖືກນັບຄວາມຍາວ ແລະ ສົ່ງຄ່າຄືນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The subtrahend, or number to subtract from value1."
msgstr "ຕົວລົບ, ຫຼື ຕົວເລກທີ່ຈະນຳມາລົບອອກຈາກ value1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The table zone is invalid for an unknown reason"
msgstr "ເຂດຕາຕະລາງບໍ່ຖືກຕ້ອງເນື່ອງຈາກສາເຫດທີ່ບໍ່ຮູ້ຈັກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The table_number (%s) is out of range."
msgstr "ເລກລຳດັບຕາຕະລາງ (table_number) (%s) ຢູ່ນອກຂອບເຂດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The text or reference to a cell containing text to be trimmed."
msgstr "ຂໍ້ຄວາມ ຫຼື ການອ້າງອີງເຊວທີ່ມີຂໍ້ຄວາມທີ່ຈະຖືກຕັດຊ່ອງວ່າງ (trim)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The text to display in the cell, enclosed in quotation marks."
msgstr "ຂໍ້ຄວາມທີ່ຈະສະແດງໃນເຊວ, ຕ້ອງຢູ່ໃນເຄື່ອງໝາຍວົງຢືມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The text to divide."
msgstr "ຂໍ້ຄວາມທີ່ຈະແບ່ງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The text to search for the first occurrence of search_for."
msgstr "ຂໍ້ຄວາມທີ່ຈະຄົ້ນຫາການປະກົດຕົວຄັ້ງທຳອິດຂອງ search_for."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The text which will be inserted into the original text."
msgstr "ຂໍ້ຄວາມທີ່ຈະຖືກແຊກເຂົ້າໃນຂໍ້ຄວາມຕົ້ນສະບັບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The text which will be returned with the first letter of each word in "
"uppercase and all other letters in lowercase."
msgstr ""
"ຂໍ້ຄວາມທີ່ຈະຖືກສົ່ງຄືນໂດຍໃຫ້ຕົວອັກສອນທຳອິດຂອງແຕ່ລະຄຳເປັນຕົວພິມໃຫຍ່ ແລະ ຕົວອັກສອນອື່ນໆທັງໝົດເປັນຕົວພິມນ້ອ"
"ຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The text whose non-printable characters are to be removed."
msgstr "ຂໍ້ຄວາມທີ່ຕົວອັກສອນທີ່ບໍ່ສາມາດພິມໄດ້ຈະຖືກລຶບອອກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The text within which to search and replace."
msgstr "ຂໍ້ຄວາມທີ່ຈະໃຊ້ໃນການຄົ້ນຫາ ແລະ ແທນທີ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The text, a part of which will be replaced."
msgstr "ຂໍ້ຄວາມ, ເຊິ່ງສ່ວນໃດໜຶ່ງຈະຖືກແທນທີ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The text_to_search must be non-empty."
msgstr "text_to_search ຕ້ອງບໍ່ວ່າງເປົ່າ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The time from which to calculate the hour component."
msgstr "ເວລາທີ່ຈະໃຊ້ຄິດໄລ່ສ່ວນປະກອບຂອງຊົ່ວໂມງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The time from which to calculate the minute component."
msgstr "ເວລາທີ່ຈະໃຊ້ຄິດໄລ່ສ່ວນປະກອບຂອງນາທີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The time from which to calculate the second component."
msgstr "ເວລາທີ່ຈະໃຊ້ຄິດໄລ່ສ່ວນປະກອບຂອງວິນາທີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The time_string (%s) cannot be parsed to date/time."
msgstr "time_string (%s) ບໍ່ສາມາດແປງເປັນ ວັນທີ/ເວລາ ໄດ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The type (%s) is out of range."
msgstr "ປະເພດ (%s) ຢູ່ນອກຂອບເຂດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The type (%s) must be 1, 2 or 3."
msgstr "ປະເພດ (%s) ຕ້ອງເປັນ 1, 2 ຫຼື 3."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The type of information requested. Can be one of %s"
msgstr "ປະເພດຂອງຂໍ້ມູນທີ່ຮ້ອງຂໍ. ສາມາດເປັນໜຶ່ງໃນ %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The unit (%s) must be strictly positive."
msgstr "ຫົວໜ່ວຍ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The unit of measure into which to convert value"
msgstr "ຫົວໜ່ວຍວັດແທກທີ່ຈະແປງຄ່າເຂົ້າໄປ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The units of the desired fraction, e.g. 8 for 1/8ths or 32 for 1/32nds."
msgstr "ຫົວໜ່ວຍຂອງເສດສ່ວນທີ່ຕ້ອງການ, ເຊັ່ນ: 8 ສຳລັບ 1/8 ຫຼື 32 ສຳລັບ 1/32."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The units of the fraction, e.g. 8 for 1/8ths or 32 for 1/32nds."
msgstr "ຫົວໜ່ວຍຂອງເສດສ່ວນ, ເຊັ່ນ: 8 ສຳລັບ 1/8 ຫຼື 32 ສຳລັບ 1/32."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The upper inflection point value must be a number"
msgstr "ຄ່າຈຸດປ່ຽນໂຄ້ງດ້ານເທິງຕ້ອງເປັນຕົວເລກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value (%s) cannot be between -1 and 1 inclusive."
msgstr "ຄ່າ (%s) ບໍ່ສາມາດຢູ່ລະຫວ່າງ -1 ແລະ 1 ລວມທັງສອງຄ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value (%s) must be a valid base %s representation."
msgstr "ຄ່າ (%s) ຕ້ອງເປັນການສະແດງຖານ %s ທີ່ຖືກຕ້ອງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value (%s) must be between -1 and 1 exclusive."
msgstr "ຄ່າ (%s) ຕ້ອງຢູ່ລະຫວ່າງ -1 ແລະ 1 ໂດຍບໍ່ລວມສອງຄ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value (%s) must be between -1 and 1 inclusive."
msgstr "ຄ່າ (%s) ຕ້ອງຢູ່ລະຫວ່າງ -1 ແລະ 1 ລວມທັງສອງຄ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value (%s) must be greater than or equal to 1."
msgstr "ຄ່າ (%s) ຕ້ອງຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value (%s) must be positive or null."
msgstr "ຄ່າ (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ເປັນສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value (%s) must be strictly positive."
msgstr "ຄ່າ (%s) ຕ້ອງເປັນຄ່າບວກເທົ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value does not match the custom formula data validation rule"
msgstr "ຄ່າບໍ່ກົງກັບກົດການກວດສອບຂໍ້ມູນຂອງສູດທີ່ກຳນົດເອງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The value for which to calculate the inverse cosine. Must be between -1 and "
"1, inclusive."
msgstr ""
"ຄ່າທີ່ຈະໃຊ້ຄິດໄລ່ cosine ປີ້ນ. ຕ້ອງຢູ່ລະຫວ່າງ -1 ແລະ 1, ລວມທັງສອງຄ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value for which to calculate the inverse cotangent."
msgstr "ຄ່າທີ່ຈະໃຊ້ຄິດໄລ່ cotangent ປີ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The value for which to calculate the inverse hyperbolic cosine. Must be "
"greater than or equal to 1."
msgstr "ຄ່າທີ່ຈະໃຊ້ຄິດໄລ່ hyperbolic cosine ປີ້ນ. ຕ້ອງຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The value for which to calculate the inverse hyperbolic cotangent. Must not "
"be between -1 and 1, inclusive."
msgstr ""
"ຄ່າທີ່ຈະໃຊ້ຄິດໄລ່ hyperbolic cotangent ປີ້ນ. ຕ້ອງບໍ່ຢູ່ລະຫວ່າງ -1 ແລະ 1, ລວມທັງສອງຄ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value for which to calculate the inverse hyperbolic sine."
msgstr "ຄ່າທີ່ຈະໃຊ້ຄິດໄລ່ hyperbolic sine ປີ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The value for which to calculate the inverse hyperbolic tangent. Must be "
"between -1 and 1, exclusive."
msgstr ""
"ຄ່າທີ່ຈະໃຊ້ຄິດໄລ່ hyperbolic tangent ປີ້ນ. ຕ້ອງຢູ່ລະຫວ່າງ -1 ແລະ 1, ໂດຍບໍ່ລວມສອງຄ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The value for which to calculate the inverse sine. Must be between -1 and 1,"
" inclusive."
msgstr "ຄ່າທີ່ຈະໃຊ້ຄິດໄລ່ sine ປີ້ນ. ຕ້ອງຢູ່ລະຫວ່າງ -1 ແລະ 1, ລວມທັງສອງຄ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value for which to calculate the inverse tangent."
msgstr "ຄ່າທີ່ຈະໃຊ້ຄິດໄລ່ tangent ປີ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value for which to calculate the logarithm, base e."
msgstr "ຄ່າທີ່ຈະໃຊ້ຄິດໄລ່ logarithm, ຖານ e."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value for which to calculate the logarithm."
msgstr "ຄ່າທີ່ຈະໃຊ້ຄິດໄລ່ logarithm."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be %s"
msgstr "ຄ່າຕ້ອງແມ່ນ %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be a boolean"
msgstr "ຄ່າຕ້ອງເປັນຄ່າບູນລີນ (boolean)"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be a date"
msgstr "ຄ່າຕ້ອງເປັນວັນທີ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be a date after %s"
msgstr "ຄ່າຕ້ອງເປັນວັນທີຫຼັງຈາກ %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be a date before %s"
msgstr "ຄ່າຕ້ອງເປັນວັນທີກ່ອນ %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be a date between %s and %s"
msgstr "ຄ່າຕ້ອງເປັນວັນທີລະຫວ່າງ %s ແລະ %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be a date not between %s and %s"
msgstr "ຄ່າຕ້ອງເປັນວັນທີທີ່ບໍ່ຢູ່ລະຫວ່າງ %s ແລະ %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be a date on or after %s"
msgstr "ຄ່າຕ້ອງເປັນວັນທີໃນ ຫຼື ຫຼັງຈາກ %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be a date on or before %s"
msgstr "ຄ່າຕ້ອງເປັນວັນທີໃນ ຫຼື ກ່ອນ %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be a formula"
msgstr "ຄ່າຕ້ອງເປັນສູດ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be a number"
msgstr "ຄ່າຕ້ອງເປັນຕົວເລກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be a text that contains \"%s\""
msgstr "ຄ່າຕ້ອງເປັນຂໍ້ຄວາມທີ່ມີ \"%s\""

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be a text that does not contain \"%s\""
msgstr "ຄ່າຕ້ອງເປັນຂໍ້ຄວາມທີ່ບໍ່ມີ \"%s\""

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be a valid date"
msgstr "ຄ່າຕ້ອງເປັນວັນທີທີ່ຖືກຕ້ອງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be a valid email address"
msgstr "ຄ່າຕ້ອງເປັນທີ່ຢູ່ອີເມວທີ່ຖືກຕ້ອງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be a valid link"
msgstr "ຄ່າຕ້ອງເປັນລິ້ງທີ່ຖືກຕ້ອງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be a valid range"
msgstr "ຄ່າຕ້ອງເປັນຂອບເຂດທີ່ຖືກຕ້ອງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be a value in the range %s"
msgstr "ຄ່າຕ້ອງເປັນຄ່າຢູ່ໃນຂອບເຂດ %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be between %s and %s"
msgstr "ຄ່າຕ້ອງຢູ່ລະຫວ່າງ %s ແລະ %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be equal to %s"
msgstr "ຄ່າຕ້ອງເທົ່າກັບ %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be exactly \"%s\""
msgstr "ຄ່າຕ້ອງແມ່ນ \"%s\" ພໍດີ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be greater or equal to %s"
msgstr "ຄ່າຕ້ອງຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be greater than %s"
msgstr "ຄ່າຕ້ອງຫຼາຍກວ່າ %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be less or equal to %s"
msgstr "ຄ່າຕ້ອງໜ້ອຍກວ່າ ຫຼື ເທົ່າກັບ %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be less than %s"
msgstr "ຄ່າຕ້ອງໜ້ອຍກວ່າ %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be one of: %s"
msgstr "ຄ່າຕ້ອງເປັນໜຶ່ງໃນ: %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must be the date %s"
msgstr "ຄ່າຕ້ອງແມ່ນວັນທີ %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must not be a formula"
msgstr "ຄ່າຕ້ອງບໍ່ແມ່ນສູດ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must not be between %s and %s"
msgstr "ຄ່າຕ້ອງບໍ່ຢູ່ລະຫວ່າງ %s ແລະ %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must not be empty"
msgstr "ຄ່າຕ້ອງບໍ່ວ່າງເປົ່າ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value must not be equal to %s"
msgstr "ຄ່າຕ້ອງບໍ່ເທົ່າກັບ %s"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value of the asset at the end of depreciation."
msgstr "ມູນຄ່າຂອງຊັບສິນເມື່ອສິ້ນສຸດການຫຼຸ້ຍຫ້ຽນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value or values to be appended using delimiter."
msgstr "ຄ່າ ຫຼື ຫຼາຍໆຄ່າທີ່ຈະຖືກຕໍ່ທ້າຍໂດຍໃຊ້ຕົວຂັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value the function returns if logical_expression is FALSE."
msgstr "ຄ່າທີ່ຟັງຊັນຈະສົ່ງຄືນຖ້າ logical_expression ເປັນ FALSE."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value the function returns if logical_expression is TRUE."
msgstr "ຄ່າທີ່ຟັງຊັນຈະສົ່ງຄືນຖ້າ logical_expression ເປັນ TRUE."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value the function returns if value is an #N/A error."
msgstr "ຄ່າທີ່ຟັງຊັນຈະສົ່ງຄືນຖ້າຄ່ານັ້ນເປັນຂໍ້ຜິດພາດ #N/A."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value the function returns if value is an error."
msgstr "ຄ່າທີ່ຟັງຊັນຈະສົ່ງຄືນຖ້າຄ່ານັ້ນເປັນຂໍ້ຜິດພາດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to append to value1."
msgstr "ຄ່າທີ່ຈະຕໍ່ທ້າຍໃສ່ value1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to be checked."
msgstr "ຄ່າທີ່ຈະກວດສອບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to be truncated."
msgstr "ຄ່າທີ່ຈະຖືກຕັດອອກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to be verified as a logical TRUE or FALSE."
msgstr "ຄ່າທີ່ຈະຖືກກວດສອບວ່າເປັນ TRUE ຫຼື FALSE ທາງໂລຊິກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to be verified as a number."
msgstr "ຄ່າທີ່ຈະຖືກກວດສອບວ່າເປັນຕົວເລກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to be verified as an error type."
msgstr "ຄ່າທີ່ຈະຖືກກວດສອບວ່າເປັນປະເພດຂໍ້ຜິດພາດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to be verified as even."
msgstr "ຄ່າທີ່ຈະຖືກກວດສອບວ່າເປັນເລກຄູ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to be verified as text."
msgstr "ຄ່າທີ່ຈະຖືກກວດສອບວ່າເປັນຂໍ້ຄວາມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to interpret as a percentage."
msgstr "ຄ່າທີ່ຈະແປຜົນເປັນເປີເຊັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to return if value itself is not #N/A an error."
msgstr "ຄ່າທີ່ຈະສົ່ງຄືນຖ້າຄ່ານັ້ນເອງບໍ່ແມ່ນຂໍ້ຜິດພາດ #N/A."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to return if value itself is not an error."
msgstr "ຄ່າທີ່ຈະສົ່ງຄືນຖ້າຄ່ານັ້ນເອງບໍ່ແມ່ນຂໍ້ຜິດພາດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to round down to the nearest integer multiple of factor."
msgstr "ຄ່າທີ່ຈະປັດລົງໃຫ້ເປັນຕົວຄູນຈຳນວນເຕັມທີ່ໃກ້ທີ່ສຸດຂອງ factor."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The value to round down to the nearest integer multiple of significance."
msgstr "ຄ່າທີ່ຈະປັດລົງໃຫ້ເປັນຕົວຄູນຈຳນວນເຕັມທີ່ໃກ້ທີ່ສຸດຂອງ significance."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to round to places number of places, always rounding down."
msgstr "ຄ່າທີ່ຈະປັດຕາມຈຳນວນຕຳແໜ່ງທີ່ກຳນົດ, ໂດຍປັດລົງສະເໝີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to round to places number of places, always rounding up."
msgstr "ຄ່າທີ່ຈະປັດຕາມຈຳນວນຕຳແໜ່ງທີ່ກຳນົດ, ໂດຍປັດຂຶ້ນສະເໝີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to round to places number of places."
msgstr "ຄ່າທີ່ຈະປັດຕາມຈຳນວນຕຳແໜ່ງທີ່ກຳນົດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to round to the next greatest odd number."
msgstr "ຄ່າທີ່ຈະປັດໃຫ້ເປັນເລກຄີກທີ່ໃຫຍ່ກວ່າຖັດໄປ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to round up to the nearest integer multiple of factor."
msgstr "ຄ່າທີ່ຈະປັດຂຶ້ນໃຫ້ເປັນຕົວຄູນຈຳນວນເຕັມທີ່ໃກ້ທີ່ສຸດຂອງ factor."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to round up to the nearest integer multiple of significance."
msgstr "ຄ່າທີ່ຈະປັດຂຶ້ນໃຫ້ເປັນຕົວຄູນຈຳນວນເຕັມທີ່ໃກ້ທີ່ສຸດຂອງ significance."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to search for."
msgstr "ຄ່າທີ່ຈະຄົ້ນຫາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to search for. For example, 42, 'Cats', or I24."
msgstr "ຄ່າທີ່ຈະຄົ້ນຫາ. ຕົວຢ່າງ: 42, 'Cats', ຫຼື I24."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to test against value1 for equality."
msgstr "ຄ່າທີ່ຈະທົດສອບກັບ value1 ວ່າເທົ່າກັນຫຼືບໍ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to test against value1 for inequality."
msgstr "ຄ່າທີ່ຈະທົດສອບກັບ value1 ວ່າບໍ່ເທົ່າກັນຫຼືບໍ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to test as being greater than or equal to value2."
msgstr "ຄ່າທີ່ຈະທົດສອບວ່າຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ value2."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to test as being greater than value2."
msgstr "ຄ່າທີ່ຈະທົດສອບວ່າຫຼາຍກວ່າ value2."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to test as being less than or equal to value2."
msgstr "ຄ່າທີ່ຈະທົດສອບວ່າໜ້ອຍກວ່າ ຫຼື ເທົ່າກັບ value2."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to test as being less than value2."
msgstr "ຄ່າທີ່ຈະທົດສອບວ່າໜ້ອຍກວ່າ value2."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value to which value2 will be appended."
msgstr "ຄ່າທີ່ value2 ຈະຖືກຕໍ່ທ້າຍໃສ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value whose rank will be determined."
msgstr "ຄ່າທີ່ຈະຖືກກຳນົດອັນດັບ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value with which to fill the extra cells in the range."
msgstr "ຄ່າທີ່ຈະໃຊ້ຕື່ມໃສ່ເຊວທີ່ເກີນມາໃນຂອບເຂດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value with which to pad."
msgstr "ຄ່າທີ່ຈະໃຊ້ຕື່ມ (pad)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The value(s) on the x-axis to forecast."
msgstr "ຄ່າໃນແກນ x ທີ່ຈະໃຊ້ພະຍາກອນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The values of the independent variable(s) corresponding with known_data_y."
msgstr "ຄ່າຂອງຕົວປ່ຽນເອກະລາດທີ່ກົງກັບ known_data_y."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The weekend (%s) must be a string or a number in the range 1-7 or 11-17."
msgstr "ວັນຢຸດສຸດສັບປະດາ (%s) ຕ້ອງເປັນຂໍ້ຄວາມ ຫຼື ຕົວເລກໃນຂອບເຂດ 1-7 ຫຼື 11-17."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The weekend must be a number or a string."
msgstr "ວັນຢຸດສຸດສັບປະດາຕ້ອງເປັນຕົວເລກ ຫຼື ຂໍ້ຄວາມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The weekend must be different from '1111111'."
msgstr "ວັນຢຸດສຸດສັບປະດາຕ້ອງຕ່າງຈາກ '1111111'."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The x coordinate of the endpoint of the line segment for which to calculate "
"the angle from the x-axis."
msgstr "ພິກັດ x ຂອງຈຸດສິ້ນສຸດຂອງສ່ວນຂອງເສັ້ນຊື່ທີ່ຈະໃຊ້ຄິດໄລ່ທຽບກັບແກນ x."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The y coordinate of the endpoint of the line segment for which to calculate "
"the angle from the x-axis."
msgstr "ພິກັດ y ຂອງຈຸດສິ້ນສຸດຂອງສ່ວນຂອງເສັ້ນຊື່ທີ່ຈະໃຊ້ຄິດໄລ່ທຽບກັບແກນ x."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The year (%s) must be between 0 and 9999 inclusive."
msgstr "ປີ (%s) ຕ້ອງຢູ່ລະຫວ່າງ 0 ແລະ 9999 ລວມທັງສອງຄ່ານັ້ນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The year component of the date."
msgstr "ສ່ວນປະກອບຂອງປີຈາກວັນທີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The yield (%s) must be positive or null."
msgstr "ຜົນຕອບແທນ (%s) ຕ້ອງເປັນຄ່າບວກ ຫຼື ເປັນສູນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The yield of a US Treasury bill based on price."
msgstr "ຜົນຕອບແທນຂອງພັນທະບັດຄັງເງິນສະຫະລັດໂດຍອີງຕາມລາຄາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/list/list_functions.js:0
msgid "There is no list with id \"%s\""
msgstr "ບໍ່ມີລາຍການທີ່ມີ id \"%s\""

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "There is no match for the selected separator in the selection"
msgstr "ບໍ່ມີສິ່ງທີ່ກົງກັບຕົວແຍກທີ່ເລືອກໃນການເລືອກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "There is no pivot with id \"%s\""
msgstr "ບໍ່ມີ pivot ທີ່ມີ id \"%s\""

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "There is not enough visible sheets"
msgstr "ມີແຜ່ນງານທີ່ສະແດງໃຫ້ເຫັນບໍ່ພຽງພໍ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"There must be both positive and negative values in [payment_amount, "
"present_value, future_value]."
msgstr ""
"ຕ້ອງມີທັງຄ່າບວກ ແລະ ຄ່າລົບໃນ [payment_amount, present_value, future_value]."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "There must be both positive and negative values in cashflow_amounts."
msgstr "ຕ້ອງມີທັງຄ່າບວກ ແລະ ຄ່າລົບໃນ cashflow_amounts."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"There must be the same number of values in cashflow_amounts and "
"cashflow_dates."
msgstr "ຕ້ອງມີຈຳນວນຄ່າເທົ່າກັນໃນ cashflow_amounts ແລະ cashflow_dates."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"This formula has over 100 parts. It can't be processed properly, consider "
"splitting it into multiple cells"
msgstr ""
"ສູດນີ້ມີຫຼາຍກວ່າ 100 ສ່ວນ. ມັນບໍ່ສາມາດປະມວນຜົນໄດ້ຢ່າງຖືກຕ້ອງ, ກະລຸນາພິຈາລະນາແບ່ງມັນອອກເປັນຫຼາຍເຊວ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/currency/formulas.js:0
msgid ""
"This function takes in two currency codes as arguments, and returns the "
"exchange rate from the first currency to the second as float."
msgstr ""
"ຟັງຊັນນີ້ຮັບລະຫັດສະກຸນເງິນສອງລະຫັດເປັນອາຄິວເມນ, ແລະ ສົ່ງຄືນອັດຕາແລກປ່ຽນຈາກສະກຸນເງິນທຳອິດໄປຫາສະກຸນ"
"ເງິນທີສອງເປັນເລກທົດສະນິຍົມ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "This operation is not allowed due to an overlapping frozen pane."
msgstr "ການດຳເນີນການນີ້ບໍ່ໄດ້ຮັບອະນຸຍາດເນື່ອງຈາກມີການຊ້ອນທັບກັບແຖບທີ່ຖືກຕຶງໄວ້."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "This operation is not allowed with multiple selections."
msgstr "ການດຳເນີນການນີ້ບໍ່ໄດ້ຮັບອະນຸຍາດເມື່ອມີການເລືອກຫຼາຍບ່ອນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"This operation is not possible due to a merge. Please remove the merges "
"first than try again."
msgstr ""
"ການດຳເນີນການນີ້ບໍ່ສາມາດເຮັດໄດ້ເນື່ອງຈາກມີການລວມເຊວ. ກະລຸນາລຶບການລວມເຊວອອກກ່ອນ ແລ້ວຈຶ່ງລອງໃໝ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.xml:0
msgid "This pivot has no cell missing on this sheet"
msgstr "pivot ນີ້ບໍ່ມີເຊວທີ່ຂາດຫາຍໄປໃນແຜ່ນງານນີ້"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.xml:0
msgid "This pivot is not used"
msgstr "pivot ນີ້ບໍ່ໄດ້ຖືກນຳໃຊ້"

#. module: spreadsheet
#. odoo-javascript
