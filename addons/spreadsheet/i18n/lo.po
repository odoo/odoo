msgstr "ການອອກແບບແຜນພູມນ້ຳຕົກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"We found data next to your selection. Since this data was not selected, it "
"will not be sorted. Do you want to extend your selection?"
msgstr ""
"ພວກເຮົາພົບຂໍ້ມູນຢູ່ຂ້າງການເລືອກຂອງທ່ານ. ເນື່ອງຈາກຂໍ້ມູນນີ້ບໍ່ໄດ້ຖືກເລືອກ, ມັນຈະບໍ່ຖືກຈັດລຽງ. ທ່ານຕ້ອງການຂະ"
"ຫຍາຍການເລືອກຂອງທ່ານບໍ່?"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Web"
msgstr "ເວັບ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Wednesday"
msgstr "ວັນພຸດ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Week"
msgstr "ອາທິດ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Week & Year"
msgstr "ອາທິດ ແລະ ປີ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Week number of the year."
msgstr "ເລກລຳດັບອາທິດຂອງປີ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Weight"
msgstr "ນໍ້າໜັກ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Weighted average."
msgstr "ຄ່າສະເລ່ຍແບບຖ່ວງນ້ຳໜັກ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Weights for each corresponding value."
msgstr "ນ້ຳໜັກສຳລັບແຕ່ລະຄ່າທີ່ກົງກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.xml:0
msgid "When value is"
msgstr "ເມື່ອຄ່າມີຄ່າແມ່ນ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "When weekend is a string (%s) it must be composed of \"0\" or \"1\"."
msgstr "ເມື່ອວັນຢຸດສຸດສັບປະດາເປັນຂໍ້ຄວາມ (%s) ມັນຕ້ອງປະກອບດ້ວຍ \"0\" ຫຼື \"1\"."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Whether a value is `true` or `false`."
msgstr "ກວດສອບວ່າຄ່າແມ່ນ `true` ຫຼື `false`."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Whether a value is a number."
msgstr "ກວດສອບວ່າຄ່າແມ່ນຕົວເລກຫຼືບໍ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Whether a value is an error other than #N/A."
msgstr "ກວດສອບວ່າຄ່າແມ່ນຂໍ້ຜິດພາດທີ່ບໍ່ແມ່ນ #N/A."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Whether a value is an error."
msgstr "ກວດສອບວ່າຄ່າແມ່ນຂໍ້ຜິດພາດຫຼືບໍ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Whether a value is non-textual."
msgstr "ກວດສອບວ່າຄ່າບໍ່ແມ່ນຂໍ້ຄວາມຫຼືບໍ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Whether a value is text."
msgstr "ກວດສອບວ່າຄ່າແມ່ນຂໍ້ຄວາມຫຼືບໍ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Whether a value is the error #N/A."
msgstr "ກວດສອບວ່າຄ່າແມ່ນຂໍ້ຜິດພາດ #N/A ຫຼືບໍ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Whether or not to divide text around each character contained in delimiter."
msgstr "ຕ້ອງການແບ່ງຂໍ້ຄວາມຕາມແຕ່ລະຕົວອັກສອນທີ່ມີຢູ່ໃນຕົວແຍກຫຼືບໍ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Whether or not to remove empty text messages from the split results. The "
"default behavior is to treat         consecutive delimiters as one (if "
"TRUE). If FALSE, empty cells values are added between consecutive "
"delimiters."
msgstr ""
"ຕ້ອງການລຶບຂໍ້ຄວາມຫວ່າງເປົ່າອອກຈາກຜົນຂອງການແບ່ງຫຼືບໍ່. ພຶດຕິກຳເລີ່ມຕົ້ນແມ່ນຖືວ່າ ຕົວແຍກທີ່ຢູ່ຕິດກັນເປັນອັນດຽ"
"ວ (ຖ້າເປັນ TRUE). ຖ້າເປັນ FALSE, ຈະມີຄ່າເຊວຫວ່າງເປົ່າລະຫວ່າງຕົວແຍກທີ່ຢູ່ຕິດກັນ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Whether payments are due at the end (0) or beginning (1) of each period."
msgstr ""
"ກວດສອບວ່າການຊຳລະເງິນແມ່ນຮອດກຳນົດເມື່ອສິ້ນສຸດ (0) ຫຼື ເລີ່ມຕົ້ນ (1) ຂອງແຕ່ລະຮອບເວລາ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Whether the array should be scanned by column. True scans the array by "
"column and false (default)       scans the array by row."
msgstr ""
"ອາເຣ (array) ຄວນຖືກສະແກນຕາມຄໍລຳຫຼືບໍ່. True ຈະສະແກນຕາມຄໍລຳ ແລະ False (ເລີ່ມຕົ້ນ) ຈະສະແກນ"
"ຕາມແຖວ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Whether the provided value is even."
msgstr "ກວດສອບວ່າຄ່າທີ່ໃຫ້ມາແມ່ນເລກຄູ່ຫຼືບໍ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Whether the referenced cell is empty"
msgstr "ກວດສອບວ່າເຊວທີ່ອ້າງອີງນັ້ນວ່າງເປົ່າຫຼືບໍ່"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Whether to consider the values in data in descending or ascending order."
msgstr "ຕ້ອງການພິຈາລະນາຄ່າໃນຂໍ້ມູນແບບລຽງຈາກຫຼາຍຫາໜ້ອຍ ຫຼື ໜ້ອຍຫາຫຼາຍ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Whether to filter the data by columns or by rows."
msgstr "ຕ້ອງການກອງຂໍ້ມູນຕາມຄໍລຳ ຫຼື ຕາມແຖວ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Whether to include the column titles or not."
msgstr "ຕ້ອງການລວມຫົວຂໍ້ຄໍລຳນຳຫຼືບໍ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Whether to include total/sub-totals or not."
msgstr "ຕ້ອງການລວມຜົນລວມທັງໝົດ/ຜົນລວມຍ່ອຍນຳຫຼືບໍ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Whether to return only entries with no duplicates."
msgstr "ຕ້ອງການໃຫ້ສົ່ງຄືນສະເພາະລາຍການທີ່ບໍ່ຊ້ຳກັນເທົ່ານັ້ນຫຼືບໍ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Whether to switch to straight-line depreciation when the depreciation is "
"greater than the declining balance calculation."
msgstr ""
"ຕ້ອງການປ່ຽນໄປໃຊ້ວິທີຫຼຸ້ຍຫ້ຽນແບບເສັ້ນຊື່ຫຼືບໍ່ ເມື່ອຄ່າຫຼຸ້ຍຫ້ຽນນັ້ນຫຼາຍກວ່າການຄິດໄລ່ແບບຫຼຸດນ້ອຍຖອຍລົງ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Which quartile value to return."
msgstr "ຕ້ອງການໃຫ້ສົ່ງຄືນຄ່າຄວໍໄທ (quartile) ໃດ."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Which quartile value, exclusive of 0 and 4, to return."
msgstr "ຕ້ອງການໃຫ້ສົ່ງຄືນຄ່າຄວໍໄທໃດ (ໂດຍບໍ່ລວມ 0 ແລະ 4)."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Width value is %(_width)s. It should be greater than or equal to 1."
msgstr "ຄ່າຄວາມກວ້າງແມ່ນ %(_width)s. ມັນຄວນຈະຫຼາຍກວ່າ ຫຼື ເທົ່າກັບ 1."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Wrap"
msgstr "ຕັດຂໍ້ຄວາມ (Wrap)"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Wrapping"
msgstr "ການຕັດຂໍ້ຄວາມ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Wraps the provided row or column of cells by columns after a specified "
"number of elements to form a new array."
msgstr ""
"ຕັດແຖວ ຫຼື ຄໍລຳຂອງເຊວທີ່ໃຫ້ມາຕາມຄໍລຳ ຫຼັງຈາກຄົບຈຳນວນອົງປະກອບທີ່ກຳນົດ ເພື່ອສ້າງເປັນອາເຣໃໝ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"Wraps the provided row or column of cells by rows after a specified number "
"of elements to form a new array."
msgstr ""
"ຕັດແຖວ ຫຼື ຄໍລຳຂອງເຊວທີ່ໃຫ້ມາຕາມແຖວ ຫຼັງຈາກຄົບຈຳນວນອົງປະກອບທີ່ກຳນົດ ເພື່ອສ້າງເປັນອາເຣໃໝ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Wrong function call"
msgstr "ການເອີ້ນໃຊ້ຟັງຊັນບໍ່ຖືກຕ້ອງ"

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Wrong number of arguments. Expected an even number of arguments."
msgstr "ຈຳນວນອາຄິວເມນບໍ່ຖືກຕ້ອງ. ຕ້ອງການອາຄິວເມນເປັນຈຳນວນຄູ່."

#. module: spreadsheet
#. odoo-javascript
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "Wrong size for %s. Expected a range of size 1x%s. Got %sx%s."
