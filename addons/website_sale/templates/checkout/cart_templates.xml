<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Lines that show items in the cart. Called in `website_sale.cart`. -->
    <template id="website_sale.cart_lines" name="Shopping Cart Lines">
        <!-- target tag for interaction to mount cart lines component -->
        <div id="cart_products"/>
        <!-- dummy cart line to display in edit mode only -->
        <div class="css_non_editable_mode_hidden">
            <div
                id="cart_products_edit_mode"
                t-attf-class="#{'d-none' if not website_sale_order or not website_sale_order.website_order_line else ''}"
            >
                <div class="o_cart_product d-flex gap-3 pb4">
                    <div class="o_cart_product_image" style="width: 64px; height: 64px">
                        <div class="placeholder w-100 h-100 rounded ratio ratio-1x1"/>
                    </div>
                    <div class="d-flex flex-column flex-grow-1 gap-3 min-w-0">
                        <div class="d-flex gap-3">
                            <div class="flex-grow-1 w-100">
                                <span class="placeholder col-5 d-block mb-2 rounded"/>
                                <span class="placeholder col-7 d-block mb-2 rounded"/>
                                <div class="d-none d-md-flex align-items-center gap-2 mt-2">
                                    <button name="cart_remove" class="cart_remove btn btn-link btn-sm p-0">
                                        Remove
                                    </button>
                                </div>
                            </div>
                            <div class="d-none d-md-block text-end">
                                <span class="placeholder col-4 d-block mb-2 ms-auto rounded"/>
                                <div class="css_quantity input-group justify-content-end border">
                                    <a href="#" class="btn btn-link border-end-0 cart_quantity_minus">
                                        <i class="oi oi-minus"/>
                                    </a>
                                    <input type="text" class="js_quantity quantity form-control border-0" value="1"/>
                                    <a href="#" class="btn btn-link border-start-0 cart_quantity_plus">
                                        <i class="oi oi-plus"/>
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="d-flex d-md-none align-items-center">
                            <div
                                class="css_quantity input-group justify-content-end h-100 border me-auto"
                                name="website_sale_cart_line_quantity_mobile"
                            >
                                <button
                                    name="remove_quantity"
                                    class="btn btn-link d-inline-block border border-end-0 cart_quantity_minus_mobile"
                                >
                                    <i class="oi oi-minus position-relative z-1"/>
                                </button>
                                <input
                                    type="text"
                                    class="js_quantity quantity form-control border border-start-0 border-end-0"
                                    value="1"
                                />
                                <button
                                    name="add_quantity"
                                    class="btn btn-link d-inline-block border border-start-0 cart_quantity_plus_mobile"
                                >
                                    <i class="oi oi-plus position-relative z-1"/>
                                </button>
                            </div>

                            <button name="cart_remove_mobile" class="cart_remove_mobile btn btn-link d-inline-block px-2">
                                <i class="fa fa-fw fa-trash-o"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <div
                id="empty_cart_edit_mode"
                t-attf-class="w-100 #{'' if not website_sale_order or not website_sale_order.website_order_line else 'd-none'}"
            >
                <div class="mt-5 mb-3"><t t-call="website_sale.empty_cart_svg"/></div>
                <h5 class="mb-3 empty_cart_title" style="text-align: center;">
                    Your cart is empty!
                </h5>
                <p style="text-align: center;">
                    <a href="/shop" class="btn btn-primary shop_button_title">
                        Shop
                    </a>
                </p>
            </div>
        </div>
        <div class="availability_messages"/>
    </template>

    <template id="website_sale.cart_combo_item_line">
        <a
            t-att-href="combo_item_line.product_id.website_url if combo_item_line._is_sellable() and combo_item_line.product_id.website_published else '#'"
            t-attf-class="list-group-item #{'list-group-item-action' if combo_item_line._is_sellable() and combo_item_line.product_id.website_published else 'cursor-default text-decoration-none'}"
        >
            <h6 class="d-inline small">
                <span t-out="combo_item_line._get_displayed_quantity()"/>
                x
                <span t-out="combo_item_line.name_short"/>
            </h6>
            <t
                t-set="description_lines"
                t-value="combo_item_line.get_description_following_lines()"
            />
            <div t-if="description_lines" class="small text-muted">
                <t t-foreach="description_lines" t-as="description_line">
                    <span
                        t-if="description_line"
                        class="d-block"
                        t-out="description_line"
                    />
                </t>
            </div>
        </a>
    </template>

    <template id="website_sale.cart_product_price">
        <span
            t-out="product_price"
            style="white-space: nowrap;"
            t-options="{'widget': 'monetary', 'display_currency': website_sale_order.currency_id}"
        />
    </template>

    <!-- /shop/cart route -->
    <template id="website_sale.cart" name="Shopping Cart">
        <t t-set="oe_structure">
            <!-- This is the drag-and-drop area for website building blocs at the end of each
                 checkout page. This is append at the of the page in `checkout_layout`. The
                 templates created in the database to store blocs are hooked using XPath on the
                 `oe_struture` element ID. Therefore, we can't use dynamic IDs (like with
                 t-att-id) and each template needs to define a div element. -->
            <div class="oe_structure" id="oe_structure_website_sale_cart_2"/>
        </t>
        <t t-call="website_sale.checkout_layout"
            show_shorter_cart_summary="True"
            show_footer="True"
            oe_structure="oe_structure">
            <div id="shop_cart" class="col">
                <div class="d-flex align-items-center mb-3">
                    <h4 class="mb-0">Order summary</h4>
                    <div class="ms-3 border-start ps-2"><t t-call="website_sale.quick_reorder_button"/></div>
                </div>
                <div t-if="abandoned_proceed or access_token" class="alert alert-info mt8 mb8" role="alert"> <!-- abandoned cart choices -->
                    <t t-if="abandoned_proceed">
                        <p>Your previous cart has already been completed.</p>
                        <p t-if="website_sale_order">Please proceed your current cart.</p>
                    </t>
                    <t t-if="access_token">
                        <p>This is your current cart.</p>
                        <p>
                            <strong>
                                <a class="o_translate_inline" t-attf-href="/shop/cart/?id={{id}}&amp;access_token={{access_token}}&amp;revive_method=squash">Click here</a>
                            </strong> if you want to restore your previous cart. Your current cart will be replaced with your previous cart.
                        </p>
                        <p>
                            <strong>
                                <a class="o_translate_inline" t-attf-href="/shop/cart/?id={{id}}&amp;access_token={{access_token}}&amp;revive_method=merge">Click here</a>
                            </strong> if you want to merge your previous cart into current cart.
                        </p>
                    </t>
                </div>
                <t t-call="website_sale.cart_lines"/>
                <div class="clearfix" />
                <div class="oe_structure" id="oe_structure_website_sale_cart_1"/>
            </div>
        </t>
    </template>

    <template id="website_sale.quick_reorder_button">
        <span id="quick_reorder"></span>
        <span class="quick_reorder_edit_mode css_non_editable_mode_hidden btn btn-sm btn-link">
            <i class="fa fa-rotate-left me-2"/>Quick reorder
        </span>
    </template>

    <!-- Deactivatable through the website editor. -->
    <template
        id="website_sale.suggested_products_list"
        inherit_id="website_sale.cart_lines"
        name="Accessory Products in my cart"
    >
        <div id="cart_products_edit_mode" position="inside">
            <h5 class="mt-3 accessory_products_title">Suggested accessories</h5>
            <div id="suggested_products_edit_mode" class="d-flex align-items-stretch">
                <div class="o_cart_product_image" style="width: 64px; height: 64px">
                    <div class="placeholder rounded w-100 ratio ratio-1x1"/>
                </div>
                <div class="flex-grow-1 ms-3">
                    <div class="d-flex justify-content-between">
                        <div class="flex-grow-1">
                            <span class="placeholder col-5 mb-2 d-block rounded"/>
                            <span class="placeholder col-8 d-block rounded"/>
                        </div>
                        <div class="d-flex flex-column gap-2 align-items-end ms-3">
                            <span class="placeholder col-6 d-block rounded"/>
                            <button class="btn btn-primary text-nowrap add_to_cart_button">
                                <i class="d-md-none fa fa-shopping-cart"/>
                                <span class="d-none d-md-inline">Add to cart</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </template>

    <template
        id="website_sale.wishlist_cart_lines"
        inherit_id="website_sale.cart_lines"
        active="True"
    >
        <button name="cart_remove" position="after">
            <span class="text-300">|</span>
            <button class="cart_wishlist btn btn-link btn-sm p-0">
                Save for Later
            </button>
        </button>

        <button name="cart_remove_mobile" position="before">
            <button class="cart_wishlist_mobile btn btn-link d-inline-block px-2">
                <i class="fa fa-fw fa-heart-o"></i>
            </button>
        </button>
    </template>

</odoo>
