<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="website_sale.snippets" inherit_id="website.snippets" name="e-commerce snippets">
    <xpath expr="//t[@id='sale_products_hook']" position="replace">
        <t
            string="Products Carousel"
            label="Carousel"
            t-snippet="website_sale.s_dynamic_snippet_products_carousal"
            group="catalog"
        />
        <t
            string="Products Grid"
            label="Grid"
            t-snippet="website_sale.s_dynamic_snippet_products_grid"
            group="catalog"
        />
        <t t-snippet="website_sale.s_dynamic_snippet_category_list" string="Category List" label="Dynamic Content" group="catalog"/>
    </xpath>
    <xpath expr="//t[@id='snippet_add_to_cart_hook']" position="replace">
        <t t-snippet="website_sale.s_add_to_cart" string="Add to Cart Button" t-thumbnail="/website/static/src/img/snippets_thumbs/s_add_to_cart.svg" t-grid-column-span="3"/>
    </xpath>
    <xpath expr="//t[@id='snippet_donation_hook']" position="replace">
        <t
            t-snippet="website_sale.s_donation"
            string="Donation"
            t-forbid-sanitize="form"
            group="contact_and_forms"
            label="Donation"
        />
    </xpath>
    <xpath expr="//t[@id='snippet_donation_inline_hook']" position="replace">
        <t
            t-snippet="website_sale.s_donation_inline"
            string="Donation"
            t-thumbnail="/website/static/src/img/snippets_thumbs/s_donation_button.svg"
            t-forbid-sanitize="form"
            t-grid-column-span="6"
        />
    </xpath>
    <xpath expr="//t[@t-set='shop_btn_href']" position="replace">
        <t t-set="shop_btn_href">/shop</t>
    </xpath>
</template>

</odoo>
