<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- This view should only be used from the product o2m because the required field product_tmpl_id has to be automatically set. -->
    <record id="view_product_image_form" model="ir.ui.view">
        <field name="name">product.image.view.form</field>
        <field name="model">product.image</field>
        <field name="arch" type="xml">
            <form string="Product Images">
                <div class="row o_website_sale_image_modal">
                    <div class="col-md-6 col-xl-5">
                        <label for="name" string="Image Name"/>
                        <h2><field name="name" placeholder="Image Name"/></h2>
                        <label for="video_url" string="Video URL"/><br/>
                        <field name="video_url"/><br/>
                    </div>
                    <div class="col-md-6 col-xl-7 text-center o_website_sale_image_modal_container">
                        <div class="row">
                            <div class="col">
                                <field name="image_1920" widget="image"/>
                            </div>
                            <div class="col" invisible="video_url in ['', False]">
                                <div class="o_video_container p-2">
                                    <span>Video Preview</span>
                                    <field name="video_url" class="mt-2" widget="video_preview"/>
                                    <h4 class="o_invalid_warning text-muted text-center" invisible="video_url">
                                        Please enter a valid Video URL.
                                    </h4>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </field>
    </record>

    <record id="product_image_view_kanban" model="ir.ui.view">
        <field name="name">product.image.view.kanban</field>
        <field name="model">product.image</field>
        <field name="arch" type="xml">
            <kanban string="Product Images" default_order="has_attribute_value desc, sequence, id">
                <field name="has_attribute_value"/>
                <field name="sequence" widget="handle"/>
                 <!-- Needed to create new `product.image` records with default values. (see: x2many_media_viewer.js) -->
                <field name="name"/>
                <field name="video_url" invisible="1"/>
                <!-- Needed in attribute_value_selector.js -->
                <field name="image_type"/>
                <field name="product_tmpl_id"/>
                <templates>
                    <t t-name="card" class="p-0 border-0">
                        <t
                            t-set="isApplicable"
                            t-value="(
                                !context.variant_image_ids
                                || context.variant_image_ids?.includes(record.id.raw_value)
                                || !record.has_attribute_value.raw_value
                            )"
                        />
                        <div t-attf-class="card flex-row h-100 border rounded-0 #{!isApplicable ? 'opacity-50' : ''}">
                            <div class="o_website_sale_image_list_card_image ratio ratio-1x1">
                                <field name="image_1920" widget="x2_many_image"/>
                            </div>

                            <field
                                name="attribute_value_ids"
                                class="overflow-y-auto p-2"
                                widget="many2many_tags_color_dot"
                                options="{'color_field': 'html_color', 'tag_limit': 11}"
                            />
                        </div>
                        <div t-att-class="!isApplicable ? 'opacity-50' : ''">
                            <field name="attribute_value_ids" widget="attribute_value_selector"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

</odoo>
