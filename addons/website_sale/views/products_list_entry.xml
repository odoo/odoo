<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- ==== "Zones" ====
     Areas that options/modules can xpath to inject their content.
     Zones are t-call inside `products_item` accordingly to the chosen
     design.
-->
<template id="products_item_zone_1" name="Products entry - Zone 1">
    <div class="oe_product_cart_zone_1 d-contents"/>
</template>


<!-- ==== Main template ==== -->
<template id="products_item" name="Products item">
    <form
        class="oe_product_cart d-flex"
        t-att-data-publish="product.website_published and 'on' or 'off'"
        role="article"
        t-att-aria-label="product.name"
        >

        <t t-if="context and 'shop'">
            <!-- URLs -->
            <t
                t-set="product_path"
                t-value="'%s/%s/%s' % (shop_path, slug(category), slug(product)) if category else '%s/%s' % (shop_path, slug(product))"
            />
            <t
                t-set="product_href"
                t-value="product_path + (product_query_string and '?' + product_query_string) + selected_attributes_hash"
            />
            <!-- Images -->
            <t t-set="image_type" t-value="product._get_suitable_image_size(ppr, td_product['x'], td_product['y'])"/>
            <t t-set="image_holder" t-value="product._get_image_holder()"/>

            <!-- Prices -->
            <t t-set="template_price_vals" t-value="get_product_prices(product)"/>
            <t t-if="template_price_vals['price_reduce'] or not website.prevent_zero_price_sale">
                <t t-set="product_price" t-value="template_price_vals['price_reduce']"></t>
            </t>
            <t t-if="'base_price' in template_price_vals and (template_price_vals['base_price'] &gt; template_price_vals['price_reduce']) and (template_price_vals['price_reduce'] or not website.prevent_zero_price_sale)">
                <t t-set="product_price_discounted" t-value="template_price_vals['base_price']"/>
            </t>
        </t>

        <div class="oe_product_image position-relative flex-grow-0 overflow-hidden">
            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()" t-nocache="The csrf token must always be up to date."/>
            <a
                t-att-href="product_href"
                class="oe_product_image_link d-block position-relative"
                contenteditable="false"
                t-att-title="product.name"
                >

                <t t-if="context and 'shop'">
                    <t t-set="image_holder" t-value="product._get_image_holder()"/>
                    <t t-set="image_type" t-value="product._get_suitable_image_size(ppr, td_product['x'], td_product['y'])"/>
                    <t t-set="product_variant_id" t-value="product._get_first_possible_variant_id()"/>
                    <t t-set="product_variant" t-value="request.env['product.product'].browse(product_variant_id) if product_variant_id else None"/>
                    <t t-set="all_images" t-value="product_variant._get_images() if product_variant else product._get_images()"/>
                    <t t-set="primary_image" t-value="all_images[0] if all_images else image_holder"/>
                    <t t-set="secondary_image" t-value="all_images[1] if len(all_images) > 1 else None"/>

                    <!-- Primary image -->
                    <span t-field="primary_image.image_1920"
                        t-options="{'widget': 'image', 'preview_image': image_type, 'class': 'oe_product_image_img h-100 w-100 position-absolute'}"
                        class="oe_product_image_img_wrapper o_product_image_primary d-flex h-100 justify-content-center align-items-center position-absolute"/>

                    <!-- Secondary image (shown on hover) -->
                    <span t-if="secondary_image"
                        t-field="secondary_image.image_1920"
                        t-options="{'widget': 'image', 'preview_image': image_type, 'class': 'oe_product_image_img_secondary h-100 w-100 position-absolute'}"
                        class="oe_product_image_img_wrapper oe_product_image_img_wrapper_hover o_product_image_secondary d-flex h-100 justify-content-center align-items-center position-absolute"/>
                </t>
                <t t-else="">
                    <span
                        role="img"
                        t-attf-alt="{{product.name}} image"
                        class="oe_product_image_img_wrapper d-flex h-100 justify-content-center align-items-center position-absolute"
                    >
                        <span class="oe_product_image_img h-100 w-100 position-absolute" t-attf-style="background-image: url({{product_image_href}});"/>
                    </span>
                </t>

                <t t-if="context and 'shop'">
                    <t t-set="bg_color" t-value="td_product['ribbon'].bg_color"/>
                    <t t-set="text_color" t-value="td_product['ribbon'].text_color"/>
                    <t t-set="bg_class" t-value="td_product['ribbon']._get_position_class()"/>
                    <span
                        t-attf-class="o_ribbon o_not_editable #{bg_class}"
                        t-attf-style="#{text_color and ('color: %s;' % text_color)} #{bg_color and 'background-color:' + bg_color}"
                        t-out="td_product['ribbon'].name or ''"
                    />
                </t>
            </a>
            <div
                class="oe_product_cart_zone_top_right position-absolute d-flex flex-column gap-1"
                t-if="not is_view_active('website_sale.products_list_view')">
                <t t-call="website_sale.products_item_zone_1">
                    <t t-set="wish_btn_classes" t-valuef="p-1 lh-1"/>
                    <t t-set="wish_btn_classes_active" t-valuef="p-1 lh-1 text-danger"/>
                </t>
            </div>

            <!-- <t
                t-else=""
                groups="website.group_website_designer"
                t-call="website_sale.products_item_zone_1">
            </t> -->
        </div>
        <div class="o_wsale_product_information d-flex flex-grow-1 flex-shrink-1">
            <div class="o_wsale_product_information_text">
                <h2 class="o_wsale_products_item_title h6 mb-2 text-break">
                    <a
                        class="text-decoration-none"
                        t-att-href="product_href"
                        t-att-content="product.name"
                        t-att-title="product.name"
                        t-field="product.name"
                    />
                    <a
                        t-if="not product.website_published"
                        role="button"
                        t-att-href="product_href"
                        class="btn btn-sm btn-danger"
                        title="This product is unpublished."
                    >
                        Unpublished
                    </a>
                </h2>
                <div
                    class="oe_subdescription_wrapper"
                    groups="website.group_website_designer">
                    <div
                        class="oe_subdescription mb-2 text-muted small"
                        contenteditable="false"
                    >
                        <div t-field="product.description_sale"/>
                    </div>
                </div>
            </div>
            <div class="o_wsale_product_sub d-flex justify-content-between gap-2">
                <div class="product_price" aria-label="Price information">
                    <t t-if="product_price">
                        <span t-if="product_price_before" t-out="product_price_before"/>
                        <span
                            aria-label="Sale price"
                            class="mb-0"
                            t-out="product_price"
                            t-options="{'widget': 'monetary', 'display_currency': website.currency_id}"
                        />
                        <t t-if="product_price_discounted">
                            <del
                                aria-label="Original price"
                                t-attf-class="text-muted me-1 mb-0"
                                style="white-space: nowrap;">
                                <em class="small" t-esc="product_price" t-options="{'widget': 'monetary', 'display_currency': website.currency_id}" />
                            </del>
                        </t>
                        <span t-if="product_price_after" class="fw-bold" t-out="product_price_after"/>
                    </t>
                </div>
                <div class="o_wsale_product_btn d-flex gap-2">
                    <div class="o_wsale_product_btn_cta" groups="website.group_website_designer">
                        <t t-if="context and 'shop'">
                            <t t-set="product_variant_id" t-value="product._get_first_possible_variant_id()"/>
                            <input name="product_id" t-att-value="product_variant_id" type="hidden"/>
                            <input name="product_template_id" t-att-value="product.id" type="hidden"/>
                            <input name="product_type" t-att-value="product.type" type="hidden"/>
                            <t t-if="product_variant_id and template_price_vals['price_reduce'] or not website.prevent_zero_price_sale">
                                <a
                                    t-if="product._website_show_quick_add()"
                                    href="#"
                                    role="button"
                                    class="btn a-submit"
                                    aria-label="Shopping cart"
                                    title="Shopping cart"
                                    t-att-data-show-quantity="is_view_active('website_sale.product_quantity')"
                                >
                                    <i class="fa fa-shopping-cart" role="img"/>
                                    <span class="o_label small ms-2">Add to Cart</span>
                                </a>
                            </t>
                        </t>
                        <t t-else="">
                            <a
                                t-att-href="product_href"
                                t-att-title="product.name"
                                class="btn"
                                role="button">
                                View
                            </a>
                        </t>
                    </div>
                    <t
                        t-if="is_view_active('website_sale.products_list_view')"
                        t-call="website_sale.products_item_zone_1">
                    </t>

                    <!-- <t
                        t-else=""
                        groups="website.group_website_designer"
                        t-call="website_sale.products_item_zone_1">
                    </t> -->
                </div>
            </div>
        </div>
    </form>
</template>

</odoo>