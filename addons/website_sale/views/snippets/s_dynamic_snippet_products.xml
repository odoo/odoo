<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Snippet -->
    <template id="s_dynamic_snippet_products" name="Products">
        <t t-call="website.s_dynamic_snippet_template">
            <!--
                TODO: `.oe_website_sale` is used as a selector in `website_sale_tracking.js`. This
                is a temporary solution to load the tracking utilities and will be removed once
                tracking utilities will be fully integrated into a service.
            -->
            <t t-set="snippet_classes" t-value="'oe_website_sale %s' % snippet_extra_classes"/>
            <t t-set="main_page_url" t-value="'/shop'"/>
            <t t-out="0"/>
        </t>
    </template>
    <!-- Multi record snippets -->
    <template id="s_dynamic_snippet_products_add_to_cart" name="Products Add To Cart">
        <t t-set="snippet_name" t-value="'s_dynamic_snippet_products_add_to_cart'"/>
        <t t-set="snippet_extra_classes" t-value="'s_product_product_add_to_cart'"/>
        <t t-call="website_sale.s_dynamic_snippet_products">
            <t t-call="website_sale.s_dynamic_snippet_products_add_to_cart_preview_data"/>
        </t>
    </template>
