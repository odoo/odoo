<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_floating_blocks" name="Floating Cards">
    <section class="s_floating_blocks pt32 pb32 o_cc o_cc2">
        <div class="container">
            <div class="d-flex flex-column gap-5">
                <span class="s_floating_blocks_wrapper s_floating_blocks_wrapper_shadow d-contents rounded-3">
                    <section
                        data-name="Card"
                        class="o_block position-sticky overflow-hidden py-5 px-4 px-lg-5 o_cc o_cc5 oe_img_bg o_bg_img_center o_background_video"
                        data-bg-video-src="https://player.vimeo.com/video/329369394?autoplay=1&amp;muted=1&amp;autopause=0&amp;controls=0&amp;loop=1"
                        style="background-image:url(https://i.vimeocdn.com/video/774173730-b7a179626fb9429551c395a423571c56515633a3cdbf18261054f281a022b19d-d?mw=80&amp;q=85)"
                        >
                        <div class="o_we_bg_filter bg-black-25"/>
                        <div class="row">
                            <div class="col-12">
                                <p class="lead">New collection</p>
                                <h2 class="display-2">Your New <br class="d-none d-lg-inline"/>Workspace!</h2>
                            </div>
                            <div class="col-12 pt48">
                                <a href="" class="btn btn-lg btn-secondary">Shop Now</a>
                            </div>
                        </div>
                    </section>
                    <section
                        data-name="Card"
                        class="o_block position-sticky parallax overflow-hidden o_cc o_cc1 py-5 px-4 px-lg-5"
                        data-scroll-background-ratio="3"
                        >
                        <span
                            class="s_parallax_bg oe_img_bg o_bg_img_center"
                            style="background-image: url('/web/image/website_sale.s_floating_blocks_1'); background-position: top center"
                        />
                        <div class="row">
                            <div class="col-12">
                                <p class="lead">New collection</p>
                                <h2 class="display-2">A fast <br class="d-none d-lg-inline"/>bicycle</h2>
                            </div>
                            <div class="col-12 pt48">
                                <a href="" class="btn btn-lg btn-secondary">Shop Now</a>
                            </div>
                        </div>
                    </section>
                    <section
                        data-name="Card"
                        class="o_block position-sticky parallax overflow-hidden o_cc o_cc5 py-5 px-4 px-lg-5"
                        data-scroll-background-ratio="1.5"
                        >
                        <span
                            class="s_parallax_bg oe_img_bg"
                            style="background-image: url('/web/image/website_sale.s_floating_blocks_2'); background-position: 50% 50%;"
                        />
                        <div class="row">
                            <div class="col-12">
                                <p class="lead">New collection</p>
                                <h2 class="display-2">A great <br class="d-none d-lg-inline"/>entry</h2>
                            </div>
                            <div class="col-12 pt48">
                                <a href="" class="btn btn-lg btn-secondary">Shop Now</a>
                            </div>
                        </div>
                    </section>
                </span>
            </div>
        </div>
    </section>
</template>

<template id="s_floating_blocks_options" inherit_id="website.snippet_options">
    <!-- Remove the default height widget for both the snippet and its cards -->
    <xpath expr="//t[@t-set='ScrollButton_exclude']" position="attributes">
        <attribute name="t-valuef" add=".s_floating_blocks, .s_floating_blocks .o_block" separator=", "/>
    </xpath>

    <!-- Snippet options: .s_floating_blocks -->
    <xpath expr="." position="inside">
        <div data-js="FloatingBlocks" data-selector=".s_floating_blocks">
            <we-row string="Cards">
                <we-button title="Add a new Card" data-add-card="" data-no-preview="true" class="o_we_bg_success">Add New</we-button>
            </we-row>
        </div>

        <!-- Apply global cards options to ".s_floating_blocks_wrapper".
             Each Card will inherit these values in CSS -->
        <div data-selector=".s_floating_blocks" data-target=".s_floating_blocks_wrapper">
            <we-divider/>
            <we-title>Cards Design</we-title>
            <we-range string="Height"
                class="o_we_sublevel_1"
                title="Relative to the screen size"
                data-select-style="0"
                data-css-property="--floating-boxes-box-ratio-adjust"
                data-min="0"
                data-max="1"
                data-step="0.05"/>

            <we-range string="Roundness"
                class="o_we_sublevel_1"
                title="Applies to all cards"
                data-select-class="rounded-0|rounded-1|rounded-2|rounded-3|rounded-4|rounded-5"/>

            <we-checkbox string="Shadows"
                class="o_we_sublevel_1"
                data-select-class="|s_floating_blocks_wrapper_shadow"
                title="Applies to all cards"/>
        </div>
    </xpath>

    <!-- Specific Card Options: .s_floating_blocks .o_block -->
    <xpath expr="//div[@data-js='GridColumns']" position="after">
        <!-- Bind custom JS -->
        <div data-js="FloatingBlocksBlock" data-selector=".s_floating_blocks .o_block"/>

        <!-- Enable border control -->
        <div data-js="Box" data-selector=".s_floating_blocks .o_block">
            <t t-call="website.snippet_options_border_widgets">
                <t t-set="no_border_radius" t-value="true"/>
            </t>
        </div>
    </xpath>
</template>


<!-- Assets -->
<record id="website_sale.s_floating_blocks_000_scss" model="ir.asset">
    <field name="name">Floating Blocks 000 SCSS</field>
    <field name="bundle">web.assets_frontend</field>
    <field name="path">website_sale/static/src/snippets/s_floating_blocks/000.scss</field>
</record>

<record id="website_sale.s_floating_blocks_000_js" model="ir.asset">
    <field name="name">Floating Blocks 000 JS</field>
    <field name="bundle">web.assets_frontend</field>
    <field name="path">website_sale/static/src/snippets/s_floating_blocks/000.js</field>
</record>

</odoo>
