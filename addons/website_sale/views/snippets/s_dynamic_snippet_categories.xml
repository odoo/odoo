<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="website_sale.s_dynamic_snippet_template" inherit_id="website.s_dynamic_snippet_template" primary="True">
        <xpath expr="//section[hasclass('s_dynamic_snippet_title')]/*" position="replace">
            <div class="container">
                <h2 class="h4">Crafting Beautiful Spaces</h2>
                <p>Designing elegant, inviting environments that inspire and delight.</p>
            </div>
        </xpath>
    </template>
    <template id="s_dynamic_snippet_category" name="Category List">
        <t t-call="website_sale.s_dynamic_snippet_template">
            <t t-set="snippet_name" t-value="'s_dynamic_snippet_category'"/>
            <!--
                TODO: `.oe_website_sale` is used as a selector in `website_sale_tracking.js`. This
                is a temporary solution to load the tracking utilities and will be removed once
                tracking utilities will be fully integrated into a service.
            -->
            <t t-set="snippet_classes" t-value="'oe_website_sale s_dynamic_category_clickable_items'"/>
            <t t-set="main_page_url" t-value="'/shop'"/>
            <t t-call="website_sale.s_dynamic_snippet_category_preview_data"/>
        </t>
    </template>
</odoo>
