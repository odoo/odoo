<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="s_dynamic_category" name="Category List">
        <section
            class="s_dynamic_category pt32 pb32"
            data-snippet="s_dynamic_category"
            data-all-products="true"
        >
            <div class="container">
                <section class="oe_unremovable oe_unmovable pb-1">
                    <h4>Crafting Beautiful Spaces</h4>
                </section>
                <div class="s_category_container d-grid gap-3" contenteditable="false">
                    <div class="all_products rounded position-relative oe_unremovable">
                        <img
                            src="/website_sale/static/src/img/all_products.jpeg"
                            alt="All Products"
                            class="s_category_image img-fluid w-100 h-100 position-absolute"
                        />
                        <div class="s_category_overlay p-3 bg-black-25 position-relative w-100 h-100 d-flex flex-column oe_unremovable oe_unmovable">
                            <h4 class="text-light all_products_heading">All Collections</h4>
                            <a
                                role="button"
                                href="/shop"
                                class="btn btn-primary align-self-start o_not-animable oe_unremovable"
                            >
                                Explore Now
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </template>
</odoo>
