<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="s_dynamic_category" name="Category List">
        <section
            class="s_dynamic_category pt32 pb32"
            data-snippet="s_dynamic_category"
            data-all-products="true"
        >
            <div class="container">
                <div>
                    <section class="s_dynamic_snippet_title oe_unremovable oe_unmovable" data-name="Intro text" role="heading">
                        <div class="container">
                            <h2 class="h4">Crafting Beautiful Spaces</h2>
                            <p>Designing elegant, inviting environments that inspire and delight.</p>
                        </div>
                    </section>
                    <div class="s_category_container d-grid gap-3" contenteditable="false">
                        <div class="all_products rounded position-relative bg-black overflow-hidden oe_unremovable" role="article">
                            <img
                                src="/website_sale/static/src/img/all_products.jpg"
                                alt="All Products"
                                class="s_category_image img-fluid position-absolute w-100 h-100 object-fit-cover"
                            />
                            <div class="s_category_overlay p-3 bg-black-25 position-relative w-100 h-100 d-flex flex-column oe_unremovable oe_unmovable">
                                <h3 class="text-light all_products_heading h4">All Collections</h3>
                                <a
                                    role="button"
                                    href="/shop"
                                    class="btn btn-primary align-self-start o_not-animable oe_unremovable"
                                >
                                    Explore Now
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </template>
</odoo>
