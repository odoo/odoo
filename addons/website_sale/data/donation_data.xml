<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="product_category_donations" model="product.category">
            <field name="name">Donations</field>
        </record>

        <record id="product_donation" model="product.template">
            <field name="name">Donation</field>
            <field name="type">service</field>
            <field name="categ_id" ref="product_category_donations"/>
            <field name="list_price">1.0</field>
            <field name="sale_ok" eval="True"/>
            <field name="purchase_ok" eval="False"/>
            <field name="is_published" eval="True"/>
        </record>

    </data>
</odoo>
