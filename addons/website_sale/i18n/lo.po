#. module: website_sale
#: model_terms:ir.ui.view,arch_db:website_sale.empty_cart_svg
msgid ""
".heartBeat {\n"
"                    animation: heartBeat 1.3s ease-in-out forwards;\n"
"                    animation-delay: 0.75s;\n"
"                    transform-origin: 80.5px 28.5px;\n"
"                }\n"
"                .tilt {\n"
"                    animation: tilt 1s ease forwards;\n"
"                    animation-delay: 0.75s;\n"
"                    transform-origin: bottom left;\n"
"                }\n"
"                @keyframes heartBeat {\n"
"                    0% {\n"
"                    transform: scale(1);\n"
"                    }\n"
"\n"
"                    14% {\n"
"                        transform: scale(1.2);\n"
"                    }\n"
"\n"
"                    28% {\n"
"                        transform: scale(1);\n"
"                    }\n"
"\n"
"                    42% {\n"
"                        transform: scale(1.2);\n"
"                    }\n"
"\n"
"                    70% {\n"
"                        transform: scale(1);\n"
"                    }\n"
"                }\n"
"                @keyframes tilt {\n"
"                    0% {\n"
"                        transform: rotate(0deg);\n"
"                    }\n"
"                    50% {\n"
"                        transform: rotate(-7deg);\n"
"                    }\n"
"                    100% {\n"
"                        transform: rotate(0deg);\n"
"                    }\n"
"                }"
msgstr ""
".heartBeat { (ຈັງຫວະຫົວໃຈ)\n"
"    animation: heartBeat 1.3s ease-in-out forwards; (ການເຄື່ອນໄຫວ: ຈັງຫວະຫົວໃຈ "
"1.3 ວິນາທີ ແບບເລີ່ມຊ້າແລະຈົບຊ້າ ໄປທາງໜ້າ)\n"
"    animation-delay: 0.75s; (ການໜ່ວງເວລາເຄື່ອນໄຫວ: 0.75 ວິນາທີ)\n"
"    transform-origin: 80.5px 28.5px; (ຈຸດປ່ຽນຮູບ: 80.5px 28.5px)\n"
"}\n"
".tilt { (ອຽງ)\n"
"    animation: tilt 1s ease forwards; (ການເຄື່ອນໄຫວ: ອຽງ 1 ວິນາທີ ແບບຜ່ອນ ໄປທາງໜ້າ)"
"\n"
"    animation-delay: 0.75s; (ການໜ່ວງເວລາເຄື່ອນໄຫວ: 0.75 ວິນາທີ)\n"
"    transform-origin: bottom left; (ຈຸດປ່ຽນຮູບ: ລຸ່ມ ຊ້າຍ)\n"
"}\n"
"@keyframes heartBeat { (ກຳນົດຈັງຫວະການເຄື່ອນໄຫວ ຈັງຫວະຫົວໃຈ)\n"
"    0% {\n"
"        transform: scale(1); (ປ່ຽນຮູບ: ຂະໜາດ 1)\n"
"    }\n"
"    14% {\n"
"        transform: scale(1.2); (ປ່ຽນຮູບ: ຂະໜາດ 1.2)\n"
"    }\n"
"    28% {\n"
"        transform: scale(1); (ປ່ຽນຮູບ: ຂະໜາດ 1)\n"
"    }\n"
"    42% {\n"
"        transform: scale(1.2); (ປ່ຽນຮູບ: ຂະໜາດ 1.2)\n"
"    }\n"
"    70% {\n"
"        transform: scale(1); (ປ່ຽນຮູບ: ຂະໜາດ 1)\n"
"    }\n"
"}\n"
"@keyframes tilt { (ກຳນົດຈັງຫວະການເຄື່ອນໄຫວ ອຽງ)\n"
"    0% {\n"
"        transform: rotate(0deg); (ປ່ຽນຮູບ: ໝູນ 0 ອົງສາ)\n"
"    }\n"
"    50% {\n"
"        transform: rotate(-7deg); (ປ່ຽນຮູບ: ໝູນ -7 ອົງສາ)\n"
"    }\n"
"    100% {\n"
"        transform: rotate(0deg); (ປ່ຽນຮູບ: ໝູນ 0 ອົງສາ)\n"
"    }\n"
"}"

