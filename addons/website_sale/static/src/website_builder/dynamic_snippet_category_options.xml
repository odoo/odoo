<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t
        t-name="website_sale.DynamicSnippetCategoryOptions"
        name="Category List"
        t-inherit="website.DynamicSnippetOption"
    >
        <BuilderRow id="this.template_opt_row" position="replace"/>
        <BuilderRow id="this.number_of_records_opt_row" position="replace"/>
        <BuilderRow id="this.filter_opt_row" position="replace">
            <BuilderRow label.translate="Columns">
                <BuilderRange action="'dynamicSnippetInnerArg'" actionParam="{ arg: 'wrapper_data', key: 'cols_count' }" min="2" max="5"/>
            </BuilderRow>
            <BuilderRow label.translate="Spacing">
                <BuilderRange action="'dynamicSnippetInnerArg'" actionParam="{ arg: 'wrapper_data', key: 'gap' }" min="0" max="5"/>
            </BuilderRow>
            <BuilderRow label.translate="Size">
                <BuilderSelect action="'composite'" actionParam="[
                    { action: 'dynamicSnippetInnerArg', actionParam: { arg: 'content_data', key: 'size' } },
                    { action: 'dynamicSnippetInnerArg', actionParam: { arg: 'wrapper_data', key: 'size' } },
                ]">
                    <BuilderSelectItem actionValue="'small'">Small</BuilderSelectItem>
                    <BuilderSelectItem actionValue="'medium'">
                        Medium
                    </BuilderSelectItem>
                    <BuilderSelectItem actionValue="'large'">Large</BuilderSelectItem>
                </BuilderSelect>
            </BuilderRow>
            <BuilderRow label.translate="Alignment">
                <BuilderButtonGroup action="'dynamicSnippetInnerArg'" actionParam="{ arg: 'content_data', key: 'alignment' }">
                    <BuilderButton actionValue="'left'">
                        <i class="fa fa-fw fa-align-left"/>
                    </BuilderButton>
                    <BuilderButton actionValue="'center'">
                        <i class="fa fa-fw fa-align-center"/>
                    </BuilderButton>
                    <BuilderButton actionValue="'right'">
                        <i class="fa fa-fw fa-align-right"/>
                    </BuilderButton>
                </BuilderButtonGroup>
            </BuilderRow>
            <BuilderRow label.translate="Filters">
                <BuilderSelect action="'composite'" actionParam="[
                    { action: 'dynamicSnippetInnerArg', actionParam: { arg: 'content_data', key: 'parent_category_id' } },
                    { action: 'dynamicSnippetInnerArg', actionParam: { arg: 'search_extra', key: 'parent_id' } },
                ]">
                    <BuilderSelectItem
                        actionValue=""
                        title.translate="All Categories"
                    >
                        All Categories
                    </BuilderSelectItem>
                    <t
                        t-foreach="this.categories"
                        t-as="category"
                        t-key="category.id"
                    >
                        <BuilderSelectItem
                            actionValue="category.id"
                            label="category.name"
                            t-out="category.name"
                        />
                    </t>
                </BuilderSelect>
            </BuilderRow>
            <BuilderRow
                t-if="this.dynamicOptionParams.domState.parentCategoryId"
                label.translate="Parent Category"
            >
                <BuilderCheckbox action="'dynamicSnippetInnerArg'" actionParam="{ arg: 'content_data', key: 'include_parent' }" actionValue="true"/>
            </BuilderRow>
            <BuilderRow label.translate="Clickable items">
                <BuilderCheckbox
                    id="'clickable_items_opt'"
                    action="'toggleClickable'"
                    classAction="'s_dynamic_category_clickable_items'"
                />
            </BuilderRow>
            <BuilderRow
                t-if="this.isActiveItem('clickable_items_opt')"
                label.translate="Arrows"
                level="1"
            >
                <BuilderCheckbox
                    classAction="'s_dynamic_category_no_arrows'"
                    inverseAction="true"
                />
            </BuilderRow>
            <BuilderRow
                t-if="this.isActiveItem('clickable_items_opt')"
                label.translate="Darken overlay"
                level="1"
            >
                <BuilderCheckbox
                    classAction="'s_dynamic_category_no_overlay'"
                    inverseAction="true"
                />
            </BuilderRow>
            <BuilderRow label.translate="Button" t-if="!this.isActiveItem('clickable_items_opt')">
                <BuilderTextInput action="'dynamicSnippetInnerArg'" actionParam="{ arg: 'content_data', key: 'button_text' }"/>
            </BuilderRow>
            <BuilderContext>
                <hr class="mx-3"/>
                <div class="h6 px-3 text-reset">Blocks Design</div>
                <div class="mb-2 px-3 opacity-75 small">Global options for all inner blocks.</div>
                <BuilderRow label.translate="Roundness">
                    <BuilderRange action="'dynamicSnippetInnerArg'" actionParam="{ arg: 'wrapper_data', key: 'rounded' }" min="0" max="5"/>
                </BuilderRow>
            </BuilderContext>
        </BuilderRow>
    </t>
    <t t-name="website_sale.dynamicSnippetCategoryItemOptions" name="Category">
        <BuilderRow label.translate="Media">
            <BuilderButton
                label.translate="Replace"
                className="'w-100'"
                type="'success'"
                action="'setCategoryImage'"
                preview="false"
            />
        </BuilderRow>
    </t>
</templates>
