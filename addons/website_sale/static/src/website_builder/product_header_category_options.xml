<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="website_sale.ProductHeaderCategoryOption">
        <BuilderContext applyTo="'#o_wsale_products_header'">
            <BuilderRow label.translate="Show Title">
                <BuilderCheckbox
                    classAction="'o_wsale_products_header_show_category_title'"
                />
            </BuilderRow>
            <BuilderRow label.translate="Show Description">
                <BuilderCheckbox
                    classAction="'o_wsale_products_header_show_category_description'"
                />
            </BuilderRow>
            <BuilderRow label.translate="Center Content">
                <BuilderCheckbox
                    classAction="'o_wsale_products_header_category_center_content'"
                />
            </BuilderRow>
        </BuilderContext>
    </t>
</templates>
