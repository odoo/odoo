<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="website_sale.s_floating_blocks.alert.no_cards">
        <div role="dialog" class="alert alert-info mx-auto w-lg-75 w-xl-50 text-center">
            You need at least two cards to perform the effect<br/>
            Add new cards using the sidebar
        </div>
    </t>

    <t t-name="website_sale.s_floating_blocks.new_card">
        <section data-name="Card" class="o_block position-sticky o_cc o_cc1 py-5 px-4 px-lg-5 opacity-0 transition-base">
            <div class="row">
                <div class="col-12">
                    <p class="lead">New collection</p>
                    <h2 class="display-2">A fast <br class="d-none d-lg-inline"/>bicycle</h2>
                </div>
                <div class="col-12 pt48">
                    <a href="" class="btn btn-lg btn-secondary">Shop Now</a>
                </div>
            </div>
        </section>
    </t>
</templates>
