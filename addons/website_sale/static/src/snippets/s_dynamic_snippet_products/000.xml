<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- GRID LAYOUT -->
    <t t-name="website_sale.s_dynamic_snippet.grid.layout">
        <div
            class="s_dynamic_snippet_grid_container py-3"
            t-att-data-grid-columns="gridColumns"
            t-att-data-mobile-columns="mobileColumns"
            t-att-style="'--ds-grid-gap: ' + gridGap"
        >
            <t t-foreach="data" t-as="record" t-key="record_index">
                <t t-out="record"/>
            </t>
        </div>
    </t>
</templates>
