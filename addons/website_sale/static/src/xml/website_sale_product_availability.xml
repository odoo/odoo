<?xml version="1.0" encoding="UTF-8"?>

<templates>
    <t t-name="website_sale.product_availability">
        <div
            t-if="this.is_storable and !this.prevent_sale"
            id="product_stock_availability"
        >
            <div
                t-if="this.free_qty lte 0 and !this.cart_qty"
                t-attf-class="availability_message_#{this.product_template_id} d-flex flex-column gap-2 mb-4"
            >
                <div id="out_of_stock_message" class="d-flex flex-column gap-1 align-items-start">
                    <t t-if="!this.allow_out_of_stock_order">
                        <div class="badge text-bg-danger">
                            <i class="fa fa-circle me-2 text-danger"/>Out of Stock
                        </div>
                    </t>
                    <t t-if="this.has_out_of_stock_message" t-out="this.out_of_stock_message"/>
                </div>
            </div>
            <div
                id="threshold_message"
                t-elif="this.show_availability and this.free_qty lte this.available_threshold"
                t-attf-class="availability_message_#{this.product_template_id} my-3 badge text-bg-warning"
            >
                <i class="fa fa-circle text-warning me-2" role="presentation"/>
                <t t-out="this.formatQuantity(this.free_qty)"/> <t t-out="this.uom_name" /> in stock
                <span
                    id="already_in_cart_message"
                    t-if="!this.allow_out_of_stock_order and this.show_availability and this.cart_qty"
                    t-attf-class="availability_message_#{this.product_template_id}"
                >
                    <t t-if="!this.free_qty">
                        You already added all the available product in your cart
                    </t>
                    <t t-else="">
                        (<t t-out="this.cart_qty" /> in your cart)
                    </t>
                </span>
            </div>
        </div>
    </t>
</templates>
