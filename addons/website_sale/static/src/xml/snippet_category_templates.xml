<?xml version="1.0" encoding="utf-8"?>

<templates xml:space="preserve">
    <t t-name="website_sale.dynamic_filter_template_categories">
        <t t-foreach="data" t-as="category" t-key="category.id">
            <div
                class="category_item rounded position-relative oe_unremovable oe_unmovable"
                t-att-data-category-id="category.id"
                t-attf-style="grid-row: span {{size}};"
                contenteditable="false"
            >
                <img
                    loading="lazy"
                    t-attf-src="/web/image/product.public.category/{{category.id}}/cover_image"
                    alt="Category Image"
                    class="s_category_image img-fluid position-absolute w-100 h-100"
                />
                <div t-attf-class="s_category_overlay p-3 bg-black-25 position-relative w-100 h-100 d-flex flex-column justify-content-between {{alignmentClass}}">
                    <h4 class="text-light" t-out="category.name"/>
                    <a
                        role="button"
                        t-attf-href="/shop/category/{{category.id}}"
                        class="btn btn-primary align-self-start oe_unremovable"
                        t-out="buttonText"
                    />
                </div>
            </div>
        </t>
    </t>
</templates>
