<?xml version="1.0" encoding="UTF-8"?>
<templates>

    <t t-name="website_sale.CartLine">
        <div class="o_cart_product d-flex gap-3 pb-4">
            <div class="o_cart_product_image">
                <!--
                    Unsellable lines can have unpublished products, but portal users have no
                    access to unpublished product images. To ensure product images are
                    always shown for unsellable lines, we use the raw image data as src
                    (which doesn't require access, unlike the image URL).
                -->
                <t t-call="website_sale.CartLineProductLink">
                    <img
                        t-att-src="(
                            this.props.line.image_uri
                            || `/web/image/product.product/${this.props.line.product_id}/image_128`
                        )"
                        class="img border rounded"
                        t-att-alt="this.props.line.name_short"
                    />
                </t>
            </div>
            <div class="d-flex flex-column flex-grow-1 gap-3 min-w-0">
                <div class="d-flex gap-3">
                    <div class="flex-grow-1 text-wrap w-100">
                        <div class="d-flex justify-content-between">
                            <div class="d-md-flex flex-md-wrap column-gap-md-1 align-items-md-center">
                                <t t-call="website_sale.CartLineProductLink">
                                    <h6
                                        t-out="this.props.line.header_name"
                                        class="text-wrap mb-1"
                                    />
                                </t>
                                <span
                                    t-if="this.props.line.combination_name"
                                    class="d-none d-md-inline h6 text-muted mb-1"
                                >
                                    -
                                </span>
                                <div
                                    t-if="this.props.line.combination_name || this.props.line.has_multiple_uoms"
                                    class="d-inline-flex flex-wrap column-gap-2 row-gap-1 align-items-center my-1 my-md-0 w-100 w-md-auto"
                                >
                                    <span
                                        t-if="this.props.line.combination_name"
                                        class="h6 text-muted mb-1"
                                        t-out="this.props.line.combination_name"
                                    />
                                    <span
                                        t-if="this.props.line.has_multiple_uoms"
                                        class="badge bg-light mb-1"
                                        t-out="this.props.line.uom_name"
                                    />
                                </div>
                            </div>
                            <div
                                t-att-class="!this.props.line.is_combo ? 'd-block d-md-none' : ''"
                            >
                                <t t-call="website_sale.CartLinesPrice"/>
                            </div>
                        </div>
                        <!-- This div displays all the lines following the first one on the description of the sale
                            order line, with a muted style. For typical products this content will be the product
                            description_sale. -->
                        <div
                            t-if="this.props.line.description_lines.length > 0"
                            name="cart_lines_description"
                            class="text-muted small"
                        >
                            <t
                                t-foreach="this.props.line.description_lines"
                                t-as="descriptionLine"
                                t-key="descriptionLine"
                            >
                                <span
                                    t-if="descriptionLine"
                                    class="d-block"
                                    t-out="descriptionLine"
                                />
                            </t>
                        </div>
                        <ul t-if="this.props.line.is_combo" class="list-group">
                            <t
                                t-foreach="this.props.line.combo_item_lines"
                                t-as="comboItemLine"
                                t-key="comboItemLine.id"
                            >
                                <t t-call="website_sale.CartComboItemLine"/>
                            </t>
                        </ul>
                        <div
                            name="o_wsale_cart_line_button_container"
                            t-attf-class="d-none d-md-flex align-items-center gap-2 mt-2 {{ this.props.line.is_combo ? 'justify-content-between' : ''}}"
                        >
                            <button
                                class="js_delete_product btn btn-link btn-sm p-0"
                                t-out="this.props.templateData.removeButtonText"
                                aria-label="Remove from cart"
                                t-on-click="(event) => this.updateQuantity(0)"
                            />
                            <t t-if="this.props.line.is_sellable and this.props.isWishlistViewActive">
                                <span class="text-300">|</span>
                                <button
                                    class="btn btn-link btn-sm p-0"
                                    t-out="this.props.templateData.wishlistButtonText"
                                    aria-label="Save for later"
                                    title="Save for later"
                                    t-on-click="() => this.addToWishlist()"
                                />
                            </t>
                            <div t-if="this.props.line.is_combo" class="d-none d-md-block ms-auto">
                                <t t-call="website_sale.CartLinesQuantity"/>
                            </div>
                        </div>
                    </div>
                    <div t-if="!this.props.line.is_combo" class="d-none d-md-block">
                        <t t-call="website_sale.CartLinesPrice"/>
                        <div class="d-none d-md-block mt-2">
                            <t t-call="website_sale.CartLinesQuantity"/>
                        </div>
                    </div>
                </div>
                <div
                    name="o_wsale_cart_line_button_container_mobile"
                    class="d-flex d-md-none"
                >
                    <div class="d-flex d-md-none align-items-center me-auto">
                        <t t-call="website_sale.CartLinesQuantity" isMobile="True"/>
                    </div>
                    <button
                        t-if="this.props.line.is_sellable and this.props.isWishlistViewActive"
                        class="btn btn-link d-inline-block d-md-none px-2"
                        title="Wishlist"
                        t-on-click="() => this.addToWishlist()"
                        aria-label="Wishlist"
                    >
                        <i class="fa fa-fw fa-heart-o"/>
                    </button>
                    <button
                        class="js_delete_product btn btn-link d-inline-block d-md-none px-2"
                        title="Remove"
                        t-on-click="() => this.updateQuantity(0)"
                        aria-label="Remove"
                    >
                        <i class="fa fa-fw fa-trash-o"/>
                    </button>
                </div>
            </div>
        </div>
    </t>

    <t t-name="website_sale.CartLinesPrice">
        <h6
            class="d-flex flex-column flex-md-row align-items-end align-items-md-start justify-content-md-end mb-1"
            name="website_sale_cart_line_price"
        >
            <del
                t-if="this.props.line.should_show_strikethrough_price"
                class="me-md-2 text-muted text-nowrap opacity-50"
                t-out="this.env.formatPrice(this.props.line.displayed_unit_price * this.props.line.product_uom_qty)"
            />
            <span t-out="this.env.formatPrice(this.props.line.product_price)" style="white-space: nowrap;"/>
        </h6>
        <div
            t-if="this.props.line.is_sellable and this.props.isUomFeatureEnabled and this.props.line.base_unit_price"
            class="cart_product_base_unit_price d-block text-muted text-end"
        >
            <small class="o_product_price_unit text-muted d-block">
                (<span t-out="this.env.formatPrice(this.props.line.base_unit_price)"/>
                / <span class="oe_custom_base_unit" t-out="this.props.line.base_unit_name"/>)
            </small>
        </div>
    </t>

    <t t-name="website_sale.CartComboItemLine">
        <a
            class="list-group-item"
            t-att-href="comboItemLine.is_sellable and comboItemLine.website_published ? comboItemLine.website_url : '#'"
            t-att-class="comboItemLine.is_sellable and comboItemLine.website_published ? 'list-group-item-action' : 'cursor-default text-decoration-none'"
        >
            <h6 class="d-inline small">
                <span t-out="comboItemLine.displayed_quantity"/>
                x
                <span t-out="comboItemLine.name_short"/>
            </h6>
            <div t-if="comboItemLine.description_lines" class="small text-muted">
                <t t-foreach="comboItemLine.description_lines" t-as="description_line" t-key="description_line">
                    <span
                        t-if="description_line"
                        class="d-block"
                        t-out="description_line"
                    />
                </t>
            </div>
        </a>
    </t>

    <t t-name="website_sale.CartLinesQuantity">
        <t t-set="showQuantitySelector" t-value="this.props.isQuantityViewActive"/>
        <div
            t-attf-class="css_quantity input-group justify-content-end h-100"
            t-attf-name="{{ isMobile ? 'website_sale_cart_line_quantity_mobile' : 'website_sale_cart_line_quantity' }}"
        >
            <t t-if="showQuantitySelector and this.props.line.is_sellable">
                <button
                    name="remove_quantity"
                    class="btn btn-link d-inline-block border border-end-0"
                    aria-label="Remove one"
                    title="Remove one"
                    t-on-click="() => this.updateQuantity(this.state.quantity - 1)"
                >
                    <i
                        class="oi oi-minus position-relative z-1"
                        t-out="isMobile ? this.props.templateData.qtyMinusButtonTextMobile : this.props.templateData.qtyMinusButtonText"
                    />
                </button>
                <input
                    type="text"
                    class="js_quantity quantity form-control border border-start-0 border-end-0"
                    t-att-value="this.state.quantity"
                    t-on-input="(event) => this.updateQuantity(event.target.value)"
                    t-attf-name="cart-quantity-{{this.props.line.id}}{{ isMobile ? '-mobile' : ''}}"
                    aria-label="Quantity"
                />
                <t
                    t-if="this.props.line.alert_message"
                    t-call="website_sale.AlertInline"
                    message="this.props.line.alert_message"
                    level="this.props.line.alert_level"
                />
                <button
                    t-else=""
                    name="add_quantity"
                    class="btn btn-link d-inline-block border border-start-0"
                    aria-label="Add one"
                    title="Add one"
                    t-on-click="() => this.updateQuantity(this.state.quantity + 1)"
                >
                    <i
                        class="oi oi-plus position-relative z-1"
                        t-out="isMobile ? this.props.templateData.qtyPlusButtonTextMobile : this.props.templateData.qtyPlusButtonText"
                    />
                </button>
            </t>
            <t t-else="">
                <t
                    t-if="this.props.line.alert_message"
                    t-call="website_sale.AlertInline"
                    message="this.props.line.alert_message"
                    level="this.props.line.alert_level"
                    classes="'d-none d-md-block pe-1 align-self-center'"
                />
                <input
                    type="text"
                    class="js_quantity form-control quantity p-0 shadow-none w-auto border-0"
                    t-att-value="this.state.quantity"
                    t-attf-name="cart-quantity-{{this.props.line.id}}{{ isMobile ? '-mobile' : ''}}"
                    readonly="True"
                    aria-label="Quantity"
                />
                <t
                    t-if="this.props.line.alert_message"
                    t-call="website_sale.AlertInline"
                    message="this.props.line.alert_message"
                    level="this.props.line.alert_level"
                    classes="'d-md-none ps-1 align-self-center'"
                />
            </t>
        </div>
    </t>

    <!-- Encapsulate the content in a `a` tag with a link to the product page. Override this
        template to change or remove the product link. -->
    <t t-name="website_sale.CartLineProductLink">
        <a
            t-if="this.props.line.is_sellable"
            class="text-reset"
            t-att-href="this.props.line.website_url"
            name="o_cart_line_product_link"
        >
            <t t-out="0"/>
        </a>
        <t t-else="" t-out="0"/>
    </t>

    <t t-name="website_sale.AlertInline">
        <i
            t-attf-class="fa fa-{{level == 'info' ? 'info-circle' : 'warning'}} text-{{level ? 'danger' : ''}} {{classes}}"
            t-att-title="message"
            t-att-aria-label="message"
            data-bs-toggle="tooltip"
            data-bs-placement="top"
            data-bs-delay="0"
            role="tooltip"
        />
    </t>
</templates>
