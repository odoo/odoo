<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-inherit="sale.ProductConfiguratorDialog" t-inherit-mode="extension">
        <button name="sale_product_configurator_confirm_button" position="attributes">
            <attribute name="t-if">!showShopButtons()</attribute>
        </button>
        <button name="sale_product_configurator_cancel_button" position="attributes">
            <attribute name="t-if">!showShopButtons()</attribute>
        </button>
        <xpath expr="//button[@name='sale_product_configurator_cancel_button']" position="after">
            <div t-if="showShopButtons()" class="d-flex flex-column flex-sm-row align-items-center flex-grow-1 gap-2 justify-content-end">
                <h6 class="d-none d-sm-inline-block me-3 mb-0" name="sale_product_configurator_list_total">
                    <t t-out="formattedTotal" />
                </h6>
                <div class="o_wsale_product_configurator_vr vr d-none d-sm-block my-2" />
                <button
                    name="website_sale_product_configurator_checkout_button"
                    class="btn btn-primary w-100 w-sm-auto flex-shrink-0 flex-grow-0 order-sm-last"
                    t-on-click="() => this.onConfirm({goToCart: true})"
                    t-att-disabled="!isPossibleConfiguration() || !canBeSold()">
                    Checkout
                    <i class="fa fa-angle-right ms-2"/>
                </button>
                <button
                    name="website_sale_product_configurator_continue_button"
                    class="btn btn-link w-100 w-sm-auto flex-shrink-0 flex-grow-0"
                    t-if="!this.props.options.isBuyNow"
                    t-on-click="() => this.onConfirm({goToCart: false})"
                    t-att-disabled="!isPossibleConfiguration() || !canBeSold()">
                    <i class="fa fa-angle-left d-sm-none me-2"/>
                    Continue Shopping
                </button>
            </div>
        </xpath>
    </t>
</templates>
