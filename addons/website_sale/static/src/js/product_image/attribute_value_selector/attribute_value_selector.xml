<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="website_sale.attribute_value_selector">
        <Dropdown
            t-if="this.showDropdown"
            state="this.dropdownState"
            beforeOpen.bind="this.beforeOpen"
            onStateChanged.bind="this.onDropdownStateChanged"
        >
            <button t-attf-class="btn btn-outline-secondary border-top-0 rounded-0 w-100">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center gap-2">
                        <span>Apply to attributes</span>
                        <span class="badge rounded-pill bg-secondary">
                            <t t-out="selectedValuesCount"/>
                        </span>
                    </div>
                    <div class="d-flex align-items-center gap-1">
                        <span
                            t-out="this.badgeLabel"
                            class="badge rounded-1 bg-warning-subtle text-warning-emphasis"
                        />
                        <i t-attf-class="fa ms-1 #{this.dropdownState.isOpen ? 'fa-caret-up' : 'fa-caret-down'}"/>
                    </div>
                </div>
            </button>
            <t t-set-slot="content">
                <t
                    t-if="this.attributeValueMapping.length"
                    t-foreach="this.attributeValueMapping"
                    t-as="attr"
                    t-key="attr.id"
                >
                    <t t-foreach="attr.values" t-as="val" t-key="val.id">
                        <DropdownItem
                            class="'d-flex align-items-center justify-content-between gap-3 px-3'"
                            onSelected="() => this.toggleValue(val.id)"
                            closingMode="'none'"
                        >
                            <div class="o-checkbox form-check">
                                <input
                                    class="form-check-input"
                                    type="checkbox"
                                    t-att-checked="this.state.selectedValues.has(val.id)"
                                />
                                <span t-out="val.name" class="small"/>
                            </div>
                        </DropdownItem>
                    </t>
                    <div t-if="!attr_last" class="d-flex align-items-center my-1 px-2">
                        <span class="mx-2 small text-muted">And</span>
                        <div class="flex-grow-1 border-top"/>
                    </div>
                </t>
            </t>
        </Dropdown>
    </t>

</templates>
