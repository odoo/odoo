<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="mrp_subcontracting.report_mrp_bom" inherit_id="mrp.report_mrp_bom">
        <xpath expr="//thead" position="before">
            <t t-set="show_subcontract_column" t-value="data['forecast_mode'] and data['is_subcontract']"/>
        </xpath>

        <xpath expr="//th[@name='th_mrp_bom_free_to_use']" position="after">
            <th t-if="show_subcontract_column" class="text-center">
                Free to Use / On Hand<br/>
                subcontractor location
            </th>
        </xpath>

        <xpath expr="//td[@name='td_mrp_bom_free_to_use']" position="after">
            <td t-if="show_subcontract_column" class="text-center">
                <t t-out="data.get('subcontract_free_qty', 0)" t-options='{"widget": "float", "decimal_precision": "Product Unit"}'/> /
                <t t-out="data.get('subcontract_qty_on_hand', 0)" t-options='{"widget": "float", "decimal_precision": "Product Unit"}'/>
            </td>
        </xpath>

        <xpath expr="//td[@name='free_to_use']" position="after">
            <td name="free_to_use_subcontract" t-if="show_subcontract_column"/>
        </xpath>

        <xpath expr="//td[@name='free_to_use_byproducts']" position="after">
            <td name="free_to_use_subcontract" t-if="show_subcontract_column"/>
        </xpath>
    </template>

    <template id="mrp_subcontracting.report_mrp_bom_pdf_line" inherit_id="mrp.report_mrp_bom_pdf_line">
        <xpath expr="//td[@name='td_mrp_bom_free_to_use']" position="after">
            <td t-if="data['forecast_mode'] and data['is_subcontract']" class="text-center">
                <t t-if="l.get('is_storable', False)">
                    <t t-out="l.get('subcontract_free_qty', 0)" t-options='{"widget": "float", "decimal_precision": "Product Unit"}'/> /
                    <t t-out="l.get('subcontract_qty_on_hand', 0)" t-options='{"widget": "float", "decimal_precision": "Product Unit"}'/>
                </t>
            </td>
        </xpath>
    </template>
</odoo>
