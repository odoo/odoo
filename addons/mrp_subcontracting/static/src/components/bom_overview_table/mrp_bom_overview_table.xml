<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="mrp_subcontracting.BomOverviewTable" t-inherit="mrp.BomOverviewTable" t-inherit-mode="extension">
        <xpath expr="//th[@name='th_mrp_bom_free_to_use']" position="after">
            <th t-if="this.forecastMode and this.env.isSubcontract" class="text-center"
                title="Availabilities on subcontract location.">
                Free to Use / On Hand<br/>
                subcontractor location
            </th>
        </xpath>
        <xpath expr="//td[@name='free_to_use']" position="after">
            <td name="free_to_use_subcontract" t-if="this.forecastMode and this.env.isSubcontract"/>
        </xpath>
        <xpath expr="//t[@t-foreach='this.data.byproducts']//td[@name='free_to_use']" position="after">
            <td name="free_to_use_subcontract" t-if="this.forecastMode and this.env.isSubcontract"/>
        </xpath>
    </t>

</templates>
