<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_payment_method_view_form_inherit_pos_six" model="ir.ui.view">
        <field name="name">pos.payment.method.form.inherit.six</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <notebook invisible="payment_provider != 'six'">
                    <page name="settings" string="SIX">
                        <group>
                            <field name="six_terminal_ip"
                                invisible="payment_provider != 'six'"
                                required="payment_provider == 'six'"/>
                        </group>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>
</odoo>
