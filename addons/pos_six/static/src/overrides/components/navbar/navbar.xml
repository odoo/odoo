<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_six.Navbar" t-inherit="point_of_sale.Navbar" t-inherit-mode="extension">
        <xpath expr="//DropdownItem/i[hasclass('fa-plus')]/.." position="before">
            <DropdownItem onSelected="() => this.sendBalance()">
                <i class="fa fa-fw fa-usd" aria-hidden="true" /> Six Terminal Balance
            </DropdownItem>
        </xpath>
    </t>
</templates>
