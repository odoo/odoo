<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="point_of_sale.CustomerDisplay">
        <t t-set="orderData" t-value="this.order.order" />
        <t t-set="lines" t-value="this.order.lines or []" />
        <t t-set="orderPrices" t-value="this.order.extra_data?.prices" />
        <div t-if="this.order.displayScreenSaver" class="login-overlay fixed-top w-100 h-100 p-4 d-flex flex-column">
            <div class="screen-login-header d-flex justify-content-between">
                <div class="screen-login-timer d-flex align-items-center gap-2 bg-transparent">
                    <div class="timer-hours fs-1" t-out="this.time.hours" />
                    <div class="timer-date-container d-flex flex-column smaller">
                        <div class="timer-day" t-out="this.time.day" />
                        <div class="timer-date" t-out="this.time.date" />
                    </div>
                </div>
                <div class="screen-login-logo ms-auto">
                    <img t-att-src="this.configLogoSrc" alt="Logo"/>
                </div>
            </div>
            <div class="d-flex h-100 w-100 justify-content-center align-items-center">
                <div class="pos-logo w-100 h-25"/>
            </div>
        </div>
        <div t-elif="orderData?.state == 'paid' and orderPrices?.total_amount" class="h-100 d-flex flex-column">
            <FeedbackPaymentSummary formattedAmount="orderPrices.total_amount" class="'h-100'" loading="this.order.processingValidation"/>
            <div class="d-flex justify-content-center mb-4">
                <t t-call="point_of_sale.CustomerDisplayFooter"/>
            </div>
        </div>
        <div t-else="" class="o_customer_display d-flex h-100">
            <div class="o_customer_display_sidebar d-flex flex-column align-items-center justify-content-center gap-3 p-4 bg-view" t-att-style="this.session.has_bg_img
                ? `background-image: url(/web/image/pos.config/${this.session.config_id}/customer_display_bg_img); min-width: 35%;`
                : `min-width: 35%;`">
                <t t-set="qrData" t-value="this.qrPaymentData" />
                <img t-if="!qrData.qrCode" class="img-fluid o_customer_display_logo d-flex justify-content-center w-100" t-att-src="this.configLogoSrc" style="max-width: 220px;"/>
                <div t-else=""
                    class="qr-payment-card rounded-5 d-flex flex-column align-items-center justify-content-center p-4 shadow-lg border border-dark">
                    <h2 class="qr-title text-center mb-2">
                        Scan the QR for payment
                    </h2>
                    <img t-att-src="qrData.qrCode" alt="QR Code" class="qr-image p-4" t-attf-style="{{ !this.env.isSmall ? 'width: 300px' : ''}}"/>
                    <h3 class="qr-amount text-center mt-2">
                        Amount:
                        <t t-out="qrData.amount"/>
                    </h3>
                </div>
                <div class="o_customer_display_footer position-absolute bottom-0 mb-4 align-items-center rounded-3 text-bg-dark">
                    <t t-call="point_of_sale.CustomerDisplayFooter">
                        <t t-set="monochrome" t-value="true"/>
                    </t>
                </div>
            </div>
            <div class="o_customer_display_main d-flex flex-column flex-grow-1 overflow-auto">
                <div t-if="lines.length and orderData?.state == 'draft'" class="d-flex flex-column flex-grow-1 rounded-3 overflow-hidden">
                    <div style="scroll-snap-type: y mandatory;" class="order-container gap-0 p-0 pb-3 bg-view d-flex flex-column flex-grow-1 overflow-y-auto text-start">
                        <li t-foreach="lines"
                            t-as="line"
                            t-key="line.uuid"
                            class="orderline position-relative d-flex align-items-center p-1 lh-sm cursor-pointer o_customer_display_orderline fs-3 rounded-3"
                            t-attf-class="{{ line.combo_parent_id ? 'orderline-combo ms-4 fst-italic' : '' }}"
                            t-ref="this.lines"
                            t-att-data-uuid="line.uuid"
                        >
                            <div class="o_line_container d-flex align-items-center justify-content-center">
                                <img t-attf-style="border-radius: 1rem;" t-att-src="`/web/image/product.product/${line.product_id}/image_128`"/>
                            </div>
                            <div class="d-flex flex-column w-100 gap-1">
                                <div class="d-flex justify-content-between">
                                    <div class="product-name d-inline-block flex-grow-1 fw-bolder pe-1 text-truncate">
                                        <span class="text-wrap" t-out="line.full_product_name"/>
                                    </div>
                                    <div class="product-price price fw-bolder pe-2" t-out="line.price_subtotal_incl" />
                                </div>
                                <ul class="info-list d-flex flex-column p-0">
                                    <li class="price-per-unit">
                                        <span class="qty px-1 border rounded text-bg-view fw-bolder me-1" t-out="line.qty"/>
                                        x
                                        <t t-out="line.unit_price" />
                                        /
                                        <t t-if="line.product_uom_name" t-out="line.product_uom_name" />
                                    </li>
                                    <li t-if="line.price_unit !== 0 and line.discount" class="price-per-unit">
                                        <i class="fa fa-tag pe-1"/><em><t t-out="line.discount" />% </em> discount off on <t t-out="line.displayPriceNoDiscount"/>
                                    </li>
                                    <li t-if="line.customer_note" class="customer-note w-100 p-2 mt-2 rounded text-break text-bg-warning bg-opacity-25">
                                        <i class="fa fa-sticky-note me-1" role="img" aria-label="Customer Note" title="Customer Note"/>
                                        <t t-out="line.customer_note" />
                                    </li>
                                    <t t-set="notes" t-value="this.parseInternalNotes(line.note)" />
                                    <div t-if="notes.length" class="internal-note-container d-flex gap-2 p-2">
                                        <BadgeTag
                                            t-foreach="notes"
                                            t-as="note"
                                            t-key="note_index"
                                            color="note.colorIndex"
                                            text="note.text"
                                        />
                                    </div>
                                    <t t-call-slot="default" />
                                </ul>
                            </div>
                        </li>
                        <div t-if="orderData.general_customer_note" class="customer-note row flex-wrap m-0 w-100 p-2 mt-2 rounded text-bg-warning bg-opacity-25">
                            <div class="col-auto px-1">
                                <i class="fa fa-sticky-note me-1 fa-lg" role="img"
                                    aria-label="Customer Note" title="Customer Note"/>
                            </div>
                            <div class="col ps-0">
                                <div t-foreach="orderData.general_customer_note.split('\n')"
                                    t-as="subNote"
                                    t-key="subNote_index"
                                    class="text-break"
                                    t-out="subNote"
                                />
                            </div>
                        </div>
                        <t t-set="internalNotes" t-value="this.parseInternalNotes(orderData.internal_note)" />
                        <div t-if="internalNotes.length" class="internal-note-container d-flex gap-2 p-2">
                            <BadgeTag
                                t-foreach="internalNotes"
                                t-as="note"
                                t-key="note_index"
                                color="note.colorIndex"
                                text="note.text"
                            />
                        </div>
                    </div>
                    <div t-if="orderPrices" class="o_customer_display_total py-3 px-4 bg-view border-top">
                        <div class="d-flex flex-column justify-content-center gap-1 w-100 w-sm-50 ms-auto">
                            <div class="d-flex flex-column gap-1 fw-bolder lh-sm">
                                <div class="row fs-5 text-muted">
                                    <div class="col text-end">Subtotal</div>
                                    <div class="col text-end" t-out="orderPrices.subtotal_amount"/>
                                </div>
                                <div class="row fs-5 text-muted">
                                    <div class="col text-end">Taxes</div>
                                    <div class="col text-end" t-out="orderPrices.tax_amount"/>
                                </div>
                                <div class="row fs-2">
                                    <div class="col text-end">Total</div>
                                    <div class="col text-end" t-out="orderPrices.total_amount"/>
                                </div>
                            </div>
                            <div t-foreach="this.order.payments or []" t-as="line" t-key="line_index" class="o_customer_display_payment_line row">
                                <div class="col text-end" t-out="line.payment_method_data.name" />
                                <div class="col text-end" t-out="line.amount"/>
                            </div>
                            <t t-set="change" t-value="this.order.changes" />
                            <div class="row" t-if="change">
                                <div class="col text-end" t-out="change.statusText"/>
                                <div class="col text-end" t-out="change.amountText"/>
                            </div>
                        </div>
                    </div>
                </div>
                <div t-else="" class="d-flex flex-column align-items-center justify-content-center h-100 w-100">
                    <h1 class="display-2 w-75 mt-2 fw-bold text-center text-muted">Welcome</h1>
                </div>
                <div t-if="this.order.scaleData">
                    <t t-set-slot="header">
                        <h4 class="modal-title text-break text-center w-100" t-att-class="{ 'me-auto': this.env.isSmall }">
                            <span class="me-2">Weighing Product:</span>
                            <t t-out="this.order.scaleData.product.name"/>
                        </h4>
                    </t>
                    <div class="d-flex flex-column px-3">
                        <div t-if="this.order.scaleData.grossWeight" class="d-flex justify-content-between align-items-center mb-2">
                            <div class="w-60 fs-5 me-2 form-control-plaintext">Gross Weight:</div>
                            <div class="weight fs-5 js-weight text-end form-control-plaintext" t-out="this.order.scaleData.grossWeight"></div>
                        </div>
                        <div t-if="this.order.scaleData.tare" class="d-flex justify-content-between align-items-center mb-2">
                            <div class="w-60 fs-5 me-2 form-control-plaintext">Tare Weight:</div>
                            <div class="weight fs-5 js-weight text-end form-control-plaintext" t-out="this.order.scaleData.tare"></div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="w-60 fs-5 me-2 form-control-plaintext">Net Weight:</div>
                            <div class="text-end fs-5 form-control-plaintext" t-out="this.order.scaleData.netWeight"></div>
                        </div>
                        <div class="d-flex px-5 flex-row gap-2 m-2 align-items-center">
                            <div class="product-price w-50 fs-5 text-center" t-out="this.order.scaleData.unitPrice"/>
                            <div class="computed-price fd-flex flex-grow-1 p-2 rounded text-center text-bg-info bg-opacity-25 text-info fs-5 fw-bold" t-out="this.order.scaleData.totalPrice" />
                        </div>
                    </div>
                </div>
                <div class="o_customer_display_footer d-flex justify-content-center" t-att-class="{ 'bg-view': this.order.amount and !this.order.finalized }">
                    <t t-call="point_of_sale.CustomerDisplayFooter"/>
                </div>
            </div>
        </div>
        <MainComponentsContainer />
    </t>

    <t t-name="point_of_sale.CustomerDisplayFooter">
        <div class="d-flex bottom-0 align-items-center ps-3 pe-2 py-1 rounded-3 small">
            Powered by
            <OdooLogo t-if="!monochrome" style="'width: 3rem;'" />
            <OdooLogo t-else="" style="'width: 3rem;'" monochrome="true"/>
        </div>
    </t>
</templates>
