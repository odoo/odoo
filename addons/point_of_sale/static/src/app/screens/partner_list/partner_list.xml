<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="point_of_sale.PartnerList">
        <Dialog bodyClass="'partner-list overflow-y-auto p-0'" contentClass="'h-100'">
            <t t-set-slot="header">
                <button t-if="!ui.isSmall and this.pos.cashier._role !== 'minimal'" class="btn btn-primary btn-lg lh-lg" role="img" aria-label="Add a customer"
                        t-on-click="() => this.editPartner()"
                        title="Add a customer">
                Create 
                </button>
                <Input tModel="[state, 'query']"
                    class="'ms-auto'"
                    isSmall="ui.isSmall"
                    placeholder.translate="Search Customers..."
                    icon="{type: 'fa', value: 'fa-search'}"
                    autofocus="true"
                    debounceMillis="100" />
            </t>
            <div class="fixed-head h-100 p-3 pt-0" t-ref="partner-list">
                <table class="table table-hover">
                    <thead t-if="!ui.isSmall">
                        <tr>
                            <th class="py-2 bg-white">Name</th>
                            <th class="py-2 bg-white">Address</th>
                            <th class="partner-line-email py-2 bg-white">Contact</th>
                            <th class="pos-right-align py-2 bg-white" t-if="isBalanceDisplayed">Balance</th>
                            <th class="py-2 bg-white"></th>
                            <th class="py-2 bg-white"></th>
                        </tr>
                    </thead>
                    <tbody class="overflow-scroll h-100">
                        <t t-foreach="getPartners(this.state.initialPartners)" t-as="partner" t-key="partner.id">
                            <PartnerLine
                                close="props.close"
                                partner="partner"
                                isSelected="props.partner?.id === partner.id"
                                isBalanceDisplayed="isBalanceDisplayed"
                                onClickEdit.bind="(p) => this.editPartner(p)"
                                onClickUnselect.bind="() => this.clickPartner()"
                                onClickOrders.bind="(p) => this.goToOrders(p)"
                                onClickPartner.bind="clickPartner"/>
                        </t>
                        <t t-foreach="getPartners(this.state.loadedPartners)" t-as="partner" t-key="partner.id">
                            <PartnerLine
                                close="props.close"
                                partner="partner"
                                isSelected="props.partner?.id === partner.id"
                                isBalanceDisplayed="isBalanceDisplayed"
                                onClickEdit.bind="(p) => this.editPartner(p)"
                                onClickUnselect.bind="() => this.clickPartner()"
                                onClickOrders.bind="(p) => this.goToOrders(p)"
                                onClickPartner.bind="clickPartner"/>
                        </t>
                    </tbody>
                </table>
            </div>
            <t t-set-slot="footer">
                <div class="d-flex justify-content-start flex-wrap gap-2 w-100">
                    <button t-if="ui.isSmall and this.pos.cashier._role !== 'minimal'" class="btn btn-primary btn-lg lh-lg" role="img" aria-label="Add a customer"
                        t-on-click="() => this.editPartner()"
                        title="Add a customer">
                    New 
                    </button>
                    <button class="btn btn-secondary btn-lg lh-lg o-default-button" t-on-click="() => this.clickPartner(this.props.partner)">Discard</button>
                </div>
            </t>
        </Dialog>
    </t>

</templates>
