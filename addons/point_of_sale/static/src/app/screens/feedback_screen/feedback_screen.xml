<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="point_of_sale.FeedbackScreen">
        <div t-ref="feedback-screen" class="feedback-screen bg-100 fixed-top w-100 h-100 d-flex flex-column align-items-center justify-content-center" t-on-click="onClick">
            <div class="d-flex flex-column align-items-center">
                <div style="width: 115px; height: 115px;">
                    <t t-if="!this.state.loading">
                        <t t-call="point_of_sale.ValidationAnimation"/>
                    </t>
                </div>

                <div class="amount-paid fw-bolder">
                    <t t-if="this.state.loading">Processing...</t>
                    <t t-else="">Amount Paid</t>
                </div>
            </div>

            <div t-ref="amount" class="amount lh-sm">
                <PriceFormatter price="this.env.utils.formatCurrency(this.currentOrder.amount_total, false)"/>
            </div>
        </div>
    </t>
</templates>
