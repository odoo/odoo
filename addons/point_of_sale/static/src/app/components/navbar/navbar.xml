<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="point_of_sale.Navbar">
        <div class="pos-topheader position-relative d-flex align-items-center justify-content-between gap-1 p-2 m-0 bg-view border-bottom">
            <div class="pos-leftheader d-flex align-items-center flex-grow-1 overflow-auto min-w-0" t-att-class="{'d-none': this.ui.isSmall and this.state.searchBarOpen, 'mw-100': this.pos.getOrder()}">
                <div class="d-flex flex-shrink-0 align-items-center gap-2 gap-lg-3 position-relative pe-2 min-w-0" t-att-class="{ 'w-100': !this.ui.isSmall }">
                    <div class="navbar-menu btn-group" role="group" aria-label="Navigation Menu">
                        <button class="register-label btn btn-outline-secondary btn-lg lh-lg" t-att-class="{'active': this.mainButton === 'register'}" t-on-click="() => this.onClickRegister()">
                            <span t-if="!this.ui.isSmall">Register</span>
                            <i t-else="" class="fa fa-fw fa-pencil" t-att-class="{'fa-lg' : !this.ui.isSmall}"/>
                        </button>
                        <button class="orders-button btn btn-outline-secondary btn-lg lh-lg" t-att-class="{'active': this.mainButton === 'order'}" t-on-click="() => this.onTicketButtonClick()">
                            <t t-if="!this.ui.isSmall">
                                <span>Orders</span>
                            </t>
                            <i t-else="" class="fa fa-fw fa-book" t-att-class="{'fa-lg' : !this.ui.isSmall}"/>
                        </button>
                    </div>
                    <OrderTabs orders="this.getOrderTabs()" class="'h-50'"/>
                    <button class="btn btn-secondary d-flex align-items-center gap-1 h-100 ms-2 p-2 preset-time-btn" t-on-click="this.openPresetTiming" t-if="this.shouldDisplayPresetTime">
                        <i class="fa fa-clock-o" aria-hidden="true"/>
                        <span class="fw-bolder lh-1" t-out="this.pos.getOrder()?.presetTime || '--:--'" />
                    </button>
                </div>
            </div>
            <div t-if="!this.pos.getOrder()" class="pos-centerheader d-none d-xl-flex position-absolute start-50 translate-middle-x">
                <div class="pos-logo mw-100" />
            </div>
            <div class="pos-rightheader flex-shrink-0">
                <div class="status-buttons d-flex align-items-center justify-content-end gap-1">
                    <div t-if="this.pos.data.network.offline or this.pos.data.network.loading" class="oe_status px-3">
                        <span t-if="this.pos.data.network.unsyncData.length > 0" t-out="this.pos.data.network.unsyncData.length" />
                        <div t-if="this.pos.data.network.offline" class="fa fa-fw fa-chain-broken text-danger"/>
                        <div t-else="" class="fa fa-fw fa-spin fa-circle-o-notch text-warning"/>
                    </div>
                    <Input tModel="[this.pos, 'searchProductWord']"
                    class="this.ui.isSmall ? 'p-0' : 'w-100 w-xl-50 me-0 me-lg-2'"
                    isSmall="this.ui.isSmall"
                    placeholder.translate="Search products..."
                    icon="{type: 'fa', value: 'fa-search fa-lg fa-fw'}"
                    debounceMillis="500"
                    getRef="(ref) => this.inputRef = ref"
                    t-if="this.pos.showSearchButton()"
                    isOpenCallback="(isOpen) => this.state.searchBarOpen = isOpen" />
                    <button class="btn btn-light btn-lg lh-lg" t-if="this.isBarcodeScannerSupported() and ['ProductScreen', 'TicketScreen'].includes(this.pos.router.state.current) and !this.pos.config.module_pos_restaurant" t-on-click="this.onClickScan">
                        <i class="fa fa-fw fa-lg fa-barcode" /><span t-if="this.pos.scanning" class="ms-1">Stop</span>
                    </button>
                    <!-- No need to show the cashier name on small screens -->
                    <CashierName t-if="!this.ui.isSmall"/>
                    <button class="btn btn-light btn-lg lh-lg" t-on-click="this.openBurgerMenu">
                        <i class="fa fa-fw fa-bars" aria-label="Open Menu"/>
                    </button>
                </div>
            </div>
        </div>
    </t>

    <t t-name="point_of_sale.BurgerDialogMenuButton">
        <button
            t-att-class="'btn btn-lg ' + (btnClasses or 'btn-secondary') + ' d-inline-flex flex-md-column justify-content-md-center align-items-center gap-2'"
            t-on-click="onClick">
            <i t-if="iconClasses" t-attf-class="{{iconClasses}} fa-fw align-self-center opacity-50" role="img" aria-hidden="true"/>
            <t t-out="btnLabel"/>
        </button>
    </t>

    <t t-name="point_of_sale.BurgerMenuDialog">
        <Dialog bodyClass="'d-flex flex-column'" footer="false" title.translate="" backdrop="true">
            <div class="d-flex justify-content-between pb-2">
                <button t-att-class="'btn btn-lg btn-outline-' + (this.pos.lnaState.type)" title="Local Network Access" t-on-click="() => this.props.openLnaPopup()">
                    <i t-att-class="'fa fa-fw fa-' + (this.pos.lnaState.type === 'success' ? 'wifi' : 'chain-broken')" aria-hidden="true"/> LNA
                </button>
            </div>
            <div class="o_pos_burger_menu_buttons d-grid gap-2">
                <t t-call="point_of_sale.BurgerDialogMenuButton"
                    t-name="customer_display"
                    iconClasses="'fa fa-desktop'"
                    onClick="() => this.do(() => this.props.openCustomerDisplay())"
                    btnLabel.translate="Customer Display"
                />

                <t t-if="!this.isDisplayStandalone and this.pos.cashier._role != 'minimal'"
                    t-call="point_of_sale.BurgerDialogMenuButton"
                    t-name="install-app"
                    iconClasses="'fa fa-download'"
                    onClick="() => this.do(() => window.open(this.appUrl))"
                    btnLabel.translate="Install App"
                />
                <t t-if="this.showCashMoveButton and this.pos.cashier._role != 'minimal'"
                    t-call="point_of_sale.BurgerDialogMenuButton"
                    iconClasses="'fa fa-money'"
                    onClick="() => this.do(() => this.pos.cashMove())"
                    btnLabel.translate="Cash In/Out"
                />
                <t t-if="!this.pos.data.network.offline"
                    t-call="point_of_sale.BurgerDialogMenuButton"
                    iconClasses="'fa fa-refresh'"
                    onClick="() => this.do(() => this.props.reloadProducts())"
                    btnLabel.translate="Reload Data"
                />
                <t t-if="this.showCreateProductButton"
                    t-call="point_of_sale.BurgerDialogMenuButton"
                    t-name="create_product"
                    iconClasses="'fa fa-plus'"
                    onClick="() => this.do(() => this.pos.editProduct())"
                    btnLabel.translate="Create Product"
                />
                <t t-if="this.showPrinterButton"
                    t-call="point_of_sale.BurgerDialogMenuButton"
                    iconClasses="'fa fa-print'"
                    onClick="() => this.do(() => this.pos.ticketPrinter.selectPrinter(true))"
                    btnLabel.translate="Printers"
                />
                <t t-if="this.isBarcodeScannerSupported() and this.pos.router.state.current == 'ProductScreen' and this.ui.isSmall and !this.pos.config.module_pos_restaurant"
                    t-call="point_of_sale.BurgerDialogMenuButton"
                    iconClasses="'fa fa-barcode'"
                    onClick="() => this.do(() => this.props.onClickScan())"
                    btnLabel.translate="Barcode Scanner"
                />
                <t t-if="this.pos.ticketPrinter.hasReceiptPrinters"
                    t-call="point_of_sale.BurgerDialogMenuButton"
                    iconClasses="'fa fa-file-pdf-o'"
                    onClick="() => this.do(() => this.props.showSaleDetails())"
                    btnLabel.translate="Print Report"
                />
                <t t-call="point_of_sale.BurgerDialogMenuButton"
                    t-name="backend"
                    iconClasses="'fa fa-chevron-left'"
                    onClick="() => this.do(() => this.pos.closePos())"
                    btnLabel.translate="Backend"
                />
                <t t-call="point_of_sale.BurgerDialogMenuButton"
                    t-name="close_register"
                    iconClasses="'fa fa-key'"
                    onClick="() => this.do(() => this.pos.closeSession())"
                    btnLabel.translate="Close Register"
                    btnClasses="'btn-danger'"
                />
            </div>
        </Dialog>
    </t>
</templates>
