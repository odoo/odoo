<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="point_of_sale.PaymentMethodBreakdown">
        <AccordionItem disabled="this.props.transactions.length === 0">
            <t t-set-slot="header">
                <div class="name-amount d-flex justify-content-between w-100">
                    <span t-out="this.props.title"/>
                    <span t-out="this.env.utils.formatCurrency(this.props.total_amount)"/>
                </div>
            </t>
            <t t-set-slot="content">
                <div class="border-start small text-muted d-flex flex-column ps-2 ms-1">
                    <div t-foreach="this.props.transactions" t-as="payment" t-key="payment.id" class="d-flex justify-content-between">
                        <span t-out="payment.name"/>
                        <span t-out="this.env.utils.formatCurrency(payment.amount)"/>
                    </div>
                </div>
            </t>
        </AccordionItem>
    </t>
</templates>
