<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="point_of_sale.SelectDefaultPrinterPopup" owl="1">
        <Dialog size="'sm'" title.translate="Several receipt printers are available">
            Which one would you like to use as default for this device?
            <t t-foreach="this.props.receipt_printers" t-as="p" t-key="p.id">
                <div class="my-2">
                    <label class="d-flex align-items-center">
                        <input type="radio"
                            name="Fallback printer"
                            t-custom-model="this.state.selectedId"
                            t-att-value="p.id"
                            class="me-2"/>
                        <span>
                            <t t-out="p.name"/>
                        </span>
                    </label>
                </div>
            </t>
            <div class="text-warning">
                You can change your choice from the menu, under <b>Printers</b> item
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-primary" t-on-click="this.confirmSelection" t-att-disabled="!this.state.selectedId">
                    Confirm
                </button>
                <button class="btn btn-secondary" t-on-click="this.cancel">
                    Cancel
                </button>
            </t>
        </Dialog>
    </t>
</templates>
