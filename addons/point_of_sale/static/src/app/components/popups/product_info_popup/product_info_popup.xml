<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="point_of_sale.ProductInfoPopup">
        <Dialog contentClass="'product-info-popup'">
            <t t-set-slot="header">
                <button t-on-click="this.toggleFavorite" class="border-0 bg-transparent mb-2" t-att-disabled="this.pos.cashier._role == 'minimal'">
                    <i t-attf-class="fa fa-lg fa-fw  {{this.props.productTemplate.is_favorite ? 'fa-star' : 'fa-star-o'}}"
                        t-att-style="this.props.productTemplate.is_favorite ? 'color: #f3cc00;' : ''"
                        role="img"/>
                </button>
                <h3 class="section-title" t-out="this.props.productTemplate.displayName + ' | ' + this.env.utils.formatCurrency(this.props.info.productInfo.all_prices.price_with_tax)"/>
                <button type="button" class="btn-close mb-2" aria-label="Close" tabindex="-1" t-on-click="this.props.close"/>
            </t>
            <div class="section-public-description mt-3 mb-4 pb-4 border-bottom text-start" t-if="this.props.productTemplate.productDescriptionMarkup">
                <h3 class="section-title">
                    Description
                </h3>
                <t t-out="this.props.productTemplate.productDescriptionMarkup" />
            </div>
            <div class="section-inventory mt-3 mb-4 pb-4 border-bottom text-start">
                <div class="d-flex align-items-center gap-2">
                    <div class="d-flex flex-column">
                        <h3 class="section-title">Inventory</h3>
                        <div class="section-inventory-body">
                            <div>
                                On hand: <span class="me-1 fw-bolder"><t t-out="this.props.info.productInfo.free_qty"/></span>
                                <t t-out="this.props.info.productInfo.uom"/>
                            </div>
                        </div>
                    </div>
                    <button class="btn btn-lg lh-lg ms-auto text-nowrap" t-on-click="this.openSnoozeDialog" t-attf-class="{{this.state.activeSnooze ? 'btn-warning' : 'btn-secondary'}}">
                        <i class="fa fa-clock-o me-1" t-if="!(this.state.activeSnooze and this.ui.isSmall)" aria-hidden="true"></i>
                        <span t-if="!this.state.activeSnooze and !this.ui.isSmall">Snooze</span>
                        <span class="m-0" t-if="this.state.activeSnooze" style="font-variant-numeric: tabular-nums;">
                            <t t-out="this.state.countdown" />
                        </span>
                    </button>
                </div>
            </div>
            <div class="section-supplier mt-3 mb-4 pb-4 border-bottom text-start" t-if="props.info?.productInfo?.suppliers?.length">
                <h3 class="section-title">Replenishment</h3>
                <div class="section-supplier-body">
                    <t t-foreach="this.props.info.productInfo.suppliers" t-as="supplier" t-key="supplier.id">
                        <div class="d-flex flex-column flex-md-row gap-2">
                            <div>
                                <span t-out="supplier.name" class="table-name"/>:
                            </div>
                            <span class="me-1 fw-bolder">
                                <t t-out="supplier.delay"/>
                                Days
                            </span>
                            <span t-if="this._hasMarginsCostsAccessRights()">
                                <t t-out="this.env.utils.formatCurrency(supplier.price)"/>
                            </span>
                        </div>
                    </t>
                </div>
            </div>
            <div class="section-optional-product mt-3 mb-4 pb-4 border-bottom text-start" t-if="this.props.info?.productInfo?.optional_products?.length > 0">
                <h3 class="section-title">Optional Products:</h3>
                <div class="section-optional-product-body" t-foreach="this.props.info.productInfo.optional_products" t-as="optional" t-key="optional.id">
                    <span>
                        <a class="text-primary text-decoration-underline" t-out="optional.name" t-on-click="() => this.searchProduct(optional.name)"/>
                            from
                        <t t-out="this.env.utils.formatCurrency(optional.list_price)"/>
                    </span>
                </div>
            </div>
            <div class="financials-order d-grid gap-2 mt-3" style="grid-template-columns: repeat(2, 1fr);">
                <div class="section-financials text-start">
                    <h3 class="section-title">Financials</h3>
                    <div class="grid gap-2">
                        <label class="fw-bold">Price excl. Tax:</label>
                        <span><t t-out="this.env.utils.formatCurrency(this.props.info.productInfo.all_prices.price_without_tax)"/></span>
                        <label class="fw-bold vat-label"><t t-out="this.vatLabel"/></label>
                        <span class="vat-value">
                            <t t-out="this.props.info.taxAmount"/>
                            (<t t-out="this.props.info.taxName"/>)
                        </span>
                        <label class="fw-bold">Price incl. Tax:</label>
                        <span><t t-out="this.env.utils.formatCurrency(this.props.info.productInfo.all_prices.price_with_tax)"/></span>
                        <t t-if="this._hasMarginsCostsAccessRights()">
                            <label class="fw-bold">Cost:</label>
                            <span><t t-out="this.props.info.costCurrency"/></span>
                            <label class="fw-bold">Margin:</label>
                            <span><t t-out="this.props.info.marginCurrency"/> (<t t-out="this.props.info.marginPercent"/>%) </span>
                        </t>
                    </div>
                    <div class="grid gap-2 mt-3">
                        <t t-foreach="this.props.info.productInfo.pricelists" t-as="pricelist" t-key="pricelist.name">
                            <label class="fw-bold" t-out="pricelist.name"/>
                            <span t-out="this.env.utils.formatCurrency(pricelist.price)"/>
                        </t>
                    </div>
                </div>
                <div class="section-order text-start">
                    <h3 class="section-title">Order</h3>
                    <div class="grid gap-2">
                        <label class="fw-bold">Total Price excl. Tax:</label>
                        <span t-out="this.props.info.orderPriceWithoutTaxCurrency"/>
                        <label class="fw-bold"><t t-out="this.totalVatLabel"/></label>
                        <span t-out="this.props.info.orderTaxTotalCurrency"/>
                        <label class="fw-bold">Total Price incl. Tax:</label>
                        <span t-out="this.props.info.orderPriceWithTaxCurrency"/>
                        <t t-if="this._hasMarginsCostsAccessRights()">
                            <label class="fw-bold">Total Cost:</label>
                            <span t-out="this.props.info.orderCostCurrency"/>
                            <label class="fw-bold">Total Margin:</label>
                            <span><t t-out="this.props.info.orderMarginCurrency"/> (<t t-out="this.props.info.orderMarginPercent"/>%)</span>
                        </t>
                    </div>
                </div>
            </div>
            <t t-set-slot="footer">
                <div class="d-flex flex-row gap-2 w-100">
                    <button class="btn btn-primary btn-lg lh-lg w-50" t-on-click="this.props.close">Close</button>
                    <button t-if="this.allowProductEdition" class="btn btn-secondary btn-lg lh-lg w-50" t-on-click="this.editProduct">Edit</button>
                </div>
            </t>
        </Dialog>
    </t>
</templates>
