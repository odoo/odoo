<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="point_of_sale.QRPopup">
        <Dialog size="'sm'" contentClass="'o_qr_popup rounded-5 p-2'" header="false">
            <div class="d-flex flex-column align-items-center">
                <h2 class="border-bottom border-dark w-75 text-center pb-1">QR Payment</h2>
                <div class="qr-container my-2 w-75">
                    <div
                        t-if="!this.state.qrLoaded"
                        class="skeleton"
                    />
                    <img
                        t-att-src="this.props.qrCode"
                        t-on-load="this.onQrLoaded" t-on-error="this.onQrLoaded"
                        t-attf-class="qr-code loaded w-100 {{ this.state.qrLoaded ? '' : 'd-none' }}"
                        alt="QR Code"
                    />
                </div>
                <div class="qr-code-amount fs-2">
                    <strong>Amount: <t t-out="this.props.amount" /></strong>
                </div>
            </div>
            <t t-if="this.props.footer" t-set-slot="footer">
                <div class="qr-code-popup-footer d-flex align-items-center justify-content-center w-100 mt-2">
                    <button t-if="this.props.confirm" class="btn btn-primary btn-lg confirm-button mx-2" t-on-click="this.confirm" t-out="this.props.confirmLabel" />
                    <button t-if="this.props.close" class="btn btn-secondary btn-lg cancel-button mx-2" t-on-click="this.props.close" t-out="this.props.cancelLabel" />
                </div>
            </t>
        </Dialog>
    </t>
</templates>
