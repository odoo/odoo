<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="point_of_sale.LotAutoComplete" t-inherit="web.AutoComplete" t-inherit-mode="primary">
        <xpath expr="//div[hasclass('o-autocomplete')]" position="attributes">
            <attribute name="class" separator="" add="input-group"/>
        </xpath>
        <xpath expr="//input" position="attributes">
            <attribute name="class">form-control</attribute>
        </xpath>
    </t>
</templates>
