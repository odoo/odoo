<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="point_of_sale.PrintPopup">
        <Dialog title="''" footer="false" size="'md'" contentClass="`print-popup ${!this.ui.isSmall? 'rounded-4' : ''}`" bodyClass="">
            <div class="print-popup-modal d-grid gap-2 py-3">
                <button t-foreach="this.printList" t-as="item" t-key="item_index"
                        class="btn btn-lg py-3 rounded-3 d-flex gap-2 align-items-center justify-content-center"
                        t-att-class="item.isPrimary ? 'btn-primary' : 'btn-secondary'"
                        t-on-click="() => this.clickPrintButton(item)">
                        <i
                            class="oi oi-2x me-1"
                            t-att-class="{'oi-fw oi-spin': item.status === 'loading'}"
                            t-att-data-icon="item.status === 'loading' ? 'autorenew' : item.icon"
                        /><t t-out="item.label" />
                </button>
            </div>
        </Dialog>
    </t>

</templates>
