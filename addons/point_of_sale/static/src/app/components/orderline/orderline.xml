<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="point_of_sale.Orderline">
        <li t-if="line.order_id" class="orderline position-relative d-flex align-items-center p-2 lh-sm cursor-pointer"
            t-attf-class="{{ line.combo_parent_id?.getFullProductName() ? 'orderline-combo ms-4 fst-italic' : '' }}"
            t-att-class="{'selected' : line.isSelected() and this.props.mode === 'display', ...line.getDisplayClasses(), ...(props.class || [])}">
            <div class="product-order"></div>
            <div t-if="props.showImage and line.product_id.getImageUrl()" class="o_line_container d-flex align-items-center justify-content-center">
                <img t-attf-style="border-radius: 1rem;" t-att-src="line.product_id.getImageUrl()"/>
            </div>
            <div class="d-flex flex-column w-100 gap-1">
                <div class="line-details d-flex justify-content-between">
                    <div class="product-name d-inline-block flex-grow-1 fw-bolder pe-1 text-truncate">
                        <span class="text-wrap" t-esc="line.getFullProductName()"/>
                        <t t-slot="product-name" />
                    </div>
                    <div t-if="!line.config.basic_receipt" t-esc="line.getPriceString()" class="product-price price fw-bolder"/>
                    <div t-if="props.showTaxGroup" t-esc="this.taxGroup" class="text-end" style="width: 2rem"/>
                </div>
                <ul class="info-list d-flex flex-column">
                    <li class="price-per-unit">
                        <span class="qty px-1 border rounded text-bg-view fw-bolder me-1" t-esc="line.getQuantityStr()"/>
                        <t t-if="!line.config.basic_receipt">
                            x
                            <t t-set="oldUnitPrice" t-value="line.getOldUnitDisplayPrice() ? formatCurrency(line.getOldUnitDisplayPrice()) : ''" />
                            <s t-esc="oldUnitPrice" t-if="oldUnitPrice" />
                            <t t-esc="formatCurrency(line.unitDisplayPrice)" />
                            /
                        </t>
                        <t t-if="line.product_id.uom_id ? line.product_id.uom_id.name : ''" t-esc="line.product_id.uom_id ? line.product_id.uom_id.name : ''" />
                    </li>
                    <li t-if="line.getDiscountStr() and line.getDiscountStr() !== '0' and !props.basic_receipt">
                        <t t-esc="formatCurrency(line.getUnitDisplayPriceBeforeDiscount())"/> With a <em><t t-esc="line.getDiscountStr()" />% </em> discount
                    </li>
                    <li t-if="line.getCustomerNote()" class="customer-note w-100 p-2 mt-2 rounded text-break text-bg-warning bg-opacity-25">
                        <i class="fa fa-sticky-note me-1" role="img" aria-label="Customer Note" title="Customer Note"/>
                        <t t-esc="line.getCustomerNote()" />
                    </li>
                    <div class="internal-note-container d-flex gap-2">
                        <t t-foreach="line.getNote()?.split?.('\n') or []" t-as="note" t-key="note_index">
                            <li t-if="note.trim() !== ''" t-esc="note" class="internal-note badge mt-2 p-2 rounded-pill bg-info text-info bg-opacity-25" style="font-size: 0.85rem;" />
                        </t>
                    </div>
                    <li t-foreach="line.packLotLines" t-as="lot" t-key="lot_index" t-esc="lot" />
                    <t t-slot="default" />
                </ul>
            </div>
        </li>
    </t>
</templates>
