<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="point_of_sale.DebugWidget">
        <div t-if="!this.state.isOpen and !this.isDisabled"
            class="o-debug-widget-btn open position-absolute align-items-center justify-content-center d-flex cursor-pointer shadow-sm bg-danger text-white"
            t-on-click="this.toggleWidget"
            data-tooltip="Open debug widget"
            data-tooltip-delay="0">
            <i class="oi" data-icon="bug_report" aria-hidden="true" />
        </div>
        <div class="debug-widget position-absolute bottom-0 end-0 bg-100 shadow-lg p-2 d-flex flex-column gap-1 m-2"
            t-attf-class="{{ this.state.isOpen ? '' : 'd-none' }}">
            <div class="d-flex gap-1 mb-2">
                <span class="badge o_colorlist_item_color_3 rounded">Device ID: <t t-out="this.state.device_identifier" /></span>
                <span class="badge o_colorlist_item_color_3 rounded">Next number: <t t-out="this.state.next_number" /></span>
                <span class="badge o_colorlist_item_color_3 rounded">Number stack: <t t-out="this.state.unsynced_number_stack" /></span>
            </div>
            <div class="gap-1 d-flex align-items-center flex-wrap">
                <div class="input-group input-group-sm">
                    <span class="input-group-text">Barcode</span>
                    <input type="text"
                        class="form-control ean"
                        t-custom-model="this.state.barcodeInput"
                        t-att-disabled="!this.barcodeReader"
                        t-attf-placeholder="{{ !this.barcodeReader ? 'No nomenclature' : '' }}"
                        t-on-keydown="this.onBarcodeInputKeydown"
                    />
                    <div class="d-flex align-items-center gap-1 ms-1">
                        <button class="btn btn-secondary btn-sm text-nowrap" t-on-click="this.barcodeScan">
                            <i class="oi" data-icon="barcode" aria-hidden="true"/> Scan
                        </button>
                        <button class="btn btn-secondary btn-sm text-nowrap" t-on-click="this.barcodeScanEAN">
                            <i class="oi" data-icon="barcode" aria-hidden="true"/> EAN-13
                        </button>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-1 w-100 flex-wrap">
                    <div data-tooltip="Close debug widget" data-tooltip-delay="0">
                        <button class="btn btn-secondary btn-sm text-nowrap" t-on-click="this.toggleWidget">
                            <i class="oi" data-icon="close" aria-hidden="true" /> Close
                        </button>
                    </div>
                    <div data-tooltip="Disable debug mode" data-tooltip-delay="0">
                        <button class="btn btn-secondary btn-sm text-nowrap" t-on-click="this.disableDebugMode">
                            <i class="oi" data-icon="logout" aria-hidden="true" /> Disable
                        </button>
                    </div>
                    <div data-tooltip="Refresh customer display" data-tooltip-delay="0">
                        <button class="btn btn-secondary btn-sm text-nowrap" t-on-click="this.refreshDisplay">
                            <i class="oi" data-icon="refresh" aria-hidden="true" /> Refresh
                        </button>
                    </div>
                    <div data-tooltip="Export PoS data" data-tooltip-delay="0">
                        <button class="btn btn-secondary btn-sm text-nowrap" t-on-click="() => this.exportData()">
                            <i class="oi" data-icon="download" aria-hidden="true" /> Export data
                        </button>
                    </div>
                    <div data-tooltip="Import orders" data-tooltip-delay="0">
                        <button t-custom-ref="import-order-input" class="btn btn-danger btn-sm text-nowrap">
                            <i class="oi" data-icon="upload" aria-hidden="true" /> Import data
                        </button>
                        <input t-on-change="this.importData" type="file" class="d-none" id="import-order-input" />
                    </div>
                    <div data-tooltip="Delete paid orders" data-tooltip-delay="0">
                        <button class="btn btn-danger btn-sm text-nowrap" t-on-click="() => this.deleteOrders({ paid: true })">
                            <i class="oi oi-filled" data-icon="delete" aria-hidden="true" /> Paid
                        </button>
                    </div>
                    <div data-tooltip="Delete unpaid orders" data-tooltip-delay="0">
                        <button class="btn btn-danger btn-sm text-nowrap" t-on-click="() => this.deleteOrders({ paid: false })">
                            <i class="oi oi-filled" data-icon="delete" aria-hidden="true" /> Unpaid
                        </button>
                    </div>
                    <div data-tooltip="Delete all indexed DB" data-tooltip-delay="0">
                        <button class="btn btn-danger btn-sm text-nowrap" t-on-click="this.deleteAllIndexedDB">
                            <i class="oi oi-filled" data-icon="delete" aria-hidden="true" /> Delete all indexed DB
                        </button>
                    </div>
                    <div data-tooltip="Download logs" data-tooltip-delay="0">
                        <button class="btn btn-secondary btn-sm text-nowrap" t-on-click="this.downloadLogs">
                            <i class="oi" data-icon="download" aria-hidden="true" /> Download Logs
                        </button>
                    </div>
                    <div data-tooltip="Download IndexedDB error logs from localStorage" data-tooltip-delay="0">
                        <button class="btn btn-secondary btn-sm text-nowrap" t-on-click="this.downloadIdbErrors">
                            <i class="fa fa-download" aria-hidden="true" /> Download IDB Errors
                        </button>
                    </div>
                    <div data-tooltip="Print cash receipt" data-tooltip-delay="0">
                        <button class="btn btn-secondary btn-sm text-nowrap" t-on-click="this.openCashBox">
                            <i class="oi" data-icon="payments" aria-hidden="true" /> Open cashbox
                        </button>
                    </div>
                    <div data-tooltip="Print cash move receipt" data-tooltip-delay="0">
                        <button class="btn btn-secondary btn-sm text-nowrap" t-on-click="this.cashInOutPrint">
                            <i class="oi" data-icon="print" aria-hidden="true" /> Cash Receipt
                        </button>
                    </div>
                    <div data-tooltip="Print order receipt" data-tooltip-delay="0">
                        <button class="btn btn-secondary btn-sm text-nowrap" t-on-click="this.randomOrderPrint">
                            <i class="oi" data-icon="print" aria-hidden="true" /> Order Receipt
                        </button>
                    </div>
                    <div data-tooltip="Print tip receipt" data-tooltip-delay="0">
                        <button class="btn btn-secondary btn-sm text-nowrap" t-on-click="this.printTipReceipt">
                            <i class="oi" data-icon="print" aria-hidden="true" /> Tip Receipt
                        </button>
                    </div>
                    <div data-tooltip="Print details receipt" data-tooltip-delay="0">
                        <button class="btn btn-secondary btn-sm text-nowrap" t-on-click="this.printSaleDetails">
                            <i class="oi" data-icon="print" aria-hidden="true" /> Details Receipt
                        </button>
                    </div>
                    <div data-tooltip="Print changes receipt" data-tooltip-delay="0">
                        <button class="btn btn-secondary btn-sm text-nowrap" t-on-click="this.printOrderChanges">
                            <i class="oi" data-icon="print" aria-hidden="true" /> Changes Receipt
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
