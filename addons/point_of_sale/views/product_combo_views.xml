<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="point_of_sale.product_combo_view_form" model="ir.ui.view">
        <field name="name">product.combo.form.inherit.point.of.sale</field>
        <field name="model">product.combo</field>
        <field name="inherit_id" ref="product.product_combo_view_form"/>
        <field name="arch" type="xml">
            <field name="product_id" position="attributes">
                <attribute name="context">{'default_available_in_pos': True}</attribute>
            </field>

            <xpath expr="//group[field[@name='company_id']]" position="replace">
                <group>
                    <group>
                        <field name="qty_max" string="Maximum items" invisible="not is_from_pos"/>
                        <field name="qty_free" string="Includes" invisible="is_upsell"/>
                        <field name="is_upsell" widget="boolean_toggle" invisible="not is_from_pos"/>
                        <field
                            name="upsell_warning"
                            readonly="1"
                            nolabel="1"
                            invisible="not is_upsell or is_from_pos"
                            class="oe_edit_only"
                        />
                    </group>
                    <group>
                        <field
                            name="base_price"
                            widget="monetary"
                            options="{'field_digits': True}"
                            invisible="not is_from_pos"
                        />
                        <field
                            name="company_id"
                            placeholder="Visible to all"
                            groups="base.group_multi_company"
                            options="{'no_create': True}"
                            class="oe_inline"
                        />
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
