<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_price_inclusion_wizard_form" model="ir.ui.view">
        <field name="name">pos.price.inclusion.wizard.form</field>
        <field name="model">pos.price.inclusion.wizard</field>
        <field name="arch" type="xml">
            <form string="How do you want to display prices?">
                <sheet>
                        <p>
                            Odoo stores one price per product. How tax is applied to
                            that price is not mathematically reversible so rounding
                            creates permanent discrepancies.
                        </p>
                        <div class="d-flex gap-2 alert alert-warning" role="alert">
                            <div class="fw-bold">Example: </div>
                            <field name="example_text" nolabel="1"/>
                        </div>
                </sheet>
                <footer>
                    <button name="action_tax_included" string="Tax Included" type="object" class="btn-primary"/>
                    <button name="action_tax_excluded" string="Tax Excluded" type="object" class="btn-primary"/>
                    <button name="action_discard" string="Discard" type="object" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
