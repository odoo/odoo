<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <template id="point_of_sale.pos_order_change_receipt">
            <html id="pos-receipt">
                <head>
                    <meta charset="UTF-8"></meta>  <!--  Needed for wkhtmltoimage to render UTF-8 characters properly -->
                    <t t-call="point_of_sale.pos_order_receipt_style" />
                </head>
                <body>
                    <div class="pos-receipt m-0 p-0 pt-5">
                        <div name="receipt-header" class="text-center">
                            <div name="preset-info" class="preset-name text-huge text-center text-bold" t-if="preset"> <!-- TODO: remove class .preset-name in master -->
                                <span t-esc="preset['name']"/>
                                <span t-if="extra_data.get('preset_time')"> (<t t-esc="extra_data['preset_time']"/>)</span>
                            </div>
                            <div name="employee-info" class="text-small">
                                <span><t t-esc="config['name']"/> : <t t-esc="extra_data['time']"/></span><br/>
                                <span t-if="extra_data.get('employee_name')">By: <t t-esc="extra_data['employee_name']"/></span>
                            </div>
                            <div name="order-info" class="my-2 text-huge">
                                <div>
                                    <span t-if="extra_data.get('order_name_prefix')" t-esc="extra_data['order_name_prefix'] + ' '"/>
                                    <span class="text-bold" t-esc="extra_data['order_name']"/>
                                </div>
                                <div t-if="conditions.get('show_tracking_number')">
                                    # <t t-esc="order['tracking_number']"/>
                                </div>
                            </div>
                            <div name="order-reference" t-if="conditions.get('show_pos_reference')" t-out="order['pos_reference']" />
                        </div>
                        <hr style="border: none; border-top: 4px dashed black;"/>
                        <div name="receipt-body" class="pos-receipt-body pb-5"> <!-- TODO: remove class .pos-receipt-body in master -->
                            <t t-set="hasDataChanges" t-value="changes.get('data') or changes.get('title') or changes.get('groupedData')" />
                            <div t-if="changes.get('title')" class="text-center text-bold text-insane w-100">
                                <t t-esc="changes['title']" />
                                <t t-if="extra_data['reprint']">
                                    (DUPLICATE !)
                                </t>
                            </div>

                            <t t-if="changes.get('groupedData') and len(changes['groupedData'])">
                                <div t-foreach="changes['groupedData']" t-as="group">
                                    <div style="border-bottom: 2px dashed black;" class="mb-2 pb-1 text-bold mt-1 text-huge" t-esc="group['name']" />
                                    <div t-foreach="group['data']" t-as="line">
                                        <t t-call="point_of_sale.pos_order_change_receipt_line" />
                                    </div>
                                </div>
                            </t>
                            <t t-else="">
                                <div t-foreach="changes['data']" t-as="line">
                                    <t t-call="point_of_sale.pos_order_change_receipt_line" />
                                </div>
                            </t>

                            <div t-if="extra_data.get('internal_note')" name="new-changes-internal-note" class="new-changes w-100" t-att-class="{'mb-3': order['general_customer_note']}"> <!-- TODO: remove class .new-changes in master -->
                                <div class="text-center text-insane w-100 text-bold">
                                    <strong>INTERNAL NOTE</strong>
                                </div>
                                <div class="text-center text-huge text-italic" t-esc="extra_data['internal_note']" />
                            </div>

                            <div t-if="extra_data['general_customer_note']" name="new-changes-customer-note" class="new-changes w-100"> <!-- TODO: remove class .new-changes in master -->
                                <div class="text-center text-insane w-100 text-bold">
                                    <strong>CUSTOMER NOTE</strong>
                                </div>
                                <div class="text-center text-large" t-esc="extra_data['general_customer_note']" />
                            </div>
                        </div>
                    </div>
                </body>
            </html>
        </template>

        <template id="point_of_sale.pos_order_change_receipt_line">
            <div t-att-class="{'ps-5': line['combo_parent_uuid']}" class="orderline text-large">
                <div class="text-huge">
                    <span class="d-inline-block me-1 font-monospace" style="min-width: 44px;" t-esc="line['quantity']"/>
                    <span class="product-name text-break" t-esc="line['basic_name']"/>
                </div>
                <div t-if="line.get('attribute_value_names') and len(line['attribute_value_names'])" class="ps-5">
                    <t t-foreach="line['attribute_value_names']" t-as="name">
                        <div class="text-large">- <t t-esc="name" /></div>
                    </t>
                </div>
                <div t-if="line.get('note')" class="text-italic text-large">
                    <t t-esc="line['note']"/>
                </div>
                <div t-if="line.get('customer_note')" class="text-italic text-large">
                    <t t-esc="line['customer_note']"/>
                </div>
            </div>
        </template>
    </data>
</odoo>
