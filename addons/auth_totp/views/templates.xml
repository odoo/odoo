<odoo>

    <template id="auth_totp_form" name="Two-Factor Authentication">
        <t t-call="web.login_layout" disable_footer.translate="1">
            <div class="oe_login_form">
                <h5 class="card-title">Enter verification code</h5>
                <form method="POST" action="" class="">
                    <div class="mb-2 mt-2 text-muted">
                        <!-- Key emoji HTML code-->
                        &#128273; Check your Authenticator app for your code.
                        <br/>
                    </div>
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <input type="hidden" name="redirect" t-att-value="redirect"/>
                    <div class="mb-3">
                        <input
                            id="totp_token" name="totp_token" class="form-control mb-2" autocomplete="one-time-code"
                            inputmode="numeric" autofocus="autofocus" required="required" placeholder="Enter code"
                        />
                    </div>
                    <div class="text-center py-2 border-top">
                        <p class="alert alert-danger" t-if="error" role="alert">
                            <t t-out="error"/>
                        </p>
                    <div class="mb-2 mt-2 text-muted">
                        <input type="checkbox" name="remember" id="switch-remember" value="1"/>
                        <label for="switch-remember">Don't ask again on this device</label>
                    </div>
                        <div t-attf-class="clearfix oe_login_buttons text-center d-grid mb-1">
                            <button type="submit" class="btn btn-primary">
                                Log in
                            </button>
                        </div>

                    </div>
                </form>
            </div>
        </t>
    </template>
</odoo>
