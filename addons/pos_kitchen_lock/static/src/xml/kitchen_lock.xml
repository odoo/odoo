<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <!--
        Add a lock badge next to the product name for kitchen-sent lines.
        The 'kitchen-sent-locked' CSS class is applied via PosOrderline.getDisplayClasses()
        in kitchen_lock.js — no xpath attribute override needed here.
    -->
    <t t-name="pos_kitchen_lock.Orderline" t-inherit="point_of_sale.Orderline" t-inherit-mode="extension">
        <xpath expr="//span[hasclass('text-wrap')]" position="after">
            <span t-if="line.isKitchenSent() and !vals.isReceipt" class="kitchen-lock-badge">&#x1F512;</span>
        </xpath>
    </t>

    <!-- Saver screen: replace logo -->
    <t t-name="pos_kitchen_lock.SaverScreen" t-inherit="point_of_sale.SaverScreen" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos-logo')]" position="replace">
            <div class="rkpos-saver-brand">RKPOS</div>
        </xpath>
    </t>

    <!-- Login screen: add Attendance button next to Open Register / Unlock Register -->
    <t t-name="pos_kitchen_lock.LoginScreen" t-inherit="point_of_sale.LoginScreen" t-inherit-mode="extension">
        <xpath expr="//button[hasclass('open-register-btn')]" position="after">
            <AttendanceLoginButton/>
        </xpath>
    </t>

    <!-- Navbar: replace logo + add AttendanceButton BEFORE the Dropdown (hamburger) -->
    <t t-name="pos_kitchen_lock.Navbar" t-inherit="point_of_sale.Navbar" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos-centerheader')]//div[hasclass('pos-logo')]" position="replace">
            <span class="rkpos-navbar-brand">RKPOS</span>
        </xpath>
        <xpath expr="//div[hasclass('status-buttons')]/Dropdown" position="before">
            <AttendanceButton/>
        </xpath>
    </t>
</templates>
