<?xml version="1.0" encoding="UTF-8"?>

<templates id="template" xml:space="preserve">
    <t t-name="website_links.RecentLink">
        <div class="row mb32 flex-nowrap">
            <div class="col-6">
                <h4 class="truncate_text">
                    <a class="no-link-style" t-att-href="widget.link_obj.url"><t t-esc="widget.link_obj.title"/></a>
                </h4>
                <p class="text-muted mb0">
                    <span class="o_website_links_short_url d-inline-flex flex-wrap align-items-center border border-primary rounded overflow-hidden">
                        <span t-esc="widget.link_obj.short_url" class="small text-break px-2 py-1"/>
                        <button class="btn btn-primary rounded-0 btn_shorten_url_clipboard py-1 w-100 w-md-auto" t-att-data-url="widget.link_obj.short_url">
                            <small>Copy</small>
                        </button>
                    </span>
                    <br/>
                    <span class="badge text-bg-secondary me-1" t-esc="widget.link_obj.campaign_id[1]"/>
                    <span class="badge text-bg-secondary me-1" t-esc="widget.link_obj.medium_id[1]"/>
                    <span class="badge text-bg-secondary me-1" t-esc="widget.link_obj.source_id[1]"/>
                </p>
                <p class="o_website_links_code_error"/>
            </div>
            <div class="col d-flex flex-column align-items-center justify-content-center">
                <h4 t-esc="widget.link_obj.count"/>
                <p class="text-muted">clicks</p>
            </div>
            <div class="col d-flex align-items-center justify-content-end">
                <a role="button" t-attf-href="{{widget.link_obj.short_url}}+" class="btn btn-primary">Open</a>
            </div>
        </div>
    </t>
</templates>
