<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="link_tracker_view_tree" model="ir.ui.view">
        <field name="name">link.tracker.view.list.inherit.website.links</field>
        <field name="model">link.tracker</field>
        <field name="inherit_id" ref="link_tracker.link_tracker_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='source_id']" position="after">
                <button name="action_visit_page_statistics" type="object" string="Statistics" icon="fa-bar-chart"/>
            </xpath>
        </field>
    </record>

    <record id="website_link_tracker_view_list" model="ir.ui.view">
        <field name="name">website.link.tracker.view.list</field>
        <field name="model">link.tracker</field>
        <field name="arch" type="xml">
            <list action="action_visit_page_statistics" type="object" default_order="create_date desc">
                <field name="create_date" string="Create Date"/>
                <field name="short_url" string="Link Tracker" optional="show"/>
                <field name="short_url" string="Copy" widget="CopyClipboardButton" options="{'btn_class': 'link'}"/>
                <field name="count" string="Click"/>
                <field name="campaign_id" string="Campaign"/>
                <field name="medium_id" string="Medium"/>
                <field name="source_id" string="Source"/>
                <field name="title"/>
                <button name="action_visit_page" type="object" string="Visit link" icon="fa-sign-out"/>
            </list>
        </field>
    </record>

    <record id="website_link_tracker_view_form" model="ir.ui.view">
        <field name="name">website.link.tracker.view.form</field>
        <field name="model">link.tracker</field>
        <field name="arch" type="xml">
            <form string="Website Link">
                <div class="oe_title mw-100">
                    <label for="url" string="Target Link"/>
                    <h2 class="d-flex flex-wrap fw-normal">
                        <field name="url" string="Target Link" class="w-100" placeholder="e.g. https://www.odoo.com/contactus" widget="url_autocomplete" />
                    </h2>
                </div>
                <div class="mw-100">
                    <p class="text-muted text-justify">Share this page with a <strong>short link</strong> that includes <strong>analytics trackers</strong>.</p>
                    <p class="text-muted text-justify">Those trackers can be used in Google Analytics to track clicks and visitors, or in Odoo reports to track opportunities and related revenues.</p>
                    <a target="_blank" href="https://www.odoo.com/documentation/latest/applications/websites/website/reporting/link_tracker.html">Read More</a>
                </div>
                <group class="mt-4">
                    <group name="utm" colspan="8">
                        <field name="campaign_id" options="{'create_name_field': 'title'}" placeholder="e.g. June Sale, Paris Roadshow, ..."/>
                        <field name="medium_id" placeholder="e.g. Email, Social, ..."/>
                        <field name="source_id" placeholder="e.g. Google, Facebook, ..."/>
                        <field name="label" string="Name" placeholder="e.g. &quot;Black Friday Mailing Campaign&quot;"/>
                    </group>
                </group>
            </form>
        </field>
    </record>

    <record id="action_link_tracker_tree" model="ir.actions.act_window">
        <field name="name">Link Tracker</field>
        <field name="res_model">link.tracker</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="website_link_tracker_view_list"/>
    </record>

    <menuitem id="menu_link_tracker"
        name="Link Tracker"
        sequence="25"
        parent="website.menu_current_page"
        action="website.website_preview"/>

    <menuitem id="menu_tracked_links_view_menu" name="Tracked Links"
        sequence="50"
        parent="website.menu_reporting"
        action="website_links.action_link_tracker_tree"/>
</odoo>
