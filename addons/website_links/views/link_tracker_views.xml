<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="link_tracker_view_tree" model="ir.ui.view">
        <field name="name">link.tracker.view.list.inherit.website.links</field>
        <field name="model">link.tracker</field>
        <field name="inherit_id" ref="link_tracker.link_tracker_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="replace">
                <list>
                    <field name="label" string="Name" />
                    <field name="count" string="Click"/>
                    <field name="url" string="Links"/>
                    <field name="campaign_id" string="Campaign"/>
                    <field name="medium_id" string="Medium"/>
                    <field name="source_id" string="Source"/>
                    <field name="url" string="" widget="CopyClipboardButton"/>
                    <button name="action_visit_page" type="object" string="Visit link" icon="fa-link"/>
                    <button name="action_visit_page_statistics" type="object" string="Statistics" icon="fa-bar-chart"/>
                </list>
            </xpath>
        </field>
    </record>

    <record id="link_tracker_view_form" model="ir.ui.view">
        <field name="name">link.tracker.form.view</field>
        <field name="model">link.tracker</field>
        <field name="inherit_id" ref="link_tracker.link_tracker_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="replace">
                <form js_class="link_tracker_dialog_form">
                    <sheet>
                        <group>
                            <field name="url" placeholder="Enter URL"/>
                            <field name="campaign_id"/>
                            <field name="medium_id"/>
                            <field name="source_id"/>
                            <field name="label" placeholder="Enter name" string="name"/>
                        </group>
                    </sheet>
                </form>
            </xpath>
        </field>
    </record>

    <record id="action_link_tracker_tree" model="ir.actions.act_window">
        <field name="name">Link Tracker</field>
        <field name="res_model">link.tracker</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="link_tracker_view_tree"/>
    </record>

    <menuitem id="menu_link_tracker"
        name="Link Tracker"
        sequence="25"
        parent="website.menu_current_page"
        action="website.website_preview"/>

    <menuitem id="menu_tracked_link_view_menu" name="Tracked Links"
        sequence="50"
        parent="website.menu_reporting"
        action="website_links.action_link_tracker_tree"/>
</odoo>
