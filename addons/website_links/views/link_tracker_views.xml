<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="link_tracker_view_tree" model="ir.ui.view">
        <field name="name">link.tracker.view.list.inherit.website.links</field>
        <field name="model">link.tracker</field>
        <field name="inherit_id" ref="link_tracker.link_tracker_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_visit_page']" position="after">
                <button name="action_visit_page_statistics" type="object" string="Statistics" icon="fa-bar-chart"/>
            </xpath>
        </field>
    </record>

    <record id="link_tracker_view_form" model="ir.ui.view">
        <field name="name">link.tracker.form.view</field>
        <field name="model">link.tracker</field>
        <field name="arch" type="xml">
            <form js_class="link_tracker_dialog_form">
                <group class="mt-4">
                    <div class="o_row">
                        <label for="url" string="url"/>
                        <field name="url"/>
                    </div>
                </group>
                <group>
                    <div class="o_row">
                        <label for="campaign_id" string="campaign_id"/>
                        <field name="campaign_id"/>
                    </div>
                </group>
                <group>
                    <div class="o_row">
                        <label for="medium_id" string="medium_id"/>
                        <field name="medium_id"/>
                    </div>
                </group>
                <group>
                    <div class="o_row">
                        <label for="source_id" string="source_id"/>
                        <field name="source_id"/>
                    </div>
                </group>
            </form>
        </field>
    </record>

    <menuitem id="menu_link_tracker"
        name="Link Tracker"
        sequence="25"
        parent="website.menu_current_page"
        action="website.website_preview"/>
</odoo>
