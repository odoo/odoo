<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="website_res_config_settings_view_form" model="ir.ui.view">
        <field name="name">website_res.config.settings.view.form</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='journal_id']" position="after">
                <div>
                    <label for="simplified_journal" class="o_light_label me-2"/>
                    <field name="simplified_journal" class="oe_inline"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
