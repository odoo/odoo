<odoo>
    <record id="tour_commission_action" model="ir.actions.act_window">
        <field name="name">Commissions</field>
        <field name="res_model">tour.commission</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="tour_commission_view_list" model="ir.ui.view">
        <field name="name">tour.commission.list</field>
        <field name="model">tour.commission</field>
        <field name="arch" type="xml">
            <list>
                <field name="booking_id"/>
                <field name="taxi_partner_id"/>
                <field name="commission_amount"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="tour_commission_view_form" model="ir.ui.view">
        <field name="name">tour.commission.form</field>
        <field name="model">tour.commission</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_paid" type="object" string="Mark Paid" invisible="state != 'pending'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="booking_id"/>
                        <field name="taxi_partner_id"/>
                        <field name="transport_assignment_id"/>
                        <field name="commission_amount"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
