<odoo>
    <record id="tour_vehicle_action" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">tour.vehicle</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="tour_vehicle_view_list" model="ir.ui.view">
        <field name="name">tour.vehicle.list</field>
        <field name="model">tour.vehicle</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="vehicle_type"/>
                <field name="plate_number"/>
                <field name="capacity"/>
                <field name="driver_name"/>
                <field name="utilization_count"/>
            </list>
        </field>
    </record>

    <record id="tour_vehicle_view_form" model="ir.ui.view">
        <field name="name">tour.vehicle.form</field>
        <field name="model">tour.vehicle</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <h1>
                        <field name="name"/>
                    </h1>
                    <group>
                        <group>
                            <field name="vehicle_type"/>
                            <field name="plate_number"/>
                            <field name="capacity"/>
                        </group>
                        <group>
                            <field name="driver_name"/>
                            <field name="driver_phone"/>
                            <field name="active"/>
                            <field name="utilization_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Transport Assignments">
                            <field name="assignment_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
