<odoo>
    <record id="tour_customer_action" model="ir.actions.act_window">
        <field name="name">Customers</field>
        <field name="res_model">tour.customer</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="tour_customer_view_list" model="ir.ui.view">
        <field name="name">tour.customer.list</field>
        <field name="model">tour.customer</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="nationality"/>
                <field name="total_bookings"/>
            </list>
        </field>
    </record>

    <record id="tour_customer_view_form" model="ir.ui.view">
        <field name="name">tour.customer.form</field>
        <field name="model">tour.customer</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <h1>
                        <field name="name"/>
                    </h1>
                    <group>
                        <group>
                            <field name="phone"/>
                            <field name="email"/>
                        </group>
                        <group>
                            <field name="nationality"/>
                            <field name="passport_number"/>
                            <field name="total_bookings"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Bookings">
                            <field name="booking_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
