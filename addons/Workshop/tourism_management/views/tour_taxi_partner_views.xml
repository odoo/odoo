<odoo>
    <record id="tour_taxi_partner_action" model="ir.actions.act_window">
        <field name="name">Taxi Partners</field>
        <field name="res_model">tour.taxi.partner</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="tour_taxi_partner_view_list" model="ir.ui.view">
        <field name="name">tour.taxi.partner.list</field>
        <field name="model">tour.taxi.partner</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="contact_person"/>
                <field name="phone"/>
                <field name="commission_rate"/>
            </list>
        </field>
    </record>

    <record id="tour_taxi_partner_view_form" model="ir.ui.view">
        <field name="name">tour.taxi.partner.form</field>
        <field name="model">tour.taxi.partner</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <h1>
                        <field name="name"/>
                    </h1>
                    <group>
                        <group>
                            <field name="contact_person"/>
                            <field name="phone"/>
                            <field name="email"/>
                        </group>
                        <group>
                            <field name="commission_rate"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Transport Assignments">
                            <field name="assignment_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
