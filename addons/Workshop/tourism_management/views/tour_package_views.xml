<odoo>
    <record id="tour_package_action" model="ir.actions.act_window">
        <field name="name">Tour Packages</field>
        <field name="res_model">tour.package</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="tour_package_view_list" model="ir.ui.view">
        <field name="name">tour.package.list</field>
        <field name="model">tour.package</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="package_type"/>
                <field name="base_price"/>
                <field name="max_capacity"/>
                <field name="total_bookings"/>
                <field name="expected_revenue"/>
            </list>
        </field>
    </record>

    <record id="tour_package_view_form" model="ir.ui.view">
        <field name="name">tour.package.form</field>
        <field name="model">tour.package</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <h1>
                        <field name="name"/>
                    </h1>
                    <group>
                        <group>
                            <field name="package_type"/>
                            <field name="destination_ids" widget="many2many_tags"/>
                            <field name="duration_hours"/>
                        </group>
                        <group>
                            <field name="base_price"/>
                            <field name="max_capacity"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Statistics">
                        <field name="total_bookings"/>
                        <field name="expected_revenue"/>
                    </group>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
