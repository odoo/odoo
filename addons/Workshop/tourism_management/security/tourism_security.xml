<odoo>
    <record id="module_category_tourism" model="ir.module.category">
        <field name="name">Tourism</field>
    </record>

    <record id="res_groups_privilege_tourism" model="res.groups.privilege">
        <field name="name">Tourism</field>
        <field name="category_id" ref="module_category_tourism"/>
    </record>

    <record id="group_tourism_user" model="res.groups">
        <field name="name">User</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_tourism"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_tourism_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_tourism"/>
        <field name="implied_ids" eval="[(4, ref('group_tourism_user'))]"/>
    </record>

    <record id="group_tourism_finance" model="res.groups">
        <field name="name">Tourism Finance</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>
