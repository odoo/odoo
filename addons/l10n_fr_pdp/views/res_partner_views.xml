<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_partner_form_l10n_fr_pdp" model="ir.ui.view">
        <field name="name">res.partner.form.l10n.fr.pdp</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="account_peppol.res_partner_form_account_peppol"/>
            <field name="arch" type="xml">
            <data>
                <xpath expr="//label[@for='peppol_verification_state']" position="attributes">
                    <attribute name="for">pdp_verification_display_state</attribute>
                </xpath>
                <xpath expr="//div[@invisible='not peppol_response_support']/field[@name='peppol_verification_state' and @readonly='1']" position="attributes">
                    <attribute name="name">pdp_verification_display_state</attribute>
                </xpath>
                <xpath expr="//div[@invisible='peppol_response_support']/field[@name='peppol_verification_state' and @readonly='1']" position="attributes">
                    <attribute name="name">pdp_verification_display_state</attribute>
                </xpath>
            </data>
        </field>
    </record>

</odoo>
