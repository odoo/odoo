<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_peppol_response_view_form" model="ir.ui.view">
        <field name="name">account.peppol.response.view.form.l10n.fr.pdp</field>
        <field name="model">account.peppol.response</field>
        <field name="inherit_id" ref="account_peppol.account_peppol_response_view_form"/>
        <field name="arch" type="xml">
            <field name="response_code" position="after">
                <field name="pdp_ref_response_code"/>
                <field name="pdp_flow_number"/>
                <field name="pdp_issue_date"/>
                <field name="pdp_ref_uuid"/>
                <field name="pdp_status_info"/>
                <field name="pdp_payment_info"/>
            </field>
        </field>
    </record>

    <record id="account_peppol_response_view_list" model="ir.ui.view">
        <field name="name">account.peppol.response.view.list.l10n.fr.pdp</field>
        <field name="model">account.peppol.response</field>
        <field name="inherit_id" ref="account_peppol.account_peppol_response_view_list"/>
        <field name="arch" type="xml">
            <field name="response_code" position="after">
                <field name="pdp_ref_response_code" optional="hide"/>
                <field name="pdp_flow_number" optional="hide"/>
                <field name="pdp_issue_date" optional="hide"/>
                <field name="pdp_status_info" optional="hide"/>
                <field name="pdp_ref_uuid" optional="hide"/>
                <field name="pdp_ppf_state" optional="hide"/>
            </field>
        </field>
    </record>
</odoo>
