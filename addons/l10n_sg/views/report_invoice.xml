<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_invoice_document" inherit_id="account.report_invoice_document" primary="True">
        <t name="invoice_title" position="replace">
            <t name="invoice_title">Tax Invoice</t>
        </t>
        <t name="draft_invoice_title" position="replace">
            <t name="draft_invoice_title">Draft Tax Invoice</t>
        </t>
        <t name="cancelled_invoice_title" position="replace">
            <t name="cancelled_invoice_title">Cancelled Tax Invoice</t>
        </t>
        <t name="proforma_invoice_title" position="replace">
            <t name="proforma_invoice_title">Proforma Tax Invoice</t>
        </t>
        <t name="draft_proforma_invoice_title" position="replace">
            <t name="draft_proforma_invoice_title">Draft Proforma Tax Invoice</t>
        </t>
        <t name="cancelled_proforma_invoice_title" position="replace">
            <t name="cancelled_proforma_invoice_title">Cancelled Proforma Tax Invoice</t>
        </t>
        <t name="self_billing_invoice_title" position="replace">
            <t name="self_billing_invoice_title">Self-Billing Tax Invoice</t>
        </t>
        <t name="vendor_bill_title" position="replace">
            <t name="vendor_bill_title">Tax Invoice</t>
        </t>

        <xpath expr="//div[@id='informations']/div[@name='invoice_date']" position="after">
            <div class="col" name="original_invoice_date" t-if="o.move_type == 'out_refund' and o.reversed_entry_id and o.reversed_entry_id.invoice_date">
                <strong>Original Invoice Date</strong>
                <div t-field="o.reversed_entry_id.invoice_date"/>
            </div>
        </xpath>

        <xpath expr="//div[@id='payment_term']" position="after">
            <div t-if="o.l10n_sg_customer_accounting_gst_amount" name="l10n_sg_customer_accounting" class="mt-3 mb-3">
                <p>
                    <t t-if="o.move_type == 'out_invoice'">
                        Customer Accounting: Customer to pay GST of
                        <span t-out="o.l10n_sg_customer_accounting_gst_amount"
                              t-options='{"widget": "monetary", "display_currency": o.company_currency_id}'/>
                        to IRAS
                    </t>
                    <t t-elif="o.move_type == 'out_refund'">
                        Customer Accounting: Customer to account for output tax adjustment of
                        <span t-out="-o.l10n_sg_customer_accounting_gst_amount"
                              t-options='{"widget": "monetary", "display_currency": o.company_currency_id}'/>
                        to IRAS
                    </t>
                </p>
            </div>
        </xpath>
    </template>

    <template id="report_invoice" inherit_id="account.report_invoice">
        <xpath expr='//t[@t-call="account.report_invoice_document"]' position="after">
            <t t-elif="o._get_name_invoice_report() == 'l10n_sg.report_invoice_document'"
               t-call="l10n_sg.report_invoice_document"
               t-lang="lang"/>
        </xpath>
    </template>
</odoo>
