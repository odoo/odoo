    <!-- === PRIMARY PAYMENT METHODS === -->

    <record id="payment_method_bancontact" model="payment.method">
        <field name="name">Bancontact</field>
        <field name="code">bancontact</field>
        <field name="provider_id" ref="payment.payment_provider_mollie"/>
        <field name="image" type="bytes" file="payment/static/img/bancontact.png"/>
        <field name="support_tokenization">False</field>
        <field name="supported_country_ids" eval="[Command.set([ref('base.be')])]"/>
        <field name="supported_currency_ids" eval="[Command.set([ref('base.EUR')])]"/>
    </record>

