<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="view_partner_form" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.l10n_ph_bir</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="account.view_partner_property_form"/>
        <field name="arch" type="xml">
            <label for="parent_id" position="before">
                <div class="d-flex align-items-baseline gap-2 text-muted" invisible="'PH' not in fiscal_country_codes or l10n_ph_entity_type == 'corporation'">
                    <label for="l10n_ph_first_name" class="flex-shrink-0"/>
                    <field name="l10n_ph_first_name" class="w-auto me-5"/>
                    <label for="l10n_ph_middle_name" class="flex-shrink-0"/>
                    <field name="l10n_ph_middle_name" class="w-auto me-5"/>
                    <label for="l10n_ph_last_name" class="flex-shrink-0"/>
                    <field name="l10n_ph_last_name" class="w-auto me-5"/>
                </div>
            </label>
            <xpath expr="//span[@name='address_name']" position="before">
                <field name="l10n_ph_entity_type" string="Entity type" invisible="'PH' not in fiscal_country_codes"/>
            </xpath>
            <xpath expr="//sheet" position="before">
                <div class="alert alert-warning"
                        role="alert"
                        invisible="l10n_ph_entity_type != 'individual' or (l10n_ph_first_name and l10n_ph_middle_name and l10n_ph_last_name) or 'PH' not in fiscal_country_codes">
                    First name, middle name, or last name is missing for individual entity. Accounting Reports may be affected.
                </div>
            </xpath>
            <xpath expr="//div[@id='vat_div']" position="after">
                <field name="l10n_ph_branch_code" invisible="'PH' not in fiscal_country_codes"/>
            </xpath>
        </field>
    </record>
</odoo>
