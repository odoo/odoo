<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_l10n_ph_discount_privilege_tree" model="ir.ui.view">
        <field name="name">l10n_ph.discount.privilege.list</field>
        <field name="model">l10n_ph.discount.privilege</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="discount_amount"/>
                <field name="tax_id"/>
                <field name="account_id"/>
                <field name="applied_to_category_ids" widget="many2many_tags" optional="show"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_l10n_ph_discount_privilege_form" model="ir.ui.view">
        <field name="name">l10n_ph.discount.privilege.form</field>
        <field name="model">l10n_ph.discount.privilege</field>
        <field name="arch" type="xml">
            <form string="Discount Privilege">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="discount_amount"/>
                            <field name="tax_id"/>
                            <field name="account_id"/>
                        </group>
                        <group>
                            <field name="applied_to_category_ids" widget="many2many_tags"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_l10n_ph_discount_privilege" model="ir.actions.act_window">
        <field name="name">Discount Privileges</field>
        <field name="res_model">l10n_ph.discount.privilege</field>
        <field name="view_mode">list,form</field>
        <field name="group_ids" eval="[Command.link(ref('l10n_ph.group_l10n_ph_discount_privilege'))]"/>
    </record>
</odoo>

