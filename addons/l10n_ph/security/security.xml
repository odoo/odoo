        <field name="name">Discount Privileges</field>
        <field name="sequence">70</field>
        <field name="category_id" ref="base.module_category_accounting"/>
    </record>

    <record id="group_l10n_ph_discount_privilege" model="res.groups">
        <field name="name">Discount Privileges</field>
