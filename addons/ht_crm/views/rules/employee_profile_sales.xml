<odoo>
    <!-- Trưởng phòng nắm thông tin Sales mình -->
    <record id="rule_employee_profile_manager" model="ir.rule">
        <field name="name">Trưởng Phòng (Employee Profile Sales)</field>
        <field name="model_id" ref="model_employee_profile_sales"/>
        <field name="domain_force">[
            '|',
            ('manager_id.user_id', '=', user.id),
            ('user_id', '=', user.id)
        ]</field>
        <field name="groups" eval="[(4, ref('group_ht_sales_leader'))]"/>
    </record>

    <record id="rule_employee_profile_sales" model="ir.rule">
        <field name="name">Sales (Employee Profile Sales)</field>
        <field name="model_id" ref="model_employee_profile_sales"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_ht_sales_user'))]"/>
    </record>
</odoo>