<odoo>
    <record id="rule_transaction_ga" model="ir.rule">
        <field name="name">GA (Transaction)</field>
        <field name="model_id" ref="model_sale_transaction"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_ht_general_admin'))]"/>
    </record>

    <record id="rule_employee_ga" model="ir.rule">
        <field name="name">GA (Employee)</field>
        <field name="model_id" ref="model_sale_employee"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_ht_general_admin'))]"/>
    </record>

    <record id="rule_employee_kpi_ga" model="ir.rule">
        <field name="name">GA (Employee KPI)</field>
        <field name="model_id" ref="model_sale_employee_kpi"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_ht_general_admin'))]"/>
    </record>
    
    <!-- Hệ Thống -->
    <record id="rule_employee_admin" model="ir.rule">
        <field name="name">Hệ Thống (Employee)</field>
        <field name="model_id" ref="model_sale_employee"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>

    <record id="rule_kpi_admin" model="ir.rule">
        <field name="name">Hệ Thống (KPI)</field>
        <field name="model_id" ref="model_sale_employee_kpi"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>

    <record id="rule_transaction_admin" model="ir.rule">
        <field name="name">Hệ Thống (Transaction)</field>
        <field name="model_id" ref="model_sale_transaction"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>
    
    <!-- Ban Điều Hành -->
    <record id="rule_employee_exec" model="ir.rule">
        <field name="name">Ban Điều Hành (Employee)</field>
        <field name="model_id" ref="model_sale_employee"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_ht_executive'))]"/>
    </record>

    <record id="rule_kpi_exec" model="ir.rule">
        <field name="name">Ban Điều Hành (KPI)</field>
        <field name="model_id" ref="model_sale_employee_kpi"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_ht_executive'))]"/>
    </record>

    <record id="rule_transaction_exec" model="ir.rule">
        <field name="name">Ban Điều Hành (Transaction)</field>
        <field name="model_id" ref="model_sale_transaction"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_ht_executive'))]"/>
    </record>

    <!-- Trưởng Phòng -->
    <record id="rule_employee_manager" model="ir.rule">
        <field name="name">Trưởng Phòng (Employee)</field>
        <field name="model_id" ref="model_sale_employee"/>
        <field name="domain_force">
            [
                '|',
                ('user_id', '=', user.id),
                ('manager_id.user_id', '=', user.id)
            ]
        </field>
        <field name="groups" eval="[(4, ref('group_ht_leader'))]"/>
    </record>

    <record id="rule_kpi_manager" model="ir.rule">
        <field name="name">Trưởng Phòng (Employee)</field>
        <field name="model_id" ref="model_sale_employee_kpi"/>
        <field name="domain_force">
            [
                '|',
                ('employee_id.user_id', '=', user.id),
                ('employee_id.manager_id.user_id', '=', user.id)
            ]
        </field>
        <field name="groups" eval="[(4, ref('group_ht_leader'))]"/>
    </record>

    <record id="rule_transaction_manager" model="ir.rule">
        <field name="name">Manager (Transaction)</field>
        <field name="model_id" ref="model_sale_transaction"/>
        <field name="domain_force">
            [
                '|',
                ('employee_id.user_id', '=', user.id),
                ('employee_id.manager_id.user_id', '=', user.id)
            ]
        </field>
        <field name="groups" eval="[(4, ref('group_ht_leader'))]"/>
    </record>

    <!-- User -->
    <record id="rule_employee_user" model="ir.rule">
        <field name="name">User (Employee)</field>
        <field name="model_id" ref="model_sale_employee"/>
        <field name="domain_force">
        [
            '|',
            ('user_id', '=', user.id),
            ('project_ids.sales_ids.user_id', '=', user.id)
        ]
        </field>
        <field name="groups" eval="[(4, ref('group_ht_user'))]"/>
    </record>

    <record id="rule_transaction_user" model="ir.rule">
        <field name="name">User (Transaction)</field>
        <field name="model_id" ref="model_sale_transaction"/>
        <field name="domain_force">
            [
                ('employee_id.user_id', '=', user.id)
            ]
        </field>
        <field name="groups" eval="[(4, ref('group_ht_user'))]"/>
    </record>

    <record id="view_employee_role_tree" model="ir.ui.view">
        <field name="name">sale.employee.role.tree</field>
        <field name="model">sale.employee.role</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_sale_employee_list" model="ir.ui.view">
        <field name="name">sale.employee.list</field>
        <field name="model">sale.employee</field>
        <field name="arch" type="xml">
            <list string="Danh Sách Nhân Viên" default_order="name">
                <!-- <field name="code"/> -->
                <field name="name"/>
                <field name="phone"/>
                <!-- <field name="department"/> -->
                <field name="manager_id"/>
                <!-- <field name="role_ids" widget="many2many_tags"/> -->
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_sale_transaction_list" model="ir.ui.view">
        <field name="name">sale.transaction.list</field>
        <field name="model">sale.transaction</field>
        <field name="arch" type="xml">
            <list string="Giao Dịch">
                <field name="name"/>
                <field name="date"/>
                <field name="employee_id"/>
                <field name="customer_id"/>
                <field name="product_id"/>
                <field name="price_total"/>
            </list>
        </field>
    </record>

    <record id="view_employee_kpi_list" model="ir.ui.view">
        <field name="name">sale.employee.kpi.list</field>
        <field name="model">sale.employee.kpi</field>
        <field name="arch" type="xml">
            <list string="KPI Nhân Viên" create="false" default_order="year desc, month desc, total_value desc">

                <field name="employee_id" string="Nhân viên"/>

                <!-- Thời gian -->
                <field name="month" string="Tháng"/>
                <field name="quarter" string="Quý"/>
                <field name="year" string="Năm"/>

                <!-- KPI -->
                <field name="total_value" string="Doanh thu"
                    widget="monetary"
                    options="{'currency_field': 'currency_id'}"/>

                <field name="total_deals" string="Số giao dịch"/>

                <!-- Highlight Best Seller -->
                <field name="is_best_seller_by_value" readonly="1"/>
                <field name="is_best_seller_by_quantity" readonly="1"/>

            </list>
        </field>
    </record>

    <record id="seq_sale_transaction" model="ir.sequence">
        <field name="name">Sale Transaction</field>
        <field name="code">sale.transaction</field>
        <field name="prefix">GD/%(year)s/</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
    </record>

    <record id="view_sale_transaction_form" model="ir.ui.view">
        <field name="name">sale.transaction.form</field>
        <field name="model">sale.transaction</field>
        <field name="arch" type="xml">
            <form string="Giao dịch">
                
                <!-- Header -->
                <header>
                    <button name="action_confirm_booking"
                        string="Giữ chỗ"
                        type="object"
                        class="btn-secondary"
                        invisible="state != 'draft'"/>

                    <button name="action_confirm_deposit"
                            string="Đặt cọc"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'booking'"/>

                    <button name="action_cancel"
                            string="Hủy"
                            type="object"
                            class="btn-danger"
                            invisible="state == 'cancel'"/>

                    <field name="state"
                        widget="statusbar"
                        statusbar_visible="draft,booking,deposit,cancel"/>
                </header>

                <sheet>

                    <!-- Ribbon -->
                    <widget name="web_ribbon"
                            title="Đặt cọc"
                            bg_color="bg-success"
                            invisible="state != 'deposit'"/>

                    <widget name="web_ribbon"
                            title="Booking"
                            bg_color="bg-warning"
                            invisible="state != 'booking'"/>

                    <widget name="web_ribbon"
                            title="Hủy"
                            bg_color="bg-danger"
                            invisible="state != 'cancel'"/>

                    <widget name="web_ribbon"
                        title="Nháp"
                        bg_color="bg-info"
                        invisible="state != 'draft'"/>

                    <!-- Title -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <!-- Main Info -->
                    <group>
                        <group string="Thông tin giao dịch">

                            <field name="date"/>

                            <field name="employee_id"
                                options="{'no_create': False}"/>

                            <field name="customer_id"
                                options="{'no_create': False}"/>

                        </group>

                        <group string="Thông tin sản phẩm">

                            <field name="product_id"
                                options="{'no_create': True}"/>

                            <field name="net_area" readonly="1"/>

                            <field name="gross_area" readonly="1"/>

                        </group>
                    </group>

                    <!-- Price Section -->
                    <group string="Thông tin tài chính" col="4">

                        <field name="listed_price"
                            readonly="1"
                            class="oe_inline"/>

                        <field name="discount"
                            widget="percentage"/>

                        <field name="price_total"
                            readonly="1"
                            class="oe_inline"/>

                        <label for="price_total"/>
                        <div class="text-muted">
                            Giá cuối cùng sau VAT và chiết khấu
                        </div>

                    </group>

                    <!-- Notebook -->
                    <notebook>

                        <page string="Lịch sử">
                            <group>
                                <field name="create_uid" readonly="1"/>
                                <field name="create_date" readonly="1"/>
                                <field name="write_uid" readonly="1"/>
                                <field name="write_date" readonly="1"/>
                            </group>
                        </page>

                    </notebook>

                </sheet>

                <!-- Chatter -->
                <chatter/>

            </form>
        </field>
    </record>

    <record id="view_sale_transaction_kanban" model="ir.ui.view">
        <field name="name">sale.transaction.kanban</field>
        <field name="model">sale.transaction</field>
        <field name="arch" type="xml">

            <kanban default_group_by="state">

                <field name="name"/>
                <field name="customer_id"/>
                <field name="employee_id"/>
                <field name="product_id"/>
                <field name="price_total"/>
                <field name="state"/>


                <progressbar field="state"
                        colors='{
                        "draft": "info",
                        "booking": "warning",
                        "deposit": "success",
                        "cancel": "danger"
                }'/>

                <templates>

                    <t t-name="card">

                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="mb-2">
                                <widget name="web_ribbon"
                                        title="Đặt cọc"
                                        bg_color="bg-success"
                                        invisible="state != 'deposit'"/>

                                <widget name="web_ribbon"
                                        title="Booking"
                                        bg_color="bg-warning"
                                        invisible="state != 'booking'"/>

                                <widget name="web_ribbon"
                                        title="Hủy"
                                        bg_color="bg-danger"
                                        invisible="state != 'cancel'"/>

                                <widget name="web_ribbon"
                                    title="Nháp"
                                    bg_color="bg-info"
                                    invisible="state != 'draft'"/>
                            </div>

                            <!-- Header -->
                            <div class="o_kanban_record_top">
                                <strong>
                                    <field name="name"/>
                                </strong>
                            </div>

                            <!-- Body -->
                            <div class="mt-2">

                                <div>
                                    👤 <field name="customer_id"/>
                                </div>

                                <div>
                                    🏢 <field name="product_id"/>
                                </div>

                                <div>
                                    💰 <field name="price_total"/>
                                </div>

                            </div>

                            <!-- Footer -->
                            <div class="mt-3 text-muted">

                                <field name="employee_id"/>

                            </div>

                        </div>

                    </t>

                </templates>

            </kanban>

        </field>
    </record>
</odoo>