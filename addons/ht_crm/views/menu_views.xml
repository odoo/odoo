<?xml version="1.0"?>
<odoo>
    <record id="action_phonebook" model="ir.actions.act_window">
        <field name="name">Phonebook</field>
        <field name="res_model">sale.phonebook</field>
        <field name="view_mode">list,form</field>
    </record>
    
    <record id="action_phone_interaction" model="ir.actions.act_window">
        <field name="name">Phone Interactions</field>
        <field name="res_model">sale.phonebook.interaction</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_customer" model="ir.actions.act_window">
        <field name="name">Customers</field>
        <field name="res_model">sale.customer</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_users" model="ir.actions.act_window">
        <field name="name">Users</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
    </record>


    <record id="action_estate_project" model="ir.actions.act_window">
        <field name="name">Estate Projects</field>
        <field name="res_model">estate.project</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_employee" model="ir.actions.act_window">
        <field name="name">Employee</field>
        <field name="res_model">sale.employee</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_employee_kpi" model="ir.actions.act_window">
        <field name="name">KPI</field>
        <field name="res_model">sale.employee.kpi</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_transaction" model="ir.actions.act_window">
        <field name="name">Giao Dịch</field>
        <field name="res_model">sale.transaction</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>Theo dõi giao dịch bán hàng.</p>
        </field>
    </record>

    <record id="action_employee_role" model="ir.actions.act_window">
        <field name="name">Employee Role</field>
        <field name="res_model">sale.employee.role</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_transaction" model="ir.actions.act_window">
        <field name="name">Transaction</field>
        <field name="res_model">sale.transaction</field>
        <field name="view_mode">list,form</field>
    </record>


    <menuitem id="menu_ht_root" name="HTLand CRM" sequence="10">

        <!-- CUSTOMER MANAGEMENT -->
        <menuitem id="menu_customer_root" name="Khách Hàng" sequence="10">
            <menuitem id="menu_customer" action="action_customer"/>
            <menuitem id="menu_phonebook" action="action_phonebook"/>
            <menuitem id="menu_project" action="action_estate_project"/>
        </menuitem>

        <!-- SALES -->
        <menuitem id="menu_sales_root" name="Sales" sequence="20">
            <menuitem id="menu_transaction" action="action_transaction"/>
            <menuitem id="menu_kpi" action="action_employee_kpi"/>
        </menuitem>

        <!-- ORGANIZATION -->
        <menuitem id="menu_org_root" name="Tổ Chức" sequence="30">
            <menuitem id="menu_employee" action="action_employee"/>
            <menuitem id="menu_role" action="action_employee_role"/>
        </menuitem>

        <!-- SYSTEM -->
        <menuitem id="menu_system_root" name="Hệ Thống" sequence="40">
            <menuitem id="menu_users" action="action_users"/>
        </menuitem>

    </menuitem> 
</odoo>
