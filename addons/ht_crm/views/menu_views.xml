<?xml version="1.0"?>
<odoo>
    <record id="action_phonebook" model="ir.actions.act_window">
        <field name="name">Data</field>
        <field name="res_model">sale.phonebook</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <record id="action_phonebook_batch" model="ir.actions.act_window">
        <field name="name">Tập dữ liệu</field>
        <field name="res_model">sale.phonebook.batch</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_employee_project_rel" model="ir.actions.act_window">
        <field name="name">Nhóm DA</field>
        <field name="res_model">employee.project.rel</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_customer" model="ir.actions.act_window">
        <field name="name">Khách hàng</field>
        <field name="res_model">sale.customer</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_users" model="ir.actions.act_window">
        <field name="name">Người dùng</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Dự án -->
    <record id="action_estate_project" model="ir.actions.act_window">
        <field name="name">Dự án bất động sản</field>
        <field name="res_model">estate.project</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_estate_project_promotion" model="ir.actions.act_window">
        <field name="name">Ưu đãi dự án</field>
        <field name="res_model">estate.project.promotion</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_estate_payment_plan" model="ir.actions.act_window">
        <field name="name">Phương thức thanh toán</field>
        <field name="res_model">estate.payment.plan</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_estate_payment_plan_line" model="ir.actions.act_window">
        <field name="name">Chi tiết thanh toán</field>
        <field name="res_model">estate.payment.plan.line</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_estate_property_unit" model="ir.actions.act_window">
        <field name="name">Căn hộ / Sản phẩm bất động sản</field>
        <field name="res_model">estate.property.unit</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_estate_property_unit_type" model="ir.actions.act_window">
        <field name="name">Loại căn hộ / sản phẩm</field>
        <field name="res_model">estate.property.unit.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Nhân sự -->
    <record id="action_employee_profile" model="ir.actions.act_window">
        <field name="name">Nhân Sự</field>
        <field name="res_model">employee.profile</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_employee_profile_sales" model="ir.actions.act_window">
        <field name="name">Nhân viên Sales</field>
        <field name="res_model">employee.profile.sales</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_employee_kpi" model="ir.actions.act_window">
        <field name="name">Sales KPI</field>
        <field name="res_model">employee.profile.sales.kpi</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_transaction" model="ir.actions.act_window">
        <field name="name">Giao Dịch</field>
        <field name="res_model">sale.transaction</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p>Theo dõi giao dịch bán hàng.</p>
        </field>
    </record>

    <record id="action_employee_role" model="ir.actions.act_window">
        <field name="name">Chức Vụ</field>
        <field name="res_model">employee.profile.role</field>
        <field name="view_mode">list,form</field>
    </record>


    <record id="action_customer_graph" model="ir.actions.act_window">
        <field name="name">Biểu đồ KH</field>
        <field name="res_model">sale.customer.report</field>
        <field name="view_mode">graph,list</field>
        <field name="context">{'graph_mode': 'pie'}</field>
    </record>

    <record id="action_transaction_graph" model="ir.actions.act_window">
        <field name="name">Biểu đồ GD</field>
        <field name="res_model">revenue.report</field>
        <field name="view_mode">graph,list</field>
    </record>

    <record id="action_estate_project_unit_report" model="ir.actions.act_window">
        <field name="name">Báo cáo sản phẩm dự án</field>
        <field name="res_model">estate.project.unit.report</field>
        <field name="view_mode">graph,pivot</field>
    </record>

    <record id="action_estate_project_report" model="ir.actions.act_window">
        <field name="name">Báo cáo dự án</field>
        <field name="res_model">estate.project.report</field>
        <field name="view_mode">graph,pivot</field>
    </record>

    <record id="action_employee_sales_log" model="ir.actions.act_window">
        <field name="name">Log Sales</field>
        <field name="res_model">employee.sales.log</field>
        <field name="view_mode">list,form,graph,pivot</field>
    </record>

    <record id="action_employee_sales_report" model="ir.actions.act_window">
        <field name="name">Báo cáo Sales</field>
        <field name="res_model">employee.sales.report</field>
        <field name="view_mode">graph,pivot</field>
    </record>

    <menuitem id="menu_ht_root" name="HTLand CRM">

        <!-- CUSTOMER MANAGEMENT -->
        <menuitem id="menu_customer_root" name="CRM">
            <menuitem id="menu_customer" action="action_customer"/>

            <menuitem id="menu_phonebook_root" name="Lead / Data">
                <menuitem id="menu_phonebook" action="action_phonebook"/>
                <menuitem id="menu_phonebook_batch" action="action_phonebook_batch"/>
            </menuitem>

            <menuitem id="menu_assignment" name="Phân bổ Data" action="action_employee_project_rel"/>
            <menuitem id="menu_sales_log" name="Sales Log" action="action_employee_sales_log"/>
        </menuitem>

        <menuitem id="menu_project_root" name="Dự Án" sequence="20">
            <menuitem id="menu_project" action="action_estate_project"/>
            <menuitem id="menu_project_promotion" action="action_estate_project_promotion"/>
            <menuitem id="menu_property_unit" action="action_estate_property_unit"/>
            <menuitem id="menu_property_unit_type" action="action_estate_property_unit_type"/>   
        </menuitem>

        <!-- SALES -->
        <menuitem id="menu_sales_root" name="Sales" sequence="30">
            <menuitem id="menu_transaction" action="action_transaction"/>
            <menuitem id="menu_kpi" action="action_employee_kpi"/>
            <menuitem id="menu_payment_plan" action="action_estate_payment_plan"/>
            <menuitem id="menu_payment_plan_line" action="action_estate_payment_plan_line"/>   
        </menuitem>

        <!-- ORGANIZATION -->
        <menuitem id="menu_org_root" name="Tổ Chức" sequence="40" groups="group_ht_leader,group_ht_executive">
            <menuitem id="menu_employee" action="action_employee_profile"/>
            <menuitem id="menu_employee_sales" action="action_employee_profile_sales"/>
            <menuitem id="menu_role" action="action_employee_role"/>
        </menuitem>

        <menuitem id="menu_statistics_root" name="Thống Kê" sequence="50">
            <menuitem id="menu_stats_customer" name="Khách hàng" action="action_customer_graph"/>
            <menuitem id="menu_stats_transaction" name="Giao dịch" action="action_transaction_graph"/>
            <menuitem id="menu_stats_project" name="Dự án" action="action_estate_project_report"/>
            <menuitem id="menu_stats_project_unit" name="Sản phẩm dự án" action="action_estate_project_unit_report"/>
            <menuitem id="menu_stats_sales" name="Sales" action="action_employee_sales_report"/>
        </menuitem> 

        <!-- SYSTEM -->
        <menuitem id="menu_system_root" name="Hệ Thống" sequence="50" groups="base.group_system">
            <menuitem id="menu_users" action="action_users"/>
        </menuitem>       
    </menuitem> 
</odoo>
