
<odoo>
    <!-- Hệ Thống -->
    <record id="rule_customer_admin" model="ir.rule">
        <field name="name">Hệ Thống (Customer)</field>
        <field name="model_id" ref="model_sale_customer"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_ht_executive'))]"/>
    </record>

    <record id="rule_phonebook_admin" model="ir.rule">
        <field name="name">Hệ Thống (Phonebook)</field>
        <field name="model_id" ref="model_sale_phonebook"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_ht_executive'))]"/>
    </record>

    <!-- Ban Điều Hành -->
    <record id="rule_customer_exec" model="ir.rule">
        <field name="name">Ban Điều Hành (Customer)</field>
        <field name="model_id" ref="model_sale_customer"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_ht_executive'))]"/>
    </record>

    <record id="rule_phonebook_exec" model="ir.rule">
        <field name="name">Ban Điều Hành (Phonebook)</field>
        <field name="model_id" ref="model_sale_phonebook"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_ht_executive'))]"/>
    </record>

    <!-- Trưởng Phòng-->
    <record id="rule_customer_leader" model="ir.rule">
        <field name="name">Trưởng Phòng (Customer)</field>
        <field name="model_id" ref="model_sale_customer"/>
        <field name="domain_force">
            [
                '|',
                ('salesperson_id.user_id', '=', user.id),
                ('salesperson_id.manager_id.user_id', '=', user.id)
            ]
        </field>
        <field name="groups" eval="[(4, ref('group_ht_leader'))]"/>
    </record>

    <!-- User -->
    <record id="rule_customer_user" model="ir.rule">
        <field name="name">User (Customer)</field>
        <field name="model_id" ref="model_sale_customer"/>
        <field name="domain_force">
            [
                ('salesperson_id.user_id', '=', user.id)
            ]
        </field>
        <field name="groups" eval="[(4, ref('group_ht_user'))]"/>
    </record>

    <record id="rule_phonebook_user" model="ir.rule">
        <field name="name">User (Phonebook)</field>
        <field name="model_id" ref="model_sale_phonebook"/>
        <field name="domain_force">[('project_id.sales_ids.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_ht_user'))]"/>
    </record>

    <!-- <record id="ir_cron_distribute" model="ir.cron">
        <field name="name">Phân số điện thoại</field>
        <field name="model_id" ref="model_sale_phonebook"/>
        <field name="code">model.cron_distribute()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
    </record> -->

    <record id="view_phonebook_list" model="ir.ui.view">
        <field name="name">sale.phonebook.list</field>
        <field name="model">sale.phonebook</field>
        <field name="arch" type="xml">
            <list>
                <header>
                    <button name="action_distribute_numbers" 
                            string="Distribute" 
                            type="object" 
                            class="oe_highlight"
                            groups="ht_crm.group_ht_executive,base.group_system"/>
                    <!-- <button name="reverse" 
                        string="Reverse" 
                        type="object" 
                        class="oe_highlight"
                        groups="ht_crm.group_ht_executive"/> -->
                </header>

                <field name="created_on" readonly="True"/>
                <field name="name" readonly="True"/>
                <field name="phone" widget="phone"/>
                <field name="status"/>
                <field name="note"/>
                <field name="project_id"/>
            </list>  
        </field>
    </record>

    <record id="view_sale_phonebook_log_list" model="ir.ui.view">
        <field name="name">sale.phonebook.log.list</field>
        <field name="model">sale.phonebook.log</field>
        <field name="arch" type="xml">
            <list string="Logs" create="false">
                <field name="create_date" string="Thời gian"/>
                <field name="user_id" string="Người thao tác"/>
                <field name="phonebook_id" string="Bị tác động"/>
                <field name="action" string="Hành động"/>
                <field name="note" string="Ghi chú"/>
            </list>
        </field>
    </record>

    <record id="view_sale_customer_form" model="ir.ui.view">
        <field name="name">sale.customer.form</field>
        <field name="model">sale.customer</field>

        <field name="arch" type="xml">
            <form string="Customer">
                <sheet>

                    <!-- TITLE -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Tên khách hàng..."/>
                        </h1>
                    </div>

                    <!-- 🔹 THÔNG TIN CHÍNH -->
                    <group string="Thông tin khách hàng">

                        <group>

                            <field name="partner_platform"/>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="source"/>
                            <field name="type"/>

                        </group>

                        <group>

                            <field name="salesperson_id"/>
                            <field name="status"/>

                        </group>

                    </group>

                    <!-- 🔹 THÔNG TIN CÁ NHÂN -->
                    <group string="Thông tin cá nhân">

                        <group>
                            <field name="date_of_birth"/>
                            <field name="id_number"/>
                        </group>

                        <group>
                            <field name="issue_date"/>
                            <field name="issue_place"/>
                        </group>

                    </group>

                    <!-- 🔹 ĐỊA CHỈ -->
                    <group string="Địa chỉ">

                        <field name="permanent_address"/>

                        <field name="contact_address"/>

                    </group>

                    <!-- NOTEBOOK -->
                    <notebook>
                        <page string="Giao dịch">
                            <field name="transaction_ids">
                                <list limit="5">
                                    <field name="product_id"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>

                        <!-- PROJECT -->
                        <page string="Dự án quan tâm">

                            <field name="project_ids"
                                widget="many2many_tags"/>

                        </page>

                    </notebook>

                </sheet>

            </form>
        </field>
    </record>

    <record id="view_customer_list" model="ir.ui.view">
        <field name="name">sale.customer.list</field>
        <field name="model">sale.customer</field>
        <field name="arch" type="xml">
            <list>
                <!-- TRƯỜNG CƠ BẢN -->
                <field name="name"/>
                <field name="id_number"/>
                <field name="email"/>
                <field name="date_of_birth"/>                
                <field name="issue_date"/>
                <field name="issue_place"/>
                <field name="permanent_address"/>
                <field name="contact_address"/>

                <!-- TRƯỜNG BỔ SUNG -->
                <field name="type" optional="hide"/>
                <field name="partner_platform" optional="hide"/>
            </list> 
        </field>
    </record>

</odoo>