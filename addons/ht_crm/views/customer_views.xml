
<odoo>
    <!-- Hệ Thống -->
    <record id="rule_customer_admin" model="ir.rule">
        <field name="name">Hệ Thống (Customer)</field>
        <field name="model_id" ref="model_sale_customer"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_ht_executive'))]"/>
    </record>

    <record id="rule_phonebook_admin" model="ir.rule">
        <field name="name">Hệ Thống (Phonebook)</field>
        <field name="model_id" ref="model_sale_phonebook"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_ht_executive'))]"/>
    </record>

    <!-- Ban Điều Hành -->
    <record id="rule_customer_exec" model="ir.rule">
        <field name="name">Ban Điều Hành (Customer)</field>
        <field name="model_id" ref="model_sale_customer"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_ht_executive'))]"/>
    </record>

    <record id="rule_phonebook_exec" model="ir.rule">
        <field name="name">Ban Điều Hành (Phonebook)</field>
        <field name="model_id" ref="model_sale_phonebook"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_ht_executive'))]"/>
    </record>

    <!-- Trưởng Phòng-->
    <record id="rule_customer_leader" model="ir.rule">
        <field name="name">Trưởng Phòng (Customer)</field>
        <field name="model_id" ref="model_sale_customer"/>
        <field name="domain_force">
            [
                '|',
                ('salesperson_id.user_id', '=', user.id),
                ('salesperson_id.manager_id.user_id', '=', user.id)
            ]
        </field>
        <field name="groups" eval="[(4, ref('group_ht_leader'))]"/>
    </record>

    <!-- User -->
    <record id="rule_customer_user" model="ir.rule">
        <field name="name">User (Customer)</field>
        <field name="model_id" ref="model_sale_customer"/>
        <field name="domain_force">
            [
                ('salesperson_id.user_id', '=', user.id)
            ]
        </field>
        <field name="groups" eval="[(4, ref('group_ht_user'))]"/>
    </record>

    <record id="rule_phonebook_user" model="ir.rule">
        <field name="name">User (Phonebook)</field>
        <field name="model_id" ref="model_sale_phonebook"/>
        <field name="domain_force">
            [
                ('customer_id.salesperson_id.user_id', '=', user.id)
            ]
        </field>
        <field name="groups" eval="[(4, ref('group_ht_user'))]"/>
    </record>

    
