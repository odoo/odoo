    <record id="view_phonebook_list" model="ir.ui.view">
        <field name="name">sale.phonebook.list</field>
        <field name="model">sale.phonebook</field>
        <field name="arch" type="xml">
            <list>
                <field name="customer_id" string="Tên khách hàng" readonly="True"/>
                <field name="phone" widget="phone"/>
                <field name="is_called"/>
                <field name="unreachable"/>
                <field name="is_primary"/>
                <field name="note"/>

                <!-- Nút Set Primary -->
                <button name="set_primary"
                        type="object"
                        string="Set Primary"
                        class="btn-primary"
                        icon="fa-star"/>
            </list>  
        </field>
    </record>

    <record id="view_sale_customer_form" model="ir.ui.view">
        <field name="name">sale.customer.form</field>
        <field name="model">sale.customer</field>
        <field name="arch" type="xml">
            <form string="Customer">

                <!-- Header: trạng thái -->
                <header>
                    <field name="state" widget="statusbar"
                        statusbar_visible="potential,active,vip,inactive,blocked"/>
                </header>

                <sheet>

                    <!-- Tên + thông tin cơ bản -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Tên khách hàng..."/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="email"/>
                            <field name="source"/>
                            <field name="type"/>
                        </group>

                        <group>
                            <field name="salesperson_id"/>
                            <field name="ignore"
                                groups="base.group_system,ht_crm.group_ht_leader,ht_crm.group_ht_executive"/>
                        </group>
                    </group>

                    <!-- Tabs -->
                    <notebook>

                        <!-- 📞 PHONEBOOK -->
                        <page string="Số điện thoại">

                            <field name="phonebook_ids">

                                <list editable="bottom">

                                    <!-- Ẩn vì đang ở customer -->
                                    <!-- <field name="customer_id" column_invisible="1"/> -->

                                    <!-- Chính -->
                                    <field name="phone" required="1"/>

                                    <!-- Trạng thái -->
                                    <field name="is_called"/>
                                    <field name="unreachable"/>

                                    <!-- Số chính -->
                                    <field name="is_primary"/>

                                    <!-- Ghi chú -->
                                    <field name="note"/>

                                </list>
                            </field>

                        </page>

                        <!-- 👥 SALES HISTORY -->
                        <page string="Lịch sử phụ trách"
                            groups="ht_crm.group_ht_executive">
                            <field name="previous_salesperson_ids" widget="many2many_tags"/>
                        </page>

                        <!-- 📁 PROJECT (placeholder vì bạn chưa define full) -->
                        <page string="Dự án quan tâm">
                            <field name="project_ids" widget="many2many_tags"/>
                        </page>

                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <record id="view_customer_list" model="ir.ui.view">
        <field name="name">sale.customer.list</field>
        <field name="model">sale.customer</field>
        <field name="arch" type="xml">
            <list>
                <header>
                    <button name="action_distribute_customers" 
                            string="Distribute" 
                            type="object" 
                            class="oe_highlight"
                            groups="ht_crm.group_ht_leader,ht_crm.group_ht_executive"/>
                    <button name="reverse" 
                        string="Reverse" 
                        type="object" 
                        class="oe_highlight"
                        groups="ht_crm.group_ht_leader,ht_crm.group_ht_executive"/>
                </header>
                <!-- TRƯỜNG CƠ BẢN -->
                <field name="name"/>
                <field name="partner_platform"/>
                <field name="email"/>
                <field name="date_of_birth"/>
                <field name="id_number"/>
                <field name="issue_date"/>
                <field name="issue_place"/>
                <field name="permanent_address"/>
                <field name="contact_address"/>

                <!-- TRƯỜNG BỔ SUNG -->
                <field name="salesperson_id"/>
                <field name="previous_salesperson_ids" widget="many2many_tags" groups="ht_crm.group_ht_leader,ht_crm.group_ht_executive"/>
                <field name="ignore" widget="checkbox" groups="ht_crm.group_ht_leader,ht_crm.group_ht_executive"/>
                <field name="type"/>
            </list> 
        </field>
    </record>
    
</odoo>