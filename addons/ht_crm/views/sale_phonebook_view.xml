<odoo>
    <record id="view_phonebook_list" model="ir.ui.view">
        <field name="name">sale.phonebook.list</field>
        <field name="model">sale.phonebook</field>
        <field name="arch" type="xml">
            <list>
                <field name="batch_id"/>

                <field name="created_on" readonly="True"/>
                <field name="name" readonly="True"/>
                <field name="phone" widget="phone"/>
                <field name="status"/>
                <field name="note"/>

                <!-- Trường bổ sung -->
                <field name="salesperson_id" optional="1" groups="ht_crm.group_ht_executive,ht_crm.group_ht_general_admin,ht_crm.group_ht_leader"/>
            </list>  
        </field>
    </record>

    <record id="view_phonebook_form" model="ir.ui.view">
        <field name="name">sale.phonebook.form</field>
        <field name="model">sale.phonebook</field>
        <field name="arch" type="xml">
            <form string="Phonebook">

                <header>
                    <field name="status"
                        widget="statusbar"
                        statusbar_visible="new,contacted,callback,invalid"/>
                </header>

                <sheet>

                    <!-- Ribbon -->
                    <widget name="web_ribbon"
                            title="Hủy"
                            bg_color="bg-danger"
                            invisible="status != 'invalid'"/>

                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Tên"/>
                        </h1>

                        <h2>
                            <!-- USER -->
                            <field name="phone"
                                readonly="1"
                                groups="ht_crm.group_ht_user"
                                widget="phone"/>

                            <!-- ADMIN -->
                            <field name="phone"
                                groups="base.group_system,ht_crm.group_ht_general_admin,ht_crm.group_ht_executive,ht_crm.group_ht_leader" widget="phone"/>
                        </h2>
                    </div>

                    <group>
                        <group string="Thông Tin Data">
                            <field name="batch_id"/>
                            <field name="created_on" readonly="1"/>

                            <field name="salesperson_id"
                                options="{'no_create': False}"/>
                            <field name="project_id"/>
                            <field name="previous_salesperson_ids" groups="base.group_system,ht_crm.group_ht_general_admin,ht_crm.group_ht_executive,ht_crm.group_ht_leader"/>

                        </group>

                        <group string="Tình Trạng">
                            <field name="is_hot" widget="boolean" groups="base.group_system,ht_crm.group_ht_general_admin,ht_crm.group_ht_executive,ht_crm.group_ht_leader"/>
                            <field name="status"/>
                            <field name="note" placeholder="Ghi chú..."/>

                        </group>
                    </group>

                    <notebook>
                        <page string="Lịch Sử">
                            <group>
                                <field name="create_uid" readonly="1"/>
                                <field name="write_uid" readonly="1"/>
                                <field name="write_date" readonly="1"/>
                            </group>
                        </page>

                    </notebook>

                </sheet>

            </form>
        </field>
    </record>

    <record id="view_sale_phonebook_log_list" model="ir.ui.view">
        <field name="name">sale.phonebook.log.list</field>
        <field name="model">sale.phonebook.log</field>
        <field name="arch" type="xml">
            <list string="Logs" create="false">
                <field name="create_date" string="Thời gian"/>
                <field name="user_id" string="Người thao tác"/>
                <field name="phonebook_id" string="Bị tác động"/>
                <field name="action" string="Hành động"/>
                <field name="note" string="Ghi chú"/>
            </list>
        </field>
    </record>

    <record id="ir_cron_distribute_hot" model="ir.cron">
        <field name="name">Distribute Hot</field>
        <field name="model_id" ref="model_sale_phonebook_batch"/>
        <field name="state">code</field>
        <field name="code">model.cron_distribute()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>

    <record id="view_phonebook_batch_list" model="ir.ui.view">
        <field name="name">sale.phonebook.batch.list</field>
        <field name="model">sale.phonebook.batch</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" string="Thời gian"/>
                <field name="date" string="Người thao tác"/>
                <field name="project_id" string="Dự án"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_phonebook_batch_form" model="ir.ui.view">
        <field name="name">sale.phonebook.batch.form</field>
        <field name="model">sale.phonebook.batch</field>
        <field name="arch" type="xml">

            <form string="Phonebook Batch">
                <header>
                    <button name="action_distribute"
                            string="Phân phát"
                            type="object"
                            class="oe_highlight"
                            icon="fa-random"
                            groups="ht_crm.group_ht_executive,base.group_system"/>

                    <button name="action_remove_sales"
                            string="Reset sales"
                            type="object"
                            class="oe_highlight"
                            icon="fa-undo"
                            groups="ht_crm.group_ht_executive,base.group_system"/>

                    <button name="action_clean_invalid"
                            string="Xóa số không hợp lệ"
                            type="object"
                            class="oe_highlight"
                            icon="fa-broom"
                            groups="ht_crm.group_ht_executive,base.group_system"/>
                </header>
                    
                <sheet>

                    <group>
                        <field name="name"/>
                        <field name="date"/>
                        <field name="project_id"/>
                        <field name="state"/>
                        <field name="chunk_size"/>
                        <field name="distribute_at"/>
                        <field name="rest" string="Thời gian nghỉ (phút)"/>
                    </group>

                    <notebook>
                        <page string="Danh sách số điện thoại">

                            <field name="phone_ids"
                                options="{'no_create': True, 'no_create_edit': True}">

                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="phone"/>
                                    <field name="salesperson_id"/>
                                    <field name="is_hot"/>
                                </list>

                                <!-- <form>
                                    <group>
                                        <field name="name"/>
                                        <field name="phone"/>
                                    </group>
                                </form> -->

                            </field>

                        </page>

                        <page string="Sales phụ trách">

                            <field name="e_p_rel_ids">
                                <list>
                                    <field name="sales_id"/>
                                </list>
                            </field>

                        </page>
                    </notebook>

                </sheet>
            </form>

        </field>
    </record>
</odoo>