    <record id="view_phonebook_kanban" model="ir.ui.view">
        <field name="name">sale.phonebook.kanban</field>
        <field name="model">sale.phonebook</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">
                <templates>
                    <t t-name="card">

                        <div class="oe_kanban_card rounded-4 shadow-sm p-3">
                            <!-- Header -->
                            <div class="d-flex justify-content-between align-items-start mb-2">
                            
                                <div>

                                    <!-- Customer Name -->
                                    <div class="fw-semibold text-dark fs-6">
                                        <field name="name"/>
                                    </div>

                                    <!-- Phone -->
                                    <div class="fw-bold fs-4 text-primary">
                                        <field name="phone" widget="phone"/>
                                    </div>

                                </div>

                                <div class="mt-1" t-if="record.source.raw_value">
                                    <span class="badge bg-secondary-subtle text-secondary border">
                                        <i class="fa fa-folder-open me-1" title="Nguồn Data"/> 
                                        <field name="source"/>
                                    </span>
                                </div>

                                <!-- Status -->
                                <div>
                                    <field name="status" widget="badge"/>
                                </div>
                            </div>
                            

                            <!-- Note -->
                            <div class="bg-light rounded-3 px-2 py-2 small text-secondary mb-3">

                                <div class="fw-semibold text-dark mb-1">
                                    Ghi chú
                                </div>

                                <field name="note"/>

                            </div>

                            <!-- Action -->
                            <footer>
                                <div class="d-flex flex-column flex-md-row w-100 gap-2 mt-2">
                                    <button name="action_open_status_wizard"
                                            type="object"
                                            string="Đổi trạng thái"
                                            icon="fa-history"
                                            class="btn btn-secondary btn-sm flex-grow-1 w-100"/>

                                    <button name="action_convert_to_customer" 
                                            type="object" 
                                            string="Khách hàng"
                                            icon="fa-user-plus"
                                            class="btn btn-primary btn-sm flex-grow-1 w-100"
                                            invisible="status == 'invalid'"/>
                                </div>
                            </footer>

                        </div>

                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_phonebook_form" model="ir.ui.view">
        <field name="name">sale.phonebook.form</field>
        <field name="model">sale.phonebook</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Thông tin thuê bao" name="group_general">
                            <field name="phone"/>
                            <field name="is_hot"/>
                            <field name="created_on" readonly="True"/>
                        </group>
                        <group string="Điều phối &amp; Phân bổ" name="group_assignment">
                            <field name="batch_id"/>
                            <field name="project_id"/>
                            <field name="source"/>
                            <field name="salesperson_id" placeholder="Chọn Sales phụ trách..."/>
                        </group>
                    </group>
                    
                    <group string="Thông số hệ thống (KPIs)">
                        <group>
                            <field name="given_at" readonly="True"/>
                            <field name="has_interaction_since_given" readonly="True"/>
                        </group>
                        <group>
                            <field name="last_interaction_at" readonly="True"/>
                            <field name="last_interaction_by" readonly="True"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Lịch sử dịch chuyển số">
                            <field name="previous_salesperson_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Ghi chú hệ thống">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_phonebook_form_sales" model="ir.ui.view">
            <field name="name">sale.phonebook.form.sales</field>
            <field name="model">sale.phonebook</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_convert_to_customer" 
                            string="Khách hàng" 
                            type="object" 
                            class="oe_highlight" 
                            icon="fa-user-plus"
                            invisible="status == 'invalid'"/>
                        <field name="status" widget="statusbar" statusbar_visible="new,callback,contacted"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" string="Chủ thuê bao"/>
                            <h1>
                                <field name="name" placeholder="Ví dụ: Nguyễn Văn A" readonly="status == 'invalid'"/>
                            </h1>
                            <div class="o_row">
                                <field name="is_hot" readonly="True"/>
                                <label for="is_hot" string="Số điện thoại NÓNG" class="text-danger fw-bold" invisible="not is_hot"/>
                            </div>
                        </div>
                        <group>
                            <group string="Thông tin liên hệ">
                                <field name="phone" widget="phone"/>
                                <field name="project_id" readonly="True"/>
                                <field name="source" readonly="True"/>
                            </group>
                            <group string="Lịch sử tương tác">
                                <field name="given_at" readonly="True"/>
                                <field name="last_interaction_at" readonly="True"/>
                                <field name="salesperson_id" readonly="True" groups="ht_crm.group_ht_leader"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Lịch sử Sales" groups="ht_crm.group_ht_leader">
                                <field name="previous_salesperson_ids" widget="many2many_tags"/>
                            </page>
                            <page string="Ghi chú hệ thống">
                                <field name="note"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
</odoo>