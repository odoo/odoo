<odoo>
    <record id="view_phonebook_status_wizard" model="ir.ui.view">
        <field name="name">sale.phonebook.status.wizard.form</field>
        <field name="model">sale.phonebook.status.wizard</field>
        <field name="arch" type="xml">
            <form string="Đổi trạng thái">
                <sheet>
                    <!-- Cảnh báo thân thiện khi chuyển sang trạng thái callback -->
                    <div class="alert alert-warning text-center" role="alert" 
                         invisible="status != 'callback'">
                        <i class="fa fa-exclamation-triangle me-1"/> 
                        Bạn đã chọn trạng thái <strong>Hẹn gọi lại</strong>. Vui lòng cập nhật mốc thời gian cụ thể bên dưới!
                    </div>

                    <group>
                        <!-- Ẩn ID liên kết đến bản ghi gốc -->
                        <field name="phonebook_id" invisible="1"/>
                        
                        <group>
                            <!-- Trạng thái hiện tại hoặc trạng thái mới muốn chuyển -->
                            <field name="status" string="Trạng thái"/>
                            
                            <!-- Chỉ hiển thị và bắt buộc nhập thời gian hẹn khi status là 'callback' -->
                            <field name="schedule_callback" 
                                   string="Thời gian hẹn gọi lại" 
                                   placeholder="Chọn ngày và giờ gọi lại..."
                                   invisible="status != 'callback'"
                                   required="status == 'callback'"/>
                        </group>
                    </group>
                </sheet>

                <!-- Thanh chứa nút bấm hành động dưới chân Pop-up -->
                <footer>
                    <button string="Xác nhận" 
                            name="action_confirm" 
                            type="object" 
                            class="btn-primary" 
                            data-hotkey="q"/>
                    <button string="Hủy" 
                            class="btn-secondary" 
                            special="cancel" 
                            data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>
    
    <record id="view_phonebook_list" model="ir.ui.view">
        <field name="name">sale.phonebook.list</field>
        <field name="model">sale.phonebook</field>
        <field name="arch" type="xml">
            <list>
                <field name="batch_id" groups="ht_crm.group_ht_board_of_directors,ht_crm.group_ht_executive"/>

                <field name="created_on" optional="1" readonly="True"/>
                <field name="name" readonly="True" class="col-name"/>
                <field name="phone" widget="phone" class="col-phone"/>
                <field name="status" class="col-status"/>
                <field name="note_preview" string="Ghi chú" class="col-note"/>

                <!-- Trường bổ sung -->
                <field name="salesperson_id" optional="1" groups="ht_crm.group_ht_executive,ht_crm.group_ht_general_admin,ht_crm.group_ht_sales_leader"/>
            </list>  
        </field>
    </record>

