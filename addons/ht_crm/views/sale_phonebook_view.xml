    <record id="view_phonebook_kanban" model="ir.ui.view">
        <field name="name">sale.phonebook.kanban</field>
        <field name="model">sale.phonebook</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">
                <templates>
                    <t t-name="card">

                        <!-- Header -->
                        <div class="d-flex justify-content-between align-items-start mb-2 w-100">
                            <div class="flex-grow-1 me-2">
                                <!-- Tên khách hàng - Nổi bật hơn -->

                                <div class="mb-2">
                                    <!-- Dòng 1: Tên khách hàng (Cho phép xuống dòng nếu quá dài, không sợ đè vào lịch hẹn) -->
                                    <div class="fw-bold text-dark fs-6 mb-1 pe-5">
                                        <field name="name"/>
                                    </div>
                                    
                                    <!-- Dòng 2: Badge hiển thị lịch hẹn gọi lại tách biệt, rất rõ ràng và dễ nhìn -->
                                    <div t-if="record.status.raw_value == 'callback' and record.schedule_callback.raw_value" class="mb-1">
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1" style="font-size: 0.75rem;">
                                            <i class="fa fa-clock-o me-1"/> Hẹn gọi lại: <field name="schedule_callback"/>
                                        </span>
                                    </div>
                                </div>

                                <!-- Số điện thoại kèm widget mặc định -->
                                <div class="fw-bold fs-4 text-primary">
                                    <field name="phone" widget="phone"/>
                                </div>
                                
                                <!-- Nguồn Data: Đã sửa điều kiện t-if để LUÔN HIỂN THỊ rõ ràng, đổi màu tương phản cao -->
                                <div class="mt-2" t-if="record.source.raw_value">
                                    <span t-attf-class="badge border text-wrap text-start px-2 py-1 #{record.is_hot.raw_value ? 'bg-danger text-white border-danger' : 'bg-dark-subtle text-dark border-secondary'}" style="max-width: 100%; font-size: 0.75rem;">
                                        <i class="fa fa-folder-open me-1" title="Nguồn Data"/>
                                        <field name="is_hot" invisible="1"/>
                                        <field name="source"/>
                                    </span>
                                </div>
                            </div>

                            <!-- Trạng thái Badge gốc -->
                            <div class="flex-shrink-0">
                                <field name="status" widget="badge"/>
                            </div>
                        </div>
                        
                        <!-- Note: Tối ưu khoảng trống và hiển thị nội dung tinh tế hơn -->
                        <div class="bg-light rounded-3 px-2 py-2 small text-secondary mb-3 border-start border-2 border-muted" t-if="record.note_preview.raw_value">
                            <div class="fw-semibold text-dark mb-1" style="font-size: 0.8rem;">
                                <i class="fa fa-pencil me-1 text-muted"/> Ghi chú
                            </div>
                            <div class="text-dark-50 text-truncate-2">
                                <field name="note_preview"/>
                            </div>
                        </div>
                        <!-- Trường hợp rỗng (Empty State cho Ghi chú nội bộ card): Nếu không có ghi chú, hiển thị dòng gợi ý nhẹ nhàng thay vì để khoảng trắng vô nghĩa -->
                        <div class="bg-light rounded-3 px-2 py-2 small text-muted mb-3 text-center border border-dashed" t-if="!record.note_preview.raw_value">
                            <span class="fst-italic" style="font-size: 0.75rem;"><i class="fa fa-comment-o me-1"/> Chưa có ghi chú...</span>
                        </div>

                        <!-- Action Buttons -->
                        <footer>
                            <div class="d-flex flex-column flex-md-row w-100 gap-2 mt-2">
                                <button name="action_open_status_wizard"
                                        type="object"
                                        string="Đổi trạng thái"
                                        icon="fa-history"
                                        class="btn btn-secondary btn-sm flex-grow-1 w-100"/>

                                <button name="action_convert_to_customer" 
                                        type="object" 
                                        string="Khách hàng"
                                        icon="fa-user-plus"
                                        class="btn btn-primary btn-sm flex-grow-1 w-100"
                                        invisible="status in ('invalid', 'new')"/>
                            </div>
                        </footer>

                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_phonebook_form" model="ir.ui.view">
        <field name="name">sale.phonebook.form</field>
        <field name="model">sale.phonebook</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Thông tin thuê bao" name="group_general">
                            <field name="phone"/>
                            <field name="is_hot"/>
                            <field name="created_on" readonly="True"/>
                        </group>
                        <group string="Điều phối &amp; Phân bổ" name="group_assignment">
                            <field name="batch_id"/>
                            <field name="project_id"/>
                            <field name="source"/>
                            <field name="salesperson_id" placeholder="Chọn Sales phụ trách..."/>
                        </group>
                    </group>
                    
                    <group string="Thông số hệ thống (KPIs)">
                        <group>
                            <field name="given_at" readonly="True"/>
                            <field name="has_interaction_since_given" readonly="True"/>
                        </group>
                        <group>
                            <field name="last_interaction_at" readonly="True"/>
                            <field name="last_interaction_by" readonly="True"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Lịch sử dịch chuyển số">
                            <field name="previous_salesperson_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Ghi chú hệ thống">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_phonebook_form_sales" model="ir.ui.view">
            <field name="name">sale.phonebook.form.sales</field>
            <field name="model">sale.phonebook</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_convert_to_customer" 
                            string="Khách hàng" 
                            type="object" 
                            class="oe_highlight" 
                            icon="fa-user-plus"
                            invisible="status == 'invalid'"/>
                        <field name="status" widget="statusbar" statusbar_visible="new,callback,contacted"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" string="Chủ thuê bao"/>
                            <h1>
                                <field name="name" placeholder="Ví dụ: Nguyễn Văn A" readonly="status == 'invalid'"/>
                            </h1>
                            <div class="o_row">
                                <field name="is_hot" readonly="True"/>
                                <label for="is_hot" string="Số điện thoại NÓNG" class="text-danger fw-bold" invisible="not is_hot"/>
                            </div>
                        </div>
                        <group>
                            <group string="Thông tin liên hệ">
                                <field name="phone" widget="phone"/>
                                <field name="project_id" readonly="True"/>
                                <field name="source" readonly="True"/>
                            </group>
                            <group string="Lịch sử tương tác">
                                <field name="schedule_callback" invisible="status != 'callback'"/>
                                <field name="given_at" readonly="True"/>
                                <field name="last_interaction_at" readonly="True"/>
                                <field name="salesperson_id" readonly="True" groups="ht_crm.group_ht_sales_leader"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Lịch sử Sales" groups="ht_crm.group_ht_sales_leader">
                                <field name="previous_salesperson_ids" widget="many2many_tags"/>
                            </page>
                            <page string="Ghi chú hệ thống">
                                <field name="note"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
</odoo>