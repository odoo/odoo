<odoo>
    <record id="view_phonebook_status_wizard" model="ir.ui.view">
        <field name="name">sale.phonebook.status.wizard.form</field>
        <field name="model">sale.phonebook.status.wizard</field>
        <field name="arch" type="xml">
            <form string="Đổi trạng thái">

                <group>
                    <field name="status"/>
                </group>

                <footer>

                    <button name="action_confirm"
                            type="object"
                            string="Xác nhận"
                            class="btn-primary"/>

                    <button string="Hủy"
                            special="cancel"/>

                </footer>

            </form>
        </field>
    </record>
    
    <record id="view_phonebook_list" model="ir.ui.view">
        <field name="name">sale.phonebook.list</field>
        <field name="model">sale.phonebook</field>
        <field name="arch" type="xml">
            <list>
                <field name="batch_id" groups="ht_crm.group_ht_board_of_directors,ht_crm.group_ht_executive"/>

                <field name="created_on" optional="1" readonly="True"/>
                <field name="name" readonly="True" class="col-name"/>
                <field name="phone" widget="phone" class="col-phone"/>
                <field name="status" class="col-status"/>
                <field name="note_preview" string="Ghi chú" class="col-note"/>

                <!-- Trường bổ sung -->
                <field name="salesperson_id" optional="1" groups="ht_crm.group_ht_executive,ht_crm.group_ht_general_admin,ht_crm.group_ht_leader"/>
            </list>  
        </field>
    </record>

