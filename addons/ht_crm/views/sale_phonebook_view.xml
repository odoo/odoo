<odoo>
    <record id="view_phonebook_status_wizard" model="ir.ui.view">
        <field name="name">sale.phonebook.status.wizard.form</field>
        <field name="model">sale.phonebook.status.wizard</field>
        <field name="arch" type="xml">
            <form string="Đổi trạng thái">

                <group>
                    <field name="status"/>
                </group>

                <footer>

                    <button name="action_confirm"
                            type="object"
                            string="Xác nhận"
                            class="btn-primary"/>

                    <button string="Hủy"
                            special="cancel"/>

                </footer>

            </form>
        </field>
    </record>
    
    <record id="view_phonebook_list" model="ir.ui.view">
        <field name="name">sale.phonebook.list</field>
        <field name="model">sale.phonebook</field>
        <field name="arch" type="xml">
            <list>
                <field name="batch_id" groups="ht_crm.group_ht_board_of_directors,ht_crm.group_ht_executive"/>

                <field name="created_on" optional="1" readonly="True"/>
                <field name="name" readonly="True" class="col-name"/>
                <field name="phone" widget="phone" class="col-phone"/>
                <field name="status" class="col-status"/>
                <field name="note_preview" string="Ghi chú" class="col-note"/>

                <!-- Trường bổ sung -->
                <field name="salesperson_id" optional="1" groups="ht_crm.group_ht_executive,ht_crm.group_ht_general_admin,ht_crm.group_ht_leader"/>
                
            </list>  
        </field>
    </record>

    <record id="view_phonebook_kanban" model="ir.ui.view">
        <field name="name">sale.phonebook.kanban</field>
        <field name="model">sale.phonebook</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">
                <templates>
                    <t t-name="card">

                        <div class="oe_kanban_card rounded-4 shadow-sm p-3">
                            <!-- Header -->
                            <div class="d-flex justify-content-between align-items-start mb-2">

                            
                                <div>

                                    <!-- Customer Name -->
                                    <div class="fw-semibold text-dark fs-6">
                                        <field name="name"/>
                                    </div>

                                    <!-- Phone -->
                                    <div class="fw-bold fs-4 text-primary">
                                        <field name="phone" widget="phone"/>
                                    </div>

                                </div>

                                <!-- Status -->
                                <div>
                                    <field name="status" widget="badge"/>
                                </div>
                            </div>
                            

                            <!-- Note -->
                            <div class="bg-light rounded-3 px-2 py-2 small text-secondary mb-3">

                                <div class="fw-semibold text-dark mb-1">
                                    Ghi chú
                                </div>

                                <field name="note"/>

                            </div>

                            <!-- Action -->
                            <footer>

                                <button name="action_open_status_wizard"
                                        type="object"
                                        icon="fa-refresh"
                                        string="Đổi trạng thái"
                                        class="btn btn-primary btn-sm w-100"
                                        groups="ht_crm.group_ht_board_of_directors,ht_crm.group_ht_executive"

                                />

                            </footer>

                        </div>

                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_phonebook_form" model="ir.ui.view">
        <field name="name">sale.phonebook.form</field>
        <field name="model">sale.phonebook</field>
        <field name="arch" type="xml">
            <form string="Phonebook">

                <header>
                    <field name="status"
                        widget="statusbar"
                        statusbar_visible="new,contacted,callback,invalid"/>
                </header>

                <sheet>

                    <!-- Ribbon -->
                    <widget name="web_ribbon"
                            title="Hủy"
                            bg_color="bg-danger"
                            invisible="status != 'invalid'"/>

                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Tên"/>
                        </h1>

                        <h2>
                            <!-- USER -->
                            <field name="phone"
                                readonly="1"
                                groups="ht_crm.group_ht_user"
                                widget="phone"/>

                            <!-- ADMIN -->
                            <field name="phone"
                                groups="base.group_system,ht_crm.group_ht_general_admin,ht_crm.group_ht_executive,ht_crm.group_ht_leader" widget="phone"/>
                        </h2>
                    </div>

                    <group>
                        <group string="Thông Tin Data">
                            <field name="batch_id" groups="ht_crm.group_ht_board_of_directors,ht_crm.group_ht_executive"/>
                            <field name="created_on" readonly="1"/>

                            <field name="salesperson_id" options="{'no_create': False}" groups="ht_crm.group_ht_executive,ht_crm.group_ht_general_admin"/>
                            <field name="project_id"/>
                            <field name="previous_salesperson_ids" groups="base.group_system,ht_crm.group_ht_general_admin,ht_crm.group_ht_executive,ht_crm.group_ht_leader"/>

                        </group>

                        <group string="Tình Trạng">
                            <field name="is_hot" widget="boolean" groups="base.group_system,ht_crm.group_ht_general_admin,ht_crm.group_ht_executive,ht_crm.group_ht_leader"/>
                            <field name="status"/>
                            <field name="note" placeholder="Ghi chú..."/>
                            <field name="given_at"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Lịch Sử">
                            <group>
                                <field name="create_uid" readonly="1"/>
                                <field name="write_uid" readonly="1"/>
                                <field name="write_date" readonly="1"/>
                            </group>

                            <group>
                                <field name="has_interaction_since_given" readonly="1"/>
                                <field name="last_interaction_at" readonly="1"/>
                                <field name="last_interaction_by" readonly="1"/>
                            </group>
                        </page>

                    </notebook>

                </sheet>

            </form>
        </field>
    </record>
</odoo>