<odoo>
    <record id="view_revenue_graph" model="ir.ui.view">
        <field name="name">revenue.report.graph</field>
        <field name="model">revenue.report</field>
        <field name="arch" type="xml">

            <graph string="Doanh thu theo quý" type="line">

                <field name="quarter"/>

                <field name="total_revenue" type="measure"/>

            </graph>

        </field>
    </record>

    <template id="report_sale_transaction">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">

                        <h2 class="text-center mb-4">
                            PHIẾU GIAO DỊCH
                        </h2>

                        <table class="table table-bordered table-sm">

                            <tbody>

                                <tr>
                                    <td width="35%">
                                        <strong>Mã giao dịch</strong>
                                    </td>
                                    <td>
                                        <span t-field="o.name"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>
                                        <strong>Ngày giao dịch</strong>
                                    </td>
                                    <td>
                                        <span t-field="o.date"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>
                                        <strong>Sales</strong>
                                    </td>
                                    <td>
                                        <span t-field="o.employee_id"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>
                                        <strong>Khách hàng</strong>
                                    </td>
                                    <td>
                                        <span t-field="o.customer_id"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>
                                        <strong>Sản phẩm</strong>
                                    </td>
                                    <td>
                                        <span t-field="o.product_id"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>
                                        <strong>DTTT (m²)</strong>
                                    </td>
                                    <td>
                                        <span t-field="o.net_area"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>
                                        <strong>DTLL (m²)</strong>
                                    </td>
                                    <td>
                                        <span t-field="o.gross_area"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>
                                        <strong>Giá niêm yết</strong>
                                    </td>
                                    <td>
                                        <span t-field="o.listed_price"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>
                                        <strong>Chiết khấu (%)</strong>
                                    </td>
                                    <td>
                                        <span t-field="o.discount_percent"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>
                                        <strong>Tiền chiết khấu</strong>
                                    </td>
                                    <td>
                                        <span t-field="o.discount_amount"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>
                                        <strong>Giá sau chiết khấu</strong>
                                    </td>
                                    <td>
                                        <span t-field="o.price_subtotal"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>
                                        <strong>VAT (%)</strong>
                                    </td>
                                    <td>
                                        <span t-field="o.vat_percent"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>
                                        <strong>Tiền VAT</strong>
                                    </td>
                                    <td>
                                        <span t-field="o.vat_amount"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td>
                                        <strong>Tổng thanh toán</strong>
                                    </td>
                                    <td>
                                        <strong>
                                            <span t-field="o.price_total"/>
                                        </strong>
                                    </td>
                                </tr>

                                <tr>
                                    <td>
                                        <strong>Trạng thái</strong>
                                    </td>
                                    <td>
                                        <span t-field="o.state"/>
                                    </td>
                                </tr>

                            </tbody>

                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>