<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="digest_kpi_view_form" model="ir.ui.view">
        <field name="name">digest.kpi.view.form</field>
        <field name="model">digest.kpi</field>
        <field name="arch" type="xml">
            <form create="false">
                <div class="oe_title">
                    <h1><field nolabel="1" name="name" placeholder="e.g. &quot;Opportunities Lost&quot;"/></h1>
                </div>
                <group>
                    <group>
                        <field name="group_ids" widget="many2many_tags"/>
                        <field name="action_id"/>
                        <field name="agg_mode"/>
                        <field name="date_field" invisible="agg_mode == 'custom'"/>
                        <field name="module_id"/>
                    </group>
                    <group>
                        <field name="res_model_id"/>
                        <field name="action_menu_root_id"/>
                        <field name="company_field" invisible="agg_mode == 'custom'"/>
                        <field name="domain" invisible="agg_mode == 'custom'"/>
                        <field name="agg_field" invisible="agg_mode in ('count', 'custom')"/>
                    </group>
                </group>
                <group><field name="agg_custom_code" colspan="4" invisible="agg_mode != 'custom'"></field></group>
                <footer>
                    <button string="Save" class="btn-primary" special="save" data-hotkey="q"/>
                    <button string="Discard" class="btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="digest_kpi_view_list" model="ir.ui.view">
        <field name="name">digest.kpi.view.list</field>
        <field name="model">digest.kpi</field>
        <field name="arch" type="xml">
            <list>
                <field string="Module" name="icon_url" widget="image_url" options="{'size': [24, 24]}"/>
                <field name="name"/>
                <button groups="base.group_system" name="action_edit" type="object" string="Edit"
                        icon="fa-pencil" title="Edit KPI"/>
                <button groups="base.group_system" name="action_delete" type="object" string="Delete"
                        icon="fa-trash" title="Delete KPI"
                        confirm="This will delete the KPI for all digests! Are you sure you want to proceed?"/>
            </list>
        </field>
    </record>
</odoo>

