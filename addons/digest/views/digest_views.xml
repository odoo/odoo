<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="digest_digest_view_tree" model="ir.ui.view">
        <field name="name">digest.digest.view.list</field>
        <field name="model">digest.digest</field>
        <field name="arch" type="xml">
            <list string="KPI Digest">
                <field name="name" string="Title"/>
                <field name="periodicity"/>
                <field name="next_run_date" groups="base.group_no_one"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="state" groups="base.group_no_one" widget="badge" decoration-success="state == 'activated'"/>
            </list>
        </field>
    </record>
    <record id="digest_digest_view_form" model="ir.ui.view">
        <field name="name">digest.digest.view.form</field>
        <field name="model">digest.digest</field>
        <field name="arch" type="xml">
            <form string="KPI Digest">
                <field name="is_subscribed" invisible="1"/>
                <header>
                    <button type="object" name="action_send_manual" string="Send Now"
                        class="oe_highlight"
                        invisible="state == 'deactivated'" groups="base.group_system"/>
                    <button type="object" name="action_deactivate" string="Deactivate"
                        invisible="state == 'deactivated'" groups="base.group_system"/>
                    <button type="object" name="action_activate" string="Activate"
                        class="oe_highlight"
                        invisible="state == 'activated'" groups="base.group_system"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Activated" bg_color="text-bg-success"
                            invisible="state != 'activated'"/>
                    <div class="oe_title">
                        <label for="name" string="Digest Title"/>
                        <h1>
                            <field name="name" placeholder="e.g. Your Weekly Digest"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="periodicity" widget="radio" options="{'horizontal': true}" readonly="1" groups="!base.group_system"/>
                            <field name="periodicity" widget="radio" options="{'horizontal': true}" groups="base.group_system"/>
                            <field name="company_id" options="{'no_create': True}" invisible="1"/>
                        </group>
                        <group>
                            <field name="next_run_date" groups="base.group_system"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="kpi_ids" string="KPIs">
                            <control>
                                <button name="action_add_kpi" string="Add/Remove KPIs" type="object" class="btn-link" groups="base.group_system"/>
                            </control>

                            <field name="digest_kpi_ids" nolabel="1">
                                <kanban create="false" sample="1" can_open="0">
                                    <field name="sequence" widget="handle" groups="base.group_system"/>
                                    <field name="value_last_24_hours"/>
                                    <field name="value_last_7_days"/>
                                    <field name="value_last_30_days"/>
                                    <field name="value_last_24_hours_margin"/>
                                    <field name="value_last_7_days_margin"/>
                                    <field name="value_last_30_days_margin"/>
                                    <field name="icon_url"/>
                                    <field name="module_name"/>
                                    <field name="has_compute_error"/>
                                    <templates>
                                        <t t-name="card" t-attf-class="o_digest_kpi_kanban">
                                            <t t-set="has_error" t-value="record.has_compute_error.raw_value" groups="base.group_system"/>
                                            <div t-attf-class="d-flex justify-content-between align-items-center {{ record.is_opted_in.raw_value ? '' : 'text-muted' }} {{ has_error ? 'text-danger fw-bold' : '' }}">
                                                <div class="d-flex gap-1 align-items-center">
                                                    <t if="record.icon_url.raw_value">
                                                        <img t-att-src="record.icon_url.raw_value" role="img"
                                                             t-att-title="record.module_name.raw_value" t-att-alt="record.module_name.raw_value"
                                                             onError="this.onerror=null; this.remove();"
                                                             valign="middle" width="24" height="24"/>
                                                    </t>
                                                    <field name="name"/>
                                                    <button groups="base.group_system" name="action_edit_kpi" type="object"
                                                            icon="fa-pencil" title="Edit KPI"/>
                                                </div>
                                                <field name="is_opted_in" widget="boolean_toggle_show_action"
                                                       options="{'action': 'action_opt_in', 'force_readonly': False}"/>
                                            </div>
                                            <div t-attf-class="container-fluid px-0 mx-0 {{ record.is_opted_in.raw_value ? '' : 'text-muted' }}" groups="base.group_system">
                                                <div class="row">
                                                    <div class="col-12"><hr class="mt-1 mb-2"/></div>
                                                </div>
                                                <div class="row">
                                                    <t t-call="metric_column">
                                                        <t t-set="value" t-value="record.value_last_24_hours.raw_value"/>
                                                        <t t-set="margin" t-value="record.value_last_24_hours_margin.raw_value"/>
                                                        <t t-set="label">Last 24 hours</t>
                                                    </t>
                                                    <t t-call="metric_column">
                                                        <t t-set="value" t-value="record.value_last_7_days.raw_value"/>
                                                        <t t-set="margin" t-value="record.value_last_7_days_margin.raw_value"/>
                                                        <t t-set="label">Last 7 days</t>
                                                    </t>
                                                    <t t-call="metric_column">
                                                        <t t-set="value" t-value="record.value_last_30_days.raw_value"/>
                                                        <t t-set="margin" t-value="record.value_last_30_days_margin.raw_value"/>
                                                        <t t-set="label">Last 30 days</t>
                                                    </t>
                                                </div>
                                            </div>
                                        </t>
                                        <t t-name="decimal2"><t t-out="((value * 100) - ((value * 100) % 1)) / 100"/></t>
                                        <t t-name="metric_column">
                                            <div class="col d-flex flex-column align-items-center">
                                                <div t-out="value"/>
                                                <div t-attf-class="d-flex gap-1 o_digest_kpi_margin {{ margin &gt; 0 ? 'o_digest_kpi_margin_positive' : (margin &lt; 0 ? 'o_digest_kpi_margin_negative' : '') }}">
                                                    <div t-if="margin &gt; 0">⬆</div>
                                                    <div t-if="margin &lt; 0">⬇</div>
                                                    <div><t t-call="decimal2"><t t-set="value" t-value="margin"/></t> %</div>
                                                </div>
                                                <div t-out="label"/>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </page>
                        <page name="recipients" string="Recipients" groups="base.group_system">
                            <field name="user_ids" options="{'no_create': True}">
                                <list string="Recipients">
                                    <field name="name"/>
                                    <field name="email" string="Email Address" />
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="digest_digest_view_form_add_remove_kpi" model="ir.ui.view">
        <field name="name">digest.digest.view.form.add.remove.kpi</field>
        <field name="model">digest.digest</field>
        <field name="priority">32</field>
        <field name="arch" type="xml">
            <form string="KPI Digest">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <field name="kpi_ids" placeholder="Add existing KPIs" nolabel="1"
                           options="{'no_quick_create': True, 'no_create_edit': True, 'no_open': True}"/>
                </sheet>
                <footer>
                    <button string="Save" class="btn-primary" special="save" data-hotkey="q" />
                    <button name="action_create_kpi" string="Create New KPI" type="object" class="btn-link"/>
                    <button string="Discard" class="btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="digest_digest_view_search" model="ir.ui.view">
        <field name="name">digest.digest.view.search</field>
        <field name="model">digest.digest</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="user_ids"/>
                <filter name="filter_activated" string="Activated" domain="[('state', '=', 'activated')]"/>
                <filter name="filter_deactivated" string="Deactivated" domain="[('state', '=', 'deactivated')]"/>
                <group expand="1" string="Group by">
                    <filter string="Periodicity" name="periodicity" context="{'group_by': 'periodicity'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="digest_digest_action" model="ir.actions.act_window">
        <field name="name">Digest Emails</field>
        <field name="res_model">digest.digest</field>
        <field name="context">{'search_default_filter_activated': 1}</field>
        <field name="search_view_id" ref="digest_digest_view_search"/>
    </record>

    <menuitem id="digest_menu"
        action="digest_digest_action"
        parent="base.menu_email"
        groups="base.group_erp_manager"
        sequence="80"/>

    <!-- DIGEST.TIP -->
    <record id="digest_tip_view_tree" model="ir.ui.view">
        <field name="name">digest.tip.view.list</field>
        <field name="model">digest.tip</field>
        <field name="arch" type="xml">
            <list string="KPI Digest Tips">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="group_id"/>
            </list>
        </field>
    </record>
    <record id="digest_tip_view_form" model="ir.ui.view">
        <field name="name">digest.tip.view.form</field>
        <field name="model">digest.tip</field>
        <field name="arch" type="xml">
            <form string="KPI Digest Tip">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="tip_description"/>
                        <field name="group_id"/>
                        <field name="user_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="digest_tip_view_search" model="ir.ui.view">
        <field name="name">digest.tip.view.search</field>
        <field name="model">digest.tip</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="tip_description"/>
                <field name="group_id"/>
            </search>
        </field>
    </record>
    <record id="digest_tip_action" model="ir.actions.act_window">
        <field name="name">Digest Tips</field>
        <field name="res_model">digest.tip</field>
        <field name="search_view_id" ref="digest_tip_view_search"/>
    </record>

    <menuitem id="digest_tip_menu"
        action="digest_tip_action"
        parent="base.menu_email"
        groups="base.group_erp_manager"
        sequence="81"/>

</odoo>
