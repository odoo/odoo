<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="payment_provider_form" model="ir.ui.view">
        <field name="name">APS Provider Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <group name="provider_credentials" position="inside">
                <field
                    string="Merchant Identifier"
                    name="aps_merchant_identifier"
                    invisible="code != 'aps'"
                    required="is_live"
                />
                <field
                    string="Access Code"
                    name="aps_access_code"
                    invisible="code != 'aps'"
                    required="is_live"
                    widget="password"
                />
                <field
                    string="SHA Request Phrase"
                    name="aps_sha_request"
                    invisible="code != 'aps'"
                    required="is_live"
                    widget="password"
                />
                <field
                    string="SHA Response Phrase"
                    name="aps_sha_response"
                    invisible="code != 'aps'"
                    required="is_live"
                    widget="password"
                />
            </group>
        </field>
    </record>

</odoo>
