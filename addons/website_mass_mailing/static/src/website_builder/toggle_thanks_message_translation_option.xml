<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="website_mass_mailing.ToggleThanksMessageTranslationOption">
    <BuilderRow label.translate="Display Thanks Message" t-if="this.shouldShowOption()">
        <BuilderCheckbox action="'toggleThanksMessage'"/>
    </BuilderRow>
</t>

<t t-inherit="website.TranslationBuilderOptions" t-inherit-mode="extension">
    <xpath expr="//t[@id='translation_options']" position="inside">
        <toggle_thanks_message_translation_option
            selector=".s_newsletter_subscribe_form"
            editableOnly="false"/>
    </xpath>
</t>

</templates>
