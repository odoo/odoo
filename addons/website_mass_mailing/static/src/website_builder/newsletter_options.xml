<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-inherit="website.BuilderOptions" t-inherit-mode="extension">
    <xpath expr="//t[@id='snippet_specific_options']" position="after">
        <newsletter_layout_option
            template="website_mass_mailing.NewsletterLayoutOption"
            selector=".s_newsletter_block"
            applyTo=":scope > .container, :scope > .container-fluid, :scope > .o_container_small"/>
        <newsletter_subscribe_common_option
            selector=".s_newsletter_subscribe_form" />
    </xpath>
</t>

</templates>
