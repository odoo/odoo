<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="website_mass_mailing.MailingListSubscribeOption">

    <BuilderRow label.translate="Newsletter" t-if="!this.isActiveItem('form_opt')">
        <BuilderSelect dataAttributeAction="'listId'">
            <t t-foreach="this.mailingLists" t-as="item" t-key="item.id">
                <BuilderSelectItem dataAttributeActionValue="item.id.toString()">
                    <t t-out="item.name" ></t>
                </BuilderSelectItem>
            </t>
            <t t-if="!this.mailingLists.length">
                <BuilderSelectItem>None</BuilderSelectItem>
            </t>
        </BuilderSelect>
    </BuilderRow>
    <BuilderRow label.translate="On Success">
        <BuilderSelect action="'newsletterSubscribeSuccess'" actionParam="'successMode'">
            <BuilderSelectItem actionValue="'message'">Show Message</BuilderSelectItem>
            <BuilderSelectItem actionValue="'redirect'" id="'on_success_redirect'">Redirect + Show Message</BuilderSelectItem>
            <BuilderSelectItem actionValue="'closePopup'" id="'on_success_close_popup'" t-if="this.isNewsletterPopup()">Close Popup</BuilderSelectItem>
        </BuilderSelect>
        <BuilderButton
            t-if="!this.isActiveItem('on_success_close_popup')"
            title.translate="Edit Message"
            icon="'fa-eye'"
            action="'toggleThanksMessage'" />
    </BuilderRow>
    <BuilderRow label.translate="URL" level="1" t-if="this.isActiveItem('on_success_redirect')">
        <BuilderUrlPicker
            dataAttributeAction="'successPage'"
            default="'/contactus-thank-you'" />
    </BuilderRow>

</t>

<t t-name="website_mass_mailing.MailingListSubscribeFormOption">
    <BuilderRow label.translate="Placeholder">
        <BuilderTextInput attributeAction="'placeholder'" applyTo="'.s_newsletter_subscribe_form_input'"/>
    </BuilderRow>
</t>

<t t-inherit="website.BuilderOptions" t-inherit-mode="extension">
    <xpath expr="//t[@id='snippet_specific_options']" position="after">
        <mailing_list_subscribe_form_option
            template="website_mass_mailing.MailingListSubscribeFormOption"
            selector=".s_newsletter_subscribe_form"/>
    </xpath>
</t>

<t t-name="website_mass_mailing.newsletter_subscribe_success_message">
    <div class="js_subscribed_wrap d-none">
        <p class="h4-fs text-center text-success mb-0"><i class="fa fa-check-circle-o" role="img"/> Thanks for registering!</p>
    </div>
</t>

</templates>
