<?xml version="1.0" ?>
<odoo><data>

<template id="website_sale_confirmation_slide" inherit_id="website_sale.confirmation">
    <xpath expr="//div[@id='oe_website_sale_address']" position="before">
        <t t-if="any(
            product.service_tracking == 'course' for product in order.order_line.product_id
        )" t-call="website_sale_slides.course_purchased_confirmation_message"/>
    </xpath>
</template>

<template id="course_purchased_confirmation_message">
    <div class="my-3">
        <t t-foreach="order.order_line" t-as="line">
            <div t-foreach="line.product_id.channel_ids" t-as="course" class="row mx-0 my-2 border rounded">
                <div class="col-5 p-0">
                    <span t-if="course.image_1920" class="d-block h-100 w-100 overflow-hidden ratio ratio-4x3 rounded-start" t-field="course.image_1920" t-options="{'widget': 'image', 'class': 'img img-fluid object-fit-cover'}"/>
                    <div t-else="" class="d-block h-100 w-100 overflow-hidden ratio ratio-4x3 rounded-start">
                        <img class="img img-fluid object-fit-cover" src="/website_slides/static/src/img/channel-training-default.jpg"/>
                    </div>
                </div>
                <t t-set="invitation_link" t-value="course_memberships[course].invitation_link if course in course_memberships else ''"/>
                <div class="col-7 d-flex flex-column align-items-start my-3">
                    <a class="text-decoration-none" t-att-href="invitation_link"><h4 t-out="course.name" class="text-primary m-2"/></a>
                    <div t-out="course.description_short" class="fw-light o_line_clamp ms-2"/>
                    <h6 t-if="course.total_time or course.total_slides" class="mx-2 mb-0">
                        <t t-out="course.total_time" t-options="{'widget': 'duration', 'unit': 'hour', 'round': 'minute'}"/>
                        <span t-if="course.total_slides" class="fw-light">
                            <t t-if="course.total_time"> - </t><t t-out="course.total_slides"/> step(s)
                        </span>
                    </h6>
                    <a role="button" t-attf-class="btn btn-primary mt-2 mb-2 mx-2 #{'disabled' if not invitation_link else ''}" t-att-href="invitation_link">
                        Start Learning
                    </a>
                </div>
            </div>
        </t>
    </div>
</template>

<template id="cart_summary_inherit_website_sale_slides"
          inherit_id="website_sale.cart_summary_content"
          name="Course Cart right column">
    <xpath expr="//td[@name='website_sale_cart_summary_product_name']/span" position="after">
        <div t-if="line.product_id.channel_ids"
             t-foreach="line.product_id.channel_ids.filtered(lambda course: course.enroll == 'payment')"
             t-as="course"
             t-out="course.name"/>
    </xpath>
</template>

</data></odoo>
