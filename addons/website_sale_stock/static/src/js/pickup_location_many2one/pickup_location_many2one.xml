<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="website_sale_stock.PickupLocationField">
        <div class="d-flex align-items-center">
            <Many2One t-props="this.m2oProps"/>
            <button
                type="button"
                class="btn btn-secondary px-2 py-1 ms-2"
                tabindex="-1"
                draggable="false"
                t-on-click="this.onSelectLocation"
                t-att-disabled="this.isButtonDisabled()"
            >
                <i class="fa fa-pencil"/>
            </button>
        </div>
    </t>
</templates>
