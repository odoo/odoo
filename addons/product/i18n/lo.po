#: code:addons/product/models/product_pricelist_item.py:0
msgid ""
"%(base)s with a %(discount)s %% %(discount_type)s and %(surcharge)s extra fee\n"
"Example: %(amount)s * %(discount_charge)s + %(price_surcharge)s → %(total_amount)s"
msgstr ""
"%(base)s ພ້ອມກັບ %(discount)s %% %(discount_type)s ແລະ ຄ່າທຳນຽມເພີ່ມເຕີມ %"
"(surcharge)s\n"
"ຕົວຢ່າງ: %(amount)s * %(discount_charge)s + %(price_surcharge)s → %"
"(total_amount)s"

#. module: product
#. odoo-python
#: code:addons/product/models/product_pricelist_item.py:0
