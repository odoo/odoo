<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_uom_view_form" model="ir.ui.view">
        <field name="name">product.uom.form</field>
        <field name="model">product.uom</field>
        <field name="arch" type="xml">
           <form>
                <sheet>
                    <group>
                        <group>
                            <field name="uom_id" readonly="True"/>
                            <field name="barcode"/>
                        </group>
                        <group>
                            <field name="product_id" readonly="True"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="product_uom_list_view" model="ir.ui.view">
        <field name="name">product.uom.list</field>
        <field name="model">product.uom</field>
        <field name="arch" type="xml">
            <list string="Packaging Barcodes" editable="bottom">
                <field name="product_id" column_invisible="context.get('product_ids')"/>
                <field
                    name="product_id"
                    column_invisible="not context.get('product_ids')"
                    domain="[('id', 'in', context.get('product_ids'))]"
                    options="{'no_create': True}"
                />
                <field name="barcode"/>
                <field
                    name="uom_id"
                    widget="many2one_uom"
                    readonly="context.get('default_uom_id')"
                    domain="[('id', 'in', allowed_uom_ids)]"
                    options="{'no_create': True}"
                />
            </list>
        </field>
    </record>

    <record id="product_uom_action_view_list" model="ir.actions.act_window">
        <field name="name">Packaging Barcodes</field>
        <field name="res_model">product.uom</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="product.product_uom_list_view"/>
    </record>

    <record id="uom_uom_view_form" model="ir.ui.view">
        <field name="name">uom.uom.view.form.inherit.product</field>
        <field name="model">uom.uom</field>
        <field name="inherit_id" ref="uom.uom_uom_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <div class="oe_button_box" name="button_box">
                    <button
                        class="oe_stat_button"
                        icon="fa-barcode"
                        type="object"
                        name="action_open_packaging_barcodes">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_text">Packaging Barcodes</span>
                        </div>
                    </button>
                </div>
                <div invisible="not context.get('has_variants')">
                    Barcodes can be configured on
                    <button
                        string="each variant"
                        name="action_open_packaging_barcodes"
                        type="object"
                        class="oe_link p-0 align-baseline"
                    />.
                </div>
            </xpath>
        </field>
    </record>
</odoo>
