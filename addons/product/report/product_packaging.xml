<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="report_packaging_simple_label4x7" inherit_id="product.report_simple_label4x7" primary="True">
            <xpath expr="//div[hasclass('o_label_table')]/div[hasclass('o_label_meta_block')]" position="replace">
                <div class="o_label_meta_block">
                    <div class="o_label_meta_line" t-out="label.get('uom_name', '')"/>
                </div>
            </xpath>
        </template>

        <template id="report_packagingbarcode">
            <t t-call="web.basic_layout">
                <div class="page">
                    <div class="oe_structure"/>
                    <div t-foreach="label_pages" t-as="page_rows" class="o_label_sheet" t-att-style="'padding: 14mm 3mm'">
                        <table class="my-0 table table-sm table-borderless">
                            <t t-foreach="page_rows" t-as="label_row">
                                <tr>
                                    <t t-foreach="label_row" t-as="label">
                                        <t t-call="product.report_packaging_simple_label4x7"/>
                                    </t>
                                </tr>
                            </t>
                        </table>
                        <div class="oe_structure"/>
                    </div>
                </div>
            </t>
        </template>
    </data>
</odoo>
