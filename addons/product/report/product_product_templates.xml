<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="report_label_contour_marks">
            <div class="o_label_contour_mark o_label_contour_mark_top_left">
                <div class="o_label_contour_mark_horizontal">&amp;nbsp;</div>
                <div class="o_label_contour_mark_vertical">&amp;nbsp;</div>
            </div>
            <div class="o_label_contour_mark o_label_contour_mark_top_right">
                <div class="o_label_contour_mark_horizontal">&amp;nbsp;</div>
                <div class="o_label_contour_mark_vertical">&amp;nbsp;</div>
            </div>
            <div class="o_label_contour_mark o_label_contour_mark_bottom_left">
                <div class="o_label_contour_mark_horizontal">&amp;nbsp;</div>
                <div class="o_label_contour_mark_vertical">&amp;nbsp;</div>
            </div>
            <div class="o_label_contour_mark o_label_contour_mark_bottom_right">
                <div class="o_label_contour_mark_horizontal">&amp;nbsp;</div>
                <div class="o_label_contour_mark_vertical">&amp;nbsp;</div>
            </div>
        </template>

        <template id="report_simple_label2x7">
            <t t-set="barcode_size" t-value="'width:100%;height:29mm'"/>

            <td t-att-style="label['invisible'] and 'visibility:hidden;'">
                <div class="o_label_full o_label_2x7">
                    <t t-if="not label.get('invisible')">
                    <t t-call="product.report_label_contour_marks"/>
                    <div class="o_label_centering_table">
                        <div class="o_label_centered_content">

                            <div class="o_label_table">

                                <div class="o_label_barcode_side">
                                    <div class="o_label_barcode_block" t-if="label['barcode']">
                                        <div class="o_label_barcode"
                                            t-out="label['barcode']"
                                            t-options="{
                                                'widget': 'barcode',
                                                'quiet': 0,
                                                'symbology': 'auto',
                                                'img_style': barcode_size
                                            }"/>
                                        <div class="o_label_identifier_text" t-out="label['identifier_text']"/>
                                    </div>
                                </div>

                                <div class="o_label_info_side">
                                    <div class="o_label_title" t-out="label['title']"/>

                                    <div class="o_product_code" t-out="label['product_code']"/>

                                    <div class="o_label_extra_content">
                                        <t t-if="label['extra_html']" t-out="label['extra_html']"/>
                                        <t t-else="">&amp;nbsp;</t>
                                    </div>

                                    <div t-if="label['price_included']" class="o_label_meta_block">
                                        <strong class="o_label_price"
                                                t-out="label['price']"
                                                t-options="{
                                                    'widget': 'monetary',
                                                    'display_currency': label['currency_id']
                                                }"/>
                                        <div t-if="label['base_unit_price']" class="o_label_meta_line">
                                            <t t-out="label['base_unit_price']"
                                               t-options="{'widget': 'monetary', 'display_currency': label['currency_id']}"/>
                                            /<t t-out="label['base_unit_name']"/>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                    </t>
                </div>
            </td>
        </template>

        <template id="report_simple_label4x7">
            <t t-set="barcode_size" t-value="'width:100%;height:8mm'"/>

            <td t-att-style="label['invisible'] and 'visibility:hidden;'">
                <div class="o_label_full o_label_4x7">
                    <t t-if="not label.get('invisible')">
                    <t t-call="product.report_label_contour_marks"/>
                    <div class="o_label_centering_table">
                        <div class="o_label_centered_content">

                            <div class="o_label_title" t-out="label['title']"/>

                            <div class="o_label_content">
                                <div class="o_label_barcode_block">
                                    <div t-if="label['barcode']"
                                        class="o_label_barcode"
                                        t-out="label['barcode']"
                                        t-options="{
                                            'widget': 'barcode',
                                            'quiet': 0,
                                            'symbology': 'auto',
                                            'img_style': barcode_size
                                        }"/>
                                    <div t-else="" class="o_label_barcode" t-att-style="barcode_size">&amp;nbsp;</div>
                                    <div class="o_label_identifier_text">
                                        <t t-if="label['barcode']" t-out="label['identifier_text']"/>
                                        <t t-else="">&amp;nbsp;</t>
                                    </div>
                                </div>

                                <div class="o_label_table">
                                    <div class="o_product_code" t-out="label['product_code']"/>

                                    <div t-if="label['price_included']" class="o_label_meta_block">
                                        <strong class="o_label_price"
                                                t-out="label['price']"
                                                t-options="{
                                                    'widget': 'monetary',
                                                    'display_currency': label['currency_id']
                                                }"/>
                                        <div t-if="label['base_unit_price']" class="o_label_meta_line">
                                            <t t-out="label['base_unit_price']"
                                               t-options="{'widget': 'monetary', 'display_currency': label['currency_id']}"/>
                                            /<t t-out="label['base_unit_name']"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    </t>
                </div>
            </td>
        </template>

        <template id="report_simple_label4x12">
            <t t-set="barcode_size" t-value="'width:100%;height:6mm'"/>

            <td t-att-style="label['invisible'] and 'visibility:hidden;'">
                <div t-attf-class="o_label_full o_label_4x12 #{label.get('label_class', '')}">
                    <t t-if="not label.get('invisible')">
                    <t t-call="product.report_label_contour_marks"/>
                    <div class="o_label_centering_table">
                        <div class="o_label_centered_content">
                            <div class="o_label_table o_label_header">
                                <div class="o_label_title" t-out="label['title']"/>

                                <div t-if="label['price_included']" class="o_label_meta_block">
                                    <strong class="o_label_price"
                                            t-out="label['price']"
                                            t-options="{
                                                'widget': 'monetary',
                                                'display_currency': label['currency_id']
                                            }"/>
                                    <div t-if="label['base_unit_price']" class="o_label_meta_line">
                                        <t t-out="label['base_unit_price']"
                                           t-options="{'widget': 'monetary', 'display_currency': label['currency_id']}"/>
                                        /<t t-out="label['base_unit_name']"/>
                                    </div>
                                </div>
                            </div>

                            <div class="o_label_content">
                                <div class="o_label_barcode_block">
                                    <div t-if="label['barcode']"
                                        class="o_label_barcode"
                                        t-out="label['barcode']"
                                        t-options="{
                                            'widget': 'barcode',
                                            'quiet': 0,
                                            'symbology': 'auto',
                                            'img_style': barcode_size
                                        }"/>
                                    <div t-else="" class="o_label_barcode" t-att-style="barcode_size">&amp;nbsp;</div>
                                </div>

                                <div class="o_label_table o_label_footer">
                                    <div class="o_label_identifier_text">
                                        <t t-if="label['barcode']" t-out="label['identifier_text']"/>
                                        <t t-else="">&amp;nbsp;</t>
                                    </div>

                                    <div class="o_product_code" t-out="label['product_code']"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    </t>
                </div>
            </td>
        </template>

        <template id="report_simple_label4x12_gs1">
            <t t-set="barcode_size" t-value="'width:100%;height:16mm'"/>

            <td t-att-style="label['invisible'] and 'visibility:hidden;'">
                <div class="o_label_full o_label_4x12_gs1">
                    <t t-if="not label.get('invisible')">
                    <t t-call="product.report_label_contour_marks"/>
                    <div class="o_label_centering_table">
                        <div class="o_label_centered_content">
                            <div class="o_label_table">
                                <div class="o_label_barcode_side">
                                    <div class="o_label_barcode_block">
                                        <div t-if="label['barcode']"
                                            class="o_label_barcode"
                                            t-out="label['barcode']"
                                            t-options="{
                                                'widget': 'barcode',
                                                'quiet': 0,
                                                'symbology': 'ECC200DataMatrix',
                                                'img_style': barcode_size
                                            }"/>
                                        <div t-else="" class="o_label_barcode" t-att-style="barcode_size">&amp;nbsp;</div>
                                    </div>
                                </div>

                                <div class="o_label_info_side">
                                    <div class="o_label_info_frame">
                                        <div class="o_label_info_top">
                                            <div class="o_label_title" t-out="label['title']"/>
                                            <div class="o_product_code" t-out="label['product_code']"/>
                                        </div>

                                        <div class="o_label_info_bottom">
                                            <div class="o_label_identifier_text" t-out="label['identifier_text']"/>

                                            <div t-if="label['price_included']" class="o_label_meta_block">
                                                <strong class="o_label_price"
                                                        t-out="label['price']"
                                                        t-options="{
                                                            'widget': 'monetary',
                                                            'display_currency': label['currency_id']
                                                        }"/>
                                                <div t-if="label['base_unit_price']" class="o_label_meta_line">
                                                    <t t-out="label['base_unit_price']"
                                                       t-options="{'widget': 'monetary', 'display_currency': label['currency_id']}"/>
                                                    /<t t-out="label['base_unit_name']"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    </t>
                </div>
            </td>
        </template>

        <template id="report_simple_label_dymo">
            <t t-set="barcode_size" t-value="'width:100%;height:9mm'"/>
            <t t-set="padding_page" t-value="'padding: 2mm'"/>

            <div t-attf-class="o_label_sheet o_label_dymo #{label.get('label_class', '')}" t-att-style="padding_page">
                <div class="o_label_full">
                    <div class="o_label_centering_table">
                        <div class="o_label_centered_content">
                            <div class="o_label_title" t-out="label['title']"/>

                            <div class="o_label_content">
                                <div class="o_label_barcode_block">
                                    <div t-if="label['barcode']"
                                        class="o_label_barcode"
                                        t-out="label['barcode']"
                                        t-options="{
                                            'widget': 'barcode',
                                            'quiet': 0,
                                            'symbology': 'auto',
                                            'img_style': barcode_size
                                        }"/>
                                    <div t-else="" class="o_label_barcode" t-att-style="barcode_size">&amp;nbsp;</div>
                                    <div class="o_label_identifier_text">
                                        <t t-if="label['barcode']" t-out="label['identifier_text']"/>
                                        <t t-else="">&amp;nbsp;</t>
                                    </div>
                                </div>

                                <div t-if="label['price_included'] and not label['base_unit_price']" class="o_label_no_unit_price_spacer">&amp;nbsp;</div>

                                <div class="o_label_table">
                                    <div class="o_product_code" t-out="label['product_code']"/>

                                    <div t-if="label['price_included']" class="o_label_meta_block">
                                        <strong class="o_label_price"
                                                t-out="label['price']"
                                                t-options="{
                                                    'widget': 'monetary',
                                                    'display_currency': label['currency_id']
                                                }"/>
                                        <div t-if="label['base_unit_price']" class="o_label_meta_line">
                                            <t t-out="label['base_unit_price']"
                                               t-options="{'widget': 'monetary', 'display_currency': label['currency_id']}"/>
                                            /<t t-out="label['base_unit_name']"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </template>

        <template id="report_productlabel">
            <t t-call="web.html_container">
                <t t-if="columns and rows">
                    <t t-if="columns == 2 and rows == 7">
                        <t t-set="padding_page" t-value="'padding: 14mm 3mm'"/>
                        <t t-set="report_to_call" t-value="'2x7'"/>
                    </t>
                    <t t-if="columns == 4 and rows == 7">
                        <t t-set="padding_page" t-value="'padding: 14mm 3mm'"/>
                        <t t-set="report_to_call" t-value="'4x7'"/>
                    </t>
                    <t t-if="columns == 4 and rows == 12">
                        <t t-set="padding_page" t-value="'padding: 20mm 8mm'"/>
                        <t t-set="report_to_call" t-value="'4x12'"/>
                    </t>
                    <t t-foreach="label_pages" t-as="page_rows">
                        <div class="o_label_sheet" t-att-style="padding_page">
                            <table class="my-0 table table-sm table-borderless">
                                <t t-foreach="page_rows" t-as="label_row">
                                    <tr>
                                        <t t-foreach="label_row" t-as="label">
                                            <!-- IMPORTANT: explictly call templates in place of {{template}} otherwise studio won't load report correctly -->
                                            <t t-if="report_to_call == '2x7'">
                                                <t t-call="product.report_simple_label2x7"/>
                                            </t>
                                            <t t-elif="report_to_call == '4x7'">
                                                <t t-call="product.report_simple_label4x7"/>
                                            </t>
                                            <t t-elif="report_to_call == '4x12'">
                                                <t t-call="product.report_simple_label4x12"/>
                                            </t>
                                        </t>
                                    </tr>
                                </t>
                            </table>
                        </div>
                    </t>
                </t>
            </t>
        </template>

        <template id="report_productlabel_dymo">
            <t t-call="web.html_container">
                <t t-foreach="dymo_labels" t-as="label">
                    <t t-call="product.report_simple_label_dymo"/>
                </t>
            </t>
        </template>

        <template id="normal_zpl_label">
            <t t-if="product._name == 'product.product'">
^FT35,40^A0N,25^FD<t t-out="f'[{product.default_code}] {product.name}' if product.default_code else product.name"/>^FS
^FT35,65^A0N,20^FD<t t-out="product.product_template_attribute_value_ids._get_combination_name()"/>^FS
            </t>
            <t t-else="">
^FT35,40^A0N,25^FD<t t-out="product_info['display_name_markup']"/>^FS
            </t>
            <t t-if="barcode">
^FO35,77^BY2 ^BCN,100,Y,N,N ^FD<t t-out="barcode"/>^FS
            </t>
            <t t-if="price_included">
                <t t-if="base_unit_price">
^FO150,210 ^A0N,25^FH ^FD(<t t-out="currency_id.format(base_unit_price)"/>/<t t-out="product.base_unit_name"/>)^FS
                </t>
^FO300,200 ^A0N,40^FH ^FD<t t-out="currency_id.format(price)"/>^FS
            </t>
        </template>

        <template id="alternative_zpl_label">
            <t t-if="product._name == 'product.product'">
^FT35,30^A0N,20^FD<t t-out="f'[{product.default_code}] {product.name}' if product.default_code else product.name"/>^FS
^FT35,48^A0N,15^FD<t t-out="product.product_template_attribute_value_ids._get_combination_name()"/>^FS
            </t>
            <t t-else="">
^FT35,30^A0N,20^FD<t t-out="product_info['display_name_markup']"/>^FS
            </t>
            <t t-if="barcode">
^FO35,55^BY2 ^BCN,100,Y,N,N ^FD<t t-out="barcode"/>^FS
            </t>
            <t t-if="price_included">
                <t t-if="base_unit_price">
^FO160,185 ^A0N,18^FH ^FD(<t t-out="currency_id.format(base_unit_price)"/>/<t t-out="product.base_unit_name"/>)^FS
                </t>
^FO290,165 ^A0N,30^FH ^FD<t t-out="currency_id.format(price)"/>^FS
            </t>
        </template>

        <template id="small_zpl_label">
            <t t-value="f'[{product.default_code}] {product.name}' if product.default_code else product.name"
               t-set="label_title"/>
^FT35,30^A0N,15^FD<t t-out="(label_title[:27] + '...') if len(label_title) > 30 else label_title"/>^FS
            <t t-if="barcode">
^FO35,50^BY1 ^BCN,80,Y,N,N ^FD<t t-out="barcode"/>^FS
            </t>
            <t t-if="price_included">
^FO150,165 ^A0N,25^FH ^FD<t t-out="currency_id.format(price)"/>^FS
            </t>
        </template>

        <template id="jewelry_zpl_label">
^FT210,30^A0N,25^FD<t t-out="product.name"/>^FS
            <t t-if="barcode">
^FO35,5^BY1 ^BCN,80,Y,N,N ^FD<t t-out="barcode"/>^FS
            </t>
            <t t-if="price_included">
^FO290,50 ^A0N,30^FH ^FD<t t-out="currency_id.format(price)"/>^FS
            </t>
        </template>

        <template id="report_productlabel_zpl">
            <t t-foreach="quantity.items()" t-as="barcode_and_qty_by_product">
                <t t-set="product" t-value="barcode_and_qty_by_product[0]"/>
                <t t-set="currency_id" t-value="pricelist.currency_id or product.currency_id"/>
                <t t-set="price" t-value="pricelist._get_product_price(product, 1, currency=currency_id)"/>
                <t t-set="base_unit_price" t-value="product._get_base_unit_price(price) if product.base_unit_count and product.base_unit_name else 0"/>
                <t t-foreach="barcode_and_qty_by_product[1]" t-as="product_info">
                    <t t-set="barcode" t-value="product_info['barcode']"/>
                    <t t-foreach="range(product_info['quantity'])" t-as="qty">
                        <t t-translation="off">
^XA^CI28

                            <t t-if="'normal' in zpl_template" t-call="product.normal_zpl_label"/>
                            <t t-elif="'small' in zpl_template" t-call="product.small_zpl_label"/>
                            <t t-elif="'alternative' in zpl_template" t-call="product.alternative_zpl_label"/>
                            <t t-elif="'jewelry' in zpl_template" t-call="product.jewelry_zpl_label"/>
^XZ
                        </t>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>
