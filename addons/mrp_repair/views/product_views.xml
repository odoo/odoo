<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_search_view" model="ir.ui.view">
        <field name="name">product.template.search.inherit.mrp_repair</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='favorites']" position="after">
                <filter name="bom_parts" string="Product to Repair Components"
                        domain="[('id', 'in', context.get('catalog_bom_product_ids'))]"
                        invisible="not context.get('catalog_bom_product_ids')"/>
            </xpath>
        </field>
    </record>
</odoo>
