<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_nilvera_get_edispatch_purchase_attachments" model="ir.cron">
        <field name="name">Nilvera: retrieve e-Dispatch purchase attachments</field>
        <field name="model_id" ref="model_stock_picking"/>
        <field name="state">code</field>
        <field name="code">model._cron_nilvera_get_edispatch_purchase_attachments()</field>
        <field name="interval_number">12</field>
        <field name="interval_type">hours</field>
        <field name="nextcall" eval="(DateTime.now() + timedelta(hours=12)).strftime('%Y-%m-%d %H:%M:%S')"/>
    </record>
    <record id="ir_cron_nilvera_get_edispatch_purchase_pdf" model="ir.cron">
        <field name="name">Nilvera: retrieve e-Dispatch purchase PDFs</field>
        <field name="model_id" ref="model_stock_picking"/>
        <field name="state">code</field>
        <field name="code">model._cron_nilvera_get_edispatch_purchase_pdf()</field>
        <field name="interval_number">12</field>
        <field name="interval_type">hours</field>
        <field name="nextcall" eval="(DateTime.now() + timedelta(hours=12)).strftime('%Y-%m-%d %H:%M:%S')"/>
    </record>
</odoo>
