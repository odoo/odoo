<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="l10n_tr_nilvera_ereceipt_import_view_form" model="ir.ui.view">
        <field name="name">l10n_tr.nilvera.ereceipt.import.view.form</field>
        <field name="model">l10n_tr.nilvera.ereceipt.import</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="warehouse_id" required="True"/>
                        </group>
                    </group>
                    <div class="mt-2 mb-2">
                        <field name="ereceipt_file" string="Test" widget="ereceipt_upload"/>
                    </div>
                </sheet>
                <footer>
                    <button string="Import" name="action_import_receipt" type="object" class="btn btn-primary" data-hotkey="v"/>
                    <button string="Discard" class="btn btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="edispatch_import_action" model="ir.actions.act_window">
        <field name="name">Upload E-Receipt</field>
        <field name="res_model">l10n_tr.nilvera.ereceipt.import</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
