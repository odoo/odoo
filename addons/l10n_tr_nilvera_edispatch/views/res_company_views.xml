<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_company_form_inherit_l10n_tr_nilvera_edispatch" model="ir.ui.view">
        <field name="name">res.company.view.form.inherit</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='zip']" position="after">
                <field name="l10n_tr_nilvera_edispatch_customs_zip" placeholder="Customs ZIP" invisible="country_code == 'TR'"/>
            </xpath>
        </field>
    </record>

</odoo>
