<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="website_blog.BlogPageOption">
    <BuilderContext action="'websiteConfig'">

        <!-- Generic Options -->
        <div class="options-container-section-title ps-2 pt-2 pb-1 fw-bold">General</div>
        <hr class="mx-2 mt-0 mb-2"/>

        <BuilderRow label.translate="Breadcrumb">
            <BuilderCheckbox actionParam="{views: ['website_blog.opt_blog_post_breadcrumb']}"/>
        </BuilderRow>

        <!-- Layout -->
        <div class="options-container-section-title ps-2 pt-3 pb-1 fw-bold">Layout</div>
        <hr class="mx-2 mt-0 mb-2"/>

        <BuilderRow label.translate="Style">
            <BuilderSelect>
                <BuilderSelectItem id="'regular_cover'" actionParam="{views: ['website_blog.opt_blog_post_regular_cover']}">Title Above Cover</BuilderSelectItem>
                <BuilderSelectItem id="'split_cover'" actionParam="{views: ['website_blog.opt_blog_post_split_cover']}">Split Cover</BuilderSelectItem>
                <BuilderSelectItem actionParam="{views: []}">Title Inside Cover</BuilderSelectItem>
            </BuilderSelect>
        </BuilderRow>
        <BuilderRow label.translate="Author" level="1">
            <BuilderCheckbox actionParam="{views: ['website_blog.opt_blog_post_header_author_avatar_display']}"/>
        </BuilderRow>
        <BuilderRow label.translate="Share Links" level="1">
            <BuilderCheckbox actionParam="{views: ['website_blog.opt_blog_post_header_share_links_display']}"/>
        </BuilderRow>
        <BuilderRow label.translate="Tags" level="1">
            <BuilderCheckbox actionParam="{views: ['website_blog.opt_blog_post_header_tags_display']}"/>
        </BuilderRow>
        <BuilderRow label.translate="Full Width Cover" level="1">
            <BuilderCheckbox t-if="this.isActiveItem('regular_cover')" actionParam="{views: ['website_blog.opt_blog_post_full_width_cover']}"/>
        </BuilderRow>

        <BuilderRow label.translate="Comments" tooltip.translate="Toggle comments">
            <BuilderCheckbox actionParam="{views: ['website_blog.opt_blog_post_comment']}"/>
        </BuilderRow>

        <BuilderRow label.translate="Bottom">
            <BuilderCheckbox actionParam="{views: ['website_blog.opt_blog_post_read_next']}" id="'next_article_opt'"/>
        </BuilderRow>

        <!-- Sidebar -->
        <div class="options-container-section-title ps-2 pt-3 pb-1 fw-bold">Sidebar</div>
        <hr class="mx-2 mt-0 mb-2"/>

        <BuilderRow label.translate="Author">
            <BuilderCheckbox id="'blog_post_author_opt'" actionParam="{views: ['website_blog.opt_blog_post_author_avatar_display']}"/>
        </BuilderRow>

        <BuilderRow label.translate="Table of Contents">
            <BuilderCheckbox id="'blog_post_toc_opt'" actionParam="{views: ['website_blog.opt_blog_post_toc_display']}"/>
        </BuilderRow>

        <BuilderRow label.translate="Share Links">
            <BuilderCheckbox id="'blog_post_share_links_opt'" actionParam="{views: ['website_blog.opt_blog_post_share_links_display']}"/>
        </BuilderRow>

        <BuilderRow label.translate="Tags">
            <BuilderCheckbox id="'blog_post_tags_opt'" actionParam="{views: ['website_blog.opt_blog_post_tags_display']}"/>
        </BuilderRow>

        <BuilderRow label.translate="Blogs List">
            <BuilderCheckbox id="'blog_post_blogs_opt'" actionParam="{views: ['website_blog.opt_blog_post_blogs_display']}"/>
        </BuilderRow>

        <BuilderRow label.translate="Archive">
            <BuilderCheckbox id="'blog_post_archive_opt'" actionParam="{views: ['website_blog.opt_blog_post_archive_display']}"/>
        </BuilderRow>

        <BuilderRow
            label.translate="Container Size"
            tooltip.translate="Adapt the size of the blog post's content"
            t-if="!this.isActiveItem('split_cover') and !this.isActiveItem('blog_post_archive_opt') and !this.isActiveItem('blog_post_author_opt') and !this.isActiveItem('blog_post_blogs_opt') and !this.isActiveItem('blog_post_share_links_opt') and !this.isActiveItem('blog_post_tags_opt') and !this.isActiveItem('blog_post_toc_opt')"
        >
            <BuilderSelect>
                <BuilderSelectItem actionParam="{views: []}">Default</BuilderSelectItem>
                <BuilderSelectItem actionParam="{views: ['website_blog.opt_blog_post_large_container']}">Large</BuilderSelectItem>
            </BuilderSelect>
        </BuilderRow>
    </BuilderContext>

    <BuilderRow label.translate="Recommended Post" tooltip.translate="Promote a post" level="1" t-if="this.isActiveItem('next_article_opt')">
        <BuilderMany2One
            action="'setRecommendedNextPost'"
            applyTo="'#o_wblog_post_footer'"
            model="'blog.post'"
            domain="[
                ['is_published', '=', true],
                ['id', '!=', this.services.website.currentWebsite.metadata.mainObject.id],
                ['website_id', 'in', [false, this.services.website.currentWebsite.id]],
            ]"
            allowUnselect="this.state.isNextPostRecommended"
            unselectBtnTitle.translate="Reset to default post"
        />
    </BuilderRow>
</t>

<t t-inherit="website.BuilderOptions" t-inherit-mode="extension">
    <xpath expr="//t[@id='page_options_hook']" position="after">
        <blog_page_option
            selector="main:has(#o_wblog_post_main)"
            title="Blog Page"
            groups='["website.group_website_designer"]'
            editableOnly="false"/>
    </xpath>
</t>

</templates>
