<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="website_visitor_view_form" model="ir.ui.view">
        <field name="name">website.visitor.view.form.inherit.blog</field>
        <field name="model">website.visitor</field>
        <field name="inherit_id" ref="website.website_visitor_view_form"/>
        <field name="arch" type="xml">
            <!-- Add stat button near product views -->
            <xpath expr="//button[@name='%(website.website_visitor_page_action)d']" position="after">
                <button name="visitor_view_action_button"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-tags"
                    context="{'model_name': 'blog.post', 'title': 'Blog Views History'}">
                    <field name="visitor_blog_count" widget="statinfo" string="Blog Views"/>
                </button>
            </xpath>

            <!-- Show viewed blogs in tag list -->
            <field name="page_ids" position="after">
                <field name="blog_post_ids" widget="many2many_tags"/>
            </field>
        </field>
    </record>

    <record id="website_blog_visitor_view_tree" model="ir.ui.view">
        <field name="name">website.visitor.view.list</field>
        <field name="model">website.visitor</field>
        <field name="inherit_id" ref="website.website_visitor_view_tree"/>
        <field name="arch" type="xml">
            <field name="page_ids" position="after">
                <field name="blog_post_ids" widget="many2many_tags"/>
            </field>
        </field>
    </record>

</odoo>
