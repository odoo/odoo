<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="product_product_delivery_gelato" model="product.product">
            <field name="name">Economic Delivery</field>
            <field name="default_code">ED</field>
            <field name="type">service</field>
            <field name="categ_id" ref="delivery.product_category_deliveries"/>
            <field name="sale_ok" eval="False"/>
            <field name="purchase_ok" eval="False"/>
            <field name="list_price">0.0</field>
            <field name="invoice_policy">order</field>
        </record>

        <record id="delivery_carrier_gelato_economy_delivery" model="delivery.carrier">
            <field name="name">Economic Delivery</field>
            <field name="sequence">30</field>
            <field name="delivery_type">gelato</field>
            <field name="integration_level">rate</field>
            <field name="product_id" ref="sale_gelato_connector.product_product_delivery_gelato"/>
        </record>
    </data>
</odoo>