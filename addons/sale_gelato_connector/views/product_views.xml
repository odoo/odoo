<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="product_template_form_view" model="ir.ui.view">
                <field name="name">product.template.product.gelato.form</field>
                <field name="model">product.template</field>
                <field name="inherit_id" ref="product.product_template_form_view"></field>
                <field name="arch" type="xml">
                <group name="upsell" position="after">
                    <group string="Gelato" invisible="(type not in ['product', 'consu'])">

                        <field name="gelato_template_id" invisible="is_product_variant"/>
                        <field name="gelato_reference"  invisible="(product_variant_count &gt; 1) and not is_product_variant"/>
                        <field name="gelato_photo_url"/>
                        <button type="object" name="create_product_variants_from_gelato_template" class="btn btn-secondary" string="Generate variants"  invisible="is_product_variant" />
                    </group>
                </group>
                </field>
        </record>
</odoo>