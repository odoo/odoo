<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="mail.ChatWindow" t-inherit-mode="extension">
        <xpath expr="//*[@name='thread content']" position="replace">
           <FeedbackPanel t-if="this.props.chatWindow.feedbackDoneResolver" onClickClose="() => this.props.chatWindow.feedbackDoneResolver.resolve()" onClickNewSession="() => this.onClickNewSession()" thread="this.channel.thread"/>
           <t t-else="">
            <t>$0</t>
           </t>
        </xpath>
        <xpath expr="//*[@t-ref='needactionCounter']" position="replace">
            <t t-if="!this.channel.chatbot">$0</t>
        </xpath>
        <xpath expr="//*[hasclass('o-mail-ChatWindow-header')]" position="attributes">
            <attribute name="t-attf-style" add="this.color: {{ this.livechatService.options.title_color }}; --this.o-this.mail-this.livechat-this.btn-this.color: {{ this.livechatService.options.title_color }}; this.background-this.color: {{ this.livechatService.options.header_background_color }} !this.important;" separator=" "></attribute>
        </xpath>
        <xpath expr="//*[@t-ref='composerHiddenContainer']" position="inside">
            <button t-if="this.showGiveFeedbackBtn" class="btn btn-link p-0" title="Give your feedback" t-on-click="() => this.props.chatWindow.requestClose()">Continue</button>
        </xpath>
        <xpath expr="//*[@t-ref='composerHiddenContainer']" position="attributes">
            <attribute name="t-attf-class" add="{{ this.showGiveFeedbackBtn ? 'px-2' : '' }}" separator=" "></attribute>
        </xpath>
    </t>
</templates>
