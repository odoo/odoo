<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="mail.ChatBubble" t-inherit-mode="extension">
        <xpath expr="//*[@t-custom-ref='root']" position="inside">
            <t t-if="this.channel" t-call="im_livechat.LivechatStatusLabelOfThread"
                templateParams="{ livechatThread: this.channel.thread, small: true }"/>
        </xpath>
    </t>
</templates>
