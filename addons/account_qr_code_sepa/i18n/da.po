#. module: account_qr_code_sepa
#: model:ir.model,name:account_qr_code_sepa.model_res_partner_bank
msgid "Bank Accounts"
msgstr "Bankkonti"

#. module: account_qr_code_sepa
#. odoo-python
#: code:addons/account_qr_code_sepa/models/res_bank.py:0
#, python-format
msgid "Can't generate a SEPA QR Code with the %s currency."
msgstr "Det er ikke muligt at generere en SEPA-QR-kode med valutaen %s."

#. module: account_qr_code_sepa
#. odoo-python
#: code:addons/account_qr_code_sepa/models/res_bank.py:0
#, python-format
msgid "Can't generate a SEPA QR code if the account type isn't IBAN."
msgstr ""
"Det er ikke muligt at generere en SEPA-QR-kode, hvis kontooplysningerne ikke "
"er i IBAN-format."

#. module: account_qr_code_sepa
#. odoo-python
#: code:addons/account_qr_code_sepa/models/res_bank.py:0
#, python-format
msgid "Can't generate a SEPA QR code with a non SEPA iban."
msgstr ""
"Kan ikke generere en SEPA-QR-kode med en konto, der ikke er i SEPA-IBAN-"
"format."

#. module: account_qr_code_sepa
#. odoo-python
#: code:addons/account_qr_code_sepa/models/res_bank.py:0
#, python-format
msgid "SEPA Credit Transfer QR"
msgstr "QR til SEPA-overførsel"

#. module: account_qr_code_sepa
#. odoo-python
#: code:addons/account_qr_code_sepa/models/res_bank.py:0
#, python-format
msgid ""
"The account receiving the payment must have an account holder name or "
"partner name set."
msgstr ""
"Kontoen, der modtager betalingen, skal have angivet et kontohaver- eller "
"partnernavn."
