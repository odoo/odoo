<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- https://sdk.qfapi.com/integration/online-shop/checkout-integration/payment-element -->

    <record id="payment_method_unionpay" model="payment.method">
        <field name="name">UnionPay</field>
        <field name="code">unionpay</field>
        <field name="sequence">1000</field>
        <field name="active">False</field>
        <field name="image" type="bytes" file="payment/static/img/unionpay.png"/>
        <field name="support_tokenization">False</field>
        <field name="support_express_checkout">False</field>
        <field name="support_manual_capture">none</field>
        <field name="support_refund">none</field>
        <!-- <field name="provider_id" ref="payment.payment_provider_qfpay"/>-->
    </record>

</odoo>
