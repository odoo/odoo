"                    <t t-set=\"loop_cycle_number\" t-"
"value=\"loop_cycle_number or 0\"/>\n"
"                    <tr t-att-style=\"'background-color: #f2f2f2' if "
"loop_cycle_number % 2 == 0 else 'background-color: #ffffff'\">\n"
