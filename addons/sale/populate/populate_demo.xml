<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- A Populate demo for the Sale module -->
    <record id="fake_sale_demo" model="populate.blueprint">
        <field name="name">Sale - Populate Demo</field>
        <field name="definition_xml" type="xml">
            <model name="res.partner" count="1000" id="sale_customers">
                <field name="name" generator="fake.company"/>
                <field name="email" generator="fake.company_email"/>
                <field name="phone" generator="fake.phone_number"/>
                <field name="is_company" eval="True"/>
                <field name="active" eval="True"/>
                <field name="street" generator="fake.street_address"/>
                <field name="city" generator="fake.city"/>
                <field name="zip" generator="fake.postcode"/>
                <field name="country_id" domain="[('code', 'in', ['US', 'CA', 'GB', 'DE', 'FR'])]" null_ratio="0.1"/>
            </model>

            <model name="res.users" count="200" id="sale_users" context="{'tracking_disable': True, 'install_mode': True}">
                <field name="name" generator="fake.name"/>
                <field name="v_user_name" virtual="True" generator="fake.user_name"/>
                <field name="v_rng_digits" virtual="True" generator="scalar.integer" start="10" end="99"/>
                <field name="login" eval="f'{v_user_name}{v_rng_digits if v_rng_digits else ''}'" unique="True"/>
                <field name="email" generator="fake.email"/>
                <field name="group_ids" eval="[Command.set([env.ref('sales_team.group_sale_salesman').id])]"/>
            </model>

            <model name="crm.team" count="10" id="sale_teams" scale="False">
                <field name="v_counter" virtual="True" generator="misc.counter" start="1"/>
                <field name="name" eval="f'Sales Team {v_counter}'"/>
                <field name="member_ids" ref="sale_users" count="20" std="5"/>
            </model>

            <model name="sale.order" count="2000" id="sale_orders" context="{'mail_auto_subscribe_no_notify': True}">
                <field name="partner_id" ref="sale_customers"/>
                <field name="user_id" ref="sale_users" null_ratio="0.1"/>
                <field name="team_id" ref="sale_teams" null_ratio="0.1"/>
                <field name="state" values="{'draft': 4, 'sent': 2, 'sale': 6, 'cancel': 1}"/>
                <field name="date_order" start="now -2y" end="now" distribution="exponential(rate=0.003)"/>
                <field name="validity_date" start="today" end="today +30d" null_ratio="0.5"/>
                <field name="client_order_ref" generator="fake.bothify" text="PO-####-????" null_ratio="0.6"/>
                <field name="note" generator="fake.paragraph" null_ratio="0.7"/>
            </model>

            <model name="sale.order.line" count="8000" id="sale_order_lines" context="{'mail_auto_subscribe_no_notify': True}">
                <field name="order_id" ref="sale_orders" partition="True"/>
                <field name="product_id" domain="[('sale_ok', '=', True), ('type', '!=', 'combo')]"/>
                <field name="product_uom_qty" start="1" end="50" distribution="exponential(rate=0.1)"/>
                <field name="price_unit" start="5.0" end="5000.0" distribution="exponential(rate=0.001)"/>
                <field name="discount" start="0" end="30" distribution="exponential(rate=0.2)" null_ratio="0.7"/>
                <field name="v_qty_delivered_ratio" virtual="True" generator="scalar.float" start="0" end="1" distribution="beta(alpha=2, beta=2)"/>
                <field name="qty_delivered" eval="product_uom_qty * v_qty_delivered_ratio if v_qty_delivered_ratio else 0" null_ratio="0.4"/>
                <field name="sequence" start="1" end="100"/>
            </model>
        </field>
    </record>
</odoo>
