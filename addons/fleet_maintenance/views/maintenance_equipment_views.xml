<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="maintenance_equipment_view_form_inherit_fleet" model="ir.ui.view">
        <field name="name">maintenance.equipment.view.form.inherit.fleet</field>
        <field name="model">maintenance.equipment</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='equipment_assign_to']" position="after">
                <field name="vehicle_id" string="Vehicle" invisible="equipment_assign_to != 'vehicle' and equipment_assign_to != 'other'"/>
            </xpath>
            <xpath expr="//field[@name='owner_user_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="maintenance_equipment_view_search_inherit_fleet" model='ir.ui.view'>
        <field name="name">maintenance.equipment.view.search.inherit.fleet</field>
        <field name="model">maintenance.equipment</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_view_search"/>
        <field name="arch" type="xml">
        <filter name="assigned" position="attributes">
            <attribute name="invisible">1</attribute>
        </filter>
        <filter name="assigned" position="after">
            <filter string="Assigned to Vehicle" name="assigned_to_vehicle" domain="[('vehicle_id', '!=', False)]"/>
        </filter>
        <filter name="available" position="attributes">
            <attribute name="invisible">1</attribute>
        </filter>
        </field>
    </record>

    <record id="maintenance_equipment_view_kanban_inherit_fleet" model="ir.ui.view">
        <field name="name">maintenance.equipment.view.kanban.inherit.fleet</field>
        <field name="model">maintenance.equipment</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_view_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='owner_user_id']" position='attributes'>
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='serial_no']" position='after'>
                <field name="vehicle_id"/>
            </xpath>
        </field>
    </record>

    <record id="maintenance_equipment_view_tree_inherit_fleet" model="ir.ui.view">
        <field name="name">maintenance.equipment.view.list.inherit.fleet</field>
        <field name="model">maintenance.equipment</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='owner_user_id']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='owner_user_id']" position="after">
                <field name="vehicle_id" string="Employee"/>
            </xpath>
        </field>
    </record>
</odoo>
