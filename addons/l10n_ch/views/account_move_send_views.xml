<?xml version="1.0"?>
<odoo>
    <record id="l10n_ch_account_move_send_form" model="ir.ui.view">
        <field name="name">l10n_ch.account.move.send.form</field>
        <field name="model">account.move.send</field>
        <field name="inherit_id" ref="account.account_move_send_form"/>
        <field name="arch" type="xml">

            <div name="warnings" position="inside">
                <field name="partners_without_street" invisible="1"/>
                <div class="alert alert-info" role="alert" name="infos" invisible="not partners_without_street">
                    <span>You might want to specify an address on the following partner(s).</span>
                    <i class="oi oi-arrow-right ms-1"/>
                    <span class="ms-1">
                        <a
                            name="action_view_street_missing_partners"
                            type="object"
                            string="View Partner(s)"
                            />
                    </span>
                </div>
            </div>

        </field>
    </record>
</odoo>
