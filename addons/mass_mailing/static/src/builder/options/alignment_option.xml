<templates>
<t t-name="mass_mailing.BlockAlignmentOption">
    <BuilderRow label.translate="Alignment" t-if="!this.isActiveItem('so_width_100')">
        <BuilderButtonGroup>
            <!-- TODO EGGMAIL: investigate how margins behave in email clients -->
