<templates>
    <t t-name="mass_mailing.HorizontalPaddingOption">
        <BuilderRow label.translate="Padding ↔">
            <t t-set="left">Left</t>
            <t t-set="right">Right</t>
            <t t-set="sameLangDir" t-value="this.env.langDir.content === this.env.langDir.builder"/>
            <BuilderNumberInput
                title="this.env.langDir.builder === 'ltr' ? left : right"
                styleAction="sameLangDir ? 'padding-left' : 'padding-right'"
                unit="'px'"/>
            <BuilderNumberInput
                title="this.env.langDir.builder === 'ltr' ? right : left"
                styleAction="sameLangDir ? 'padding-right' : 'padding-left'"
                unit="'px'"/>
        </BuilderRow>
    </t>
    <t t-name="mass_mailing.VerticalPaddingOption">
        <BuilderRow label.translate="Padding ↕">
            <BuilderNumberInput title.translate="Top" styleAction="'padding-top'" unit="'px'"/>
            <BuilderNumberInput title.translate="Bottom" styleAction="'padding-bottom'" unit="'px'"/>
        </BuilderRow>
    </t>
</templates>
