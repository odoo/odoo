<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="mass_mail_1_body">
        <div class="o_layout o_default_theme oe_unremovable oe_unmovable" data-name="Mailing">
            <div class="container o_mail_wrapper oe_unremovable oe_unmovable o_mail_regular" style="border-collapse:collapse;">
                <div class="row mw-100 mx-0">
                    <div class="col o_mail_no_options o_mail_wrapper_td oe_structure">
                        <t t-call="mass_mailing.theme_default_template"/>
                    </div>
                </div>
            </div>
        </div>
    </template>

    <data noupdate="1">
        <record id="mass_mail_attach_1" model="ir.attachment">
            <field name="raw">bWlncmF0aW9uIHRlc3Q=</field>
            <field name="name">SampleDoc.doc</field>
        </record>

        <record id="mass_mail_1" model="mailing.mailing">
            <field name="subject">Thanks for joining us!</field>
            <field name="state">done</field>
            <field name="user_id" ref="base.user_admin"/>
            <field name="email_from">info@yourcompany.example.com</field>
            <field name="sent_date" eval="(DateTime.today() - relativedelta(days=5)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="campaign_id" ref="mass_mail_campaign_1"/>
            <field name="medium_id" ref="utm.utm_medium_email"/>
            <field name="source_id" ref="utm.utm_source_mailing"/>
            <field name="mailing_model_id" ref="base.model_res_partner"/>
            <field name="mailing_domain">[]</field>
            <field name="reply_to_mode">new</field>
            <field name="reply_to">Info &lt;info@yourcompany.example.com&gt;</field>
            <field name="body_arch" model="mail.render.mixin" eval="obj().env['ir.qweb']._render('mass_mailing.mass_mail_1_body', {'company_id': obj().env.ref('base.main_company'), 'res_company': obj().env.ref('base.main_company')})"/>
            <field name="body_html" type="html">
                <!-- Add links to generate demo link trackers, the body_html is removed in post-init hook -->
                <a class="btn btn-link" href="http://www.example.com">Follow this Link</a>
                <a class="btn btn-link" href="http://www.example.net/page/contactus">Follow this Link</a>
            </field>
            <field name="attachment_ids" eval="[(4, ref('mass_mail_attach_1'))]"/>
        </record>
        <!-- Generate link tracker information from the links -->
        <function model="mailing.mailing" name="convert_links" eval="[ref('mass_mailing.mass_mail_1')]"/>

        <record id="mass_mail_sale_order_0" model="mailing.mailing">
            <field name="subject">Don't miss this chance to learn more, {{object.name}}</field>
            <field name="state">draft</field>
            <field name="user_id" ref="base.user_admin"/>
            <field name="schedule_date" eval="(DateTime.today() + relativedelta(days=5)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="campaign_id" ref="mass_mailing.mass_mail_campaign_1"/>
            <field name="medium_id" ref="utm.utm_medium_email"/>
            <field name="mailing_model_id" ref="base.model_res_partner"/>
            <field name="mailing_domain" eval="[('country_id', '=', ref('base.us'))]"/>
            <field name="reply_to_mode">new</field>
            <field name="reply_to">{{ object.company_id.email }}</field>
            <field name="body_arch" type="html">
<div data-name="Mailing" class="o_layout oe_unremovable oe_unmovable o_empty_theme" style="background-color: #F7F7F7;">
    <div class="container o_mail_wrapper o_mail_regular oe_unremovable">
        <div class="row mw-100 mx-0">
            <div class="col o_mail_no_options o_mail_wrapper_td bg-white oe_structure">
                <!-- social header added in post-init hook -->
                <section class="o_mail_snippet_general s_text_image o_colored_level" data-vxml="001" data-snippet="s_mailing_list_advertisement" data-name="Mailing List">
                    <div class="container">
                        <div class="row align-items-center">
                            <div class="col-md-6 col-12 pt16 pb16 o_colored_level">
                                <div class="o_not_editable">
                                    <img class="img img-fluid o_editable_media mx-auto" src="/html_editor/shape/mass_mailing/s_newsletter_benefits_popup.svg" data-original-src="/html_editor/shape/mass_mailing/s_newsletter_benefits_popup.svg" data-mimetype="image/svg+xml" data-format-mimetype="image/svg+xml"/>
                                </div>
                            </div>
                            <div class="col-md-6 col-12 pt16 pb16 o_colored_level">
                                <h2><strong>
                                    <t title="object.name" t-out="object.name" data-oe-demo="Dear Customer"></t>, stay ahead with weekly insights &amp; updates</strong></h2>
                                <p>Join our mailing list to receive carefully curated resources, tips, and updates straight to your inbox.</p>
                                <p><span class="fa fa-check text-o-color-1" role="img"></span>  Curated Industry Insights</p>
                                <p><span class="fa fa-check text-o-color-1" role="img"></span>  Expert Tips &amp; How-Tos</p>
                                <p><span class="fa fa-check text-o-color-1" role="img"></span>  Guides &amp; Resources</p>
                                <p><a href="#" class="btn btn-primary">Subscribe</a></p>
                            </div>
                        </div>
                    </div>
                </section>
                <!-- social footer added in post-init hook-->
            </div>
        </div>
    </div>
</div>
            </field>
        </record>
    </data>
</odoo>
