<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="contact_to_mailing_list_view_form" model="ir.ui.view" >
        <field name="name">contact.to.mailing.list.view.form</field>
            <field name="model">contact.to.mailing.list</field>
            <field name="arch" type="xml">
                <form string="Send a Sample Mail">
                    <group>
                        <field name="mailing_list_ids" 
                            options="{'no_create_edit': True, 'no_open': True, 'color_field': 'color'}" placeholder="Select or create a list..."
                            widget="many2many_tags"/>
                        <field name="partner_ids" invisible="1"/>
                    </group>
                    <footer>
                        <button string="Add to List" name="action_add_contacts_to_mailing_lists" type="object" class="btn-primary"/>
                        <button string="Add &amp; Create Mailing" name="action_add_contacts_and_create_mailing" type="object" class="btn-primary"/>
                        <button class="btn-secondary" special="cancel" data-hotkey="x"/>
                    </footer>
                </form>
            </field>
    </record>

    <record id="contact_to_mailing_list_action" model="ir.actions.act_window">
        <field name="name">Add Contacts to Mailing Lists</field>
        <field name="res_model">contact.to.mailing.list</field>
        <field name="view_mode">form</field>
        <field name="context">{"dialog_size": "medium"}</field>
        <field name="target">new</field>
    </record>

</odoo>
