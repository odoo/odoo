<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="mass_mailing_egg.Builder">
    <div class="h-100 o-snippets-menu d-flex flex-column" t-ref="builderSidebar">
        <div class="o-snippets-top-actions d-flex justify-content-between flex-shrink-0">
            <div class="d-flex">
                <button type="button" t-on-click="() => this.undo()" t-att-disabled="!state.canUndo"
                    class="btn btn-secondary fa fa-undo"/>
                <button type="button" t-on-click="() => this.redo()" t-att-disabled="!state.canRedo"
                    class="btn btn-secondary fa fa-repeat"/>
            </div>
            <div class="d-flex">
                <button t-if="slots.viewModeButtons" t-on-click="onMobilePreviewClick" type="button" accesskey="v"
                    data-action="mobile" title="Mobile Preview" class="btn btn-secondary">
                    <span class="fa fa-mobile"/>
                </button>
                <button t-on-click="onFullscreenClick" type="button" data-action="fullscreen" accesskey="e"
                    title="Fullscreen Edition" class="btn btn-secondary">
                    <span class="fa fa-expand"/></button>
                <button type="button" t-on-click="discard" data-action="cancel" accesskey="j" title="Tip: Esc to preview"
                    class="btn btn-secondary">Discard</button>
                <button type="button" t-on-click="save" data-action="save" accesskey="s"
                    class="btn btn-primary">Save</button>
            </div>
        </div>
        <div class="o-snippets-tabs d-flex justify-content-between mt-2 p-2 pb-0 flex-shrink-0">
            <button data-name="blocks" t-on-click="() => this.onTabClick('blocks')" t-att-disabled="props.isTranslation"
                class="px-2 cursor-pointer pb-1 pe-auto bg-transparent text-uppercase border-0"
                t-att-class="{'active text-white': state.activeTab === 'blocks'}">
                <span class="ps-1">Blocks</span>
            </button>
            <button data-name="customize" t-on-click="() => this.onTabClick('customize')"
                class="px-2 cursor-pointer pb-1 bg-transparent text-uppercase border-0"
                t-att-class="{'active text-white': state.activeTab === 'customize'}">
                <span>Customize</span>
            </button>
            <button data-name="design" t-on-click="() => this.onTabClick('design')" t-att-disabled="props.isTranslation"
                class="px-2 cursor-pointer pb-1 bg-transparent text-uppercase border-0"
                t-att-class="{'active text-white': state.activeTab === 'design'}">
                <span class="pe-1">Design</span>
            </button>
        </div>
        <div class="o-tab-content overflow-y-auto overflow-x-hidden flex-grow-1 pt-1">
            <t t-if="state.activeTab === 'blocks'">
                <BlockTab/>
            </t>
            <t t-if="state.activeTab === 'customize'">
                <CustomizeTab currentOptionsContainers="state.currentOptionsContainers" snippetModel="snippetModel"/>
            </t>
            <t t-if="state.activeTab === 'design'">
                <!-- TODO EGGMAIL  -->
                <DesignTab/>
            </t>
        </div>
    </div>
</t>

</templates>
