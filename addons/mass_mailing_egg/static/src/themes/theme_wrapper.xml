<templates id="template">
    <!-- TODO EGGMAIL: check editor classes (should use only new editor technical classes) -->
    <t t-name="mass_mailing_egg.ThemeLayout">
        <div data-name="Mailing" class="o_layout oe_unremovable oe_unmovable bg-200"
            t-att-class="className" t-att-style="layoutStyles">
            <t t-if="nowrap" t-call="mass_mailing_egg.ThemeStructure"/>
            <t t-else="" t-call="mass_mailing_egg.ThemeWrapper"/>
        </div>
    </t>
    <t t-name="mass_mailing_egg.ThemeWrapper">
        <div class="container o_mail_wrapper o_mail_regular oe_unremovable">
            <div class="row">
                <!-- TODO data-oe-model guarantees that o_editable class is added, this is bullshit -->
                <div class="col o_mail_no_options o_mail_wrapper_td bg-white oe_structure" data-oe-model="" t-out="html"/>
            </div>
        </div>
    </t>
    <t t-name="mass_mailing_egg.ThemeStructure">
        <div class="oe_structure" t-out="html"/>
    </t>
</templates>
