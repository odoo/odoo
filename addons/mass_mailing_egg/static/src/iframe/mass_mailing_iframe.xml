<templates>
    <t t-name="mass_mailing_egg.MassMailingIframe">
        <div class="o_mass_mailing_iframe_wrapper bg-200" t-att-class="{'o_mass_mailing_fullscreen': state.showFullscreen}">
            <div class="d-flex w-100 h-100">
                <div class="flex-grow-1">
                    <LocalOverlayContainer localOverlay="overlayRef" identifier="env.localOverlayContainerKey"/>
                    <div class="h-100">
                        <iframe class="h-100" t-ref="iframeRef"/>
                    </div>
                </div>
                <div t-if="props.themeOptions.withBuilder"
                    class="o_mass_mailing_egg-builder_sidebar border-start border-dark o_builder_sidebar_open">
                    <LazyComponent t-if="state.ready" Component="'website.Builder'"
                        props="() => this.getBuilderProps()" bundle="'mass_mailing_egg.assets_builder'"/>
                </div>
            </div>
        </div>
    </t>
    <t t-name="mass_mailing_egg.IframeHead">
        <meta charset="utf-8"/>
        <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
        <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no"/>
    </t>
    <t t-name="mass_mailing_egg.IframeBody">
        <div class="note-editable"/>
    </t>
</templates>
