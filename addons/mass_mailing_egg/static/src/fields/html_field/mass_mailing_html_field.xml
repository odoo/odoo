<templates>
    <t t-name="mass_mailing_egg.HtmlField">
        <div t-if="displayTransition.shouldMount" t-att-class="displayTransition.class">
            <t t-if="state.showThemeSelector">
                <ThemeSelector config="getThemeSelectorConfig()"/>
            </t>
            <MassMailingIframe t-key="state.key"
                config="this.getConfig()" themeOptions="state.themeOptions" readonly="props.readonly"
                onEditorLoad.bind="onEditorLoad" onIframeLoad.bind="onIframeLoad" iframeRef="iframeRef"
                showThemeSelector="state.showThemeSelector" onBlur.bind="onBlur"/>
        </div>
    </t>
</templates>
