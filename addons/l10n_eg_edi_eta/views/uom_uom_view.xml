<odoo>
    <data>
        <record id="uom_uom_view_form" model="ir.ui.view">
            <field name="name">uom.uom.view.form.inherit.l10n.eg.edi.eta</field>
            <field name="model">uom.uom</field>
            <field name="inherit_id" ref="uom.uom_uom_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="l10n_eg_unit_code_id" groups="base.group_no_one" invisible="'EG' not in fiscal_country_codes"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
