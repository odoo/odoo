    <record id="payment_method_paypal_paylater" model="payment.method">
        <field name="name">Pay Later by PayPal</field>
        <field name="code">paypal_paylater</field>
        <field name="provider_id" ref="payment.payment_provider_paypal"/>
        <field name="image" type="bytes" file="payment/static/img/paypal_paylater.png"/>
        <field 
            name="supported_country_ids"
            eval="[Command.set([
                        ref('base.us'),
                        ref('base.au'),
                        ref('base.ca'),
                        ref('base.fr'),
                        ref('base.de'),
                        ref('base.it'),
                        ref('base.es'),
                        ref('base.uk'),
                    ])]"
        />
        <field 
            name="supported_currency_ids"
            eval="[Command.set([
                        ref('base.USD'),
                        ref('base.AUD'),
                        ref('base.CAD'),
                        ref('base.EUR'),
                        ref('base.GBP'),
                    ])]"
    />
    </record>

