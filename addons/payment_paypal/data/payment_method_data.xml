        />
    </record>

    <record id="payment_method_card" model="payment.method">
        <field name="name">Card</field>
        <field name="code">card</field>
        <field name="provider_id" ref="payment.payment_provider_paypal"/>
        <field name="image" type="bytes" file="payment/static/img/card.png"/>
        <field name="support_tokenization">True</field>
        <field
            name="supported_country_ids"
            eval="[Command.set([
                        ref('base.au'),
                        ref('base.at'),
                        ref('base.be'),
                        ref('base.bg'),
                        ref('base.ca'),
                        ref('base.cn'),
                        ref('base.cy'),
                        ref('base.cz'),
                        ref('base.dk'),
                        ref('base.ee'),
                        ref('base.fi'),
                        ref('base.fr'),
                        ref('base.de'),
                        ref('base.gr'),
                        ref('base.hk'),
                        ref('base.hu'),
                        ref('base.ie'),
                        ref('base.it'),
                        ref('base.jp'),
                        ref('base.lv'),
                        ref('base.li'),
                        ref('base.lt'),
                        ref('base.lu'),
                        ref('base.mt'),
                        ref('base.mx'),
                        ref('base.nl'),
                        ref('base.no'),
                        ref('base.pl'),
                        ref('base.pt'),
                        ref('base.ro'),
                        ref('base.sg'),
                        ref('base.sk'),
                        ref('base.si'),
                        ref('base.es'),
                        ref('base.se'),
                        ref('base.uk'),
                        ref('base.us'),
                    ])]"
        />
        <field
            name="supported_currency_ids"
            eval="[Command.set([
                        ref('base.AUD'),
                        ref('base.BRL'),
                        ref('base.CAD'),
                        ref('base.CHF'),
                        ref('base.CZK'),
                        ref('base.DKK'),
                        ref('base.EUR'),
                        ref('base.GBP'),
                        ref('base.HKD'),
                        ref('base.HUF'),
                        ref('base.ILS'),
                        ref('base.JPY'),
                        ref('base.MXN'),
                        ref('base.NOK'),
                        ref('base.NZD'),
                        ref('base.PHP'),
                        ref('base.PLN'),
                        ref('base.SEK'),
                        ref('base.SGD'),
                        ref('base.THB'),
                        ref('base.TWD'),
                        ref('base.USD'),
                    ])]"
        />
    </record>

