<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- === PRIMARY PAYMENT METHODS === -->

    <record id="payment_method_paypal" model="payment.method">
        <field name="name">Paypal</field>
        <field name="code">paypal</field>
        <field name="provider_id" ref="payment.payment_provider_paypal"/>
        <field name="image" type="bytes" file="payment/static/img/paypal.png"/>
    </record>

    <record id="payment_method_bancontact" model="payment.method">
        <field name="name">Bancontact</field>
        <field name="code">bancontact</field>
        <field name="provider_id" ref="payment.payment_provider_paypal"/>
        <field name="image" type="bytes" file="payment/static/img/bancontact.png"/>
        <field 
            name="supported_country_ids"
            eval="[Command.set([
                        ref('base.be'),
                    ])]"
        />
        <field 
            name="supported_currency_ids"
            eval="[Command.set([
                        ref('base.EUR'),
                    ])]"
        />
    </record>

