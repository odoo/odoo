<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="payment_provider_form" model="ir.ui.view">
        <field name="name">PayPal Provider Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <group name="provider_credentials" position="inside">
                <field
                    string="Email"
                    name="paypal_email_account"
                    invisible="code != 'paypal'"
                    required="is_live"
                />
                <field
                    string="Client ID"
                    name="paypal_client_id"
                    invisible="code != 'paypal'"
                    required="is_live"
                />
                <field
                    string="Client Secret"
                    name="paypal_client_secret"
                    invisible="code != 'paypal'"
                    required="is_live"
                    widget="password"
                />
                <label string="Webhook ID" for="paypal_webhook_id" invisible="code != 'paypal'"/>
                <div invisible="code != 'paypal'" class="o_row" col="2">
                    <field name="paypal_webhook_id"/>
                    <button
                        string="Generate your webhook"
                        type="object"
                        name="action_paypal_create_webhook"
                        invisible="paypal_webhook_id"
                        class="btn-primary"
                    />
                </div>
            </group>
        </field>
    </record>

</odoo>
