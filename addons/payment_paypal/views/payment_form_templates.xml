<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Only load the SDK on pages with the payment form. -->
    <template id="payment_paypal.form" inherit_id="payment.form">
        <xpath expr="." position="inside">
            <script src="/payment_paypal/static/src/js/payment_form.js"></script>
        </xpath>
    </template>

    <template id="payment_submit_button_inherit" inherit_id="payment.submit_button">
        <xpath expr="//button[@name='o_payment_submit_button']" position="before">
            <div id="o_provider_payment_submit_button"/>
            <div id="loading" class="d-flex justify-content-center d-none">
                <div class="spinner-border"/>
            </div>
        </xpath>
    </template>

    <template id="payment_paypal.method_form" inherit_id="payment.method_form">
        <xpath expr="//input[@name='o_payment_radio']" position="attributes">
            <attribute name="t-att-data-paypal-inline-form-values">
                provider_sudo._paypal_get_inline_form_values(amount, currency)
            </attribute>
            <attribute name="t-att-data-paypal-color">
                "blue"
            </attribute>
        </xpath>
    </template>

</odoo>
