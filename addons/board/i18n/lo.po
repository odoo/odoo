#. module: board
#. odoo-javascript
#: code:addons/board/static/src/board_controller.xml:0
msgid ""
"\"Add to\n"
"                  Dashboard\""
msgstr ""
"\"ເພີ່ມໃສ່\n"
"                  ກະດານຂໍ້ມູນ\""

#. module: board
#. odoo-javascript
#: code:addons/board/static/src/add_to_board/add_to_board.xml:0
msgid "Add"
msgstr "ເພີ່ມ"

#. module: board
#. odoo-javascript
#: code:addons/board/static/src/add_to_board/add_to_board.xml:0
msgid "Add to my dashboard"
msgstr "ເພີ່ມໃສ່ກະດານຂໍ້ມູນຂອງຂ້ອຍ"

#. module: board
#. odoo-javascript
#: code:addons/board/static/src/board_controller.js:0
msgid "Are you sure that you want to remove this item?"
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການລຶບລາຍການນີ້ອອກ?"

#. module: board
#. odoo-javascript
#: code:addons/board/static/src/board_view.js:0
#: model:ir.model,name:board.model_board_board
msgid "Board"
msgstr "ກະດານ"

#. module: board
#. odoo-javascript
#: code:addons/board/static/src/board_controller.xml:0
msgid "Change Layout"
msgstr "ປ່ຽນຮູບແບບ"

#. module: board
#. odoo-javascript
#: code:addons/board/static/src/add_to_board/add_to_board.js:0
msgid "Could not add filter to dashboard"
msgstr "ບໍ່ສາມາດເພີ່ມຕົວຕອງໃສ່ກະດານຂໍ້ມູນໄດ້"

#. module: board
#. odoo-javascript
#: code:addons/board/static/src/add_to_board/add_to_board.xml:0
msgid "Dashboard"
msgstr "ກະດານຂໍ້ມູນ"

#. module: board
#: model:ir.model.fields,field_description:board.field_board_board__id
msgid "ID"
msgstr "ລະຫັດ"

#. module: board
#. odoo-javascript
#: code:addons/board/static/src/board_action.xml:0
msgid "Invalid action"
msgstr "ການດຳເນີນການບໍ່ຖືກຕ້ອງ"

#. module: board
#. odoo-javascript
#: code:addons/board/static/src/board_controller.xml:0
msgid "Layout"
msgstr "ຮູບແບບ"

#. module: board
#: model:ir.actions.act_window,name:board.open_board_my_dash_action
#: model:ir.ui.menu,name:board.menu_board_my_dash
#: model_terms:ir.ui.view,arch_db:board.board_my_dash_view
msgid "My Dashboard"
msgstr "ກະດານຂໍ້ມູນຂອງຂ້ອຍ"

#. module: board
#. odoo-javascript
#: code:addons/board/static/src/add_to_board/add_to_board.js:0
msgid "Please refresh your browser for the changes to take effect."
msgstr "ກະລຸນາໂຫຼດໜ້າບຣາວເຊີຂອງທ່ານຄືນໃໝ່ເພື່ອໃຫ້ການປ່ຽນແປງມີຜົນ."

#. module: board
#. odoo-javascript
#: code:addons/board/static/src/board_controller.xml:0
msgid ""
"To add your first report into this dashboard, go to any\n"
"                  menu, switch to list or graph view, and click"
msgstr ""
"ເພື່ອເພີ່ມລາຍງານທຳອິດຂອງທ່ານເຂົ້າໃນກະດານຂໍ້ມູນນີ້, ໃຫ້ໄປທີ່\n"
"                  ເມນູໃດໜຶ່ງ, ປ່ຽນເປັນມຸມມອງລາຍການ ຫຼື ກຣາບ, ແລ້ວກົດ"

#. module: board
#. odoo-javascript
#: code:addons/board/static/src/board_controller.xml:0
msgid ""
"You can filter and group data before inserting into the\n"
"                  dashboard using the search options."
msgstr ""
"ທ່ານສາມາດຕອງ ແລະ ຈັດກຸ່ມຂໍ້ມູນກ່ອນທີ່ຈະແຊກໃສ່ໃນ\n"
"                  ກະດານຂໍ້ມູນໂດຍການໃຊ້ຕົວເລືອກການຄົ້ນຫາ."

#. module: board
#. odoo-javascript
#: code:addons/board/static/src/board_controller.xml:0
msgid "Your personal dashboard is empty"
msgstr "ກະດານຂໍ້ມູນສ່ວນຕົວຂອງທ່ານວ່າງເປົ່າ"

#. module: board
#. odoo-javascript
#: code:addons/board/static/src/board_controller.xml:0
msgid "in the extended search options."
msgstr "ໃນຕົວເລືອກການຄົ້ນຫາແບບຂະຫຍາຍ."

#. module: board
#. odoo-javascript
#: code:addons/board/static/src/add_to_board/add_to_board.js:0
msgid "“%s” added to dashboard"
msgstr "“%s” ຖືກເພີ່ມເຂົ້າໃນກະດານຂໍ້ມູນແລ້ວ"
