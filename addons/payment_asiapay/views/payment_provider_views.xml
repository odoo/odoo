<?xml version='1.0' encoding='utf-8' ?>
<odoo>

    <record id="payment_provider_form" model="ir.ui.view">
        <field name="name">AsiaPay Provider Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <group name="provider_credentials" position="inside">
                <field
                    string="Brand"
                    name="asiapay_brand"
                    invisible="code != 'asiapay'"
                    required="is_live"
                />
                <field
                    string="Merchant ID"
                    name="asiapay_merchant_id"
                    invisible="code != 'asiapay'"
                    required="is_live"
                />
                <field
                    string="Secure Hash Secret"
                    name="asiapay_secure_hash_secret"
                    invisible="code != 'asiapay'"
                    required="is_live"
                    widget="password"
                />
                <field
                    string="Secure Hash Function"
                    name="asiapay_secure_hash_function"
                    invisible="code != 'asiapay'"
                    required="is_live"
                    groups="base.group_no_one"/>
            </group>
            <field name="available_currency_ids" position="attributes">
                <attribute
                    name="required"
                    separator="or"
                    add="(code == 'asiapay')"
                />
            </field>
        </field>
    </record>

</odoo>
