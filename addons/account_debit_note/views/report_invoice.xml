<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_invoice_document_inherit_debit_note" inherit_id="account.report_invoice_document">

            <xpath expr="//t[@name='invoice_title']" position="replace">
                <t name="invoice_title">
                    <t t-if="o.debit_origin_id">Debit Note</t>
                    <t t-else="">Invoice</t>
                </t>
            </xpath>

            <xpath expr="//t[@name='draft_invoice_title']" position="replace">
                <t name="draft_invoice_title">
                    <t t-if="o.debit_origin_id">Draft Debit Note</t>
                    <t t-else="">Draft Invoice</t>
                </t>
            </xpath>

            <xpath expr="//t[@name='cancelled_invoice_title']" position="replace">
                <t name="cancelled_invoice_title">
                    <t t-if="o.debit_origin_id">Cancelled Debit Note</t>
                    <t t-else="">Cancelled Invoice</t>
                </t>
            </xpath>

            <xpath expr="//t[@name='proforma_invoice_title']" position="replace">
                <t name="proforma_invoice_title">
                    <t t-if="o.debit_origin_id">Proforma Debit Note</t>
                    <t t-else="">Proforma Invoice</t>
                </t>
            </xpath>

            <xpath expr="//t[@name='draft_proforma_invoice_title']" position="replace">
                <t name="draft_proforma_invoice_title">
                    <t t-if="o.debit_origin_id">Draft Proforma Debit Note</t>
                    <t t-else="">Draft Proforma Invoice</t>
                </t>
            </xpath>

            <xpath expr="//t[@name='cancelled_proforma_invoice_title']" position="replace">
                <t name="cancelled_proforma_invoice_title">
                    <t t-if="o.debit_origin_id">Cancelled Proforma Debit Note</t>
                    <t t-else="">Cancelled Proforma Invoice</t>
                </t>
            </xpath>

            <xpath expr="//div[@name='invoice_date']/t[@t-if=&quot;o.move_type == 'out_invoice'&quot;]" position="replace">
                <t t-if="o.move_type == 'out_invoice' and o.debit_origin_id"><strong>Debit Note Date</strong></t>
                <t t-elif="o.move_type == 'out_invoice'"><strong>Invoice Date</strong></t>
            </xpath>

        </template>
    </data>
</odoo>
