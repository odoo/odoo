msgid "ID"
msgstr "ລະຫັດ"

#. module: auth_password_policy
#. odoo-javascript
#: code:addons/auth_password_policy/static/src/password_meter.js:0
msgid "Medium"
msgstr "ປານກາງ"

#. module: auth_password_policy
#: model:ir.model.fields,field_description:auth_password_policy.field_res_config_settings__minlength
msgid "Minimum Password Length"
msgstr "ຄວາມຍາວລະຫັດຜ່ານຂັ້ນຕ່ຳ"

#. module: auth_password_policy
#: model:ir.model.fields,help:auth_password_policy.field_res_config_settings__minlength
msgid ""
"Minimum number of characters passwords must contain, set to 0 to disable."
msgstr "ຈຳນວນຕົວອັກສອນຂັ້ນຕ່ຳທີ່ລະຫັດຜ່ານຕ້ອງມີ, ຕັ້ງເປັນ 0 ເພື່ອປິດການໃຊ້ງານ."

#. module: auth_password_policy
#. odoo-javascript
#: code:addons/auth_password_policy/static/src/password_field.js:0
msgid "Password"
msgstr "ລະຫັດຜ່ານ"

#. module: auth_password_policy
#. odoo-javascript
#: code:addons/auth_password_policy/static/src/password_meter.js:0
msgid ""
"Required: %s\n"
"\n"
"Hint: to increase password strength, increase length, use multiple words, and use non-letter characters."
msgstr ""
"ຕ້ອງການ: %s\n"
"\n"
"ຄຳແນະນຳ: ເພື່ອເພີ່ມຄວາມປອດໄພຂອງລະຫັດຜ່ານ, ໃຫ້ເພີ່ມຄວາມຍາວ, ໃຊ້ຫຼາຍຄຳສັບ, ແລະ ໃຊ້ຕົວອັກສອນພິເສ"
"ດ."

#. module: auth_password_policy
#. odoo-javascript
#: code:addons/auth_password_policy/static/src/password_meter.js:0
msgid "Strong"
msgstr "ແຂງແຮງ"

#. module: auth_password_policy
#: model:ir.model,name:auth_password_policy.model_res_users
msgid "User"
msgstr "ຜູ້ໃຊ້"

#. module: auth_password_policy
#. odoo-javascript
#: code:addons/auth_password_policy/static/src/password_meter.js:0
msgid "Weak"
msgstr "ອ່ອນແອ"

#. module: auth_password_policy
#. odoo-python
#: code:addons/auth_password_policy/models/res_users.py:0
msgid ""
"Your password must contain at least %(minimal_length)d characters and only "
"has %(current_count)d."
msgstr ""
"ລະຫັດຜ່ານຂອງທ່ານຕ້ອງມີຢ່າງໜ້ອຍ %(minimal_length)d ຕົວອັກສອນ ແຕ່ປະຈຸບັນມີພຽງ %"
"(current_count)d ຕົວອັກສອນ."

#. module: auth_password_policy
#. odoo-javascript
#: code:addons/auth_password_policy/static/src/password_policy.js:0
msgid "at least %s character classes"
msgstr "ຢ່າງໜ້ອຍ %s ປະເພດຕົວອັກສອນ"

#. module: auth_password_policy
#. odoo-javascript
#: code:addons/auth_password_policy/static/src/password_policy.js:0
msgid "at least %s characters"
msgstr "ຢ່າງໜ້ອຍ %s ຕົວອັກສອນ"

#. module: auth_password_policy
#. odoo-javascript
#: code:addons/auth_password_policy/static/src/password_policy.js:0
msgid "at least %s words"
msgstr "ຢ່າງໜ້ອຍ %s ຄຳສັບ"

#. module: auth_password_policy
#. odoo-javascript
#: code:addons/auth_password_policy/static/src/password_meter.js:0
msgid "no requirements"
msgstr "ບໍ່ມີຂໍ້ກຳນົດ"
