<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="view_partner_form_inherit_l10n_th" model="ir.ui.view">
            <field name="name">res.partner.form.inherit.l10n_th</field>
            <field name="model">res.partner</field>
            <field name="priority">14</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='category_id']" position="after">
                    <field name="l10n_th_title" invisible="country_code != 'TH' or 'TH' not in fiscal_country_codes or is_company"/>
                    <field name="l10n_th_company_type" invisible="country_code != 'TH' or 'TH' not in fiscal_country_codes or not is_company"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
