<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_payment_form_inherit_l10n_th" model="ir.ui.view">
        <field name="name">account.payment.form.inherit.l10n_th</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="l10n_account_withholding_tax.view_account_payment_form"/>
        <field name="arch" type="xml">
            <field name="should_withhold_tax" position="after">
                <!-- As it only affects the printed certificate, we can keep it editable -->
                <field name="l10n_th_wth_condition" invisible="not should_withhold_tax or country_code != 'TH'"/>
            </field>
        </field>
    </record>
</odoo>
