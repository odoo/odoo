<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="hr_recruitment.GaugeChartWidget">
        <div class="oe_gauge position-relative pt-3">
            <canvas t-custom-ref="canvas"/>
            <span class="o_gauge_value position-absolute start-0 end-0 bottom-0 text-center fs-2 fw-bolder">
                <t t-out="this.formatPercent(this.totalScore)"/>
            </span>
        </div>
        <p class="text-center text-uppercase fw-bolder mt-2 mb-0">
            <t t-out="this.chartTitle"/>
        </p>
        <p class="text-center text-uppercase fw-bolder mt-0 mb-2" t-if="this.matchingJobName">
            <t t-out="this.matchingJobName"/>
        </p>
    </t>

</templates>
