<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_hr.LoginScreen">
        <div class="login-overlay o_attendance_background fixed-top w-100 h-100">
            <div class="screen-login-header d-flex justify-content-between px-4 pt-4 mb-0 w-100">
                <div class="screen-login-timer d-flex align-items-center">
                    <div class="timer-hours d-flex align-items-center" t-att-class="{'fs-6': ui.isSmall, 'fs-1': !ui.isSmall}" t-esc="state.hours"> </div>
                    <div class="timer-date-container flex-column justify-content-center ms-2 d-none d-lg-flex fs-6">
                        <div class="timer-day d-flex align-items-center" t-esc="state.day"> </div>
                        <div class="timer-date d-flex align-items-center" t-esc="state.date"> </div>
                    </div>
                </div>
                <div class="screen-login-logo ms-auto">
                    <img t-attf-src="/web/image?model=res.company&amp;id={{pos.company.id}}&amp;field=logo" alt="Logo"/>
                </div>
            </div>
            <div class="screen-login position-absolute top-0 start-0 bottom-0 end-0 d-flex flex-column py-4 m-auto w-100 rounded text-center fw-bolder">
                <div class="login-body d-flex d-flex flex-column flex-sm-row align-items-center justify-content-center gap-2">
                    <span class="login-element d-flex flex-column justify-content-center align-items-center bg-white mb-4 rounded-4 mobile-scanner" t-on-click="open_mobile_scanner">
                        <img class="login-barcode-img login-element-img" src="/pos_hr/static/img/barcode.png" />
                        <div class="login-barcode-text">Scan your badge</div>
                    </span>
                    <span class="login-element select-cashier d-flex flex-column justify-content-center align-items-center bg-white mb-4 rounded-4" t-on-click="selectCashier">
                        <img src="/pos_hr/static/img/profile.png" class="login-element-img" />
                        <p class="mt-4 mb-0">Identify Manually</p>
                    </span>
                    <span class="login-element d-flex flex-column justify-content-center align-items-center bg-white mb-4 rounded-4" t-on-click="displayEnterPinPopup">
                        <img src="/pos_hr/static/img/enterPin.png" class="login-element-enter-pin mx-auto w-50"/>
                    </span>
                </div>
            </div>
        </div>
    </t>
</templates>
