<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_config_form_view_inherit" model="ir.ui.view">
        <field name="name">pos.config.form.view.inherit</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='warning_text_employees']" position='replace'>
                <field name="company_id" invisible="1" />
                <div class="row">
                    <label for="manager_employee_ids" string="Manager" class="col-lg-5 o_light_label" />
                    <field name="manager_employee_ids" widget="many2many_tags" placeholder="Select Employee(s)" domain="[('company_id', '=', company_id)]" />
                </div>
                <div class="row">
                    <label for="cashier_employee_ids" string="Cashier" class="col-lg-5 o_light_label" />
                    <field name="cashier_employee_ids" widget="many2many_tags" placeholder="Select Employee(s)" domain="[('company_id', '=', company_id)]" />
                </div>
                <div class="row">
                    <label for="restrictive_employee_ids" string="Restrictive" class="col-lg-5 o_light_label" />
                    <field name="restrictive_employee_ids" widget="many2many_tags" placeholder="Select Employee(s)" domain="[('company_id', '=', company_id)]" />
                </div>
                <div class="row">
                    <label for="supervised_employee_ids" string="Supervised" class="col-lg-5 o_light_label" />
                    <field name="supervised_employee_ids" widget="many2many_tags" placeholder="Select Employee(s)" domain="[('company_id', '=', company_id)]" />
                </div>
            </xpath>
        </field>
    </record>
</odoo>
