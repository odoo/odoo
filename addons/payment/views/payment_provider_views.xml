<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="payment_provider_form" model="ir.ui.view">
        <field name="name">payment.provider.form</field>
        <field name="model">payment.provider</field>
        <field name="arch" type="xml">
            <form string="Payment provider">
                <header/>
                <sheet>
                    <!-- === Stat Buttons === -->
                    <div class="oe_button_box" name="button_box"
                         invisible="module_state != 'installed'">
                        <button
                            type="object"
                            name="action_toggle_is_published"
                            icon="fa-globe"
                            invisible="not is_published"
                            class="oe_stat_button"
                        >
                            <div class="o_stat_info o_field_widget">
                                <span class="o_stat_text text-success">Published</span>
                            </div>
                        </button>
                        <button
                            type="object"
                            name="action_toggle_is_published"
                            icon="fa-eye-slash"
                            invisible="is_published"
                            class="oe_stat_button"
                        >
                            <div class="o_stat_info o_field_widget">
                                <span class="o_stat_text text-danger">Unpublished</span>
                            </div>
                        </button>
                        <button
                            type="object"
                            name="action_view_payment_transactions"
                            icon="fa-dollar"
                            context="{'search_default_confirmed_transactions': 1}"
                            class="oe_stat_button"
                        >
                            <div class="o_stat_info">
                                <span class="o_stat_value order-first d-flex gap-1">
                                    <field
                                        name="transaction_count"
                                        nolabel="1"
                                        widget="statinfo"
                                        class="oe_inline"
                                    />
                                    Transactions
                                </span>
                                <span class="o_stat_value d-flex text-muted">
                                    <field name="main_currency_id" invisible="True"/>
                                    <field name="processed_amount"/>
                                </span>
                            </div>
                        </button>
                        <button
                            type="object"
                            name="action_view_payment_tokens"
                            icon="fa-credit-card"
                            invisible="token_count == 0 and not allow_tokenization"
                            class="oe_stat_button"
                        >
                            <div class="o_stat_info o_field_widget align-items-start">
                                <span class="o_stat_value order-first d-flex gap-1">
                                    <field
                                        name="token_count"
                                        nolabel="1"
                                        widget="statinfo"
                                        class="oe_inline"
                                    />
                                    Tokens
                                </span>
                            </div>
                        </button>
                    </div>
                    <field
                        name="image_128"
                        widget="image"
                        class="oe_avatar"
                        readonly="module_state != 'installed'"
                    />
                    <widget
                        title="Test Mode"
                        name="web_ribbon"
                        bg_color="text-bg-warning"
                        invisible="module_state != 'installed' or is_live or not active"
                    />
                    <widget
                        title="Archived"
                        name="web_ribbon"
                        bg_color="text-bg-danger"
                        invisible="active"
                    />
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Name"/></h1>
                        <div invisible="module_state == 'installed' or not module_id">
                            <a
                                role="button"
                                href="https://odoo.com/pricing?utm_source=db&amp;utm_medium=module"
                                invisible="not module_to_buy"
                                class="btn btn-info"
                                target="_blank"
                            >
                                Upgrade
                            </a>
                            <button
                                string="Install"
                                type="object"
                                name="button_immediate_install"
                                invisible="module_to_buy"
                                class="btn btn-primary"
                            />
                        </div>
                    </div>
                    <div
                        id="provider_creation_warning"
                        role="alert"
                        invisible="id"
                        class="alert alert-warning"
                    >
                        <strong>Warning:</strong> Creating a payment provider from scratch is not
                        supported; please use the <em>Duplicate</em> action instead.
                    </div>
                    <group invisible="module_state not in ('installed', False)">
                        <field name="code" groups="base.group_no_one" readonly="id"/>
                        <field name="is_live"/>
                    </group>
                    <notebook invisible="module_id and module_state != 'installed'">
                        <page string="Payment Methods" name="payment_methods">
                            <field
                                name="primary_payment_method_ids"
                                readonly="0"
                                context="{'hide_provider': True}"
                            >
                                <list create="0" delete="0" limit="100">
                                    <field name="sequence" widget="handle"/>
                                    <field
                                        name="image"
                                        widget="image"
                                        options="{'size': [25, 25], 'img_class': 'rounded-2'}"
                                        nolabel="1"
                                        width="40"
                                    />
                                    <field name="name" width="200" nolabel="1"/>
                                    <field
                                        name="active"
                                        widget="boolean_toggle"
                                        nolabel="1"
                                        width="100"
                                    />
                                    <field
                                        name="supported_country_ids"
                                        widget="many2many_tags"
                                        nolabel="1"
                                        optional="hide"
                                    />
                                    <field
                                        name="supported_currency_ids"
                                        widget="many2many_tags"
                                        nolabel="1"
                                        optional="hide"
                                    />
                                    <field
                                        name="brand_ids"
                                        widget="many2many_image_tags"
                                        nolabel="1"
                                        class="float-end"
                                    />
                                </list>
                            </field>
                        </page>
                        <page string="Configuration" name="configuration">
                            <group name="provider_config">
                                <group
                                    string="Credentials"
                                    name="provider_credentials"
                                    invisible="code == 'none'"
                                />
                                <group
                                    string="Options"
                                    name="provider_options"
                                    invisible="not support_tokenization and not support_express_checkout and not support_manual_capture"
                                >
                                    <field
                                        name="allow_tokenization"
                                        invisible="not support_tokenization"
                                    />
                                    <field
                                        name="allow_express_checkout"
                                        invisible="not support_express_checkout"
                                    />
                                    <field
                                        name="capture_manually"
                                        invisible="not support_manual_capture"
                                    />
                                </group>
                                <group string="Others" name="provider_config_others">
                                    <field
                                        name="company_id"
                                        groups="base.group_multi_company"
                                        options='{"no_open":True}'
                                    />
                                </group>
                            </group>
                        </page>
                        <page string="Restrictions">
                            <group>
                                <group>
                                    <field name="minimum_amount"/>
                                    <field name="maximum_amount"/>
                                    <label for="available_currency_ids"/>
                                    <!-- Use a div to allow placing a button next to the field in
                                    overrides. -->
                                    <div name="available_currencies" class="o_row">
                                        <field
                                            name="available_currency_ids"
                                            widget="many2many_tags"
                                            placeholder="All Currencies"
                                            options="{'no_create': True}"
                                        />
                                    </div>
                                    <field
                                        name="available_country_ids"
                                        widget="many2many_tags"
                                        placeholder="All Countries"
                                        options="{'no_create': True}"
                                    />
                                </group>
                            </group>
                        </page>
                        <page
                            string="Messages"
                            name="messages"
                            invisible="module_id and module_state != 'installed'"
                        >
                            <group>
                                <field name="pre_msg"/>
                                <field name="pending_msg"/>
                                <field name="auth_msg" invisible="not support_manual_capture"/>
                                <field name="done_msg"/>
                                <field name="cancel_msg"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="payment_provider_list" model="ir.ui.view">
        <field name="name">payment.provider.list</field>
        <field name="model">payment.provider</field>
        <field name="arch" type="xml">
            <list string="Payment Providers" create="false">
                <field name="sequence" widget="handle"/>
                <field
                    name="image_128"
                    widget="image"
                    options="{'size': [25, 25], 'img_class': 'rounded-2'}"
                    nolabel="1"
                    width="40"
                />
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="payment_provider_kanban" model="ir.ui.view">
        <field name="name">payment.provider.kanban</field>
        <field name="model">payment.provider</field>
        <field name="arch" type="xml">
            <kanban create="false" quick_create="false">
                <field name="is_published"/>
                <field name="is_live"/>
                <field name="module_id"/>
                <field name="module_state"/>
                <field name="module_to_buy"/>
                <templates>
                    <t t-name="card" class="flex-row">
                        <t t-set="installed" t-value="!record.module_id.value || (record.module_id.value &amp;&amp; record.module_state.raw_value === 'installed')"/>
                        <t t-set="to_buy" t-value="record.module_to_buy.raw_value === true"/>
                        <t t-set="is_published" t-value="record.is_published.raw_value === true"/>
                        <t t-set="is_live" t-value="record.is_live.raw_value === true"/>
                        <t t-set="to_upgrade" t-value="!installed and to_buy"/>
                        <aside>
                            <field type="open"
                                 name="image_128" widget="image"
                                 class="mb-0 o_image_64_max"
                                 options="{'img_class': 'p-2 border rounded'}"
                                 alt="provider"/>
                        </aside>
                        <main class="ms-2">
                            <field name="name" class="mb-0 fw-bold fs-4"/>
                            <div class="d-flex">
                                <t t-if="installed">
                                    <div name="live_mode_badges">
                                        <span
                                            t-if="is_live"
                                            class="badge rounded-pill text-bg-success ms-1"
                                        >
                                            Live
                                        </span>
                                        <span
                                            t-else=""
                                            class="badge rounded-pill text-bg-warning ms-1"
                                        >
                                            Test
                                        </span>
                                    </div>
                                    <div>
                                        <span
                                            t-if="is_published"
                                            class="badge rounded-pill text-bg-success ms-1"
                                        >
                                            Published
                                        </span>
                                        <span
                                            t-else=""
                                            class="badge rounded-pill text-bg-info ms-1"
                                        >
                                            Unpublished
                                        </span>
                                    </div>
                                </t>
                                <span t-if="to_upgrade" class="badge text-bg-primary">Enterprise</span>
                            </div>
                            <footer>
                                <button t-if="!installed and !selection_mode and !to_buy" type="object" class="btn btn-sm btn-primary ms-auto" name="button_immediate_install">Install</button>
                                <button t-if="!installed and to_buy" href="https://odoo.com/pricing?utm_source=db&amp;utm_medium=module" target="_blank" class="btn btn-sm btn-primary ms-auto">Upgrade</button>
                            </footer>
                        </main>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="payment_provider_search" model="ir.ui.view">
        <field name="name">payment.provider.search</field>
        <field name="model">payment.provider</field>
        <field name="arch" type="xml">
            <search>
                <field string="Provider" name="name" filter_domain="[('name', 'ilike', self)]"/>
                <field
                    string="Payment Method"
                    name="payment_method_ids"
                    filter_domain="[
                        '|', '|', '|',
                        ('payment_method_ids.name', 'ilike', self),
                        ('payment_method_ids.code', 'ilike', self),
                        ('payment_method_ids.brand_ids.name', 'ilike', self),
                        ('payment_method_ids.brand_ids.code', 'ilike', self),
                   ]"
                />
                <filter name="archived_provider" string="Archived" domain="[('active', '=', False)]"/>
                <filter name="provider_installed" string="Installed" domain="[('module_state', '=', 'installed')]"/>
                <group>
                    <filter string="Provider" name="code" context="{'group_by': 'code'}"/>
                    <filter string="Company" name="company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_payment_provider" model="ir.actions.act_window">
        <field name="name">Payment Providers</field>
        <field name="res_model">payment.provider</field>
        <field name="path">payment-providers</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No providers available
            </p>
            <p class="fw-bold">To add a provider to the current company:</p>
            <ol class="text-start d-inline-block">
                <li>Toggle the main company in the company switcher.</li>
                <li>Install the provider you want to add.</li>
            </ol>
        </field>
    </record>

</odoo>
