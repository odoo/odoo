#. module: payment
#: model_terms:ir.ui.view,arch_db:payment.pay
msgid ""
"<strong>No suitable payment option could be found.</strong><br/>\n"
"                                If you believe that it is an error, please contact the website administrator."
msgstr ""
"<strong>ບໍ່ພົບຕົວເລືອກການຊຳລະເງິນທີ່ເໝາະສົມ.</strong><br/>\n"
"                                ຫາກທ່ານຄິດວ່ານີ້ແມ່ນຂໍ້ຜິດພາດ, ກະລຸນາຕິດຕໍ່ຜູ້ເບິ່ງແຍງລະບົບເວັບໄ"
"ຊ."

#. module: payment
#: model_terms:ir.ui.view,arch_db:payment.payment_methods
msgid "<strong>No suitable payment provider could be found.</strong>"
msgstr "<strong>ບໍ່ພົບຜູ້ໃຫ້ບໍລິການຊຳລະເງິນທີ່ເໝາະສົມ.</strong>"

#. module: payment
#: model_terms:ir.ui.view,arch_db:payment.payment_capture_wizard_view_form
msgid ""
"<strong>Warning!</strong> There is a partial capture pending. Please wait a\n"
"                    moment for it to be processed. Check your payment provider configuration if\n"
"                    the capture is still pending after a few minutes."
msgstr ""
"<strong>ຄຳເຕືອນ!</strong> ມີການຮຽກເກັບເງິນບາງສ່ວນທີ່ກຳລັງລໍຖ້າການປະມວນຜົນ. ກະລຸນາລໍຖ້າ\n"
"                    ຈັກຄາວເພື່ອໃຫ້ລະບົບເຮັດວຽກ. ກວດສອບການຕັ້ງຄ່າຜູ້ໃຫ້ບໍລິການຊຳລະເງິນຂອງທ່ານ "
"ຫາກ\n"
"                    ຍັງຢູ່ໃນສະຖານະລໍຖ້າຫຼັງຈາກຜ່ານໄປຫຼາຍນາທີ."

#. module: payment
#: model_terms:ir.ui.view,arch_db:payment.payment_capture_wizard_view_form
msgid ""
"<strong>Warning!</strong> You can not capture a negative amount nor more\n"
"                    than"
msgstr ""
"<strong>ຄຳເຕືອນ!</strong> ທ່ານບໍ່ສາມາດຮຽກເກັບເງິນເປັນຄ່າລົບ ຫຼື ຫຼາຍກວ່າ\n"
"                    ຈຳນວນ"

#. module: payment
#: model_terms:ir.ui.view,arch_db:payment.payment_provider_form
msgid ""
"<strong>Warning</strong> Creating a payment provider from the <em>CREATE</em> button is not supported.\n"
"                        Please use the <em>Duplicate</em> action instead."
msgstr ""
"<strong>ຄຳເຕືອນ</strong> ບໍ່ຮອງຮັບການສ້າງຜູ້ໃຫ້ບໍລິການຊຳລະເງິນຈາກປຸ່ມ <em>ສ້າງ</em>.\n"
"                        ກະລຸນາໃຊ້ຄຳສັ່ງ <em>ເຮັດຊ້ຳ</em> ແທນ."

#. module: payment
#: model_terms:ir.ui.view,arch_db:payment.pay
msgid "<strong>Warning</strong> Make sure your are logged in as the right partner before making this payment."
msgstr ""
"<strong>ຄຳເຕືອນ</strong> ກວດສອບໃຫ້ແນ່ໃຈວ່າທ່ານເຂົ້າສູ່ລະບົບໃນນາມຄູ່ຄ້າທີ່ຖືກຕ້ອງກ່ອນທີ່ຈະຊຳລະເງິນ"
"ນີ້."

#. module: payment
#: model_terms:ir.ui.view,arch_db:payment.pay
msgid "<strong>Warning</strong> The currency is missing or incorrect."
msgstr "<strong>ຄຳເຕືອນ</strong> ຂໍ້ມູນສະກຸນເງິນຫາຍສາບສູນ ຫຼື ບໍ່ຖືກຕ້ອງ."

#. module: payment
#: model_terms:ir.ui.view,arch_db:payment.pay
msgid "<strong>Warning</strong> You must be logged in to pay."
msgstr "<strong>ຄຳເຕືອນ</strong> ທ່ານຕ້ອງເຂົ້າສູ່ລະບົບກ່ອນເພື່ອຊຳລະເງິນ."

#. module: payment
#. odoo-python
#: code:addons/payment/models/payment_transaction.py:0
msgid "A refund request of %(amount)s has been sent. The payment will be created soon. Refund transaction reference: %(ref)s (%(provider_name)s)."
msgstr ""
"ຄຳຮ້ອງຂໍຄືນເງິນຈຳນວນ %(amount)s ໄດ້ຖືກສົ່ງແລ້ວ. ການຊຳລະເງິນຈະຖືກສ້າງຂຶ້ນໃນໄວໆນີ້. ອ້າງອີງທຸລະກຳຄື"
"ນເງິນ: %(ref)s (%(provider_name)s)."

#. module: payment
#. odoo-python
#: code:addons/payment/models/payment_token.py:0
msgid "A token cannot be unarchived once it has been archived."
msgstr "ໂທເຄັນບໍ່ສາມາດຍົກເລີກການຈັດເກັບໄດ້ ເມື່ອມັນຖືກຈັດເກັບໄປແລ້ວ."

#. module: payment
#. odoo-python
#: code:addons/payment/models/payment_transaction.py:0
msgid "A transaction with reference %(ref)s has been initiated (%(provider_name)s)."
msgstr "ທຸລະກຳທີ່ມີເລກອ້າງອີງ %(ref)s ໄດ້ຖືກເລີ່ມຕົ້ນແລ້ວ (%(provider_name)s)."

#. module: payment
#. odoo-python
#: code:addons/payment/models/payment_transaction.py:0
msgid "A transaction with reference %(ref)s has been initiated to save a new payment method (%(provider_name)s)"
msgstr ""
"ທຸລະກຳທີ່ມີເລກອ້າງອີງ %(ref)s ໄດ້ຖືກເລີ່ມຕົ້ນເພື່ອບັນທຶກວິທີການຊຳລະເງິນໃໝ່ (%(provider_name)s)"

#. module: payment
#. odoo-python
#: code:addons/payment/models/payment_transaction.py:0
msgid "A transaction with reference %(ref)s has been initiated using the payment method %(token)s (%(provider_name)s)."
msgstr ""
"ທຸລະກຳທີ່ມີເລກອ້າງອີງ %(ref)s ໄດ້ຖືກເລີ່ມຕົ້ນໂດຍໃຊ້ວິທີການຊຳລະເງິນ %(token)s (%"
"(provider_name)s)."

