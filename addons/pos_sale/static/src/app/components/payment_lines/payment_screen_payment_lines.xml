<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-inherit="point_of_sale.PaymentScreenPaymentLines" t-inherit-mode="extension">
        <!-- You can't cancel sale order online payment entry -->
        <xpath expr="//button[hasclass('delete-button')]" position="attributes">
            <attribute name="t-elif" add="(!line.payment_method_id.use_sale_order_payment)" separator=" and " />
        </xpath>
        <xpath expr="//span[hasclass('payment-name')]" position="attributes">
            <attribute name="t-out">line.payment_method_id.use_sale_order_payment ? line.name : line.payment_method_id.name</attribute>
        </xpath>
    </t>
</templates>
