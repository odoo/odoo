<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_sale.ControlButtons" t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
        <xpath expr="//t[@t-if='this.props.showRemainingButtons']/div/t[@name='o_pricelist_button']" position="before">
            <t t-if="this.pos.cashier._role != 'minimal'" t-call="point_of_sale.controlButton"
                iconClasses="'fa fa-link'"
                btnText.translate="Quotation / Order"
                btnClasses="'btn-secondary '"
                onClick="() =>   this.onClickQuotation()">
            </t>
        </xpath>
        <xpath expr="//t[@t-if='this.props.showRemainingButtons']/div/t[@name='o_pricelist_button']" position="attributes">
            <attribute name="disabled" add="this.pos.getOrder().hasPrePaidSOLine" separator=" or " />
        </xpath>
        <xpath expr="//t[@t-if='this.props.showRemainingButtons']/div/t[@name='o_fiscal_position_button']" position="attributes">
            <attribute name="disabled" add="this.pos.getOrder().hasPrePaidSOLine" separator=" or " />
        </xpath>
    </t>
</templates>
