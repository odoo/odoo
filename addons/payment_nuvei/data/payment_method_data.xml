        <field name="support_tokenization">False</field>
        <field name="support_refund">none</field>
        <field name="supported_currency_ids" eval="[Command.set([ref('base.BRL')])]"/>
    </record>

    <record id="payment_method_card" model="payment.method">
        <field name="name">Card</field>
        <field name="code">card</field>
        <field name="sequence">10</field>
        <field name="provider_id" ref="payment.payment_provider_nuvei"/>
        <field name="image" type="bytes" file="payment/static/img/card.png"/>
        <field name="support_tokenization">True</field>
        <field name="support_refund">partial</field>
    </record>

