<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.proxy.user</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='default_accounts']" position="inside">
                <setting
                    id="interco_clearing"
                    string="Intercompany Clearing"
                    groups="base.group_multi_company"
                >"
                    <div class="content-group">
                        <div class="row mt8">
                            <label
                                for="account_interco_clearing_journal_id"
                                class="col-lg-5 o_light_label"
                                string="Journal"
                            />
                            <field name="account_interco_clearing_journal_id"/>
                        </div>
                        <div class="row mt8">
                            <label
                                for="account_interco_payable_id"
                                class="col-lg-5 o_light_label"
                                string="Account Payable"
                            />
                            <field
                                name="account_interco_payable_id"
                                context="{'sort_by_non_trade': True}"
                                required="account_interco_clearing_journal_id"
                            />
                        </div>
                        <div class="row mt8">
                            <label
                                for="account_interco_receivable_id"
                                class="col-lg-5 o_light_label"
                                string="Account Receivable"
                            />
                            <field
                                name="account_interco_receivable_id"
                                context="{'sort_by_non_trade': True}"
                                required="account_interco_clearing_journal_id"
                            />
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
