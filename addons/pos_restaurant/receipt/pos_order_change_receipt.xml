<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <template id="pos_restaurant.pos_order_change_receipt" inherit_id="point_of_sale.pos_order_change_receipt">
            <div name="receipt-header" position="inside">
                <div class="pos-customer-info text-bold" t-if="order.get('customer_count') or extra_data.get('order_label')">
                    <span class="text-large" t-if="extra_data.get('floor_name')"><t t-out="extra_data['floor_name']"/> -</span>
                    <span class="text-huge" t-if="extra_data.get('order_label')"><t t-out="extra_data['order_label']" /></span>
                    <span t-if="order.get('customer_count')"><br/>Guest <t t-out="order['customer_count']"/></span>
                </div>
            </div>
        </template>
    </data>
</odoo>
