<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pos_restaurant.OrderChangeReceipt" t-inherit="point_of_sale.OrderChangeReceipt" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('receipt-header')]" position="inside">
            <div class="pos-customer-info fw-bolder" t-if="data.customer_count" style="font-size: 78%;">
                <t t-out="'Guest: ' + data.customer_count"/>
            </div>
        </xpath>
        <xpath expr="//div[hasclass('receipt-order-reference')]/span" position="before">
            <t t-if="data.floor_name">
                <span t-esc="data.floor_name"/> -
            </t>
        </xpath>
    </t>

</templates>
