                <!-- Split Button -->
                <t t-call="point_of_sale.controlButton"
                    iconClasses="'fa fa-files-o'"
                    btnText.translate="Split"
                    btnClasses="'btn-secondary '"
                    onClick="this.openSplitPage"
                    disabled="this.pos.getOrder()?.getOrderlines()?.filter((line) => line.isGlobalDiscountApplicable()).reduce((sum, line) => sum + line.qty, 0) lt 2">
