            <t t-set="firstSelectedTable" t-value="selectedTables.length ? selectedTables[0] : null" />
            <div t-attf-class="d-flex flex-row {{pos.isEditMode ? 'flex-wrap' : ''}} justify-content-between px-2 gap-1 border-bottom bg-view">
