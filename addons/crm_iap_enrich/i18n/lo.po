msgstr "ລູກຄ້າຄາດຫວັງ/ໂອກາດການຂາຍ"

#. module: crm_iap_enrich
#. odoo-python
#: code:addons/crm_iap_enrich/models/crm_lead.py:0
#, python-format
msgid "Not enough credits for Lead Enrichment"
msgstr "ເຄຣດິດບໍ່ພຽງພໍສຳລັບການເພີ່ມຂໍ້ມູນຜູ້ມີໂອກາດເປັນລູກຄ້າ"

#. module: crm_iap_enrich
#. odoo-python
#: code:addons/crm_iap_enrich/models/crm_lead.py:0
#, python-format
