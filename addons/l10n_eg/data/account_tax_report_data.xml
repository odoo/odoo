<?xml version="1.0" encoding="utf-8"?>
<odoo auto_sequence="1">
    <record id="tax_report_vat_return" model="account.report">
        <field name="name">VAT Return Report</field>
        <field name="root_report_id" ref="account.generic_tax_report"/>
        <field name="country_id" ref="base.eg"/>
        <field name="allow_foreign_vat" eval="True"/>
        <field name="availability_condition">country</field>
        <field name="column_ids">
            <record id="tax_report_vat_return_base" model="account.report.column">
                <field name="name">Base</field>
                <field name="expression_label">base</field>
            </record>
            <record id="tax_report_vat_return_tax" model="account.report.column">
                <field name="name">Tax</field>
                <field name="expression_label">tax</field>
            </record>
        </field>
        <field name="line_ids">
            <record id="tax_report_vat_return_sale" model="account.report.line">
                <field name="name">VAT on Sales and all other Outputs</field>
                <field name="hierarchy_level">0</field>
                <field name="children_ids">
                    <record id="tax_report_vat_return_sale_fourteen" model="account.report.line">
                        <field name="name">1. Standard Rated Sales 14%</field>
                        <field name="code">EG_1</field>
                        <field name="expression_ids">
                            <record id="tax_report_vat_return_sale_fourteen_base" model="account.report.expression">
                                <field name="label">base</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">-1b</field>
                            </record>
                            <record id="tax_report_vat_return_sale_fourteen_tax" model="account.report.expression">
                                <field name="label">tax</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">-1t</field>
                            </record>
                        </field>
                    </record>
                    <record id="tax_report_vat_return_sale_zero" model="account.report.line">
                        <field name="name">2. Zero Rated Sales</field>
                        <field name="code">EG_2</field>
                        <field name="expression_ids">
                            <record id="tax_report_vat_return_sale_zero_base" model="account.report.expression">
                                <field name="label">base</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">-2b</field>
                            </record>
                        </field>
                    </record>
                    <record id="tax_report_vat_return_sale_exempt" model="account.report.line">
                        <field name="name">3. Exempt Sales</field>
                        <field name="code">EG_3</field>
                        <field name="expression_ids">
                            <record id="tax_report_vat_return_sale_exempt_base" model="account.report.expression">
                                <field name="label">base</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">-3b</field>
                            </record>
                        </field>
                    </record>
                    <record id="tax_report_vat_return_sale_export" model="account.report.line">
                        <field name="name">4. Exports</field>
                        <field name="code">EG_4</field>
                        <field name="expression_ids">
                            <record id="tax_report_vat_return_sale_export_base" model="account.report.expression">
                                <field name="label">base</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">-4b</field>
                            </record>
                            <record id="tax_report_vat_return_sale_export_tax" model="account.report.expression">
                                <field name="label">tax</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">-4t</field>
                            </record>
                        </field>
                    </record>
                    <record id="tax_report_vat_return_sale_totals" model="account.report.line">
                        <field name="name">5. Totals</field>
                        <field name="code">EG_5</field>
                        <field name="expression_ids">
                            <record id="tax_report_vat_return_sale_totals_base" model="account.report.expression">
                                <field name="label">base</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">EG_1.base + EG_2.base + EG_3.base + EG_4.base</field>
                            </record>
                            <record id="tax_report_vat_return_sale_totals_tax" model="account.report.expression">
                                <field name="label">tax</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">EG_1.tax + EG_4.tax</field>
                            </record>
                        </field>
                    </record>
                </field>
            </record>
            <record id="tax_report_vat_return_purchase" model="account.report.line">
                <field name="name">VAT on Purchase and all other Inputs</field>
                <field name="hierarchy_level">0</field>
                <field name="children_ids">
                    <record id="tax_report_vat_return_purchas_fourteen" model="account.report.line">
                        <field name="name">6. Standard Rated Purchases 14%</field>
                        <field name="code">EG_6</field>
                        <field name="expression_ids">
                            <record id="tax_report_vat_return_purchase_fourteen_base" model="account.report.expression">
                                <field name="label">base</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">6b</field>
                            </record>
                            <record id="tax_report_vat_return_purchase_fourteen_tax" model="account.report.expression">
                                <field name="label">tax</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">6t</field>
                            </record>
                        </field>
                    </record>
                    <record id="tax_report_vat_return_purchase_zero" model="account.report.line">
                        <field name="name">7. Zero Rated Purchases</field>
                        <field name="code">EG_7</field>
                        <field name="expression_ids">
                            <record id="tax_report_vat_return_purchase_zero_base" model="account.report.expression">
                                <field name="label">base</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">7b</field>
                            </record>
                        </field>
                    </record>
                    <record id="tax_report_vat_return_purchase_exempt" model="account.report.line">
                        <field name="name">8. Exempt Purchases</field>
                        <field name="code">EG_8</field>
                        <field name="expression_ids">
                            <record id="tax_report_vat_return_purchase_exempt_base" model="account.report.expression">
                                <field name="label">base</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">8b</field>
                            </record>
                        </field>
                    </record>
                    <record id="tax_report_vat_return_purchase_import" model="account.report.line">
                        <field name="name">9. Imports</field>
                        <field name="code">EG_9</field>
                        <field name="expression_ids">
                            <record id="tax_report_vat_return_purchase_import_base" model="account.report.expression">
                                <field name="label">base</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">9b</field>
                            </record>
                            <record id="tax_report_vat_return_purchase_import_tax" model="account.report.expression">
                                <field name="label">tax</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">9t</field>
                            </record>
                        </field>
                    </record>
                    <record id="tax_report_vat_return_purchase_totals" model="account.report.line">
                        <field name="name">10. Totals</field>
                        <field name="code">EG_10</field>
                        <field name="expression_ids">
                            <record id="tax_report_vat_return_purchase_totals_base" model="account.report.expression">
                                <field name="label">base</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">EG_6.base + EG_7.base + EG_8.base + EG_9.base</field>
                            </record>
                            <record id="tax_report_vat_return_purchase_totals_tax" model="account.report.expression">
                                <field name="label">tax</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">EG_6.tax + EG_9.tax</field>
                            </record>
                        </field>
                    </record>
                </field>
            </record>
            <record id="tax_report_vat_return_net" model="account.report.line">
                <field name="name">Net VAT Due</field>
                <field name="hierarchy_level">0</field>
                <field name="children_ids">
                    <record id="tax_report_vat_return_net_1" model="account.report.line">
                        <field name="name">11. Total VAT Output</field>
                        <field name="expression_ids">
                            <record id="tax_report_total_vat_output" model="account.report.expression">
                                <field name="label">tax</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">EG_5.tax</field>
                            </record>
                        </field>
                    </record>
                    <record id="tax_report_vat_return_net_2" model="account.report.line">
                        <field name="name">12. Total VAT Input</field>
                        <field name="expression_ids">
                            <record id="tax_report_total_vat_input" model="account.report.expression">
                                <field name="label">tax</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">EG_10.tax</field>
                            </record>
                        </field>
                    </record>
                    <record id="tax_report_vat_return_net_3" model="account.report.line">
                        <field name="name">13. Net VAT Due</field>
                        <field name="expression_ids">
                            <record id="tax_report_net_vat_due" model="account.report.expression">
                                <field name="label">tax</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">EG_5.tax - EG_10.tax</field>
                            </record>
                        </field>
                    </record>
                </field>
            </record>
        </field>
    </record>
    <record id="tax_report_withholding_tax" model="account.report">
        <field name="name">Withholding Report</field>
        <field name="root_report_id" ref="account.generic_tax_report"/>
        <field name="country_id" ref="base.eg"/>
        <field name="allow_foreign_vat" eval="True"/>
        <field name="availability_condition">country</field>
        <field name="column_ids">
            <record id="tax_report_withholding_tax_base" model="account.report.column">
                <field name="name">Base</field>
                <field name="expression_label">base</field>
            </record>
            <record id="tax_report_withholding_tax_tax" model="account.report.column">
                <field name="name">Tax</field>
                <field name="expression_label">tax</field>
            </record>
        </field>
        <field name="line_ids">
            <record id="tax_report_withholding_tax_contract_supply" model="account.report.line">
                <field name="name">1. 1% Contracting and Supplying</field>
                <field name="code">EG_1W</field>
                <field name="foldability">foldable</field>
                <field name="hierarchy_level">1</field>
                <field name="expression_ids">
                    <record id="tax_report_withholding_tax_contract_supply_base" model="account.report.expression">
                        <field name="label">base</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">EG_1W_G.base + EG_1W_D.base</field>
                    </record>
                    <record id="tax_report_withholding_tax_contract_supply_tax" model="account.report.expression">
                        <field name="label">tax</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">EG_1W_G.tax + EG_1W_D.tax</field>
                    </record>
                </field>
                <field name="children_ids">
                    <record id="tax_report_withholding_tax_contract_supply_gross" model="account.report.line">
                        <field name="name">Gross</field>
                        <field name="code">EG_1W_G</field>
                        <field name="expression_ids">
                            <record id="tax_report_withholding_tax_contract_supply_gross_base" model="account.report.expression">
                                <field name="label">base</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">1B_W_G</field>
                            </record>
                            <record id="tax_report_withholding_tax_contract_supply_gross_tax" model="account.report.expression">
                                <field name="label">tax</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">-1T_W_G</field>
                            </record>
                        </field>
                    </record>
                    <record id="tax_report_withholding_tax_contract_supply_deducted" model="account.report.line">
                        <field name="name">Deducted</field>
                        <field name="code">EG_1W_D</field>
                        <field name="expression_ids">
                            <record id="tax_report_withholding_tax_contract_supply_deducted_base" model="account.report.expression">
                                <field name="label">base</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">1B_W_D</field>
                            </record>
                            <record id="tax_report_withholding_tax_contract_supply_deducted_tax" model="account.report.expression">
                                <field name="label">tax</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">-1T_W_D</field>
                            </record>
                        </field>
                    </record>
                </field>
            </record>
            <record id="tax_report_withholding_tax_all_services" model="account.report.line">
                <field name="name">2. 3% All Types of Services</field>
                <field name="code">EG_2W</field>
                <field name="foldability">foldable</field>
                <field name="hierarchy_level">1</field>
                <field name="expression_ids">
                    <record id="tax_report_withholding_tax_all_services_base" model="account.report.expression">
                        <field name="label">base</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">EG_2W_G.base + EG_2W_D.base</field>
                    </record>
                    <record id="tax_report_withholding_tax_all_services_tax" model="account.report.expression">
                        <field name="label">tax</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">EG_2W_G.tax + EG_2W_D.tax</field>
                    </record>
                </field>
                <field name="children_ids">
                    <record id="tax_report_withholding_tax_all_services_gross" model="account.report.line">
                        <field name="name">Gross</field>
                        <field name="code">EG_2W_G</field>
                        <field name="expression_ids">
                            <record id="tax_report_withholding_tax_all_services_gross_base" model="account.report.expression">
                                <field name="label">base</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">2B_W_G</field>
                            </record>
                            <record id="tax_report_withholding_tax_all_services_gross_tax" model="account.report.expression">
                                <field name="label">tax</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">-2T_W_G</field>
                            </record>
                        </field>
                    </record>
                    <record id="tax_report_withholding_tax_all_services_deducted" model="account.report.line">
                        <field name="name">Deducted</field>
                        <field name="code">EG_2W_D</field>
                        <field name="expression_ids">
                            <record id="tax_report_withholding_tax_all_services_deducted_base" model="account.report.expression">
                                <field name="label">base</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">2B_W_D</field>
                            </record>
                            <record id="tax_report_withholding_tax_all_services_deducted_tax" model="account.report.expression">
                                <field name="label">tax</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">-2T_W_D</field>
                            </record>
                        </field>
                    </record>
                </field>
            </record>
            <record id="tax_report_withholding_tax_commissions" model="account.report.line">
                <field name="name">3. 5% Commissions</field>
                <field name="code">EG_3W</field>
                <field name="foldability">foldable</field>
                <field name="hierarchy_level">1</field>
                <field name="expression_ids">
                    <record id="tax_report_withholding_tax_commissions_base" model="account.report.expression">
                        <field name="label">base</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">EG_3W_G.base + EG_3W_D.base</field>
                    </record>
                    <record id="tax_report_withholding_tax_commissions_tax" model="account.report.expression">
                        <field name="label">tax</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">EG_3W_G.tax + EG_3W_D.tax</field>
                    </record>
                </field>
                <field name="children_ids">
                    <record id="tax_report_withholding_tax_commissions_gross" model="account.report.line">
                        <field name="name">Gross</field>
                        <field name="code">EG_3W_G</field>
                        <field name="expression_ids">
                            <record id="tax_report_withholding_tax_commissions_gross_base" model="account.report.expression">
                                <field name="label">base</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">3B_W_G</field>
                            </record>
                            <record id="tax_report_withholding_tax_commissions_gross_tax" model="account.report.expression">
                                <field name="label">tax</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">-3T_W_G</field>
                            </record>
                        </field>
                    </record>
                    <record id="tax_report_withholding_tax_commissions_deducted" model="account.report.line">
                        <field name="name">Deducted</field>
                        <field name="code">EG_3W_D</field>
                        <field name="expression_ids">
                            <record id="tax_report_withholding_tax_commissions_deducted_base" model="account.report.expression">
                                <field name="label">base</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">3B_W_D</field>
                            </record>
                            <record id="tax_report_withholding_tax_commissions_deducted_tax" model="account.report.expression">
                                <field name="label">tax</field>
                                <field name="engine">tax_tags</field>
                                <field name="formula">-3T_W_D</field>
                            </record>
                        </field>
                    </record>
                </field>
            </record>
            <record id="tax_report_withholding_total" model="account.report.line">
                <field name="name">Total</field>
                <field name="expression_ids">
                    <record id="tax_report_withholding_total_base" model="account.report.expression">
                        <field name="label">base</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">EG_1W.base + EG_2W.base + EG_3W.base</field>
                    </record>
                    <record id="tax_report_withholding_total_tax" model="account.report.expression">
                        <field name="label">tax</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">EG_1W.tax + EG_2W.tax + EG_3W.tax</field>
                    </record>
                </field>
            </record>
        </field>
    </record>
</odoo>
