<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="base_address_extended.AddressMap" owl="1">
        <div class="address-map-container">
            <div id="map-container-{{ widget_id }}" class="map-wrapper" style="width: 100%; height: 400px; border: 1px solid #ddd; border-radius: 4px; margin: 10px 0;"/>
            <div class="map-loading-spinner" style="display: none; text-align: center; padding: 20px;">
                <i class="fa fa-spinner fa-spin"></i> Cargando mapa...
            </div>
        </div>
    </t>
</templates>
