<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_relationship_type_tree" model="ir.ui.view">
        <field name="name">crm.relationship.type.tree</field>
        <field name="model">crm.relationship.type</field>
        <field name="arch" type="xml">
            <list string="Tipos de relacion" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_crm_relationship_type_form" model="ir.ui.view">
        <field name="name">crm.relationship.type.form</field>
        <field name="model">crm.relationship.type</field>
        <field name="arch" type="xml">
            <form string="Tipo de relacion">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_crm_relationship_type" model="ir.actions.act_window">
        <field name="name">Tipos de relacion</field>
        <field name="res_model">crm.relationship.type</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear un tipo de relacion
            </p>
        </field>
    </record>

    <menuitem
        id="menu_crm_relationship_type"
        name="Tipos de relacion"
        parent="crm.crm_menu_config"
        action="action_crm_relationship_type"
        groups="sales_team.group_sale_manager"
        sequence="13"/>
</odoo>
