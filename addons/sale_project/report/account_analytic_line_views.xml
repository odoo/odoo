<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_analytic_line_inherit_sale_project_pivot" model="ir.ui.view">
        <field name="name">account.analytic.margins.pivot</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="account.view_account_analytic_line_pivot"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date']" position="after">
                <field name="category_report" type="row"/>
                <field name="billable_type" type="row"/>
            </xpath>
            <xpath expr="//field[@name='date']" position="replace">
                <field name="account_id" type="col"/>
            </xpath>
        </field>
    </record>

    <record id="view_account_analytic_line_inherit_sale_project_pivot_single" model="ir.ui.view">
        <field name="name">account.analytic.margins.pivot</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="account.view_account_analytic_line_pivot"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date']" position="after">
                <field name="category_report" type="row"/>
                <field name="billable_type" type="row"/>
            </xpath>
            <xpath expr="//field[@name='date']" position="replace"/>
            <xpath expr="//field[@name='account_id']" position="replace"/>
        </field>
    </record>

    <record id="view_account_analytic_line_inherit_sale_project_tree" model="ir.ui.view">
        <field name="name">account.analytic.margins.tree</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="account.view_account_analytic_line_tree_inherit_account"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//list" position='attributes'>
                <attribute name="action">action_open_account_analytic_line_origine</attribute>
                <attribute name="type">object</attribute>
            </xpath>
        </field>
    </record>

    <record id="sale_project_line_search" model="ir.ui.view">
        <field name="name">sale_project.account.analytic.margins.search</field>
        <field name="model">account.analytic.line</field>
        <field name="mode">primary</field>
        <field name="inherit_id" ref="account.view_account_analytic_line_filter_inherit_account"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='category']" position="replace">
                <filter string="Category" name='category' context="{'group_by': 'category_report'}"/>
            </xpath>
        </field>
    </record>

    <record id="action_analytic_reporting_inherit_sale_project" model="ir.actions.act_window">
        <field name="name">Real Margins</field>
        <field name="res_model">account.analytic.line</field>
        <field name="path">project-actual-margins</field>
        <field name="search_view_id" ref="sale_project.sale_project_line_search"/>
        <field name="view_id" ref="view_account_analytic_line_inherit_sale_project_pivot"/>
        <field name="view_mode">pivot,list,kanban,graph</field>
        <field name="context">{
            'search_default_month': 'custom_last_365_days',
        }</field>
    </record>

    <record id="action_view_analytic_reporting_inherit_sale_project_pivot" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="action_analytic_reporting_inherit_sale_project"/>
        <field name="sequence" eval="10"/>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="view_account_analytic_line_inherit_sale_project_pivot"/>
    </record>

    <record id="action_view_analytic_reporting_inherit_sale_project_tree" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="action_analytic_reporting_inherit_sale_project"/>
        <field name="sequence" eval="20"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_account_analytic_line_inherit_sale_project_tree"/>
    </record>
</odoo>
