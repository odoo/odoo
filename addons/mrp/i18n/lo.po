msgstr "ປະເພດໃບງານ"

#. module: mrp
#: model:ir.model.fields,field_description:mrp.field_mrp_workorder__worksheet_google_slide
msgid "Worksheet URL"
msgstr "URL ຂອງໃບງານ"

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/stock_lot.py:0
msgid "You are not allowed to create or edit a lot or serial number for the components with the operation type \"Manufacturing\". To change this, go on the operation type and tick the box \"Create New Lots/Serial Numbers for Components\"."
msgstr ""
"ທ່ານບໍ່ໄດ້ຮັບອະນຸຍາດໃຫ້ສ້າງ ຫຼື ແກ້ໄຂເລກຊຸດ ຫຼື ເລກລໍາດັບສຳລັບສ່ວນປະກອບທີ່ມີປະເພດການດຳເນີນການ \"ການ"
"ຜະລິດ\". ເພື່ອປ່ຽນແປງສິ່ງນີ້, ໃຫ້ໄປທີ່ປະເພດການດຳເນີນການ ແລະ ໝາຍເອົາຫ້ອງ \"ສ້າງເລກຊຸດ/ເລກລໍາດັບໃ"
"ໝ່ສຳລັບສ່ວນປະກອບ\"."

#. module: mrp
#: model:ir.model.fields,help:mrp.field_mrp_document__type
msgid "You can either upload a file from your computer or copy/paste an internet link to your file."
msgstr ""
"ທ່ານສາມາດອັບໂຫລດໄຟລ໌ຈາກຄອມພິວເຕີຂອງທ່ານ ຫຼື ສຳເນົາ/ວາງ ລິ້ງອິນເຕີເນັດໄປຫາໄຟລ໌ຂອງທ່ານໄດ້."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_bom.py:0
msgid "You can not create a kit-type bill of materials for products that have at least one reordering rule."
msgstr ""
"ທ່ານບໍ່ສາມາດສ້າງ BoM ປະເພດຊຸດປະກອບ (Kit) ສຳລັບຜະລິດຕະພັນທີ່ມີກົດລະບຽບການສັ່ງຄືນຢ່າງໜ້ອຍໜຶ່ງຂໍ້."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_bom.py:0
msgid ""
"You can not delete a Bill of Material with running manufacturing orders.\n"
"Please close or cancel it first."
msgstr ""
"ທ່ານບໍ່ສາມາດລຶບ BoM ທີ່ມີໃບສັ່ງຜະລິດທີ່ກຳລັງດຳເນີນການຢູ່ໄດ້.\n"
"ກະລຸນາປິດ ຫຼື ຍົກເລີກມັນກ່ອນ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_production.py:0
msgid "You can only merge manufacturing orders of identical products with same BoM."
msgstr ""
"ທ່ານສາມາດລວມໃບສັ່ງຜະລິດຂອງຜະລິດຕະພັນທີ່ຄືກັນ ແລະ ໃຊ້ BoM ອັນດຽວກັນເທົ່ານັ້ນ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_production.py:0
msgid "You can only merge manufacturing orders with no additional components or by-products."
msgstr ""
"ທ່ານສາມາດລວມໃບສັ່ງຜະລິດທີ່ບໍ່ມີສ່ວນປະກອບ ຫຼື ຜະລິດຕະພັນພອຍໄດ້ເພີ່ມເຕີມເທົ່ານັ້ນ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_production.py:0
msgid "You can only merge manufacturing with the same operation type"
msgstr "ທ່ານສາມາດລວມການຜະລິດທີ່ມີປະເພດການດຳເນີນການດຽວກັນເທົ່ານັ້ນ"

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_production.py:0
msgid "You can only merge manufacturing with the same state."
msgstr "ທ່ານສາມາດລວມການຜະລິດທີ່ມີສະຖານະດຽວກັນເທົ່ານັ້ນ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_workorder.py:0
msgid "You cannot change the workcenter of a work order that is in progress or done."
msgstr "ທ່ານບໍ່ສາມາດປ່ຽນສູນວຽກຂອງໃບສັ່ງວຽກທີ່ກຳລັງດຳເນີນການ ຫຼື ສຳເລັດແລ້ວໄດ້."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_bom.py:0
msgid "You cannot create a new Bill of Material from here."
msgstr "ທ່ານບໍ່ສາມາດສ້າງ BoM ໃໝ່ຈາກບ່ອນນີ້ໄດ້."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_routing.py:0
#: code:addons/mrp/models/mrp_workorder.py:0
msgid "You cannot create cyclic dependency."
msgstr "ທ່ານບໍ່ສາມາດສ້າງການຂຶ້ນກັບກັນແບບເປັນວົງຈອນໄດ້."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_unbuild.py:0
msgid "You cannot delete an unbuild order if the state is 'Done'."
msgstr "ທ່ານບໍ່ສາມາດລຶບໃບສັ່ງແຍກສ່ວນໄດ້ຖ້າສະຖານະແມ່ນ 'ສຳເລັດແລ້ວ'."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_production.py:0
msgid "You cannot have %s  as the finished product and in the Byproducts"
msgstr "ທ່ານບໍ່ສາມາດໃຫ້ %s ເປັນທັງຜະລິດຕະພັນສຳເລັດຮູບ ແລະ ຜະລິດຕະພັນພອຍໄດ້"

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_workorder.py:0
msgid "You cannot link this work order to another manufacturing order."
msgstr "ທ່ານບໍ່ສາມາດເຊື່ອມໂຍງໃບສັ່ງວຽກນີ້ກັບໃບສັ່ງຜະລິດອື່ນໄດ້."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_production.py:0
msgid "You cannot move a manufacturing order once it is cancelled or done."
msgstr "ທ່ານບໍ່ສາມາດເຄື່ອນຍ້າຍໃບສັ່ງຜະລິດໄດ້ເມື່ອມັນຖືກຍົກເລີກ ຫຼື ສຳເລັດແລ້ວ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_workorder.py:0
msgid "You cannot produce the same serial number twice."
msgstr "ທ່ານບໍ່ສາມາດຜະລິດເລກລໍາດັບດຽວກັນສອງຄັ້ງໄດ້."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_unbuild.py:0
msgid "You cannot unbuild a undone manufacturing order."
msgstr "ທ່ານບໍ່ສາມາດແຍກສ່ວນໃບສັ່ງຜະລິດທີ່ຍັງບໍ່ທັນສຳເລັດໄດ້."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_bom.py:0
msgid "You cannot use the 'Apply on Variant' functionality and simultaneously create a BoM for a specific variant."
msgstr ""
"ທ່ານບໍ່ສາມາດໃຊ້ຄຸນສົມບັດ 'ນຳໃຊ້ກັບລຸ້ນຍ່ອຍ' ພ້ອມກັບການສ້າງ BoM ສຳລັບລຸ້ນຍ່ອຍສະເພາະໃດໜຶ່ງ."

#. module: mrp
#: model_terms:ir.ui.view,arch_db:mrp.view_mrp_consumption_warning_form
msgid ""
"You consumed a different quantity than expected for the following products.\n"
"                        <b attrs=\"{'invisible': [('consumption', '=', 'strict')]}\">\n"
"                            Please confirm it has been done on purpose.\n"
"                        </b>\n"
"                        <b attrs=\"{'invisible': [('consumption', '!=', 'strict')]}\">\n"
"                            Please review your component consumption or ask a manager to validate\n"
"                            <span attrs=\"{'invisible':[('mrp_production_count', '!=', 1)]}\">this manufacturing order</span>\n"
"                            <span attrs=\"{'invisible':[('mrp_production_count', '=', 1)]}\">these manufacturing orders</span>.\n"
"                        </b>"
msgstr ""
"ທ່ານໄດ້ນຳໃຊ້ຈຳນວນທີ່ແຕກຕ່າງຈາກທີ່ຄາດໄວ້ສຳລັບຜະລິດຕະພັນຕໍ່ໄປນີ້.\n"
"                        <b attrs=\"{'invisible': [('consumption', '=', "
"'strict')]}\">\n"
"                            ກະລຸນາຢືນຢັນວ່ານີ້ແມ່ນຄວາມຕັ້ງໃຈ.\n"
"                        </b>\n"
"                        <b attrs=\"{'invisible': [('consumption', '!=', "
"'strict')]}\">\n"
"                            ກະລຸນາກວດສອບການນຳໃຊ້ສ່ວນປະກອບຂອງທ່ານ ຫຼື ໃຫ້ຜູ້ຈັດການກວດສອ"
"ບ\n"
"                            <span attrs=\"{'invisible':["
"('mrp_production_count', '!=', 1)]}\">ໃບສັ່ງຜະລິດນີ້</span>\n"
"                            <span attrs=\"{'invisible':["
"('mrp_production_count', '=', 1)]}\">ໃບສັ່ງຜະລິດເຫຼົ່ານີ້</span>.\n"
"                        </b>"

#. module: mrp
#. odoo-python
#: code:addons/mrp/wizard/change_production_qty.py:0
msgid "You have already processed %(quantity)s. Please input a quantity higher than %(minimum)s "
msgstr ""
"ທ່ານໄດ້ປະມວນຜົນ %(quantity)s ແລ້ວ. ກະລຸນາໃສ່ຈຳນວນທີ່ສູງກວ່າ %(minimum)s "

#. module: mrp
#: model_terms:ir.ui.view,arch_db:mrp.view_assign_serial_numbers_production
msgid ""
"You have entered less serial numbers than the quantity to produce.<br/>\n"
"                        Create a backorder if you expect to process the remaining quantities later.<br/>\n"
"                        Do not create a backorder if you will not process the remaining products."
msgstr ""
"ທ່ານໄດ້ປ້ອນເລກລໍາດັບໜ້ອຍກວ່າຈຳນວນທີ່ຈະຜະລິດ.<br/>\n"
"                        ສ້າງໃບສັ່ງຄ້າງສົ່ງຖ້າທ່ານຄາດວ່າຈະປະມວນຜົນຈຳນວນທີ່ເຫຼືອໃນພາຍຫຼັງ.<br/>"
"\n"
"                        ຢ່າສ້າງໃບສັ່ງຄ້າງສົ່ງຖ້າທ່ານຈະບໍ່ປະມວນຜົນຜະລິດຕະພັນທີ່ເຫຼືອ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_production.py:0
msgid "You must indicate a non-zero amount consumed for at least one of your components"
msgstr "ທ່ານຕ້ອງລະບຸຈຳນວນການນຳໃຊ້ທີ່ບໍ່ແມ່ນສູນ ສຳລັບສ່ວນປະກອບຢ່າງໜ້ອຍໜຶ່ງຢ່າງ"

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_production.py:0
msgid "You need at least two production orders to merge them."
msgstr "ທ່ານຕ້ອງການໃບສັ່ງຜະລິດຢ່າງໜ້ອຍສອງລາຍການເພື່ອລວມເຂົ້າກັນ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_workorder.py:0
msgid "You need to define at least one productivity loss in the category 'Performance'. Create one from the Manufacturing app, menu: Configuration / Productivity Losses."
msgstr ""
"ທ່ານຕ້ອງກໍານົດການສູນເສຍປະສິດທິພາບຢ່າງໜ້ອຍໜຶ່ງຢ່າງໃນໝວດໝູ່ 'ປະສິດທິພາບ'. ສ້າງໄດ້ຈາກແອັບການຜະລິດ, ເ"
"ມນູ: ການກໍານົດຄ່າ / ການສູນເສຍປະສິດທິຜົນ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_workorder.py:0
msgid "You need to define at least one productivity loss in the category 'Productivity'. Create one from the Manufacturing app, menu: Configuration / Productivity Losses."
msgstr ""
"ທ່ານຕ້ອງກໍານົດການສູນເສຍປະສິດທິພາບຢ່າງໜ້ອຍໜຶ່ງຢ່າງໃນໝວດໝູ່ 'ປະສິດທິຜົນ'. ສ້າງໄດ້ຈາກແອັບການຜະລິດ, ເມ"
"ນູ: ການກໍານົດຄ່າ / ການສູນເສຍປະສິດທິຜົນ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_workcenter.py:0
msgid "You need to define at least one unactive productivity loss in the category 'Performance'. Create one from the Manufacturing app, menu: Configuration / Productivity Losses."
msgstr ""
"ທ່ານຕ້ອງກໍານົດການສູນເສຍປະສິດທິພາບທີ່ບໍ່ໄດ້ໃຊ້ງານຢ່າງໜ້ອຍໜຶ່ງຢ່າງໃນໝວດໝູ່ 'ປະສິດທິພາບ'. ສ້າງໄດ້ຈາກແອັບກ"
"ານຜະລິດ, ເມນູ: ການກໍານົດຄ່າ / ການສູນເສຍປະສິດທິຜົນ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_workorder.py:0
msgid "You need to provide a lot for the finished product."
msgstr "ທ່ານຕ້ອງລະບຸເລກຊຸດສຳລັບຜະລິດຕະພັນສຳເລັດຮູບ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/wizard/mrp_consumption_warning.py:0
msgid "You need to supply Lot/Serial Number"
msgstr "ທ່ານຕ້ອງລະບຸ ເລກຊຸດ/ເລກລໍາດັບ"

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_production.py:0
msgid "You need to supply Lot/Serial Number for products:"
msgstr "ທ່ານຕ້ອງລະບຸ ເລກຊຸດ/ເລກລໍາດັບ ສຳລັບຜະລິດຕະພັນ:"

#. module: mrp
#: model:ir.actions.act_window,name:mrp.action_mrp_production_backorder
msgid "You produced less than initial demand"
msgstr "ທ່ານຜະລິດໄດ້ໜ້ອຍກວ່າຄວາມຕ້ອງການເບື້ອງຕົ້ນ"

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_unbuild.py:0
msgid "You should provide a lot number for the final product."
msgstr "ທ່ານຄວນລະບຸເລກຊຸດສຳລັບຜະລິດຕະພັນສຸດທ້າຍ."

#. module: mrp
#: model_terms:ir.ui.view,arch_db:mrp.exception_on_mo
msgid "cancelled"
msgstr "ຍົກເລີກແລ້ວ"

#. module: mrp
#: model_terms:ir.ui.view,arch_db:mrp.view_assign_serial_numbers_production
msgid "copy paste a list and/or use Generate"
msgstr "ສຳເນົາ ແລະ ວາງລາຍການ ແລະ/ຫຼື ໃຊ້ປຸ່ມສ້າງ"

#. module: mrp
#: model_terms:ir.ui.view,arch_db:mrp.mrp_bom_form_view
#: model_terms:ir.ui.view,arch_db:mrp.res_config_settings_view_form
msgid "days"
msgstr "ມື້"

#. module: mrp
#: model_terms:ir.ui.view,arch_db:mrp.mrp_production_workorder_form_view_inherit
