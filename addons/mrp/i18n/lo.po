#. module: mrp
#. odoo-python
#: code:addons/mrp/models/stock_lot.py:0
#, python-format
msgid "You are not allowed to create or edit a lot or serial number for the components with the operation type \"Manufacturing\". To change this, go on the operation type and tick the box \"Create New Lots/Serial Numbers for Components\"."
msgstr ""
"ທ່ານບໍ່ໄດ້ຮັບອະນຸຍາດໃຫ້ສ້າງ ຫຼື ແກ້ໄຂລັອດ ຫຼື ເລກລຳດັບສຳລັບສ່ວນປະກອບທີ່ມີປະເພດການດຳເນີນງານ \"ການຜະ"
"ລິດ\". ເພື່ອປ່ຽນແປງສິ່ງນີ້, ໃຫ້ໄປທີ່ປະເພດການດຳເນີນງານ ແລະ ໝາຍເອົາຫ້ອງ \"ສ້າງລັອດ/ເລກລຳດັບໃໝ່ສຳລັ"
"ບສ່ວນປະກອບ\"."

#. module: mrp
#: model:ir.model.fields,help:mrp.field_mrp_document__type
msgid "You can either upload a file from your computer or copy/paste an internet link to your file."
msgstr ""
"ທ່ານສາມາດອັບໂຫຼດໄຟລ໌ຈາກຄອມພິວເຕີຂອງທ່ານ ຫຼື ຄັດລອກ/ວາງ ລິງກ໌ອິນເຕີເນັດໄປຍັງໄຟລ໌ຂອງທ່ານ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_bom.py:0
#, python-format
msgid "You can not create a kit-type bill of materials for products that have at least one reordering rule."
msgstr ""
"ທ່ານບໍ່ສາມາດສ້າງລາຍການວັດສະດຸປະເພດຊຸດອຸປະກອນ (Kit) ສຳລັບສິນຄ້າທີ່ມີຢ່າງໜ້ອຍໜຶ່ງກົດເກນການສັ່ງຄືນ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_bom.py:0
#, python-format
msgid ""
"You can not delete a Bill of Material with running manufacturing orders.\n"
"Please close or cancel it first."
msgstr ""
"ທ່ານບໍ່ສາມາດລຶບລາຍການວັດສະດຸທີ່ມີໃບສັ່ງຜະລິດກຳລັງດຳເນີນການຢູ່.\n"
"ກະລຸນາປິດ ຫຼື ຍົກເລີກມັນກ່ອນ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_production.py:0
#, python-format
msgid "You can only merge manufacturing orders of identical products with same BoM."
msgstr ""
"ທ່ານສາມາດຮ່ວມໃບສັ່ງຜະລິດຂອງສິນຄ້າທີ່ຄືກັນ ແລະ ມີລາຍການວັດສະດຸດຽວກັນເທົ່ານັ້ນ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_production.py:0
#, python-format
msgid "You can only merge manufacturing orders with no additional components or by-products."
msgstr ""
"ທ່ານສາມາດຮ່ວມໃບສັ່ງຜະລິດທີ່ບໍ່ມີສ່ວນປະກອບເພີ່ມເຕີມ ຫຼື ຜະລິດຕະພັນພອຍໄດ້ເທົ່ານັ້ນ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_production.py:0
#, python-format
msgid "You can only merge manufacturing with the same operation type"
msgstr "ທ່ານສາມາດຮ່ວມການຜະລິດທີ່ມີປະເພດການດຳເນີນງານດຽວກັນເທົ່ານັ້ນ"

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_production.py:0
#, python-format
msgid "You can only merge manufacturing with the same state."
msgstr "ທ່ານສາມາດຮ່ວມການຜະລິດທີ່ມີສະຖານະດຽວກັນເທົ່ານັ້ນ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_workorder.py:0
#, python-format
msgid "You cannot change the workcenter of a work order that is in progress or done."
msgstr "ທ່ານບໍ່ສາມາດປ່ຽນແປງສູນງານຂອງໃບສັ່ງງານທີ່ກຳລັງດຳເນີນການ ຫຼື ສຳເລັດແລ້ວ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_bom.py:0
#, python-format
msgid "You cannot create a new Bill of Material from here."
msgstr "ທ່ານບໍ່ສາມາດສ້າງລາຍການວັດສະດຸໃໝ່ຈາກບ່ອນນີ້ໄດ້."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_routing.py:0
#: code:addons/mrp/models/mrp_workorder.py:0
#, python-format
msgid "You cannot create cyclic dependency."
msgstr "ທ່ານບໍ່ສາມາດສ້າງການຂຶ້ນຕໍ່ກັນແບບວົນລູບໄດ້."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_unbuild.py:0
#, python-format
msgid "You cannot delete an unbuild order if the state is 'Done'."
msgstr "ທ່ານບໍ່ສາມາດລຶບໃບສັ່ງຮື້ຖອນໄດ້ຖ້າສະຖານະແມ່ນ 'ສຳເລັດແລ້ວ'."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_production.py:0
#, python-format
msgid "You cannot have %s  as the finished product and in the Byproducts"
msgstr "ທ່ານບໍ່ສາມາດມີ %s  ເປັນທັງສິນຄ້າສຳເລັດຮູບ ແລະ ໃນຜະລິດຕະພັນພອຍໄດ້"

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_workorder.py:0
#, python-format
msgid "You cannot link this work order to another manufacturing order."
msgstr "ທ່ານບໍ່ສາມາດເຊື່ອມຕໍ່ໃບສັ່ງງານນີ້ໄປຫາໃບສັ່ງຜະລິດອື່ນໄດ້."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_production.py:0
#, python-format
msgid "You cannot move a manufacturing order once it is cancelled or done."
msgstr "ທ່ານບໍ່ສາມາດເຄື່ອນຍ້າຍໃບສັ່ງຜະລິດໄດ້ເມື່ອມັນຖືກຍົກເລີກ ຫຼື ສຳເລັດແລ້ວ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_workorder.py:0
#, python-format
msgid "You cannot produce the same serial number twice."
msgstr "ທ່ານບໍ່ສາມາດຜະລິດເລກລຳດັບດຽວກັນສອງຄັ້ງໄດ້."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_unbuild.py:0
#, python-format
msgid "You cannot unbuild a undone manufacturing order."
msgstr "ທ່ານບໍ່ສາມາດຮື້ຖອນໃບສັ່ງຜະລິດທີ່ຍັງບໍ່ໄດ້ເຮັດໄດ້."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_bom.py:0
#, python-format
msgid "You cannot use the 'Apply on Variant' functionality and simultaneously create a BoM for a specific variant."
msgstr ""
"ທ່ານບໍ່ສາມາດໃຊ້ຄຸນສົມບັດ 'ນຳໃຊ້ກັບລຸ້ນຍ່ອຍ' ແລະ ສ້າງລາຍການວັດສະດຸສຳລັບລຸ້ນຍ່ອຍສະເພາະໄປພ້ອມໆກັນໄດ້."

#. module: mrp
#: model_terms:ir.ui.view,arch_db:mrp.view_mrp_consumption_warning_form
msgid ""
"You consumed a different quantity than expected for the following products.\n"
"                        <b attrs=\"{'invisible': [('consumption', '=', 'strict')]}\">\n"
"                            Please confirm it has been done on purpose.\n"
"                        </b>\n"
"                        <b attrs=\"{'invisible': [('consumption', '!=', 'strict')]}\">\n"
"                            Please review your component consumption or ask a manager to validate\n"
"                            <span attrs=\"{'invisible':[('mrp_production_count', '!=', 1)]}\">this manufacturing order</span>\n"
"                            <span attrs=\"{'invisible':[('mrp_production_count', '=', 1)]}\">these manufacturing orders</span>.\n"
"                        </b>"
msgstr ""
"ທ່ານໄດ້ຊົມໃຊ້ຈຳນວນທີ່ແຕກຕ່າງຈາກທີ່ຄາດໄວ້ສຳລັບສິນຄ້າຕໍ່ໄປນີ້.\n"
"                        <b attrs=\"{'invisible': [('consumption', '=', "
"'strict')]}\">\n"
"                            ກະລຸນາຢືນຢັນວ່າມັນໄດ້ຖືກເຮັດໂດຍເຈດຕະນາ.\n"
"                        </b>\n"
"                        <b attrs=\"{'invisible': [('consumption', '!=', "
"'strict')]}\">\n"
"                            ກະລຸນາກວດສອບຄືນການຊົມໃຊ້ສ່ວນປະກອບຂອງທ່ານ ຫຼື ຂໍໃຫ້ຜູ້ຈັດການຢືນຢັ"
"ນ\n"
"                            <span attrs=\"{'invisible':["
"('mrp_production_count', '!=', 1)]}\">ໃບສັ່ງຜະລິດນີ້</span>\n"
"                            <span attrs=\"{'invisible':["
"('mrp_production_count', '=', 1)]}\">ໃບສັ່ງຜະລິດເຫຼົ່ານີ້</span>.\n"
"                        </b>"

#. module: mrp
#. odoo-python
#: code:addons/mrp/wizard/change_production_qty.py:0
#, python-format
msgid "You have already processed %(quantity)s. Please input a quantity higher than %(minimum)s "
msgstr ""
"ທ່ານໄດ້ດຳເນີນການ %(quantity)s ແລ້ວ. ກະລຸນາປ້ອນຈຳນວນທີ່ສູງກວ່າ %(minimum)s "

#. module: mrp
#: model_terms:ir.ui.view,arch_db:mrp.view_assign_serial_numbers_production
msgid ""
"You have entered less serial numbers than the quantity to produce.<br/>\n"
"                        Create a backorder if you expect to process the remaining quantities later.<br/>\n"
"                        Do not create a backorder if you will not process the remaining products."
msgstr ""
"ທ່ານໄດ້ປ້ອນເລກລຳດັບໜ້ອຍກວ່າຈຳນວນທີ່ຈະຜະລິດ.<br/>\n"
"                        ສ້າງລາຍການຄ້າງສົ່ງຖ້າທ່ານຄາດວ່າຈະດຳເນີນການຈຳນວນທີ່ເຫຼືອພາຍຫຼັ"
"ງ.<br/>\n"
"                        ຢ່າສ້າງລາຍການຄ້າງສົ່ງຖ້າທ່ານຈະບໍ່ດຳເນີນການສິນຄ້າທີ່ເຫຼືອ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_production.py:0
#, python-format
msgid "You must indicate a non-zero amount consumed for at least one of your components"
msgstr "ທ່ານຕ້ອງລະບຸຈຳນວນຊົມໃຊ້ທີ່ບໍ່ແມ່ນສູນຢ່າງໜ້ອຍໜຶ່ງສ່ວນປະກອບຂອງທ່ານ"

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_production.py:0
#, python-format
msgid "You need at least two production orders to merge them."
msgstr "ທ່ານຕ້ອງການຢ່າງໜ້ອຍສອງໃບສັ່ງຜະລິດເພື່ອຮ່ວມພວກມັນເຂົ້າກັນ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_workorder.py:0
#, python-format
msgid "You need to define at least one productivity loss in the category 'Performance'. Create one from the Manufacturing app, menu: Configuration / Productivity Losses."
msgstr ""
"ທ່ານຕ້ອງກຳນົດຢ່າງໜ້ອຍໜຶ່ງການສູນເສຍສະມັດຖະພາບໃນໝວດໝູ່ 'ສະມັດຖະພາບ'. ສ້າງມັນຈາກແອັບການຜະລິດ, ເມ"
"ນູ: ການຕັ້ງຄ່າ / ການສູນເສຍສະມັດຖະພາບ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_workorder.py:0
#, python-format
msgid "You need to define at least one productivity loss in the category 'Productivity'. Create one from the Manufacturing app, menu: Configuration / Productivity Losses."
msgstr ""
"ທ່ານຕ້ອງກຳນົດຢ່າງໜ້ອຍໜຶ່ງການສູນເສຍສະມັດຖະພາບໃນໝວດໝູ່ 'ສະມັດຖະພາບ'. ສ້າງມັນຈາກແອັບການຜະລິດ, ເມ"
"ນູ: ການຕັ້ງຄ່າ / ການສູນເສຍສະມັດຖະພາບ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_workcenter.py:0
#, python-format
msgid "You need to define at least one unactive productivity loss in the category 'Performance'. Create one from the Manufacturing app, menu: Configuration / Productivity Losses."
msgstr ""
"ທ່ານຕ້ອງກຳນົດຢ່າງໜ້ອຍໜຶ່ງການສູນເສຍສະມັດຖະພາບທີ່ບໍ່ໄດ້ໃຊ້ງານໃນໝວດໝູ່ 'ສະມັດຖະພາບ'. ສ້າງມັນຈາກແອັບກາ"
"ນຜະລິດ, ເມນູ: ການຕັ້ງຄ່າ / ການສູນເສຍສະມັດຖະພາບ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_workorder.py:0
#, python-format
msgid "You need to provide a lot for the finished product."
msgstr "ທ່ານຕ້ອງລະບຸລັອດສຳລັບສິນຄ້າສຳເລັດຮູບ."

#. module: mrp
#. odoo-python
#: code:addons/mrp/wizard/mrp_consumption_warning.py:0
#, python-format
msgid "You need to supply Lot/Serial Number"
msgstr "ທ່ານຕ້ອງລະບຸ ລັອດ/ເລກລຳດັບ"

#. module: mrp
#. odoo-python
#: code:addons/mrp/models/mrp_production.py:0
#, python-format
