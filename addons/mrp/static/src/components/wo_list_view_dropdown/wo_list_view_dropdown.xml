<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="mrp.MOViewListDropdown" style="btn">
        <Dropdown t-if="this.props.record.data.production_state !== 'done'">
            <button t-attf-class="btn btn-link d-flex p-0 {{!this.props.record.resId ? 'invisible': ''}}">
                <div class="d-flex align-items-center">
                    <span t-attf-class="o_wo_status o_wo_bubble {{this.statusColor}}" t-if="this.props.display === 'bubble'"/>
                    <span t-out="this.formattedValue" class="o_wo_status badge rounded-pill" t-attf-class="{{this.statusColor}}" t-if="this.props.display === 'badge'"/>
                </div>
            </button>
            <t t-set-slot="content">
                <DropdownItem
                    class="`d-flex align-items-center`"
                    onSelected="() => this.setState('blocked')">
                        <span class="oi oi-lg text-warning me-2" data-icon="error"/>
                        <span>Blocked</span>
                </DropdownItem>
                <DropdownItem
                    class="`d-flex align-items-center`"
                    onSelected="() => this.setState('ready')">
                        <span t-attf-class="oi oi-lg oi-filled text-muted me-2" data-icon="circle"/>
                        <span>To Do</span>
                </DropdownItem>
                <DropdownItem
                    class="`d-flex align-items-center`"
                    onSelected="() => this.setState('progress')">
                        <span t-attf-class="oi oi-lg oi-filled text-info me-2" data-icon="play_circle"/>
                        <span>In Progress</span>
                </DropdownItem>
                <DropdownItem
                    class="`d-flex align-items-center`"
                    onSelected="() => this.setState('cancel')">
                        <span t-attf-class="oi oi-lg oi-filled text-danger me-2" data-icon="cancel"/>
                        <span>Cancelled</span>
                </DropdownItem>
                <DropdownItem
                    class="`d-flex align-items-center`"
                    onSelected="() => this.setState('done')">
                        <span t-attf-class="oi oi-lg oi-filled text-success me-2" data-icon="check_circle"/>
                        <span>Done</span>
                </DropdownItem>
            </t>
        </Dropdown>
        <span t-attf-class="o_wo_status {{this.statusColor}}" t-elif="this.props.display === 'bubble'"/>
        <span t-out="this.formattedValue" class="o_wo_status badge rounded-pill" t-attf-class="{{this.statusColor}}" t-elif="this.props.display === 'badge'"/>
    </t>

</templates>
