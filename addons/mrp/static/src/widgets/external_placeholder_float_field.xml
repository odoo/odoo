<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="mrp.ExternalPlaceholderFloatField" t-inherit="web.FloatField">
        <xpath expr="//t/span[@t-if='this.props.readonly']" position="attributes">
            <attribute name="t-out" add="this.placeholderValue" separator=" || "/>
            <attribute name="t-att-class">{'text-muted': !this.formattedValue}</attribute>
        </xpath>
        <xpath expr="//t/input[@t-else]" position="attributes">
            <attribute name="t-att-placeholder">this.placeholderValue</attribute>
        </xpath>
    </t>
</templates>
