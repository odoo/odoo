<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="mrp.MrpBomPopoverField" t-inherit="stock.popoverButton">
        <xpath expr="//a" position="attributes">
            <attribute name="t-att-title">"Days to prepare estimation"</attribute>
        </xpath>
    </t>
    <div t-name="mrp.bomPopover">
        <table class="table table-sm table-borderless mb-0">
            <tbody>
                <tr>
                    <td colspan="2" class="border-bottom">
                        <t t-if="('Days to prepare estimation for ' + this.props.final_product_name).length &gt; 60">
                            Days to prepare estimation for<br/>
                            <t t-out="this.props.final_product_name"/>
                        </t>
                        <t t-else="">Days to prepare estimation for <t t-out="this.props.final_product_name"/></t>
                    </td>
                </tr>
                <t t-if="this.props.component">
                    <tr>
                        <td class="fw-bolder w-0">Component</td>
                        <td><a href="#" t-on-click.prevent="() => this.goToAction(this.props.component_id, 'product.product')"><t t-out="this.props.component"/></a></td>
                    </tr>
                    <tr t-if="this.props.route_name and this.props.route_detail">
                        <td class="fw-bolder w-0">Route</td>
                        <td>
                            <t t-out="this.props.route_name"/>:
                            <t t-if="this.props.route_type === 'manufacture'">
                                <a href="#" t-on-click.prevent="() => this.goToAction(this.props.route_id, 'mrp.bom')">
                                    <t t-out="this.props.route_detail"/>
                                </a>
                            </t>
                            <t t-else="">
                                <t t-out="this.props.route_detail"/>
                            </t>
                        </td>
                    </tr>
                </t>
                <t t-if="this.props.delay">
                    <tr>
                        <td class="fw-bolder" style="width: 75px;">Lead Time</td>
                        <td>
                            <t t-out="this.props.delay"/>
                        </td>
                    </tr>
                </t>
                <t t-else="">
                    <tr>
                        <td>
                            <strong class="fw-bolder">Not Available:</strong> Missing route info for components.
                        </td>
                    </tr>
                    <tr><td><a href="#" t-on-click.prevent="this._openBomOverview">Check BoM Overview</a></td></tr>
                </t>
            </tbody>
        </table>
    </div>
</templates>
