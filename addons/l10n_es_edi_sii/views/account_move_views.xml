<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_move_form_inherit_l10n_es_edi" model="ir.ui.view">
            <field name="name">account.move.form.inherit.l10n_es_edi</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">

                <xpath expr="//header" position="after">
                    <div class="alert alert-danger"
                         role="alert"
                         invisible="not l10n_es_edi_sii_error">
                        <field name="l10n_es_edi_sii_error"/>
                    </div>
                </xpath>

                <xpath expr="//header" position="inside">
                    <button
                        name="action_l10n_es_send_sii"
                        type="object"
                        string="Send to SII"
                        class="btn-primary"
                        invisible="move_type not in ('in_invoice', 'in_refund')
                                   or not l10n_es_edi_is_required
                                   or state != 'posted'
                                   or l10n_es_edi_sii_state == 'sent'"/>

                    <button
                        name="action_l10n_es_send_sii"
                        type="object"
                        string="Resend to SII"
                        class="btn-secondary"
                        invisible="move_type not in ('in_invoice', 'in_refund')
                                   or not l10n_es_edi_is_required
                                   or state != 'posted'
                                   or l10n_es_edi_sii_state != 'sent'"/>
                </xpath>

                <xpath expr="//group[@id='other_tab_group']//group[@name='accounting_info_group']" position="inside">
                    <field name="l10n_es_registration_date"
                           readonly="state == 'posted'"
                           invisible="country_code != 'ES'"/>
                    <field name="l10n_es_edi_csv" readonly="1"/>
                </xpath>

                <xpath expr="//button[@name='button_request_cancel']" position="attributes">
                    <attribute name="invisible">state != 'posted' or not need_cancel_request or (show_reset_to_draft_button and not l10n_es_edi_is_required)</attribute>
                </xpath>

                <xpath expr="//notebook" position="inside">
                    <page string="SII History" name="sii_history" 
                          invisible="not l10n_es_edi_is_required or not l10n_es_edi_sii_document_ids">
                        <field name="l10n_es_edi_sii_document_ids" readonly="1">
                            <list decoration-danger="state in ('to_send', 'to_cancel') and response_message"
                                  decoration-success="state == 'accepted'"
                                  decoration-warning="state == 'accepted_with_errors'"
                                  decoration-muted="state == 'cancelled'">
                                <field name="create_date" string="Date"/>
                                <field name="state" widget="badge" 
                                       decoration-success="state == 'accepted'"
                                       decoration-danger="state in ('to_send', 'to_cancel') and response_message"
                                       decoration-warning="state == 'accepted_with_errors'"
                                       decoration-info="state in ('to_send', 'to_cancel') and not response_message"/>
                                <field name="csv" string="CSV"/>
                                <field name="response_message" optional="hide"/>
                                <field name="sii_json_file" filename="sii_json_filename" widget="binary" string="Download JSON" groups="base.group_no_one"/>
                            </list>
                        </field>
                    </page>
                </xpath>

                <field name="ref" position="attributes">
                    <attribute name="readonly">l10n_es_edi_csv</attribute>
                </field>

            </field>
        </record>

        <record id="view_invoice_tree_inherit_l10n_es_edi_sii" model="ir.ui.view">
            <field name="name">account.move.tree.inherit.l10n_es_edi_sii</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_invoice_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='amount_residual_signed']" position="after">
                    <field name="l10n_es_edi_sii_state"
                           string="Electronic invoicing"
                           optional="show"
                           widget="badge"
                           decoration-success="l10n_es_edi_sii_state == 'sent'"
                           decoration-info="l10n_es_edi_sii_state == 'to_send'"
                           decoration-danger="l10n_es_edi_sii_state == 'cancelled'"/>

                    <field name="l10n_es_edi_sii_error"
                           string="Edi Blocking Level"
                           optional="show"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
