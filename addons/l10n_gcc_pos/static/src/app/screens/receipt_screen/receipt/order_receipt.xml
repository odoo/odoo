<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-inherit="point_of_sale.ReceiptHeader" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos-receipt-contact')]" position="after">
            <t t-if="order.isGccCountry">
                <br/>
                <br/>
                <div class="pos-receipt-header">
                    <span id="title_english" t-translation="off">Tax Invoice</span>
                </div>
                <div class="pos-receipt-header">
                    <span id="title_arabic" t-translation="off">الفاتورة الضريبية</span>
                </div>
            </t>
        </xpath>

        <xpath expr="//div[hasclass('cashier')]" position="attributes">
            <attribute name="t-if">!order.isGccCountry</attribute>
        </xpath>
        <xpath expr="//div[hasclass('cashier')]" position="after">
            <div t-if="order.isGccCountry" t-translation="off">
                <div>Served by / خدم بواسطة <t t-esc="order.getCashierName()"/></div>
            </div>
        </xpath>
    </t>

    <t t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('order-total')]" position="attributes">
            <attribute name="t-if">!order.isGccCountry</attribute>
        </xpath>
        <xpath expr="//div[hasclass('order-total')]" position="after">
            <div t-if="order.isGccCountry" class="pos-receipt-amount pos-receipt-amount-arabic" t-translation="off">
                TOTAL / اﻹجمالي
                <span t-esc="formatCurrency(order.getTotalWithTax())" class="pos-receipt-right-align"/>
            </div>
        </xpath>

        <xpath expr="//t[@t-if='roundAmount']" position="after">
            <t t-elif="order.getRoundingApplied() and order.isGccCountry">
                <div class="pos-receipt-amount pos-receipt-amount-arabic" t-translation="off">
                    Rounding / التقريب
                    <span t-esc="formatCurrency(order.getRoundingApplied())" class="pos-receipt-right-align"/>
                </div>
                <div class="pos-receipt-amount">
                    To Pay
                    <span t-esc="formatCurrency(order.getTotalWithTax() + order.getRoundingApplied())" class="pos-receipt-right-align"/>
                </div>
            </t>
        </xpath>
        <xpath expr="//t[@t-if='roundAmount']" position="attributes">
            <attribute name="t-if" add=" and !order.isGccCountry" separator=" "/>
        </xpath>

        <xpath expr="//div[hasclass('receipt-change')]" position="attributes">
            <attribute name="t-if">!order.isGccCountry</attribute>
        </xpath>
        <xpath expr="//div[hasclass('receipt-change')]" position="after">
            <div t-if="order.isGccCountry" class="pos-receipt-amount receipt-change pos-receipt-amount-arabic" t-translation="off">
                CHANGE / الباقي
                <span t-esc="formatCurrency(order.getChange())" class="pos-receipt-right-align"/>
            </div>
        </xpath>

        <xpath expr="//t[@t-if='totalDiscount']" position="after">
            <div t-if="order.isGccCountry" t-translation="off">
                Discounts / الخصومات
                <span t-esc="formatCurrency(order.getTotalDiscount())" class="pos-receipt-right-align"/>
            </div>
        </xpath>
        <xpath expr="//t[@t-if='totalDiscount']" position="attributes">
            <attribute name="t-if">!order.isGccCountry</attribute>
        </xpath>
    </t>
</templates>
