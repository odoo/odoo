<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_invoice_document" inherit_id="account.report_invoice_document">
        <!-- add company id -->
        <xpath expr="//div[@id='partner_vat_address_not_same_as_shipping']" position="after">
            <t t-set="partner_ident" t-value="o.partner_id._get_additional_identifier('ES_EN')"/>
            <div t-if="partner_ident and o.company_id.country_code == 'ES'">
                ID: <span t-out="partner_ident"/>
            </div>
        </xpath>

        <xpath expr="//div[@id='partner_vat_address_same_as_shipping']" position="after">
            <t t-set="partner_ident" t-value="o.partner_id._get_additional_identifier('ES_EN')"/>
            <div t-if="partner_ident and o.company_id.country_code == 'ES'">
                ID: <span t-out="partner_ident"/>
            </div>
        </xpath>

        <xpath expr="//div[@id='partner_vat_no_shipping']" position="after">
            <t t-set="partner_ident" t-value="o.partner_id._get_additional_identifier('ES_EN')"/>
            <div t-if="partner_ident and o.company_id.country_code == 'ES'">
                ID: <span t-out="partner_ident"/>
            </div>
        </xpath>
    </template>
</odoo>
