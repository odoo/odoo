<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit" model="ir.ui.view">
        <field name="name">account.move.form.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@id='other_tab']//field[@name='delivery_date']" position="after">
                <field name="l10n_es_is_simplified" invisible="country_code != 'ES'" readonly="state != 'draft'"/>
            </xpath>
            <xpath expr="//page[@name='other_info']//group[@name='sale_info_group']" position="after">
                <group string="Spanish Electronic Invoicing"
                       name="l10n_es_electronic_invoicing"
                       invisible="True">
                    <field name="l10n_es_original_invoice_credited"
                           invisible="move_type not in ['out_refund', 'in_refund'] or reversed_entry_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
