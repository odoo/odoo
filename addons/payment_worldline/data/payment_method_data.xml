        <field name="image" type="bytes" file="payment/static/img/alipay_plus.png"/>
        <field name="support_tokenization">False</field>
        <field
            name="supported_country_ids"
            eval="[Command.set([
                ref('base.at'),
                ref('base.au'),
                ref('base.be'),
                ref('base.bg'),
                ref('base.ch'),
                ref('base.cy'),
                ref('base.cz'),
                ref('base.de'),
                ref('base.dk'),
                ref('base.ee'),
                ref('base.es'),
                ref('base.fi'),
                ref('base.fr'),
                ref('base.gr'),
                ref('base.hr'),
                ref('base.hu'),
                ref('base.ie'),
                ref('base.is'),
                ref('base.it'),
                ref('base.li'),
                ref('base.lt'),
                ref('base.lu'),
                ref('base.lv'),
                ref('base.mt'),
                ref('base.nl'),
                ref('base.no'),
                ref('base.pl'),
                ref('base.pt'),
                ref('base.ro'),
                ref('base.se'),
                ref('base.si'),
                ref('base.sk'),
                ref('base.uk'),
            ])]"
        />
        <field
            name="supported_currency_ids"
            eval="[Command.set([
                ref('base.AUD'),
                ref('base.CHF'),
                ref('base.DKK'),
                ref('base.EUR'),
                ref('base.GBP'),
                ref('base.NOK'),
                ref('base.SEK'),
