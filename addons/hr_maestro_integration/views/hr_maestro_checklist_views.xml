<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_maestro_checklist_list" model="ir.ui.view">
        <field name="name">hr.maestro.checklist.list</field>
        <field name="model">hr.maestro.checklist</field>
        <field name="arch" type="xml">
            <list string="Checklists Maestro">
                <field name="date"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="profile"/>
                <field name="done_count"/>
                <field name="item_count"/>
                <field name="completion_rate" widget="percentage"/>
            </list>
        </field>
    </record>

    <record id="view_hr_maestro_checklist_form" model="ir.ui.view">
        <field name="name">hr.maestro.checklist.form</field>
        <field name="model">hr.maestro.checklist</field>
        <field name="arch" type="xml">
            <form string="Checklist Maestro">
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="department_id"/>
                        <field name="date"/>
                        <field name="profile"/>
                        <field name="completion_rate" widget="percentage"/>
                    </group>
                    <field name="item_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="code"/>
                            <field name="label"/>
                            <field name="done"/>
                            <field name="done_at"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hr_maestro_checklist_search" model="ir.ui.view">
        <field name="name">hr.maestro.checklist.search</field>
        <field name="model">hr.maestro.checklist</field>
        <field name="arch" type="xml">
            <search string="Checklists Maestro">
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="profile"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Funcionário" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Departamento" name="group_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Data" name="group_date" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hr_maestro_checklist" model="ir.actions.act_window">
        <field name="name">Checklists Maestro</field>
        <field name="res_model">hr.maestro.checklist</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_hr_maestro_checklist"
              name="Checklists Maestro"
              parent="hr.hr_menu_hr_reports"
              action="action_hr_maestro_checklist"
              groups="hr.group_hr_user"
              sequence="51"/>

</odoo>
