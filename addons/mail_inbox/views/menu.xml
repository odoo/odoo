        id="menu_incoming_mail_servers_sub"
        name="Servers"
        parent="mail.menu_action_fetchmail_server_tree"
        action="mail.action_email_server_tree"
        sequence="1"
        groups="base.group_no_one"/>
    <menuitem
        id="menu_fetchmail_mail"
        name="Inbox Mails"
        parent="mail.menu_action_fetchmail_server_tree"
        action="action_fetchmail_mail_list"
        sequence="10"
        groups="base.group_no_one"/>
    <menuitem
        id="menu_fetchmail_tag"
        name="Inbox Tags"
        parent="mail.menu_action_fetchmail_server_tree"
        action="action_fetchmail_tag_list"
        sequence="20"
        groups="base.group_no_one"/>
</odoo>
