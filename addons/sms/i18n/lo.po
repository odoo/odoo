#: model:ir.model.fields,help:sms.field_mail_mail__message_type
#: model:ir.model.fields,help:sms.field_mail_message__message_type
msgid ""
"Used to categorize message generator\n"
"'email': generated by an incoming email e.g. mailgateway\n"
"'comment': generated by user input e.g. through discuss or composer\n"
"'email_outgoing': generated by a mailing\n"
"'notification': generated by system e.g. tracking messages\n"
"'auto_comment': generated by automated notification mechanism e.g. acknowledgment\n"
"'user_notification': generated for a specific recipient"
msgstr ""
"ໃຊ້ເພື່ອແບ່ງປະເພດຕົວສ້າງຂໍ້ຄວາມ\n"
"'email': ສ້າງຂຶ້ນໂດຍອີເມວຂາເຂົ້າ ເຊັ່ນ mailgateway\n"
"'comment': ສ້າງຂຶ້ນໂດຍການປ້ອນຂໍ້ມູນຂອງຜູ້ໃຊ້ ເຊັ່ນ ຜ່ານ discuss ຫຼື composer\n"
"'email_outgoing': ສ້າງຂຶ້ນໂດຍການສົ່ງເມລ\n"
"'notification': ສ້າງຂຶ້ນໂດຍລະບົບ ເຊັ່ນ ຂໍ້ຄວາມຕິດຕາມ\n"
"'auto_comment': ສ້າງຂຶ້ນໂດຍກົນໄກການແຈ້ງເຕືອນອັດຕະໂນມັດ ເຊັ່ນ ການຕອບຮັບ\n"
"'user_notification': ສ້າງຂຶ້ນສຳລັບຜູ້ຮັບສະເພາະ"

