<?xml version="1.0" encoding="UTF-8" ?>

<templates xml:space="preserve">
    <t t-name="sms.SmsWidget" t-inherit="mail.EmojisTextField" t-inherit-mode="primary">
        <xpath expr="//div[hasclass('o_field_input_buttons')]/button[@data-icon='wand_stars']" position="replace"/>
        <xpath expr="/*[last()]/*[last()]" position="after">
            <div class="o_sms_container mt-3">
                <span class="text-muted o_sms_count me-1" t-if="this.nbrChar != 0">
                    <t t-out="this.nbrChar"/>/<t t-out="160 * this.nbrSMS" /> <t t-out="this.nbrCharExplanation" /> | <t t-out="this.nbrSMS"/> SMS (<t t-out="this.encoding"/>)
                    <a href="https://iap-services.odoo.com/iap/sms/pricing" target="_blank"
                        title="SMS Pricing" aria-label="SMS Pricing" class="oi oi-lg align-middle" data-icon="info"/>
                </span>
                <button t-if="this.props.dynamicPlaceholder"
                    class="btn btn-link py-0 border-0"
                    title="Insert Field"
                    t-on-click="this.onDynamicPlaceholderOpen"
                ><span class="oi oi-fw me-1" data-icon="wand_stars"/><span>Insert Field</span></button>
            </div>
        </xpath>
    </t>
</templates>
