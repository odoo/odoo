<?xml version="1.0" encoding="UTF-8" ?>

<templates xml:space="preserve">
    <t t-name="sms.SmsWidget" t-inherit="mail.EmojisTextField" t-inherit-mode="primary">
        <xpath expr="//div[hasclass('o_field_input_buttons')]/button[hasclass('fa-magic')]" position="replace"/>
        <xpath expr="//div[hasclass('o_field_input_buttons')]" position="inside">
            <div class="d-inline-flex align-items-center justify-content-center">
                <button t-if="this.props.dynamicPlaceholder"
                        class="btn btn-link end-0 bottom-0"
                        title="Insert Field"
                        t-on-click="this.onDynamicPlaceholderOpen">
                    <i class="fa fa-magic me-1"/>
                </button>
            </div>
        </xpath>
    </t>
    <t t-name="sms.SmsCharCounter">
        <div t-if="this.nbrChar > 0" class="ms-auto text-muted d-flex align-items-center fs-6">
            <t t-out="this.nbrChar"/>/<t t-out="this.maxChar"/> | <t t-out="this.nbrSMS"/> SMS (<t t-out="this.encoding"/>) <i class="fa fa-info-circle text-info ms-1" title="SMS length info"/>
        </div>
    </t>
</templates>
