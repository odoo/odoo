<?xml version="1.0" encoding="UTF-8" ?>

<templates xml:space="preserve">
    <t t-name="sms.SmsWidget" t-inherit="mail.EmojisTextField" t-inherit-mode="primary">
        <xpath expr="//div[hasclass('o_field_input_buttons')]/button[hasclass('fa-magic')]" position="replace"/>
        <xpath expr="//div[hasclass('o_field_input_buttons')]" position="inside">
            <div class="d-inline-flex align-items-center justify-content-center">
                <button t-if="this.props.dynamicPlaceholder"
                        class="btn btn-link end-0 bottom-0"
                        title="Insert Field"
                        t-on-click="this.onDynamicPlaceholderOpen">
                    <i class="fa fa-magic me-1"/>
                </button>
            </div>
        </xpath>
        <xpath expr="/*[last()]/*[last()]" position="after">
            <div class="o_sms_container mt-3" t-if="this.nbrChar > 0 and this.props.record.resModel !== 'sms.composer'">
                <span class="text-muted o_sms_count me-1">
                    <t t-out="this.nbrChar"/>/<t t-out="160 * this.nbrSMS" /> <t t-out="this.nbrCharExplanation" /> | <t t-out="this.nbrSMS"/> SMS (<t t-out="this.encoding"/>)
                    <a href="https://iap-services.odoo.com/iap/sms/pricing" target="_blank"
                        title="SMS Pricing" aria-label="SMS Pricing" class="fa fa-lg fa-info-circle align-middle"/>
                </span>
            </div>
        </xpath>
    </t>
    <t t-name="sms.SmsCharCounter">
        <div t-if="state.nbrChar > 0" class="ms-auto text-muted d-flex align-items-center" style="font-size: 14px;">
            <t t-out="state.nbrChar"/>/<t t-out="state.maxChar"/> | <t t-out="state.nbrSMS"/> SMS (<t t-out="state.encoding"/>) <i class="fa fa-info-circle text-info ms-1" title="SMS length info"/>
        </div>
    </t>
</templates>
