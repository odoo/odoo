<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="s_team_board" name="Team Board">
        <section class="s_team_board pt64 pb64">
            <div class="container">
                <h2 class="h3-fs">Meet Our Team</h2>
                <p class="lead">The people building the experience you rely on every day.</p>
                <div class="row gy-4">
                    <div class="col" data-name="Team Member">
                        <div class="card">
                            <img class="card-img-top" src="/web/image/website.s_company_team_image_1" />
                            <div class="card-body">
                                <h3 class="card-title">Tony Fred</h3>
                                <p class="card-subtitle text-body-secondary">Chief Executive Officer</p>
                                <p class="card-title">Tony shapes product strategy and keeps execution aligned across teams.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col" data-name="Team Member">
                        <div class="card">
                            <img class="card-img-top" src="/web/image/website.s_company_team_image_2" />
                            <div class="card-body">
                                <h3 class="card-title">Mich Stark</h3>
                                <p class="card-subtitle text-body-secondary">Chief Commercial Officer</p>
                                <p class="card-title">Mich leads go-to-market initiatives and partner relationships</p>
                            </div>
                        </div>
                    </div>
                    <div class="col" data-name="Team Member">
                        <div class="card">
                            <img class="card-img-top" src="/web/image/website.s_company_team_image_3" />
                            <div class="card-body">
                                <h3 class="card-title">Aline Turner</h3>
                                <p class="card-subtitle text-body-secondary">Chief Technical Officer</p>
                                <p class="card-title">Aline drives platform architecture and engineering quality.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </template>

</odoo>
