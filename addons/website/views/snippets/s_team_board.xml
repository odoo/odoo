<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template name="Team Board" id="s_team_board">
        <section class="s_team_board">
            <div class="container">
                <h2 class="h3-fs">Meet Our Team</h2>
                <p class="lead text-muted">The people building the experience you rely on every day</p><br/>
                <div class="s_team_board_wrapper s_team_board_grid">
                    <div class="card s_card s_team_board_member_card" data-name="Team Member" data-snippet="s_card" data-bs-toggle="modal" data-bs-target="#s_team_board_modal">
                        <div class="o_card_img">
                            <img src="/web/image/website.s_company_team_image_1" class="card-img-top o_team_board_picture" alt=""/>
                        </div>
                        <div class="card-body">
                            <h3 class="card-title o_team_board_name">Tony Fred</h3>
                            <p class="card-subtitle text-muted mb-1">Chief Executive Officer</p>
                            <p class="card-text">Tony shapes product strategy and keeps execution aligned across teams.</p>
                        </div>
                        <div>
                            <button class="visually-hidden" aria-label="Open Contact Modal" />
                        </div>
                    </div>
                    <div class="card s_card s_team_board_member_card" data-name="Team Member" data-snippet="s_card" data-bs-toggle="modal" data-bs-target="#s_team_board_modal">
                        <div class="o_card_img">
                            <img src="/web/image/website.s_company_team_image_2" class="card-img-top o_team_board_picture" alt=""/>
                        </div>
                        <div class="card-body">    
                            <h3 class="card-title o_team_board_name">Mich Stark</h3>
                            <p class="card-subtitle text-muted mb-1">Chief Commercial Officer</p>
                            <p class="card-text">Mich leads go-to-market initiatives and partner relationships.</p>
                        </div>
                        <div>
                            <button class="visually-hidden" aria-label="Open Contact Modal" />
                        </div>
                    </div>
                    <div class="card s_card s_team_board_member_card" data-name="Team Member" data-snippet="s_card" data-bs-toggle="modal" data-bs-target="#s_team_board_modal">
                        <div class="o_card_img">
                            <img src="/web/image/website.s_company_team_image_3" class="card-img-top o_team_board_picture" alt=""/>
                        </div>
                        <div class="card-body">
                            <h3 class="card-title o_team_board_name">Alice Turner</h3>
                            <p class="card-subtitle text-muted mb-1">Chief Technical Officer</p>
                            <p class="card-text">Alice drives platform architecture and engineering quality.</p>
                        </div>
                        <div>
                            <button class="visually-hidden" aria-label="Open Contact Modal" />
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal s_team_board_modal" id="s_team_board_modal" tabindex="-1" aria-label="Team Member Contact Modal">
                <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
                    <div class="modal-content">
                        <div class="modal-header">
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div class="container-fluid">
                                <div class="row">
                                    <div class="col-4">
                                        <img src="" class="card-img-top s_team_board_modal_picture" alt=""/>
                                    </div>
                                    <div class="col-8 s_team_board_modal_body"/>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer justify-content-start">
                            <button type="button" class="btn btn-primary ml-2 s_team_board_modal_button">Send a message</button>
                            <span class="s_team_board_modal_contact_buttons"/>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </template>
    <asset id="website.s_team_board_stylesheet" name="Team Board 000.scss">
        <bundle>web.assets_frontend</bundle>
        <path>website/static/src/snippets/s_team_board/000.scss</path>
    </asset>
</odoo>
