<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template name="Team Board" id="s_team_board">
        <section class="s_team_board">
            <div class="container" style="justify-content: start;">
                <h2 class="h3-fs">Meet Our Team</h2>
                <p class="lead text-muted">The people building the experience you rely on every day</p><br/>
                <div class="row row-cols-1 row-cols-md-3 g-4">
                    <div class="col">
                        <div class="card" style="width: 22rem;">
                            <img src="/web/image/website.s_company_team_image_1" class="card-img-top" alt=""/>
                            <div class="card-body">
                                <h3 class="card-title">Tony Fred</h3>
                                <p class="card-subtitle lead text-muted">Chief Executive Officer</p>
                                <p class="card-text">Tony shapes product strategy and keeps execution aligned across teams.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card" style="width: 22rem;">
                            <img src="/web/image/website.s_company_team_image_2" class="o_editable_media card-img-top" alt=""/>
                            <div class="card-body">    
                                <h3 class="card-title">Mich Stark</h3>
                                <p class="card-subtitle lead text-muted">Chief Commercial Officer</p>
                                <p class="card-text">Mich leads go-to-market initiatives and partner relationships.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card" style="width: 22rem;">
                            <img src="/web/image/website.s_company_team_image_3" class="o_editable_media card-img-top" alt=""/>
                            <div class="card-body">
                                <h3 class="card-title">Alice Turner</h3>
                                <p class="card-subtitle lead text-muted">Chief Technical Officer</p>
                                <p class="card-text">Alice drives platform architecture and engineering quality.</p>
                            </div>                    
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </template>
</odoo>
