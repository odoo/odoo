<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_launch_countdown" name="Launch Countdown">
    <section class="s_launch_countdown o_full_screen_height oe_img_bg o_bg_img_center o_bg_img_origin_border_box o_cc o_cc5 pt88 pb88" style="background-image: url('/web/image/website.s_launch_countdown_default_image');">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <h1 class="display-3-fs" style="text-align: center;">We're coming soon!</h1>
                    <p class="lead" style="text-align: center;">Something exciting is on the horizon, and we can't wait to share it with you.<br/>Sign up now to be the first to know when we launch.</p>
                    <p style="text-align: center;"><a t-att-href="cta_btn_href" class="btn btn-secondary mb-2 o_translate_inline"><t t-out="cta_btn_text">Join the waitlist</t></a></p>
                    <p><br/></p>
                    <section class="s_countdown pt16 pb0"
                        data-display="dhms" data-end-action="nothing" data-size="80"
                        t-att-data-end-time="60 * round(datetime.datetime.now().timestamp() / 60) + 228300"
                        data-layout="circle" data-layout-background="none"
                        data-progress-bar-style="disappear" data-progress-bar-weight="thin"
                        data-text-color="o-color-4" data-layout-background-color="400" data-progress-bar-color="o-color-4"
                        data-snippet="s_countdown" data-name="Countdown">
                        <div class="s_countdown_canvas_wrapper text-center d-flex justify-content-center">
                            <div class="s_countdown_canvas_flex" style="width: 25%; max-width: 80px;">
                                <svg version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="80" height="80" class="w-100" viewBox="0 0 80 80"><defs></defs><g><text fill="var(--o-color-4)" stroke="none" font-family="Arial" font-size="20px" font-style="normal" font-weight="normal" text-decoration="normal" x="40" y="40" text-anchor="middle" dominant-baseline="central">2</text><text fill="var(--o-color-4)" stroke="none" font-family="Arial" font-size="6.67px" font-style="normal" font-weight="normal" text-decoration="normal" x="40" y="53.33" text-anchor="middle" dominant-baseline="central">Days</text><path fill="none" stroke="var(--o-color-4)" paint-order="fill stroke markers" d=" M 76 40 A 36 36 0 1 1 75.99998 39.964" stroke-miterlimit="10" stroke-width="2.3" stroke-opacity="0.2" stroke-dasharray=""></path><path fill="none" stroke="var(--o-color-4)" paint-order="fill stroke markers" d=" M 40 4 A 36 36 0 0 1 66.84 15.93" stroke-miterlimit="10" stroke-width="2.3" stroke-dasharray=""></path></g></svg>
                            </div>
                            <div class="s_countdown_canvas_flex" style="width: 25%; max-width: 80px;">
                                <svg version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="80" height="80" class="w-100" viewBox="0 0 80 80"><defs></defs><g><text fill="var(--o-color-4)" stroke="none" font-family="Arial" font-size="20px" font-style="normal" font-weight="normal" text-decoration="normal" x="40" y="40" text-anchor="middle" dominant-baseline="central">16</text><text fill="var(--o-color-4)" stroke="none" font-family="Arial" font-size="6.67px" font-style="normal" font-weight="normal" text-decoration="normal" x="40" y="53.33" text-anchor="middle" dominant-baseline="central">Hours</text><path fill="none" stroke="var(--o-color-4)" paint-order="fill stroke markers" d=" M 76 40 A 36 36 0 1 1 75.99998 39.964" stroke-miterlimit="10" stroke-width="2.3" stroke-opacity="0.2" stroke-dasharray=""></path><path fill="none" stroke="var(--o-color-4)" paint-order="fill stroke markers" d=" M 40 4 A 36 36 0 1 1 8.82 58" stroke-miterlimit="10" stroke-width="2.3" stroke-dasharray=""></path></g></svg>
                            </div>
                            <div class="s_countdown_canvas_flex" style="width: 25%; max-width: 80px;">
                                <svg version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="80" height="80" class="w-100" viewBox="0 0 80 80"><defs></defs><g><text fill="var(--o-color-4)" stroke="none" font-family="Arial" font-size="20px" font-style="normal" font-weight="normal" text-decoration="normal" x="40" y="40" text-anchor="middle" dominant-baseline="central">30</text><text fill="var(--o-color-4)" stroke="none" font-family="Arial" font-size="6.67px" font-style="normal" font-weight="normal" text-decoration="normal" x="40" y="53.33" text-anchor="middle" dominant-baseline="central">Minutes</text><path fill="none" stroke="var(--o-color-4)" paint-order="fill stroke markers" d=" M 76 40 A 36 36 0 1 1 75.99998 39.964" stroke-miterlimit="10" stroke-width="2.3" stroke-opacity="0.2" stroke-dasharray=""></path><path fill="none" stroke="var(--o-color-4)" paint-order="fill stroke markers" d=" M 40 4 A 36 36 0 0 1 40 76" stroke-miterlimit="10" stroke-width="2.3" stroke-dasharray=""></path></g></svg>
                            </div>
                            <div class="s_countdown_canvas_flex" style="width: 25%; max-width: 80px;">
                                <svg version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="80" height="80" class="w-100" viewBox="0 0 80 80"><defs></defs><g><text fill="var(--o-color-4)" stroke="none" font-family="Arial" font-size="20px" font-style="normal" font-weight="normal" text-decoration="normal" x="40" y="40" text-anchor="middle" dominant-baseline="central">45</text><text fill="var(--o-color-4)" stroke="none" font-family="Arial" font-size="6.67px" font-style="normal" font-weight="normal" text-decoration="normal" x="40" y="53.33" text-anchor="middle" dominant-baseline="central">Seconds</text><path fill="none" stroke="var(--o-color-4)" paint-order="fill stroke markers" d=" M 76 40 A 36 36 0 1 1 75.99998 39.964" stroke-miterlimit="10" stroke-width="2.3" stroke-opacity="0.2" stroke-dasharray=""></path><path fill="none" stroke="var(--o-color-4)" paint-order="fill stroke markers" d=" M 40 4 A 36 36 0 1 1 4 40" stroke-miterlimit="10" stroke-width="2.3" stroke-dasharray=""></path></g></svg>
                            </div>
                        </div>
                        <div class="s_countdown_inline d-flex flex-column align-items-start o_countdown_default">
                            <div class="s_countdown_inline_wrapper d-none">
                                <t t-call="website.s_countdown_inline_default_template"/>
                            </div>
                        </div>
                    </section>
                    <p><br/></p>
                    <p><br/></p>
                    <p><br/></p>
                    <div class="s_social_media o_not_editable no_icon_color text-center" contenteditable="false" data-snippet="s_social_media" data-name="Social Media" style="--fa-icon-size: 40px;">
                        <h4 class="s_social_media_title d-block"><br/>Get updates<br/><br/></h4>
                        <a href="#" class="s_social_media_facebook" target="_blank" aria-label="Facebook">
                            <i class="fa fa-facebook rounded-empty-circle shadow-sm o_editable_media small_social_icon o_sm_custom_size"/>
                        </a>
                        <a href="#" class="s_social_media_twitter" target="_blank" aria-label="X">
                            <i class="fa fa-twitter rounded-empty-circle shadow-sm o_editable_media small_social_icon o_sm_custom_size"/>
                        </a>
                        <a href="#" class="s_social_media_linkedin" target="_blank" aria-label="LinkedIn">
                            <i class="fa fa-linkedin rounded-empty-circle shadow-sm o_editable_media small_social_icon o_sm_custom_size"/>
                        </a>
                        <a href="#" class="s_social_media_youtube" target="_blank" aria-label="YouTube">
                            <i class="fa fa-youtube-play rounded-empty-circle shadow-sm o_editable_media small_social_icon o_sm_custom_size"/>
                        </a>
                        <a href="#" class="s_social_media_instagram" target="_blank" aria-label="Instagram">
                            <i class="fa fa-instagram rounded-empty-circle shadow-sm o_editable_media small_social_icon o_sm_custom_size"/>
                        </a>
                        <a href="#" class="s_social_media_github" target="_blank" aria-label="GitHub">
                            <i class="fa fa-github rounded-empty-circle shadow-sm o_editable_media small_social_icon o_sm_custom_size"/>
                        </a>
                        <a href="#" class="s_social_media_tiktok" target="_blank" aria-label="TikTok">
                            <i class="fa fa-tiktok rounded-empty-circle shadow-sm o_editable_media small_social_icon o_sm_custom_size"/>
                        </a>
                        <a href="#" class="s_social_media_discord" target="_blank" aria-label="Discord">
                            <i class="fa fa-discord rounded-empty-circle shadow-sm o_editable_media small_social_icon o_sm_custom_size"/>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>
</template>

</odoo>
