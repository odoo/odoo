<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_services_pack" name="Services Pack">
    <section class="s_services_pack pt80 pb80">
        <div class="container">
            <h2 class="h3-fs">Our Services</h2>
            <p class="lead">We offer a wide range of services to meet your needs.</p>
            <div class="row s_nb_column_fixed mx-0 row-gap-3">
                <div class="s_services_pack_item col-lg-12 pt16 pb16 o_colored_level o_cc o_cc2" style="border-radius: 9.6px !important;" data-name="Service">
                    <div class="row s_col_no_bgcolor align-items-center">
                        <div class="col-lg-5">
                            <h3>Digital Marketing</h3>
                            <p>Grow qualified leads with content, SEO, and paid acquisition.</p>
                        </div>
                        <div class="col-lg-5 offset-lg-2">
                            <h6 class="s_services_pack_service">SEO &amp; content</h6>
                            <h6 class="s_services_pack_service">Paid ads</h6>
                            <h6 class="s_services_pack_service">Email automation</h6>
                            <h6 class="s_services_pack_service">Analytics</h6>
                        </div>
                    </div>
                </div>
                <div class="s_services_pack_item col-lg-12 pt16 pb16 o_colored_level o_cc o_cc2" style="border-radius: 9.6px !important;" data-name="Service">
                    <div class="row s_col_no_bgcolor align-items-center">
                        <div class="col-lg-5">
                            <h3>Brand &amp; Design</h3>
                            <p>Messaging and visuals that make your offer instantly clear.</p>
                        </div>
                        <div class="col-lg-5 offset-lg-2">
                            <h6 class="s_services_pack_service">Brand identity</h6>
                            <h6 class="s_services_pack_service">UI/UX design</h6>
                            <h6 class="s_services_pack_service">Web design</h6>
                            <h6 class="s_services_pack_service">Design systems</h6>
                        </div>
                    </div>
                </div>
                <div class="s_services_pack_item col-lg-12 pt16 pb16 o_colored_level o_cc o_cc2" style="border-radius: 9.6px !important;" data-name="Service">
                    <div class="row s_col_no_bgcolor align-items-center">
                        <div class="col-lg-5">
                            <h3>Software Delivery</h3>
                            <p>Build, launch, and improve reliable products with a small team.</p>
                        </div>
                        <div class="col-lg-5 offset-lg-2">
                            <h6 class="s_services_pack_service">Web apps</h6>
                            <h6 class="s_services_pack_service">Integrations</h6>
                            <h6 class="s_services_pack_service">QA &amp; testing</h6>
                            <h6 class="s_services_pack_service">Maintenance</h6>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</template>

</odoo>
