<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_animated_cover" name="Animated Cover">
    <section class="s_animated_cover o_full_screen_height o_colored_level o_cc o_cc5 oe_img_bg o_bg_img_center o_bg_img_origin_border_box" style="background-image: url('/web/image/website.s_animated_cover_default_image');">
        <div class="o_we_bg_filter bg-black-15"/>
        <div class="oe_structure oe_empty">
            <section class="s_title pt40 pb40 o_colored_level" data-vcss="001" data-snippet="s_title" data-name="Title">
                <div class="container s_allow_columns">
                    <div class="s_avatars o_not_editable d-flex flex-row flex-wrap" data-snippet="s_avatars" data-name="Avatars">
                        <div class="s_avatars_wrapper d-flex">
                            <img src="/web/image/website.s_company_team_image_1" class="s_avatars_avatar o_editable_media o_avatar img border rounded-circle" style="border-color: var(--body-bg) !important; --box-border-left-width: 3px; --box-border-bottom-width: 3px; --box-border-right-width: 3px; --box-border-top-width: 3px;" alt=""/>
                            <img src="/web/image/website.s_company_team_image_2" class="s_avatars_avatar o_editable_media o_avatar img border rounded-circle" style="border-color: var(--body-bg) !important; --box-border-left-width: 3px; --box-border-bottom-width: 3px; --box-border-right-width: 3px; --box-border-top-width: 3px;" alt=""/>
                            <img src="/web/image/website.s_company_team_image_3" class="s_avatars_avatar o_editable_media o_avatar img border rounded-circle" style="border-color: var(--body-bg) !important; --box-border-left-width: 3px; --box-border-bottom-width: 3px; --box-border-right-width: 3px; --box-border-top-width: 3px;" alt=""/>
                            <div class="s_avatars_more d-none s_avatars_avatar d-flex justify-content-center align-items-center text-bg-light border rounded-circle o-contenteditable-true" style="border-color: var(--body-bg) !important; --box-border-left-width: 3px; --box-border-bottom-width: 3px; --box-border-right-width: 3px; --box-border-top-width: 3px;">
                                <p class="m-0">10+</p>
                            </div>
                        </div>
                        <p class="s_avatars_label o_small-fs m-0 o-contenteditable-true">
                            <strong>100+</strong><br/>
                            Happy customers
                        </p>
                    </div>
                    <h1 class="h2-fs">Built to last.<br/>Designed to Inspire.</h1>
                </div>
            </section>
            <section class="s_announcement_scroll s_announcement_scroll_direction_left s_announcement_scroll_hover_pause w-100 pt24 pb24"
                     style="--marquee-animation-speed: 5s; --marquee-item-font-size: 320;"
                     role="marquee" data-snippet="s_announcement_scroll" data-name="Announcement Scroll">
                <div class="s_announcement_scroll_marquee_container d-flex s_announcement_scroll_heading_family">
                    <div class="o_not_editable s_announcement_scroll_marquee_item lh-1">• OUR SERVICES</div>
                </div>
            </section>
        </div>
    </section>
</template>

<asset id="website.s_animated_cover_000_scss" name="Animated Cover 000 SCSS">
    <bundle>web.assets_frontend</bundle>
    <path>website/static/src/snippets/s_animated_cover/000.scss</path>
</asset>

</odoo>
