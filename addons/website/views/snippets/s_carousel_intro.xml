<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_carousel_intro" name="Carousel Intro">
    <section class="s_carousel_intro_wrapper p-0">
        <t t-set="uniq" t-value="datetime.datetime.now().microsecond"/>
        <div t-attf-id="myCarouselIntro{{uniq}}" class="s_carousel_intro s_carousel_default carousel slide carousel-dark" data-bs-ride="true" data-bs-interval="10000" role="region" aria-roledescription="carousel">
            <!-- Controls and indicators are set before the content so that they
                 are focused in priority when navigating the page with tab. -->
            <div class="o_horizontal_controllers container position-absolute start-50 bottom-0 translate-middle-x w-100 mb-md-4 z-1 o_not_editable">
                <div class="o_horizontal_controllers_row row gap-3 gap-lg-5 justify-content-between flex-nowrap flex-row-reverse mx-0">
                    <!-- Controls -->
                    <div class="o_arrows_wrapper gap-2 w-auto p-0">
                        <button class="carousel-control-prev o_not_editable" contenteditable="false" t-attf-data-bs-target="#myCarouselIntro{{uniq}}" t-attf-aria-controls="myCarouselIntro{{uniq}}_inner" data-bs-slide="prev" aria-label="Previous slide" title="Previous slide">
                            <span class="carousel-control-prev-icon" aria-hidden="true"/>
                            <span class="visually-hidden">Previous slide</span>
                        </button>
                        <button class="carousel-control-next o_not_editable" contenteditable="false" t-attf-data-bs-target="#myCarouselIntro{{uniq}}" t-attf-aria-controls="myCarouselIntro{{uniq}}_inner" data-bs-slide="next" aria-label="Next slide" title="Next slide">
                            <span class="carousel-control-next-icon" aria-hidden="true"/>
                            <span class="visually-hidden">Next slide</span>
                        </button>
                    </div>
                    <!-- Indicators -->
                    <div class="s_carousel_indicators_numbers carousel-indicators align-items-center flex-shrink-1 w-auto" role="tablist">
                        <button type="button" t-attf-data-bs-target="#myCarouselIntro{{uniq}}" data-bs-slide-to="0" class="active" aria-label="Slide 1 of 3" role="tab" aria-selected="true" t-attf-aria-controls="myCarouselIntro{{uniq}}_1"/>
                        <button type="button" t-attf-data-bs-target="#myCarouselIntro{{uniq}}" data-bs-slide-to="1" aria-label="Slide 2 of 3" role="tab" aria-selected="false" t-attf-aria-controls="myCarouselIntro{{uniq}}_2"/>
                        <button type="button" t-attf-data-bs-target="#myCarouselIntro{{uniq}}" data-bs-slide-to="2" aria-label="Slide 3 of 3" role="tab" aria-selected="false" t-attf-aria-controls="myCarouselIntro{{uniq}}_3"/>
                    </div>
                </div>
            </div>
            <!-- Content -->
            <div class="carousel-inner" t-attf-id="myCarouselIntro{{uniq}}_inner" aria-live="off">
                <!-- #01 -->
                <div class="s_carousel_intro_item carousel-item o_cc o_cc1 px-0 pt72 pb96 active" data-name="Slide" t-attf-id="myCarouselIntro{{uniq}}_1" role="tabpanel" aria-roledescription="slide">
                    <div class="container">
                        <div class="row o_grid_mode" data-row-count="8">
                            <div class="o_grid_item g-height-8 g-col-lg-5 col-lg-5" style="z-index: 1; grid-area: 1 / 1 / 9 / 6;">
                                <h1 class="display-3-fs">Driving innovation together</h1>
                            </div>
                            <div class="o_grid_item g-height-3 g-col-lg-4 col-lg-4" style="z-index: 2; grid-area: 2 / 7 / 5 / 11; --grid-item-padding-y: 0px;">
                                <p class="lead">Empowering teams to collaborate and innovate, creating impactful solutions that drive business growth and deliver lasting value.</p>
                            </div>
                            <div class="o_grid_item o_grid_item_image g-height-4 g-col-lg-6 col-lg-6" style="z-index: 3; grid-area: 5 / 7 / 9 / 13;">
                                <img src="/web/image/website.landscape_md_3" alt="" class="img img-fluid"/>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- #02 -->
                <div class="s_carousel_intro_item carousel-item o_cc o_cc1 px-0 pt72 pb96" data-name="Slide" t-attf-id="myCarouselIntro{{uniq}}_2" role="tabpanel" aria-roledescription="slide">
                    <div class="container">
                        <div class="row o_grid_mode" data-row-count="8">
                            <div class="o_grid_item g-height-5 g-col-lg-6 col-lg-6" style="z-index: 1; grid-area: 1 / 7 / 6 / 13;">
                                <h2 class="display-3-fs">Innovating for business success</h2>
                            </div>
                            <div class="o_grid_item g-height-2 g-col-lg-4 col-lg-4" style="z-index: 2; grid-area: 7 / 7 / 9 / 11; --grid-item-padding-y: 20px;">
                                <p class="lead">Creating solutions that drive growth and long-term value.</p>
                            </div>
                            <div class="o_grid_item o_grid_item_image g-height-7 g-col-lg-5 col-lg-5" style="z-index: 3; grid-area: 2 / 1 / 9 / 6;">
                                <img src="/web/image/website.landscape_md_4" alt="" class="img img-fluid"/>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- #03 -->
                <div class="s_carousel_intro_item carousel-item o_cc o_cc1 px-0 pt72 pb96" data-name="Slide" t-attf-id="myCarouselIntro{{uniq}}_3" role="tabpanel" aria-roledescription="slide">
                    <div class="container">
                        <div class="row o_grid_mode" data-row-count="8">
                            <div class="o_grid_item g-height-8 g-col-lg-5 col-lg-5" style="z-index: 1; grid-area: 1 / 1 / 9 / 6;">
                                <h2 class="display-3-fs">Leading the future with innovation and strategy</h2>
                            </div>
                            <div class="o_grid_item g-height-4 g-col-lg-4 col-lg-4" style="z-index: 2; grid-area: 5 / 9 / 9 / 13;">
                                <p class="lead">We combine strategic insights and innovative solutions to drive business success, ensuring sustainable growth and competitive advantage in a dynamic market.</p>
                            </div>
                            <div class="o_grid_item o_grid_item_image g-height-8 g-col-lg-3 col-lg-3" style="z-index: 3; grid-area: 1 / 6 / 9 / 9;">
                                <img src="/web/image/website.portrait_lg_3" alt="" class="img img-fluid"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</template>

<asset id="website.s_carousel_intro_000_scss" name="Carousel Intro 000 SCSS">
    <bundle>web.assets_frontend</bundle>
    <path>website/static/src/snippets/s_carousel_intro/000.scss</path>
</asset>

</odoo>
