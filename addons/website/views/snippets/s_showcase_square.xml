<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_showcase_square" name="Showcase Square">
    <section class="s_showcase pt80 pb80" data-vcss="003">
        <div class="container">
            <div class="row">
                <div class="col-lg-6">
                    <div class="row">
                        <div class="col-lg-12 pb32">
                            <h2 class="h3-fs">Our Features</h2>
                            <p class="lead">Discover all our features and benefits that set us apart from the competition and can boost your business.</p>
                        </div>
                        <div class="col-lg-6 pt8 pb8" data-name="Feature">
                            <i class="s_showcase_icon fa fa-star-o rounded bg-o-color-3" role="img"/>
                            <div class="d-flex flex-column">
                                <h3 class="h5-fs">Highlights Attributes</h3>
                                <p>We clearly showcase the main benefits and unique aspects of your product.</p>
                            </div>
                        </div>
                        <div class="col-lg-6 pt8 pb8" data-name="Feature">
                            <i class="s_showcase_icon fa fa-user-o rounded bg-o-color-3" role="img"/>
                            <div class="d-flex flex-column">
                                <h3 class="h5-fs">Engages Visitors</h3>
                                <p>We capture your visitors' attention and help them quickly understand the value of your product.</p>
                            </div>
                        </div>
                        <div class="col-lg-6 pt8 pb8" data-name="Feature">
                            <i class="s_showcase_icon fa fa-heart-o rounded bg-o-color-3" role="img"/>
                            <div class="d-flex flex-column">
                                <h3 class="h5-fs">Boosts Conversions</h3>
                                <p>We organize and present key information effectively, increasing the likelihood of turning your visitors into customers.</p>
                            </div>
                        </div>
                        <div class="col-lg-6 pt8 pb8" data-name="Feature">
                            <i class="s_showcase_icon fa fa-bookmark-o rounded bg-o-color-3" role="img"/>
                            <div class="d-flex flex-column">
                                <h3 class="h5-fs">Organizes Information</h3>
                                <p>We structure and categorize information efficiently for easy access and understanding.</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 o_snippet_mobile_invisible d-lg-block d-none">
                    <img src="/web/image/website.set_2_square_md_1" class="img img-fluid ms-auto rounded float-end" alt="" style="width: 100% !important;"/>
                </div>
            </div>
        </div>
    </section>
</template>

</odoo>
