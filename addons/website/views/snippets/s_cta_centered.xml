<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_cta_centered" name="Centered Call to Action">
    <section class="s_cta_centered pt80 pb80">
        <div class="container">
            <div class="s_card card o_cc o_cc4" data-snippet="s_card" data-vxml="001" data-name="Card"
                 style="--card-spacer-x: 64px; --card-spacer-y: 64px; border-width: 0px !important;">
                <div class="card-body">
                    <h2 class="card-title" style="text-align: center;">50,000+ companies run Odoo<br/>to grow their businesses.</h2>
                    <p class="card-text" style="text-align: center;">Join us and make your company a better place.</p>
                    <p><br/></p>
                    <p style="text-align: center;">
                        <a t-att-href="cta_btn_href" class="btn btn-lg btn-secondary">Contact Us</a>
                    </p>
                </div>
            </div>
        </div>
    </section>
</template>

</odoo>
