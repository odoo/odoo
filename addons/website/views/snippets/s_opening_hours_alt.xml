<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_opening_hours_alt" name="Opening Hours Alt">
    <section class="s_opening_hours_alt oe_img_bg o_bg_img_center o_bg_img_origin_border_box" style="background-image: url('/web/image/website.landscape_xl_2');">
        <div class="container-fluid">
            <div class="row o_grid_mode" data-row-count="14">
                <div class="o_grid_item o_cc o_cc5 g-height-4 g-col-lg-4 col-lg-4" style="grid-area: 4 / 9 / 8 / 13; z-index: 1; --grid-item-padding-y: 32px; --grid-item-padding-x: 32px;">
                    <h2 class="h3-fs">Let's get in touch</h2>
                    <p class="lead">
                        <a href="mailto:info@yourcompany.example.com">info@yourcompany.example.com</a>
                    </p>
                    <p class="lead">
                        <a href="tel:+1 555-555-5556">+1 555-555-5556</a>
                    </p>
                </div>
                <div class="o_grid_item o_cc o_cc1 g-height-7 g-col-lg-4 col-lg-4" style="grid-area: 8 / 9 / 15 / 13; z-index: 2; --grid-item-padding-y: 32px; --grid-item-padding-x: 32px;">
                    <div class="row s_col_no_bgcolor">
                        <div class="col-6 col-lg-6">
                            <p class="o_small-fs"><u>Monday</u><br/>8.00am-6.00pm</p>
                            <p class="o_small-fs"><u>Tuesday</u><br/>8.00am-6.00pm</p>
                            <p class="o_small-fs"><u>Wednesday</u><br/>8.00am-12.00pm</p>
                            <p class="o_small-fs"><u>Thursday</u><br/>8.00am-6.00pm</p>
                        </div>
                        <div class="col-6 col-lg-6">
                            <p class="o_small-fs"><u>Friday</u><br/>8.00am-6.00pm</p>
                            <p class="o_small-fs"><u>Saturday</u><br/>8.00am-6.00pm</p>
                            <p class="o_small-fs"><u>Sunday</u><br/>Closed</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</template>

</odoo>
