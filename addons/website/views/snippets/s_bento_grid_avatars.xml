<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_bento_grid_avatars" name="Bento Avatars">
    <section class="s_bento_grid_avatars pt64 pb64">
        <div class="container">
            <div class="row o_grid_mode" style="gap: 32px;" data-row-count="10">
                <div class="o_grid_item oe_img_bg o_bg_img_center g-height-10 g-col-lg-4 col-lg-4 order-lg-0 rounded o_cc o_cc5 overflow-hidden o_colored_level"
                     style="grid-area: 1 / 1 / 11 / 5; --grid-item-padding-x: 32px; --grid-item-padding-y: 32px; border-radius: 6.4px !important; order: 1; background-image: url('/web/image/website.s_bento_grid_default_image_1');"
                     data-name="Card"
                     >
                    <div class="o_we_bg_filter bg-black-25"/>
                    <h2>
                        <span class="h3-fs">Sustainable Materials</span>
                    </h2>
                    <p>Made from ethically sourced wood and premium textiles, our furniture is as kind to the planet as it is to your living space.</p>
                </div>
                <div class="o_grid_item oe_img_bg o_bg_img_center g-height-6 g-col-lg-4 col-lg-4 order-lg-0 rounded o_cc o_cc5 overflow-hidden o_colored_level"
                     style="grid-area: 1 / 5 / 7 / 9; --grid-item-padding-x: 32px; --grid-item-padding-y: 32px; border-radius: 6.4px !important; order: 1; background-image: url('/web/image/website.s_bento_grid_default_image_2');"
                     data-name="Card"
                     >
                    <div class="o_we_bg_filter bg-black-25"/>
                    <h2>
                        <span class="h3-fs">Need help ?</span>
                    </h2>
                    <p>Elevate your living space with furniture that blends modern aesthetics and classic charm, crafted to bring both comfort and style to your home.</p>
                    <div
                        class="s_customers_avatars o_avatar_medium d-flex align-items-center justify-content-start"
                        data-snippet="s_customers_avatars"
                        data-name="Customers Avatars"
                        >
                        <div class="s_customers_avatars_wrapper d-flex">
                            <img
                                src="/web/image/website.s_company_team_image_1"
                                class="img border rounded-5 o_avatar"
                                style="border-width: 3px !important; border-color: rgb(255, 255, 255) !important;"
                                alt=""
                                />
                            <img
                                src="/web/image/website.s_company_team_image_3"
                                class="img border rounded-5 o_avatar" style="border-width: 3px !important; border-color: rgb(255, 255, 255) !important;"
                                alt=""
                                />
                            <img
                                src="/web/image/website.s_company_team_image_4"
                                class="img border rounded-5 o_avatar" style="border-width: 3px !important; border-color: rgb(255, 255, 255) !important;"
                                alt=""
                                />
                            <div class="o_avatar_count d-none">10+</div>
                        </div>
                        <p class="o_small s_customers_avatars_label d-block">
                            <strong>5,000+<br/></strong>
                            Interior Specialists
                        </p>
                    </div>
                </div>
                <div class="o_grid_item g-height-4 g-col-lg-4 col-lg-4 order-lg-0 rounded o_cc o_cc5 overflow-hidden o_colored_level"
                     style="grid-area: 7 / 5 / 11 / 9; --grid-item-padding-x: 32px; --grid-item-padding-y: 32px; border-radius: 6.4px !important; order: 1;"
                     data-name="Card"
                     >
                    <h2>
                        <span class="h3-fs">30% off wooden desks</span>
                    </h2>
                    <p>Enjoy 30% on all our wooden desks and elevate your workspace.</p>
                    <a href="#" title="" role="button" class="btn btn-secondary">
                        Start saving&#160;&#160;<span class="fa fa-long-arrow-right" role="img"/>
                    </a>
                </div>
                <div class="o_grid_item g-height-10 g-col-lg-4 col-lg-4 order-lg-0 rounded o_cc o_cc2 overflow-hidden o_colored_level"
                     style="grid-area: 1 / 9 / 11 / 13; --grid-item-padding-x: 32px; --grid-item-padding-y: 32px; border-radius: 6.4px !important; order: 1;"
                     data-name="Card"
                     >
                    <h2 style="text-align: center;">
                        <span class="h3-fs">Expert’s review</span>
                    </h2>
                    <p><br/></p>
                    <blockquote class="s_blockquote s_blockquote_default o_cc o_cc2 o_animable position-relative d-flex flex-column gap-4 w-100 mx-auto p-1 fst-normal" data-vcss="001" data-snippet="s_blockquote">
                        <div class="s_blockquote_line_elt position-absolute top-0 start-0 bottom-0 bg-o-color-1"/>
                        <div class="s_blockquote_wrap_icon position-absolute top-0 start-50 translate-middle w-100">
                            <i class="s_blockquote_icon fa fa-quote-right d-block mx-auto rounded bg-o-color-1" role="img"/>
                        </div>
                        <p class="s_blockquote_quote my-auto lead" style="text-align: center;">
                            <span class="h3-fs">“Our furniture balances style, comfort, and sustainability.”</span>
                        </p>
                        <div class="s_blockquote_infos d-flex gap-2 flex-column align-items-center w-100 text-center">
                            <img src="/web/image/website.s_blockquote_default_image" class="s_blockquote_avatar img rounded-circle" alt=""/>
                            <div class="s_blockquote_author">
                                <span class="o_small">
                                    <strong>Paul Dawson</strong><br/>
                                    <span class="text-muted">Furniture Design Specialist</span>
                                </span>
                            </div>
                        </div>
                    </blockquote>
                </div>
            </div>
        </div>
    </section>
</template>

</odoo>
