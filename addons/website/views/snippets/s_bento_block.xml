<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_bento_block" name="Bento Block">
    <section class="s_bento_block pt32 pb32 o_cc o_cc2">
        <div class="container">
            <section
                data-name="Card"
                class="s_bento_block_card oe_unmovable oe_unremovable s_col_no_resize o_cc o_cc5 d-flex rounded-4 py-5 py-lg-0 oe_img_bg o_bg_img_center shadow-lg overflow-hidden"
                style="background-image: url('/web/image/website.shop_category_2_16x9')"
                >
                <div class="o_we_bg_filter bg-black-25"/>
                <div class="container-fluid">
                    <div
                        class="oe_unremovable row mx-0 o_grid_mode"
                        data-row-count="10"
                        >
                        <div
                            class="o_grid_item g-height-4 g-col-lg-7 col-lg-7"
                            style="z-index: 1; --grid-item-padding-x: 48px; grid-area: 7 / 1 / 11 / 8;"
                            >
                            <h2>Explore our new collection</h2>
                            <p>Simple forms. Natural textures. Timeless design. Explore our new furniture collection—crafted to bring calm and clarity to your space.</p>
                        </div>
                        <div
                            class="o_grid_item g-height-4 g-col-lg-4 col-lg-4"
                            style="z-index: 2; --grid-item-padding-x: 48px; grid-area: 7 / 9 / 11 / 13; text-align: right;"
                            >
                            <a href="" title="" role="button" class="btn btn-lg btn-secondary">
                                Buy Now
                            </a>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </section>
</template>

</odoo>
