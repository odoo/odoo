<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!--
For the moment we hack the contenteditable system so that the social media
title stay editable after a save (see SOCIAL_MEDIA_TITLE_CONTENTEDITABLE).
-->
<template id="s_social_media" name="Social Media">
    <div t-attf-class="s_social_media text-start o_not_editable #{_classes}" data-vcss="001" contenteditable="false">
        <h4 class="s_social_media_title d-none" contenteditable="true">Social Media</h4>
        <a href="#" class="s_social_media_facebook" target="_blank" aria-label="Facebook">
            <i class="fa fa-facebook o_editable_media rounded bg-o-color-3"/>
            <span class="text-capitalize"><i class="fa fa-facebook fa-fw me-2"/>Facebook</span>
        </a>
        <a href="#" class="s_social_media_twitter" target="_blank" aria-label="X">
            <i class="fa fa-twitter o_editable_media rounded bg-o-color-3"/>
            <span class="text-capitalize"><i class="fa fa-twitter fa-fw me-2"/>Twitter</span>
        </a>
        <a href="#" class="s_social_media_linkedin" target="_blank" aria-label="LinkedIn">
            <i class="fa fa-linkedin o_editable_media rounded bg-o-color-3"/>
            <span class="text-capitalize"><i class="fa fa-linkedin fa-fw me-2"/>LinkedIn</span>
        </a>
        <a href="#" class="s_social_media_youtube" target="_blank" aria-label="YouTube">
            <i class="fa fa-youtube-play o_editable_media rounded bg-o-color-3"/>
            <span class="text-capitalize"><i class="fa fa-youtube-play fa-fw me-2"/>YouTube</span>
        </a>
        <a href="#" class="s_social_media_instagram" target="_blank" aria-label="Instagram">
            <i class="fa fa-instagram o_editable_media rounded bg-o-color-3"/>
            <span class="text-capitalize"><i class="fa fa-instagram fa-fw me-2"/>Instagram</span>
        </a>
        <a href="#" class="s_social_media_github" target="_blank" aria-label="GitHub">
            <i class="fa fa-github o_editable_media rounded bg-o-color-3"/>
            <span class="text-capitalize"><i class="fa fa-github fa-fw me-2"/>GitHub</span>
        </a>
        <a href="#" class="s_social_media_tiktok" target="_blank" aria-label="TikTok">
            <i class="fa fa-tiktok o_editable_media rounded bg-o-color-3"/>
            <span class="text-capitalize"><i class="fa fa-tiktok fa-fw me-2"/>TikTok</span>
        </a>
        <a href="#" class="s_social_media_discord" target="_blank" aria-label="Discord">
            <i class="fa fa-discord o_editable_media rounded bg-o-color-3"/>
            <span class="text-capitalize"><i class="fa fa-discord fa-fw me-2"/>Discord</span>
        </a>
    </div>
</template>

<asset id="website.s_social_media_000_scss" name="SocialMedia 000 SCSS">
    <bundle>web.assets_frontend</bundle>
    <path>website/static/src/snippets/s_social_media/000.scss</path>
</asset>

<asset id="website.s_social_media_001_scss" name="SocialMedia 001 SCSS">
    <bundle>web.assets_frontend</bundle>
    <path>website/static/src/snippets/s_social_media/001.scss</path>
</asset>

</odoo>
