<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_services_grid" name="Services Grid">
    <section class="s_services_grid pt64 pb64">
        <div class="container">
            <h2 class="h3-fs">Our Services</h2>
            <p class="lead">We offer a wide range of services to meet your needs.</p>
            <div class="row">
                <div class="col-lg-4">
                    <p><img src="/web/image/website.landscape_md_1" class="img img-fluid rounded" alt=""/></p>
                    <h3 class="h5-fs">Reliability</h3>
                    <p>Stable systems, tested processes, and clear ownership keep your website dependable during peaks, updates, and everyday usage.</p>
                </div>
                <div class="col-lg-4">
                    <p><img src="/web/image/website.landscape_md_2" class="img img-fluid rounded" alt=""/></p>
                    <h3 class="h5-fs">Efficiency</h3>
                    <p>Smart automation and streamlined content tools help you publish faster, reduce manual work, and focus on customers today.</p>
                </div>
                <div class="col-lg-4">
                    <p><img src="/web/image/website.landscape_md_3" class="img img-fluid rounded" alt=""/></p>
                    <h3 class="h5-fs">Quality</h3>
                    <p>Careful design, consistent typography, and polished visuals make every section feel premium, coherent, and easy to scan quickly.</p>
                </div>
                <div class="col-lg-4">
                    <t t-snippet-call="website.s_hr" string="Separator"/>
                    <p><img src="/web/image/website.landscape_md_4" class="img img-fluid rounded" alt=""/></p>
                    <h3 class="h5-fs">Innovation</h3>
                    <p>New layouts, modern components, and flexible options let you experiment safely, iterate often, and stay ahead competitively online.</p>
                </div>
                <div class="col-lg-4">
                    <t t-snippet-call="website.s_hr" string="Separator"/>
                    <p><img src="/web/image/website.landscape_md_5" class="img img-fluid rounded" alt=""/></p>
                    <h3 class="h5-fs">Security</h3>
                    <p>Secure defaults, controlled permissions, and reliable hosting features protect your content, users, and data from threats common everywhere.</p>
                </div>
                <div class="col-lg-4">
                    <t t-snippet-call="website.s_hr" string="Separator"/>
                    <p><img src="/web/image/website.landscape_md_6" class="img img-fluid rounded" alt=""/></p>
                    <h3 class="h5-fs">Support</h3>
                    <p>Helpful guidance, quick answers, and proactive monitoring ensure issues are resolved fast, with minimal disruption for your team.</p>
                </div>
            </div>
        </div>
    </section>
</template>

</odoo>
