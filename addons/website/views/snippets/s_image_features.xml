<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_image_features" name="Image Features">
    <section class="s_image_features pt80 pb80">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6 pt16 pb16">
                    <img class="img-fluid mx-auto" data-shape="html_builder/devices/macbook_front" data-file-name="s_mockup_image.webp" data-format-mimetype="image/webp" src="/html_editor/image_shape/website.s_mockup_image_default_image/html_builder/devices/macbook_front.svg" alt=""/>
                </div>
                <div class="col-lg-5 offset-lg-1 pt16 pb16">
                    <h2>Second key feature</h2>
                    <p>Write one or two paragraphs describing your product or services. To be successful your content needs to be useful to your readers.</p>
                    <t t-snippet-call="website.s_icon_list" string="Icon List"/>
                </div>
            </div>
        </div>
    </section>
</template>

</odoo>
