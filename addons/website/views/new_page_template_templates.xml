<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- This template is used to obtain the order and the translations of all
group names.
It is not done in python (eg: a method returning a list of translated terms,
overridden by modules), because:
- it needs to be simple for designers and community: only write XML in themes
- python is ignored when importing modules in Odoo, which is a common flow for
  themes
-->
<template id="new_page_template_groups">
    <div id="about_us">About Us</div>
    <div id="services">Services</div>
    <div id="pricing">Pricing</div>
    <div id="portfolio">Portfolio</div>
    <div id="contact_us">Contact Us</div>
    <div id="utility">Utility</div>
    <div id="custom">Custom</div>
</template>

<!-- Specific templates are generated from the manifest files:
    If the manifest defines:
    'new_page_template': {
        'somekind': {
            'somespecific': ['s_cover'... list of snippets],
        },
    }
    A template named: new_page_template_sections_somekind_somespecific is generated.
    Its arch contains t-snippet-calls to each listed snippet, all nested in a div#wrap.
-->

<!-- Customized snippets -->
<!--
    Level-1 intermediates that are referenced as inherit_id below must be
    defined explicitly here. The auto-generator (_generate_primary_snippet_templates)
    runs via the <function> call at the bottom of this file — too late for
    Odoo's XML loader to resolve inherit_id references in this same file.
    The auto-generator skips these once they exist in the DB.
-->
<template id="new_page_template_s_title_split" inherit_id="website.s_title_split" primary="True"/>
<template id="new_page_template_s_company_team_spotlight" inherit_id="website.s_company_team_spotlight" primary="True"/>
<template id="new_page_template_s_projects_grid_minimal" inherit_id="website.s_projects_grid_minimal" primary="True"/>
<template id="new_page_template_s_timeline_images" inherit_id="website.s_timeline_images" primary="True"/>
<template id="new_page_template_s_title" inherit_id="website.s_title" primary="True"/>
<template id="new_page_template_s_announcement_scroll" inherit_id="website.s_announcement_scroll" primary="True"/>
<template id="new_page_template_s_duo_images" inherit_id="website.s_duo_images" primary="True"/>

<!-- Previews for blocks that normally generate part of their content upon drop -->
<!-- Defined in website so that every theme can benefit from it -->
<!-- Form: adapt style -->
<template id="new_page_template_s_website_form" inherit_id="s_website_form" primary="True">
    <xpath expr="//section" position="attributes">
        <attribute name="class" add="o_colored_level" separator=" "/>
    </xpath>
    <xpath expr="//form" position="attributes">
        <attribute name="data-success-mode">redirect</attribute>
        <attribute name="data-success-page">/contactus-thank-you</attribute>
        <attribute name="data-model_name">mail.mail</attribute>
    </xpath>
</template>

<!-- APPLIES TO ALL LAYOUTS -->
<template id="new_page_template_s_map" inherit_id="s_map" primary="True">
    <xpath expr="//section" position="attributes">
        <attribute name="t-attf-class" add="o_three_quarter_height" separator=" "/>
    </xpath>
</template>

<!-- ABOUT US LAYOUTS SPECIFIC -->

<!-- FIRST LAYOUT -->
<template id="new_page_template_about_us_s_title_split" inherit_id="website.new_page_template_s_title_split" primary="True">
    <xpath expr="//h2" position="replace">
        <h1 class="display-3-fs">About Us</h1>
    </xpath>
</template>

<template id="new_page_template_about_us_s_company_team_spotlight" inherit_id="website.new_page_template_s_company_team_spotlight" primary="True">
    <xpath expr="//h2" position="attributes">
        <attribute name="style" remove="text-align: center;" separator=";"/>
    </xpath>
    <xpath expr="//div[hasclass('col-lg-3')][1]" position="attributes">
        <attribute name="class" add="col-lg-4" remove="col-lg-3" separator=" "/>
    </xpath>
    <xpath expr="//div[hasclass('col-lg-3')][1]" position="attributes">
        <attribute name="class" add="col-lg-4" remove="col-lg-3" separator=" "/>
    </xpath>
    <xpath expr="//div[hasclass('col-lg-3')][1]" position="attributes">
        <attribute name="class" add="col-lg-4" remove="col-lg-3" separator=" "/>
    </xpath>
    <xpath expr="//div[hasclass('col-lg-3')][1]" position="replace"/>
</template>

<!-- SERVICES LAYOUTS SPECIFIC -->

<!-- FIRST LAYOUT -->
<template id="new_page_template_services_s_title_split" inherit_id="website.new_page_template_s_title_split" primary="True">
    <xpath expr="//h2" position="replace">
        <h1 class="display-3-fs">Our Services</h1>
    </xpath>
</template>

<!-- PORTFOLIO LAYOUTS SPECIFIC -->
<template id="new_page_template_portfolio_s_title_split" inherit_id="website.new_page_template_s_title_split" primary="True">
    <xpath expr="//h2" position="replace">
        <h1 class="display-3-fs">Our Projects</h1>
    </xpath>
</template>

<!-- FIRST LAYOUT -->
<template id="new_page_template_portfolio_s_projects_grid_minimal" inherit_id="website.new_page_template_s_projects_grid_minimal" primary="True">
    <xpath expr="//h2" position="replace"/>
    <xpath expr="//p" position="replace"/>
    <xpath expr="//p" position="replace"/>
</template>

<!-- THIRD LAYOUT -->
<template id="new_page_template_portfolio_s_timeline_images" inherit_id="website.new_page_template_s_timeline_images" primary="True">
    <xpath expr="//h2" position="replace"><h1 style="text-align: center;">OUR PROJECTS</h1></xpath>
    <xpath expr="//p[hasclass('lead')]" position="after"><p><br/></p></xpath>
    <xpath expr="//div[hasclass('s_timeline_images_row')][1]//h3" position="replace" mode="inner">First project</xpath>
    <xpath expr="//div[hasclass('s_timeline_images_row')][2]//h3" position="replace" mode="inner">Second project</xpath>
</template>

<!-- FOURTH LAYOUT -->
<template id="new_page_template_portfolio_s_title" inherit_id="website.new_page_template_s_title" primary="True">
    <xpath expr="//h2" position="replace" mode="inner"><span class="o_rfs" style="font-size: clamp(8px, 1em + 4.2272vw, 400px);">PORTFOLIO</span></xpath>
</template>

<template id="new_page_template_portfolio_s_announcement_scroll" inherit_id="website.new_page_template_s_announcement_scroll" primary="True">
    <xpath expr="//section" position="attributes">
        <attribute name="style" add="--marquee-item-font-size: 224" remove="--marquee-item-font-size: 80" separator=";"/>
        <attribute name="class" add="pt48 pb48" remove="pt24 pb24" separator=" "/>
    </xpath>
    <xpath expr="//div[hasclass('s_announcement_scroll_marquee_item')]" position="replace" mode="inner">— FREELANCER</xpath>
</template>


<!-- CONTACT US LAYOUTS SPECIFIC  -->

<!-- FIRST LAYOUT -->
<template id="new_page_template_contact_us_s_duo_images" inherit_id="website.new_page_template_s_duo_images" primary="True">
    <xpath expr="//section" position="attributes">
        <attribute name="class" add="pt80 pb80" remove="pt32 pb32" separator=" "/>
    </xpath>
</template>

<!-- UTILITY LAYOUTS SPECIFIC -->
<template id="new_page_template_utility_s_title_split" inherit_id="website.new_page_template_s_title_split" primary="True"/>

<!-- FIRST LAYOUT -->
<template id="new_page_template_utility_0_s_title_split" inherit_id="website.new_page_template_utility_s_title_split" primary="True">
    <xpath expr="//h2" position="replace" mode="inner">Privacy Policy</xpath>
</template>

<!-- SECOND LAYOUT -->
<template id="new_page_template_utility_1_s_title_split" inherit_id="website.new_page_template_utility_s_title_split" primary="True">
    <xpath expr="//h2" position="replace" mode="inner">Terms &amp; Conditions</xpath>
</template>

<!-- Using `function` so that it is called during both module install and update -->
<!-- Generate primary snippet templates that are not predefined -->
<function model="ir.module.module" name="_generate_primary_snippet_templates">
    <value eval="[ref('base.module_website')]"/>
</function>
<!-- Generate primary page templates from manifest -->
<function model="ir.module.module" name="_generate_primary_page_templates">
    <value eval="[ref('base.module_website')]"/>
</function>

</odoo>
