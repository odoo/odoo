<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="website_technical_pages_list_view" model="ir.ui.view">
        <field name="name">website.technical.page.list</field>
        <field name="model">website.technical.page</field>
        <field name="arch" type="xml">
            <list string="Website Technical Pages" type="object" action="open_website_url" create="false">
                <field name="name" string="Page Title"/>
                <field name="website_url" string="Page url"/>
            </list>
        </field>
    </record>
    
    <record id="action_website_technical_pages" model="ir.actions.act_window">
        <field name="name">Technical Pages</field>
        <field name="res_model">website.technical.page</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="website_technical_pages_list_view"/>
    </record>

    <record id="action_load_website_technical_pages" model="ir.actions.server">
        <field name="name">Load Technical Pages</field>
        <field name="model_id" ref="model_website_technical_page"/>
        <field name="state">code</field>
        <field name="code">
            action = env["website.technical.page"].load_technical_pages()
        </field>
    </record>
</odoo>    
