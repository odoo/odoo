<odoo>
    <template id="website.website_signup_form" name="SignUp Form">
        <div id="wrap" class="oe_structure oe_empty o_editable" contenteditable="false">
        <section class="s_website_form o_signup" data-vcss="001" data-snippet="s_website_form">
            <div class="container">
                <form class="oe_signup_form o_mark_required" action="/website/signup/form/" enctype="multipart/form-data" role="form" method="post" data-mark="*" data-pre-fill="true" data-model_name="res.users" data-success-mode="redirect" data-success-page="/my">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <div data-name="Field" class="s_website_form_field s_website_form_custom mb-3 col-12 s_website_form_model_required field-login" data-type="char">
                        <label class="s_website_form_label o_not_editable" style="width: 200px" for="login">
                            <span class="s_website_form_label_content">Your Email</span>
                            <span class="s_website_form_mark"> *</span>
                        </label>
                        <input class="form-control s_website_form_input" type="text" name="login" data-fill-with="login" t-att-value="login" autofocus="autofocus" id="login" autocapitalize="off" required="1" t-att-readonly="'readonly' if only_passwords else None"/>
                    </div>

                    <div data-name="Field" class="s_website_form_field s_website_form_custom mb-3 col-12 s_website_form_model_required field-login" data-type="char">
                        <label class="s_website_form_label o_not_editable" style="width: 200px" for="name">
                            <span class="s_website_form_label_content">Your Name</span>
                            <span class="s_website_form_mark"> *</span>
                        </label>
                        <input class="form-control s_website_form_input" type="text" name="name" data-fill-with="name" t-att-value="name" autofocus="autofocus" id="name" autocapitalize="off" required="1" t-att-readonly="'readonly' if only_passwords else None"/>
                    </div>

                    <div data-name="Field" class="s_website_form_field s_website_form_custom mb-3 col-12 s_website_form_model_required field-login" data-type="char">
                        <label class="s_website_form_label o_not_editable" style="width: 200px" for="password">
                            <span class="s_website_form_label_content">Password</span>
                            <span class="s_website_form_mark"> *</span>
                        </label>
                        <input class="form-control s_website_form_input" type="password" name="password" data-fill-with="password" t-att-value="password" autofocus="autofocus" id="password" autocapitalize="off" required="1" t-att-readonly="'readonly' if only_passwords else None"/>
                    </div>

                    <div data-name="Field" class="s_website_form_field s_website_form_custom mb-3 col-12 s_website_form_model_required field-login" data-type="char">
                        <label class="s_website_form_label o_not_editable" style="width: 200px" for="confirm_password">
                            <span class="s_website_form_label_content">Confirm Password</span>
                            <span class="s_website_form_mark"> *</span>
                        </label>
                        <input class="form-control s_website_form_input" type="password" name="confirm_password" data-fill-with="confirm_password" t-att-value="confirm_password" autofocus="autofocus" id="confirm_password" autocapitalize="off" required="1" t-att-readonly="'readonly' if only_passwords else None"/>
                    </div>

                    <input type="hidden" name="redirect" t-att-value="redirect"/>
                    <input type="hidden" name="token" t-att-value="token"/>    
                    <div class="text-center oe_login_buttons d-grid pt-3">
                        <span id="s_website_form_result"/>
                        <button type="submit" class="btn btn-primary s_website_form_send"> Sign up</button>
                        <a t-attf-href="/web/login?{{ keep_query() }}" class="btn btn-link btn-sm" role="button">Already have an account?</a>
                        <div class="o_login_auth"/>
                    </div>
                </form>
            </div>
        </section>
        </div>
    </template>

    <template id="website_signup" inherit_id="auth_signup.signup">
        <xpath expr="//section" position="replace">
            <t t-call="website.website_signup_form"/>
        </xpath>
    </template>

    <template id="website_signup_form_options" inherit_id="website.snippet_options">
        <xpath expr="//div[@data-js='WebsiteFormEditor'][2]" position="attributes">
            <attribute name="data-exclude" add=".o_signup" />
        </xpath>
        <xpath expr="//div[@data-js='AddFieldForm']" position="attributes">
            <attribute name="data-exclude" add=".o_signup" />
        </xpath>
    </template> 

</odoo>
