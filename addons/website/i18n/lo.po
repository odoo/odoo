#. module: website
#. odoo-python
#: code:addons/website/models/website_rewrite.py:0
#, python-format
msgid "\"URL to\" can not be empty."
msgstr "\"URL ໄປຫາ\" ບໍ່ສາມາດວ່າງໄດ້."

#. module: website
#. odoo-python
#: code:addons/website/models/website_rewrite.py:0
#, python-format
msgid ""
"\"URL to\" cannot be set to \"/\". To change the homepage content, use the "
"\"Homepage URL\" field in the website settings or the page properties on any"
" custom page."
msgstr ""
"\"URL ໄປຫາ\" ບໍ່ສາມາດຕັ້ງເປັນ \"/\" ໄດ້. ເພື່ອປ່ຽນເນື້ອໃນໜ້າທຳອິດ, ໃຫ້ໃຊ້ຊ່ອງ \"Homepage "
"URL\" ໃນການຕັ້ງຄ່າເວັບໄຊ ຫຼື ຄຸນສົມບັດຂອງໜ້າເວັບໃດໜຶ່ງ."

#. module: website
#. odoo-python
#: code:addons/website/models/website_rewrite.py:0
#, python-format
msgid "\"URL to\" cannot be set to an existing page."
msgstr "\"URL ໄປຫາ\" ບໍ່ສາມາດຕັ້ງເປັນໜ້າເວັບທີ່ມີຢູ່ແລ້ວໄດ້."

#. module: website
#. odoo-python
#: code:addons/website/models/website_rewrite.py:0
#, python-format
msgid "\"URL to\" cannot contain parameter %s which is not used in \"URL from\"."
msgstr "\"URL ໄປຫາ\" ບໍ່ສາມາດມີພາລາມິເຕີ %s ທີ່ບໍ່ໄດ້ໃຊ້ໃນ \"URL ຈາກ\"."

#. module: website
#. odoo-python
#: code:addons/website/models/website_rewrite.py:0
#, python-format
msgid "\"URL to\" is invalid: %s"
msgstr "\"URL ໄປຫາ\" ບໍ່ຖືກຕ້ອງ: %s"

#. module: website
#. odoo-python
#: code:addons/website/models/website_rewrite.py:0
#, python-format
msgid "\"URL to\" must contain parameter %s used in \"URL from\"."
msgstr "\"URL ໄປຫາ\" ຕ້ອງມີພາລາມິເຕີ %s ທີ່ໃຊ້ໃນ \"URL ຈາກ\"."

#. module: website
#. odoo-python
#: code:addons/website/models/website_rewrite.py:0
#, python-format
msgid "\"URL to\" must start with a leading slash."
msgstr "\"URL ໄປຫາ\" ຕ້ອງເລີ່ມຕົ້ນດ້ວຍເຄື່ອງໝາຍ slash (/) ທາງໜ້າ."

