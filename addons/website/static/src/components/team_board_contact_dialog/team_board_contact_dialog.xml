<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="website.TeamBoardContactDialog">
        <Dialog size="'xl'" t-on-click="this.handleClick" t-on-keyup="this.handleKeyup" title.translate="Contact">
            <div class="row">
                <div class="col-4">
                    <img class="img-fluid" t-att-src="this.props.img"/>
                </div>
                <div class="col-8">
                    <t t-out="this.content"/>
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button class="btn" t-as="action" t-attf-class="{{action.primary ? 'btn-primary': 'btn-secondary'}}" t-foreach="this.actions" t-key="action_id" t-on-click="(event) => action.execute(event, this)" t-out="action.label"/>
            </div>
        </Dialog>
    </t>
</templates>
