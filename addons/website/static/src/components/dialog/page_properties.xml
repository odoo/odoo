<?xml version="1.0" encoding="UTF-8"?>
<templates>

<t t-name="website.DuplicatePageDialog">
    <WebsiteDialog close="this.props.close">
        <div class="mb-3 row">
            <label class="col-form-label col-md-3">
                Page Name
            </label>
            <div class="col-md-9">
                <input type="text" t-custom-model="this.state.name" class="form-control" t-custom-ref="autofocus"/>
            </div>
        </div>
        <t t-set-slot="footer">
            <button class="btn btn-primary" t-on-click="(ev) => this.duplicate(ev)" t-att-disabled="!this.state.name.trim()">
                Ok
            </button>
            <button class="btn btn-secondary" t-on-click="() => this.props.close()">
                Discard
            </button>
        </t>
    </WebsiteDialog>
</t>

<t t-name="website.PageDependencies">
    <t t-if="this.state.dependencies === null">
        <span class="text-muted"><i class="fa fa-spinner fa-spin me-1"/>Checking links...</span>
    </t>
    <t t-elif="this.state.dependencyCount > 0">
        <t t-if="this.props.mode === 'popover'">
            <t t-set="depTemplate">
                <t t-call="{{ this.constructor.popoverTemplate }}"/>
            </t>
            <div t-att-data-bs-template="depTemplate" data-bs-html="true" title="Dependencies" t-custom-ref="action">
                Could be used in many places, see here: <a href="#" t-on-click="this.showDependencies">Dependencies</a>
            </div>
        </t>
        <t t-else="">
            <p class="text-warning">We found <t t-out="this.state.dependencyCount" /> occurrences linking to the selected page(s); before proceeding with deletion, make sure you update or remove all those links so your customers don't run into a 404 error page.</p>
            <div t-foreach="this.state.dependencies" t-as="dependency" t-key="dependency" class="ml16 mb16">
                <a class="collapsed" data-bs-toggle="collapse"
                t-attf-aria-controls="collapseDependencies{{ dependency_index }}"
                t-attf-href="#collapseDependencies{{ dependency_index }}"
                aria-expanded="false">
                    <i class="fa fa-caret-right me-1"/>
                    <t t-out="dependency"/>:
                    <span class="text-muted"> <t t-out="dependency_value.length"/> found(s)</span>
                </a>
                <div t-attf-id="collapseDependencies{{ dependency_index }}" class="collapse" aria-expanded="false">
                    <ul>
                        <li t-foreach="dependency_value" t-as="item" t-key="item_index">
                            <t t-set="link_text">The URL “%(url)s“ is contained in the “%(field)s” of the following “%(model)s”</t>
                            <a t-att-href="item.link" target="_blank">
                                <t t-out="this.sprintf(link_text, { url: item.url, field: item.field_name, model: item.model_name })"/>: <b t-out="item.record_name"/>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </t>
    </t>
    <t t-elif="this.props.mode !== 'popover'">
        <span class="text-success">No links found, you are safe to delete.</span>
    </t>
</t>

<t t-name="website.PageDependencies.Tooltip">
    <t t-foreach="dependencies" t-as="dependency" t-key="dependency">
        <b><t t-out="dependency"/></b>
        <ul>
            <li t-foreach="dependency_value" t-as="item" t-key="item_index">
                <a t-att-href="item.link" t-att-title="item.record_name" class="o_text_overflow" target="_blank">
                    <t t-out="item.record_name"/>
                </a>
            </li>
        </ul>
    </t>
</t>

<t t-name="website.DeletePageDialog">
    <WebsiteDialog title.translate="Delete Page" close="this.props.close">
        <p>Ready to make these web page(s) disappear into thin air? Are you sure?<br/> They will be gone forever!</p>
        <PageDependencies resIds="this.props.resIds" resModel="this.props.resModel" mode="'collapse'" onDependenciesLoaded="this.onDependenciesLoaded"/>
        <t t-if="this.state.hasDependencies">
            <CheckBox value="this.state.confirm" onChange.bind="this.onConfirmCheckboxChange">
                <span class="text-warning">I am sure about this.</span>
            </CheckBox>
        </t>

        <t t-set-slot="footer">
            <button class="btn btn-danger" t-on-click="() => this.onClickDelete()" t-att-disabled="!this.state.confirm">
                Delete
            </button>
            <button class="btn btn-secondary" t-on-click="() => this.props.close()">
                No, keep it
            </button>
        </t>
    </WebsiteDialog>
</t>

<t t-name="website.PagePropertiesDialogButtons" t-inherit="web.FormViewDialog.ToOne.buttons">
    <xpath expr="//button[hasclass('o_form_button_cancel')]" position="after">
        <button class="btn btn-link order-last ms-auto" t-on-click="this.props.clonePage"><i class="fa fa-fw fa-clone"/>Duplicate Page</button>
        <button class="btn btn-link order-last" t-on-click="this.props.deletePage"><i class="fa fa-fw fa-trash"/>Delete Page</button>
    </xpath>
</t>

</templates>
