<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

<div t-name="website.s_searchbar.autocomplete.skeleton.loader" class="o_dropdown_menu o_cc o_cc1 show w-100">
    <ul class="list-unstyled mb-0">
        <li class="o_search_result_item o_search_result_item_placeholder" t-foreach="[1, 2, 3]" t-as="i" t-key="i">
            <div class="d-flex align-items-center justify-content-between gap-3 py-2 px-3">
                <div class="o_search_result_image flex-shrink-0 rounded-2 placeholder-glow">
                    <span class="placeholder rounded-2 w-100 h-100 d-block bg-500"/>
                </div>
                <div class="o_search_result_content d-flex justify-content-between flex-grow-1 placeholder-glow gap-1">
                    <div class="placeholder col-4 bg-500"/>
                    <div t-attf-class="placeholder col-{{ i % 2 ? '6' : '4' }} bg-500"/>
                </div>
            </div>
        </li>
    </ul>
</div>

<!-- Search Bar autocomplete item -->
<div t-name="website.s_searchbar.autocomplete" class="o_dropdown_menu o_cc o_cc1 show position-absolute w-100">
    <!-- Fuzzy search fallback -->
    <t t-if="fuzzySearch and Object.keys(results).length !== 0">
        <span class="dropdown-item-text px-3">
            <span class="text-muted">
                No results found for '<t t-out="search"/>'. <br/>Showing results for
                '<a href="#" class="s_searchbar_fuzzy_submit" t-out="fuzzySearch"/>'.
            </span>
        </span>
    </t>
    <!-- No result state -->
    <t t-elif="Object.keys(results).length === 0">
        <span class="dropdown-item-text px-3">
            <span class="text-muted">No results found. Please try another search.</span>
        </span>
    </t>
    <!-- Render results -->
    <ul class="list-unstyled mb-0">
        <div t-out="results"/>
    </ul>
</div>

<t t-name="website.s_searchbar.modal">
    <div id="o_search_modal" class="modal fade css_editable_mode_hidden" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg pt-5">
            <div class="modal-content mt-lg-5 o_colored_level o_cc o_cc2 border-0">
                <form method="get"
                      class="o_searchbar_form s_searchbar_input"
                      t-att-action="action"
                      data-snippet="s_searchbar_input">
                    <div role="search" class="o_search_input_group input-group">
                        <input
                            type="search"
                            name="search"
                            class="oe_search_box search-query form-control border-0 p-3 text-bg-light"
                            t-att-placeholder="placeholder"
                            t-att-data-limit="limit"
                            t-att-data-order-by="order"
                            t-att-data-search-type="searchType"
                            t-att-autocomplete="autocomplete"/>
                        <button type="submit"
                                class="oe_search_button btn btn-light border-start px-3"
                                aria-label="Search"
                                title="Search">
                            <span class="o_search_spinner d-none spinner-border spinner-border-sm text-500"
                                  style="--spinner-border-width: 0.1em;"
                                  role="status">
                                <span class="visually-hidden">Loading...</span>
                            </span>
                            <small class="o_search_found_results d-none">
                                <span class="o_search_count"></span> result(s)
                            </small>
                            <i class="oi oi-search"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</t>

</templates>
