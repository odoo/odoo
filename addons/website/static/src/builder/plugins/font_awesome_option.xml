<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="website.FontAwesomeOption" t-inherit="html_builder.FontAwesomeOption">
    <xpath expr="//BuilderRow[@id=&quot;'background_color_opt'&quot;]" position="attributes">
        <attribute name="t-if">state.showBackground</attribute>
    </xpath>
    <xpath expr="//BuilderRow[@id=&quot;'font_size_opt'&quot;]" position="attributes">
        <attribute name="t-if">state.showSize</attribute>
    </xpath>
    <xpath expr="//BuilderRow[@id=&quot;'font_size_opt'&quot;]/BuilderButtonGroup" position="attributes">
        <attribute name="action">'faResize'</attribute>
    </xpath>
</t>

</templates>
