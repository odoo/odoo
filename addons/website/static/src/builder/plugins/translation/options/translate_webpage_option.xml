<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="website.TranslateWebpageOption">
    <BuilderContext preview="false">
        <BuilderRow label.translate="Translate to"
            tooltip.translate="Translate your content (yellow part) with AI">
            <BuilderButton action="'translateWebpageAI'" type="'success'" className="this.translationState.isTranslating ? 'disabled': ''">
                <t t-if="this.translationState.isTranslating">
                    <i class="oi oi-spin lh-1" data-icon="autorenew"/> Translating...
                </t>
                <t t-else="" t-out="this.env.services.website.currentWebsite.metadata.langName"/>
            </BuilderButton>
        </BuilderRow>
    </BuilderContext>
</t>

</templates>
