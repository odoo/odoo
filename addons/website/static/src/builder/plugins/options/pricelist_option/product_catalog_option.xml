<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="website.ProductCatalogDescriptionOption">
    <BuilderRow label.translate="Descriptions">
        <BuilderCheckbox
            action="'togglePriceListDescription'"
            actionParam="{ itemClass:'s_product_catalog_dish', descriptionClass: 's_product_catalog_dish_description' }"/>
    </BuilderRow>
    <BuilderContext applyTo="'.s_product_catalog_dish_dot_leaders'">
        <BorderConfigurator withRoundCorner="false" withBSClass="false" label.translate="Separator" direction="'top'"/>
    </BuilderContext>
</t>

<t t-inherit="website.BuilderOptions" t-inherit-mode="extension">
    <xpath expr="//t[@id='snippet_specific_options']" position="after">
        <product_catalog_description_option template="website.ProductCatalogDescriptionOption" selector=".s_product_catalog"/>
    </xpath>
</t>

</templates>
