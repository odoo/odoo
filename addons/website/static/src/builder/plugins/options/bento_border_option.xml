<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="website.BentoBorderOption">
    <BuilderRow label.translate="Roundness">
        <BuilderRange action="'setClassRange'" actionParam="['rounded-0','rounded-1','rounded-2','rounded-3','rounded-4','rounded-5']" max="5"/>
    </BuilderRow>
    <BorderConfigurator label.translate="Border" withRoundCorner="false"/>
    <ShadowOption/>
</t>

<t t-inherit="website.BuilderOptions" t-inherit-mode="extension">
    <xpath expr="//t[@id='snippet_specific_options']" position="after">
        <bento_border_option template="website.BentoBorderOption" selector=".s_bento_banner section[data-name='Card'], .s_bento_block_card"/>
    </xpath>
</t>

</templates>
