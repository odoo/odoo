<templates>
    <t t-name="website.TeamBoardOption">
        <BuilderRow label.translate="Cards Layout">
            <BuilderSelect>
                <BuilderSelectItem
                    action="'classAction'" 
                    actionParam="'s_team_layout_grid'">
                    Grid
                </BuilderSelectItem>
                <BuilderSelectItem
                    action="'classAction'" 
                    actionParam="'s_team_layout_list'">
                    List
                </BuilderSelectItem>
            </BuilderSelect>
        </BuilderRow>

        <BuilderRow label.translate="Density" applyTo="'.card-body p'">
            <BuilderSelect styleAction="'font-size'">
                <BuilderSelectItem 
                    styleActionValue="'18px'">
                    Comfortable
                </BuilderSelectItem>
                <BuilderSelectItem 
                    styleActionValue="'14px'">
                    Compact
                </BuilderSelectItem>
            </BuilderSelect>
        </BuilderRow>
    </t>


    <t t-inherit="website.BuilderOptions" t-inherit-mode="extension">
        <xpath expr="//t[@id='snippet_specific_options']" position="after">
            <team_board_option
                template="website.TeamBoardOption"
                selector=".s_team_board"/>
        </xpath>
    </t>
</templates>
