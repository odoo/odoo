<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="website.TeamBoardOption">
    <BuilderRow label.translate="Cards Layout">
        <BuilderSelect>
            <BuilderSelectItem classAction="''">Grid</BuilderSelectItem>
            <BuilderSelectItem classAction="'o_team_board_list'">List</BuilderSelectItem>
        </BuilderSelect>
    </BuilderRow>
    <BuilderRow label.translate="Density">
        <BuilderSelect>
            <BuilderSelectItem classAction="''">Comfortable</BuilderSelectItem>
            <BuilderSelectItem classAction="'o_team_board_compact'">Compact</BuilderSelectItem>
        </BuilderSelect>
    </BuilderRow>
    <BuilderRow label.translate="Members">
        <BuilderButton action="'addTeamMember'" preview="false">
            Add member
        </BuilderButton>
    </BuilderRow>
    <BuilderRow label.translate="Sort">
        <BuilderButton action="'sortTeamMembersAlphabetically'" preview="false">
            Sort alphabetically
        </BuilderButton>
    </BuilderRow>
</t>

<t t-name="website.TeamBoardHeaderMiddleButtons">
    <button class="btn btn-success-color-hover ms-0 py-0 px-1 me-1"
            title="Add new Team Board"
            aria-label="Add new Team Board"
            t-on-click="this.onAddBoard">
        <span class="oi oi-fw oi-plus"/>
    </button>
</t>

<t t-name="website.TeamBoardHeaderMiddleButtons">
    <button class="btn btn-success-color-hover ms-0 py-0 px-1 me-1"
            title="Add new Team Board"
            aria-label="Add new Team Board"
            t-on-click="this.onAddBoard">
        <span class="oi oi-fw oi-plus"/>
    </button>
</t>

<t t-inherit="website.BuilderOptions" t-inherit-mode="extension">
    <xpath expr="//t[@id='snippet_specific_options']" position="after">
        <team_board_option
            template="website.TeamBoardOption"
            selector=".s_team_board"/>
    </xpath>
</t>

</templates>
