<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="website.AnimatedNumberOption">
    <BuilderRow label.translate="Alignment">
       <BuilderButtonGroup applyTo="'.s_animated_number_content'">
            <BuilderButton ltrRtlMapping="'left-right'" classAction="'me-auto'" icon="'fa-align-left'" title.translate="Left"/>
            <BuilderButton icon="'fa-align-center'" title.translate="Center" classAction="'mx-auto'"/>
            <BuilderButton ltrRtlMapping="'left-right'" classAction="'ms-auto'" icon="'fa-align-right'" title.translate="Right"/>
        </BuilderButtonGroup>
    </BuilderRow>
    <BuilderRow label.translate="Title Position">
        <BuilderButtonGroup action="'toggleTitleAnimatedNumber'" applyTo="'.s_animated_number_content'">
            <BuilderButton
                classAction="''"
                icon="'fa-eye-slash'"
                title.translate="Hide"/>
            <BuilderButton
                classAction="'flex-column'"
                actionValue="'top'"
                iconImg="'/website/static/src/img/snippets_options/pos_top.svg'"
                title.translate="Top"/>
            <BuilderButton
                classAction="'flex-row gap-2'"
                actionValue="'left'"
                iconImg="'/website/static/src/img/snippets_options/pos_left.svg'"
                title.translate="Left"/>
            <BuilderButton
                classAction="'flex-row-reverse gap-2'"
                actionValue="'right'"
                iconImg="'/website/static/src/img/snippets_options/pos_right.svg'"
                title.translate="Right"/>
            <BuilderButton
                classAction="'flex-column-reverse'"
                actionValue="'bottom'"
                iconImg="'/website/static/src/img/snippets_options/pos_bottom.svg'"
                title.translate="Bottom"/>
        </BuilderButtonGroup>
    </BuilderRow>

    <BuilderContext preview="false">
        <BuilderRow label.translate="Start / End">
            <BuilderNumberInput title.translate="Start Value" dataAttributeAction="'startValue'"/>
            <BuilderNumberInput title.translate="End Value" dataAttributeAction="'endValue'"/>
        </BuilderRow>
    </BuilderContext>
    <BuilderContext preview="false">
        <BuilderRow label.translate="Start After" styleAction="'animation-delay'">
            <BuilderNumberInput unit="'s'" default="0" min="0" step="0.1"/>
        </BuilderRow>
        <BuilderRow label.translate="Duration" styleAction="'animation-duration'">
            <BuilderNumberInput unit="'s'" default="1" min="0.1" step="0.1"/>
        </BuilderRow>
    </BuilderContext>
</t>

<t t-inherit="website.BuilderOptions" t-inherit-mode="extension">
    <xpath expr="//animate_option" position="before">
        <animated_number_option template="website.AnimatedNumberOption" selector=".s_animated_number"/>
    </xpath>
</t>


</templates>
