<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="website.BlockquoteOption">
    <t t-if="!this.props.disableWidth">
        <WebsiteBackgroundOption
            withColors="true"
            withImages="true"
            withShapes="true"
            withColorCombinations="true"
        />
        <BuilderRow label.translate="Width">
            <BuilderSelect>
                <BuilderSelectItem classAction="'w-25'">25%</BuilderSelectItem>
                <BuilderSelectItem classAction="'w-50'">50%</BuilderSelectItem>
                <BuilderSelectItem classAction="'w-75'">75%</BuilderSelectItem>
                <BuilderSelectItem classAction="'w-100'" id="'so_width_100'">100%</BuilderSelectItem>
            </BuilderSelect>
        </BuilderRow>
        <BuilderRow label.translate="Alignment" t-if="!this.isActiveItem('so_width_100')" level="1">
            <BuilderButtonGroup>
                <BuilderButton ltrRtlMapping="'left-right'" classAction="'me-auto'" icon="'fa-align-left'" title.translate="Left"/>
                <BuilderButton icon="'fa-align-center'" title.translate="Center" classAction="'mx-auto'"/>
                <BuilderButton ltrRtlMapping="'left-right'" classAction="'ms-auto'" icon="'fa-align-right'" title.translate="Right"/>
            </BuilderButtonGroup>
        </BuilderRow>
    </t>
    <!-- Layout -->
    <BuilderRow label.translate="Edge Spacing">
        <BuilderRange action="'setClassRange'" actionParam="['p-1','p-2','p-3','p-4','p-5']" max="4"/>
    </BuilderRow>
    <BuilderRow label.translate="Decoration">
        <BuilderSelect>
            <t t-set="left">Left line</t>
            <t t-set="right">Right line</t>
            <BuilderSelectItem classAction="'s_blockquote_default'">None</BuilderSelectItem>
            <BuilderSelectItem
                id="'blockquote_with_line_opt'"
                classAction="'s_blockquote_with_line'"
                t-out="this.env.langDir.content === 'ltr' ? left : right"/>
            <BuilderSelectItem classAction="'s_blockquote_with_icon'">Icon</BuilderSelectItem>
        </BuilderSelect>
    </BuilderRow>

    <BuilderRow label.translate="Style" applyTo="':scope > .s_blockquote_line_elt'" level="1" t-if="this.isActiveItem('blockquote_with_line_opt')">
        <BuilderNumberInput styleAction="'width'" min="0" unit="'px'"/>
        <BuilderColorPicker styleAction="'background-color'" enabledTabs="['solid', 'custom', 'gradient']"/>
    </BuilderRow>

    <BuilderContext applyTo="':scope > .s_blockquote_infos'">
        <BuilderRow label.translate="Show Author">
            <BuilderCheckbox id="'blockquote_show_author_opt'" classAction="'d-flex'"/>
        </BuilderRow>
        <BuilderRow t-if="this.isActiveItem('blockquote_show_author_opt')" label.translate="Author Alignment" level="1">
            <BuilderSelect>
                <BuilderSelectItem ltrRtlMapping="'left-right'" classAction="'flex-row align-items-start justify-content-start text-start'">
                    Left
                </BuilderSelectItem>
                <BuilderSelectItem classAction="'flex-column align-items-center text-center'">Center</BuilderSelectItem>
                <BuilderSelectItem ltrRtlMapping="'left-right'" classAction="'flex-row-reverse align-items-start justify-content-start text-end'">
                    Right
                </BuilderSelectItem>
            </BuilderSelect>
        </BuilderRow>
    </BuilderContext>

    <BorderConfigurator label.translate="Border"/>
    <ShadowOption/>
</t>

<t t-inherit="website.BuilderOptions" t-inherit-mode="extension">
    <xpath expr="//t[@id='snippet_specific_options']" position="after">
        <blockquote_option selector=".s_blockquote" t-att-exclude="this.specialBlockquoteSelector"/>
        <blockquote_option
            t-att-selector="this.blockquoteParentHandlers"
            t-att-applyTo="this.blockquoteDisableWidthApplyTo"
            props='{ "disableWidth": true }'/>
    </xpath>
</t>

</templates>
