<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="website.GalleryElementOption">
    <BuilderRow label.translate="Re-order" disabled="!this.state.hasMultiItems">
        <BuilderButtonGroup preview="false" action="'setGalleryElementPosition'">
            <BuilderButton ltrRtlMapping="'first-last'" isLabelLinkedToContent="true"
                icon="'fa-angle-double-left'"
                title.translate="Move to first"
                actionValue="'first'"
                className="!this.state.hasMultiItems || this.state.isFirstItem ? 'disabled' : ''"/>
            <BuilderButton ltrRtlMapping="'prev-next'" isLabelLinkedToContent="true"
                icon="'fa-angle-left'"
                title.translate="Move to previous"
                actionValue="'prev'"
                className="!this.state.hasMultiItems ? 'disabled' : ''"/>
            <BuilderButton ltrRtlMapping="'prev-next'" isLabelLinkedToContent="true"
                icon="'fa-angle-right'"
                title.translate="Move to next"
                actionValue="'next'"
                className="!this.state.hasMultiItems ? 'disabled' : ''"/>
            <BuilderButton ltrRtlMapping="'first-last'" isLabelLinkedToContent="true"
                icon="'fa-angle-double-right'"
                title.translate="Move to last"
                actionValue="'last'"
                className="!this.state.hasMultiItems || this.state.isLastItem ? 'disabled' : ''"/>
        </BuilderButtonGroup>
    </BuilderRow>
</t>

<t t-inherit="website.BuilderOptions" t-inherit-mode="extension">
    <xpath expr="//t[@id='snippet_specific_options']" position="after">
        <gallery_element_option selector=".s_image_gallery img, .s_carousel .carousel-item, .s_quotes_carousel .carousel-item, .s_carousel_intro .carousel-item, .s_carousel_cards .carousel-item"/>
    </xpath>
</t>

</templates>
