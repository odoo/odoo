<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="website.PortalOption">
        <BuilderRow label.translate="Background Color">
            <BuilderColorPicker
                defaultColor="''"
                action="'customizeWebsiteColor'"
                actionParam="{
                    mainParam: 'portal-card-custom',
                    gradientColor: 'portal-gradient',
                    combinationColor: 'portal-card',
                }"/>
        </BuilderRow>
        <BorderConfigurator label.translate="Border" withBSClass="false" action="'setStylePortalCard'"/>
    </t>
    <t t-name="website.PortalCardVisibilityOption">
            <BuilderRow t-if="this.entries.length" label.translate="Cards Design">
                    Global options for all inner cards.
            </BuilderRow>
        <t t-foreach="this.entries" t-as="entry" t-key="entry.id">
            <BuilderRow label="entry.name" level="1">
                <BuilderCheckbox action="'cardVisibilityOption'" actionValue="entry.id"/>
            </BuilderRow>
        </t>
    </t>
    
    <t t-inherit="website.BuilderOptions" t-inherit-mode="extension">
        <xpath expr="//t[@id='snippet_specific_options']" position="after">
            <portal_option
                template="website.PortalOption"
                selector=".o_portal_index_card > a"
                editableOnly="false"
                groups='["website.group_website_designer"]'/>
            <portal_card_visibility_option
                selector=".o_portal_wrap"
                editableOnly="false"
                reloadTarget="true"
                groups='["website.group_website_designer"]'/>
        </xpath>
    </t>
</templates>
