<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="website.PortalOption">
        <BuilderRow label.translate="Background Color">
            <BuilderColorPicker
                defaultColor="''"
                action="'customizeWebsiteColor'"
                actionParam="{
                    mainParam: 'portal-card-custom',
                    gradientColor: 'portal-gradient',
                    combinationColor: 'portal-card',
                    nullValue: 'NULL',
                }"/>
        </BuilderRow>
        <BuilderRow label.translate="Gap">
            <BuilderRange
                action="'setPortalCardGap'"
                unit="'px'"
                saveUnit="'rem'"
                min="0"
                max="60"
                step="1"
                withNumberInput="true"/>
        </BuilderRow>
        <WebsiteBorderConfigurator label.translate="Border" withBSClass="false" action="'setStylePortalCard'"/>
    </t>

    <t t-name="website.PortalCardDisplayOption">
        <BuilderList
            action="'updatePortalCardList'"
            itemShape="{ id: 'number', name: 'text', show_in_portal: 'boolean' }"
            hiddenProperties="['id']"
            isEditable="false"
            withScrollbar="false"/>
    </t>

    <t t-inherit="website.BuilderOptions" t-inherit-mode="extension">
        <xpath expr="//t[@id='snippet_specific_options']" position="after">
            <portal_option
                selector=".o_portal_index_card > a"
                editableOnly="false"
                groups='["website.group_website_designer"]'/>
            <portal_card_display_option
                template="website.PortalCardDisplayOption"
                selector="main:has(.o_portal_wrap)"
                editableOnly="false"
                reloadTarget="true"
                groups='["website.group_website_designer"]'/>
        </xpath>
    </t>
</templates>
