<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="website.MediaListOption">
    <BuilderRow label.translate="Media">
        <BuilderButton
            type="'success'"
            action="'addItem'"
            actionParam="'.s_media_list_item:last-of-type'"
            preview="false">
            Add Media
        </BuilderButton>
    </BuilderRow>
</t>

<t t-inherit="website.BuilderOptions" t-inherit-mode="extension">
    <xpath expr="//t[@id='snippet_specific_options']" position="after">
        <media_list_option template="website.MediaListOption" selector=".s_media_list"/>
    </xpath>
</t>

</templates>
