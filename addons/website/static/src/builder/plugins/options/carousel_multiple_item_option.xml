<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="website.CarouselMultipleItemOption" t-inherit="website.CardOption">
    <!-- // Remove the Border Option for s_carousel_multiple_card -->
    <xpath expr="//BorderConfigurator" position="replace"/>
</t>

<t t-inherit="website.BuilderOptions" t-inherit-mode="extension">
    <xpath expr="//t[@id='snippet_specific_options']" position="after">
        <carousel_multiple_item_option
            selector=".s_carousel_multiple_item"
            applyTo=":scope > .s_carousel_multiple_card"/>
    </xpath>
</t>

</templates>
