<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="website.CarouselMultipleOption" t-inherit="website.CarouselBottomControllersOption" t-inherit-mode="primary">
    <xpath expr="//BuilderRow[@label.translate=&quot;Slide&quot;]/BuilderButton" position="attributes">
        <attribute name="action">"addCarouselMultipleSlide"</attribute>
    </xpath>
    <xpath expr="//BuilderRow[@label.translate=&quot;Slide&quot;]" position="after">
        <BuilderRow label.translate="Displayed slides" tooltip.translate="Number of slides fully visible at once">
            <BuilderSelect action="'changeSlidesToDisplay'">
                <BuilderSelectItem classAction="'o_displayed_items_1'">1</BuilderSelectItem>
                <BuilderSelectItem classAction="'o_displayed_items_2'">2</BuilderSelectItem>
                <BuilderSelectItem classAction="'o_displayed_items_3'">3</BuilderSelectItem>
                <BuilderSelectItem classAction="'o_displayed_items_4'">4</BuilderSelectItem>
                <BuilderSelectItem classAction="'o_displayed_items_5'">5</BuilderSelectItem>
            </BuilderSelect>
        </BuilderRow>
        <BuilderRow label.translate="Spacing" tooltip.translate="Spacing between slides">
            <BuilderRange styleAction="'--carousel-multiple-items-gap'" max="64" min="0" step="4" unit="'px'"/>
        </BuilderRow>
        <BuilderRow label.translate="Items Roundness" tooltip.translate="Applies to all items" applyTo="'.s_carousel_multiple_card'">
            <BuilderRange action="'setClassRange'" actionParam="['rounded-0','rounded-1','rounded-2','rounded-3','rounded-4','rounded-5']" max="5"/>
        </BuilderRow>
    </xpath>
    <xpath expr="//t[@t-call='website.CarouselAnimationOption']" position="attributes">
        <attribute name="t-call">website.CarouselMultipleAnimationOption</attribute>
    </xpath>
</t>

<t t-name="website.CarouselMultipleAnimationOption" t-inherit="website.CarouselAnimationOption" t-inherit-mode="primary">
    <xpath expr="//BuilderRow[@label.translate='Transition']" position="replace"/>

    <xpath expr="//BuilderRow[@label.translate='Autoplay']" position="attributes">
        <attribute name="level"/>
    </xpath>
</t>

<t t-inherit="website.BuilderOptions" t-inherit-mode="extension">
    <xpath expr="//t[@id='snippet_specific_options']" position="after">
        <carousel_multiple_option
            template="website.CarouselMultipleOption"
            selector="section"
            applyTo=".s_carousel_multiple"/>
    </xpath>
</t>

</templates>
