<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="website.highlightPicker">
    <div t-custom-ref="root" class="p-2 grid gap-1" style="overflow: auto; scrollbar-width: thin; --text-highlight-color: #000000; --text-highlight-width: .15em;">
        <t t-foreach="this.getHighlightFactory()" t-as="highlight" t-key="highlight">
                <div class="btn btn-secondary g-col-4 position-relative align-content-center"
                    style="aspect-ratio: 1; --btn-border-color: transparent; --btn-bg: transparent;"
                    t-att-class="{ active: highlight === this.props.currentHighlightId }"
                    t-on-click="() => this.props.selectHighlight(highlight)"
                    t-on-mouseenter="() => this.props.previewHighlight(highlight)"
                    t-on-mouseleave="() => this.props.revertHighlight()">
                <div class="overflow-visible position-relative fw-bolder fs-3 text-center">
                    <span t-att-style="this.props.style"
                          t-attf-class="o_text_highlight o_text_highlight_{{highlight}}">Text</span>
                </div>
            </div>
        </t>
    </div>
</t>
</templates>
