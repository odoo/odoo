<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="website.ImageAndFaOption" t-inherit="html_builder.ImageAndFaOption">
    <xpath expr="//BorderConfigurator" position="after">
        <BuilderRow label.translate="Alignment">
            <BuilderSelect action="'imageAndFaAlignClassAction'">
                <BuilderSelectItem actionParam="''" title.translate="Unalign">None</BuilderSelectItem>
                <BuilderSelectItem ltrRtlMapping="'left-right'" actionParam="'me-auto float-start'" title.translate="Align Left">Left</BuilderSelectItem>
                <BuilderSelectItem actionParam="'mx-auto d-block'" title.translate="Align Center">Center</BuilderSelectItem>
                <BuilderSelectItem ltrRtlMapping="'left-right'" actionParam="'ms-auto float-end'" title.translate="Align Right">Right</BuilderSelectItem>
            </BuilderSelect>
        </BuilderRow>

        <BuilderRow label.translate="Style">
            <BuilderButton icon="'fa-square'" classAction="'rounded'" title.translate="Shape: Rounded"/>
            <BuilderButton icon="'fa-circle-o'" classAction="'rounded-circle'" title.translate="Shape: Circle"/>
            <BuilderButton icon="'fa-sun-o'" classAction="'shadow'" title.translate="Shadow"/>
            <BuilderButton icon="'fa-picture-o'" classAction="'img-thumbnail'" title.translate="Shape: Thumbnail"/>
        </BuilderRow>
    </xpath>
    <xpath expr="//BorderConfigurator" position="attributes">
        <attribute name="withRoundCorner">false</attribute>
        <attribute name="t-if">state.showBorder and !state.isImage</attribute>
    </xpath>
</t>

</templates>
