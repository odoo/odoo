<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="website.WebsiteBuilder">
    <Builder t-props="this.builderProps">
        <t t-set-slot="extraActions">
            <div class="o-website-discard-save-buttons d-flex">
                <button type="button" t-on-click="this.discard"
                    t-on-pointerover="this.updateTooltip"
                    class="o-hb-btn btn" data-action="cancel"
                    data-tooltip="Tip: Esc to preview" accesskey="j">
                    <span class="d-inline-block text-truncate mw-100 align-bottom">Discard</span>
                </button>
                <button type="button" t-on-click="this.save"
                    t-on-pointerover="this.updateTooltip"
                    class="o-hb-btn btn btn-success px-3" data-action="save"
                    accesskey="s">
                    <span class="d-inline-block text-truncate mw-100 align-bottom">Save</span>
                </button>
            </div>
        </t>
    </Builder>
</t>

</templates>
