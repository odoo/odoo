<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="website.WebsiteBuilder">
    <Builder t-props="this.builderProps">
        <t t-set-slot="extraActions">
            <button type="button" t-on-click="this.discard" class="o-hb-btn btn" data-action="cancel" title="Tip: Esc to preview" accesskey="j">Discard</button>
            <t t-if="this.websiteService.isDraftPreview">
                <button type="button" t-on-click="this.deleteDraft" class="o-hb-btn btn btn-danger" data-action="remove" title="Delete draft">
                    <i class="fa fa-trash fa-fw"/>
                </button>
                <button type="button" t-on-click="this.publishDraft" class="o-hb-btn btn btn-primary" data-action="publish" title="Publish draft">
                    <i class="fa fa-cloud-upload fa-fw" />
                </button>
            </t>
            <button type="button" t-on-click="this.save" class="o-hb-btn btn btn-success" t-attf-class="{{ this.websiteService.isDraftPreview ? 'px-2' : 'px-3' }}" data-action="save" accesskey="s">Save</button>
        </t>
    </Builder>
</t>

</templates>
