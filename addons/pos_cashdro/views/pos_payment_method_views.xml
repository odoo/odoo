<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_payment_method_view_form_inherit_pos_cashdro" model="ir.ui.view">
        <field name="name">pos.payment.method.form.inherit.cashdro</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <notebook invisible="payment_method_type != 'cashdro'">
                    <page name="settings" string="Cashdro Settings">
                        <group>
                            <group>
                                <field name="cashdro_ip" required="payment_method_type == 'cashdro'"/>
                                <field name="cashdro_username"/>
                                <field name="cashdro_password" password="True"/>
                                <field name="cashdro_use_lna"/>
                            </group>
                            <widget name="pos_cashdro_admin_buttons"/>
                        </group>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>
</odoo>
