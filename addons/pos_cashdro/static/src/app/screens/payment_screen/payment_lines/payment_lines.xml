<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-inherit="point_of_sale.PaymentScreenPaymentLines" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('paymentline_status_title')]" position="after">
            <div t-if="['waiting', 'waiting_cancel', 'waiting_capture'].includes(state.id) and line.payment_method_id.payment_provider === 'cashdro'"
                class="d-flex align-items-center justify-content-between pb-3 px-4 fs-4">
                <span>Cash inserted</span>
                <span t-out="this.env.utils.formatCurrency(line.payment_method_id.payment_interface.amountInserted)"/>
            </div>
        </xpath>
    </t>
</templates>
