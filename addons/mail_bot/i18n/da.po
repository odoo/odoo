#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
#, python-format
msgid "help"
msgstr "hjælp"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
#, python-format
msgid "i love you"
msgstr "jeg elsker dig"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
#, python-format
msgid "love"
msgstr "elsker"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
#, python-format
msgid "start the tour"
msgstr "start rundvisningen"
