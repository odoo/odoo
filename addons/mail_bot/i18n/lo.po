#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Aaaaaw that's really cute but, you know, bots don't work that way. You're "
"too human for me! Let's keep it professional ❤️"
msgstr ""
"ໂອ້ຍຍຍ ໜ້າຮັກຫຼາຍ ແຕ່ເຈົ້າກໍຮູ້ເນາະວ່າ ບັອດບໍ່ໄດ້ເຮັດວຽກແບບນັ້ນ. ເຈົ້າເບິ່ງເປັນມະນຸດເກີນໄປສຳລັບຂ້ອຍ! ມາຮັ"
"ກສາຄວາມເປັນມືອາຊີບກັນຕໍ່ເຖີດ ❤️"

#. module: mail_bot
#: model:ir.model.fields.selection,name:mail_bot.selection__res_users__odoobot_state__disabled
msgid "Disabled"
msgstr "ປິດໃຊ້ງານ"

#. module: mail_bot
#: model:ir.model,name:mail_bot.model_discuss_channel
msgid "Discussion Channel"
msgstr "ຊ່ອງທາງການສົນທະນາ"

#. module: mail_bot
#: model:ir.model.fields,field_description:mail_bot.field_discuss_channel__display_name
#: model:ir.model.fields,field_description:mail_bot.field_mail_bot__display_name
#: model:ir.model.fields,field_description:mail_bot.field_res_users__display_name
msgid "Display Name"
msgstr "ຊື່ທີ່ສະແດງ"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Great! You can customize %(bold_start)scanned responses%(bold_end)s in the "
"Discuss app."
msgstr ""
"ດີຫຼາຍ! ເຈົ້າສາມາດປັບແຕ່ງ %(bold_start)sຄຳຕອບແບບສຳເລັດຮູບ%(bold_end)s ໄດ້ໃນແອັບ ສົນທະນາ."

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Great! 👍%(new_line)sTo access special commands, %(bold_start)sstart your "
"sentence with%(bold_end)s %(command_start)s/%(command_end)s. Try getting "
"help."
msgstr ""
"ດີຫຼາຍ! 👍%(new_line)sເພື່ອເຂົ້າເຖິງຄຳສັ່ງພິເສດ, %(bold_start)sເລີ່ມຕົ້ນປະໂຫຍກຂອງເຈົ້າດ້ວຍ%"
"(bold_end)s %(command_start)s/%(command_end)s. ລອງຂໍຄວາມຊ່ວຍເຫຼືອເບິ່ງ."

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/res_users.py:0
msgid "Hello,"
msgstr "ສະບາຍດີ,"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "Hmmm..."
msgstr "ອືມມມ..."

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "I'm afraid I don't understand. Sorry!"
msgstr "ຂ້ອຍເກງວ່າຂ້ອຍຈະບໍ່ເຂົ້າໃຈ. ຂໍໂທດເດີ!"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"I'm not smart enough to answer your question.%(new_line)sTo follow my guide,"
" ask: %(command_start)sstart the tour%(command_end)s."
msgstr ""
"ຂ້ອຍຍັງບໍ່ເກັ່ງພໍທີ່ຈະຕອບຄຳຖາມຂອງເຈົ້າໄດ້.%(new_line)sເພື່ອເຮັດຕາມຄຳແນະນຳຂອງຂ້ອຍ, ໃຫ້ຖາມວ່າ: %"
"(command_start)sເລີ່ມຕົ້ນການທ່ຽວຊົມ%(command_end)s."

#. module: mail_bot
#: model:ir.model.fields,field_description:mail_bot.field_discuss_channel__id
#: model:ir.model.fields,field_description:mail_bot.field_mail_bot__id
#: model:ir.model.fields,field_description:mail_bot.field_res_users__id
msgid "ID"
msgstr "ID"

#. module: mail_bot
#: model:ir.model.fields.selection,name:mail_bot.selection__res_users__odoobot_state__idle
msgid "Idle"
msgstr "ຫວ່າງ"

#. module: mail_bot
#: model:ir.model,name:mail_bot.model_mail_bot
msgid "Mail Bot"
msgstr "ບັອດອີເມລ"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Not exactly. To continue the tour, send an emoji: "
"%(bold_start)stype%(bold_end)s%(command_start)s :)%(command_end)s and press "
"enter."
msgstr ""
"ຍັງບໍ່ທັນຖືກປານໃດ. ເພື່ອດຳເນີນການທ່ຽວຊົມຕໍ່, ສົ່ງ ອີໂມຈິ: %(bold_start)sພິມ%(bold_end)s%"
"(command_start)s :)%(command_end)s ແລ້ວກົດ enter."

#. module: mail_bot
#: model:ir.model.fields.selection,name:mail_bot.selection__res_users__odoobot_state__not_initialized
msgid "Not initialized"
msgstr "ຍັງບໍ່ທັນໄດ້ເລີ່ມລະບົບ"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Not sure what you are doing. Please, type %(command_start)s/%(command_end)s "
"and wait for the propositions. Select %(command_start)shelp%(command_end)s "
"and press enter."
msgstr ""
"ບໍ່ແນ່ໃຈວ່າເຈົ້າກຳລັງເຮັດຫຍັງຢູ່. ກະລຸນາພິມ %(command_start)s/%(command_end)s ແລະ ລໍຖ້າຕົວເລືອ"
"ກທີ່ສະເໜີຂຶ້ນມາ. ເລືອກ %(command_start)shelp%(command_end)s ແລ້ວກົດ enter."

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Not sure what you are doing. Please, type %(command_start)s:%(command_end)s "
"and wait for the propositions. Select one of them and press enter."
msgstr ""
"ບໍ່ແນ່ໃຈວ່າເຈົ້າກຳລັງເຮັດຫຍັງຢູ່. ກະລຸນາພິມ %(command_start)s:%(command_end)s ແລະ ລໍຖ້າຕົວເລືອ"
"ກທີ່ສະເໜີຂຶ້ນມາ. ເລືອກອັນໃດອັນໜຶ່ງ ແລ້ວກົດ enter."

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/res_users.py:0
msgid ""
"Odoo's chat helps employees collaborate efficiently. I'm here to help you "
"discover its features."
msgstr ""
"ລະບົບສົນທະນາຂອງ Odoo ຊ່ວຍໃຫ້ພະນັກງານຮ່ວມມືກັນໄດ້ຢ່າງມີປະສິດທິພາບ. ຂ້ອຍຢູ່ທີ່ນີ້ເພື່ອຊ່ວຍໃຫ້ເຈົ້າຄົ້ນພົບຄຸນສົ"
"ມບັດຕ່າງໆຂອງມັນ."

#. module: mail_bot
#: model:ir.model.fields,field_description:mail_bot.field_res_users__odoobot_state
msgid "OdooBot Status"
msgstr "ສະຖານະ OdooBot"

#. module: mail_bot
#: model:ir.model.fields,field_description:mail_bot.field_res_users__odoobot_failed
msgid "Odoobot Failed"
msgstr "OdooBot ຜິດພາດ"

#. module: mail_bot
#: model:ir.model.fields.selection,name:mail_bot.selection__res_users__odoobot_state__onboarding_attachement
msgid "Onboarding attachment"
msgstr "ການແນະນຳການຄັດຕິດໄຟລ໌"

#. module: mail_bot
#: model:ir.model.fields.selection,name:mail_bot.selection__res_users__odoobot_state__onboarding_canned
msgid "Onboarding canned"
msgstr "ການແນະນຳຄຳຕອບແບບສຳເລັດຮູບ"

#. module: mail_bot
#: model:ir.model.fields.selection,name:mail_bot.selection__res_users__odoobot_state__onboarding_command
msgid "Onboarding command"
msgstr "ການແນະນຳຄຳສັ່ງ"

#. module: mail_bot
#: model:ir.model.fields.selection,name:mail_bot.selection__res_users__odoobot_state__onboarding_emoji
msgid "Onboarding emoji"
msgstr "ການແນະນຳອີໂມຈິ"

#. module: mail_bot
#: model:ir.model.fields.selection,name:mail_bot.selection__res_users__odoobot_state__onboarding_ping
msgid "Onboarding ping"
msgstr "ການແນະນຳການແທັກ (@)"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Sorry I'm sleepy. Or not! Maybe I'm just trying to hide my unawareness of "
"human language...%(new_line)sI can show you features if you write: "
"%(command_start)sstart the tour%(command_end)s."
msgstr ""
"ຂໍໂທດເດີ ຂ້ອຍເຫງົານອນແລ້ວ. ຫຼື ບໍ່ແມ່ນ! ບາງທີຂ້ອຍອາດຈະພະຍາຍາມປົກປິດຄວາມບໍ່ເຂົ້າໃຈໃນພາສາມະນຸດຂອງຂ້"
"ອຍ...%(new_line)sຂ້ອຍສາມາດສະແດງຄຸນສົມບັດຕ່າງໆໃຫ້ເຈົ້າເບິ່ງໄດ້ ຖ້າເຈົ້າຂຽນວ່າ: %"
"(command_start)sເລີ່ມຕົ້ນການທ່ຽວຊົມ%(command_end)s."

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Sorry, I am not listening. To get someone's attention, %(bold_start)sping "
"him%(bold_end)s. Write %(command_start)s@OdooBot%(command_end)s and select "
"me."
msgstr ""
"ຂໍໂທດເດີ, ຂ້ອຍບໍ່ໄດ້ຟັງຢູ່. ເພື່ອດຶງດູດຄວາມສົນໃຈຈາກໃຜບາງຄົນ, ໃຫ້ %(bold_start)sແທັກເຂົາເຈົ້າ%"
"(bold_end)s. ຂຽນ %(command_start)s@OdooBot%(command_end)s ແລ້ວເລືອກຂ້ອຍ."

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "Thanks"
msgstr "ຂອບໃຈ"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "Thanks for your feedback. Goodbye!"
msgstr "ຂອບໃຈສຳລັບຄຳຄິດເຫັນ. ລາກ່ອນ!"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "That's not nice! I'm a bot but I have feelings... 💔"
msgstr "ແບບນັ້ນບໍ່ດີເລີຍ! ຂ້ອຍເປັນພຽງບັອດ ແຕ່ຂ້ອຍກໍມີຄວາມຮູ້ສຶກເດີ... 💔"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"That’s the end of this overview. You can %(bold_start)sclose this "
"conversation%(bold_end)s or type %(command_start)sstart the "
"tour%(command_end)s to see it again. Enjoy exploring Odoo!"
msgstr ""
"ນັ້ນຄືການສິ້ນສຸດຂອງການແນະນຳທົ່ວໄປນີ້. ເຈົ້າສາມາດ %(bold_start)sປິດການສົນທະນານີ້%(bold_end)s "
"ຫຼື ພິມ %(command_start)sເລີ່ມຕົ້ນການທ່ຽວຊົມ%(command_end)s ເພື່ອເບິ່ງມັນອີກຄັ້ງ. ຂໍໃຫ້ມີຄວາມສຸກກັບ"
"ການຄົ້ນຫາ Odoo!"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "This is a temporary canned response to see how canned responses work."
msgstr ""
"ນີ້ແມ່ນຄຳຕອບແບບສຳເລັດຮູບຊົ່ວຄາວ ເພື່ອເບິ່ງວ່າຄຳຕອບແບບສຳເລັດຮູບເຮັດວຽກແນວໃດ."

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"To %(bold_start)ssend an attachment%(bold_end)s, click on the "
"%(paperclip_icon)s icon and select a file."
msgstr ""
"ເພື່ອ %(bold_start)sສົ່ງໄຟລ໌ຄັດຕິດ%(bold_end)s, ໃຫ້ຄລິກທີ່ໄອຄອນ %(paperclip_icon)s ແລ້ວເລື"
"ອກໄຟລ໌."

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "To start, try to send me an emoji :)"
msgstr "ເພື່ອເລີ່ມຕົ້ນ, ລອງສົ່ງ ອີໂມຈິ ໃຫ້ຂ້ອຍເບິ່ງ :)"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/res_users.py:0
msgid "Try to send me an emoji"
msgstr "ລອງສົ່ງ ອີໂມຈິ ໃຫ້ຂ້ອຍເບິ່ງ"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Unfortunately, I'm just a bot 😞 I don't understand! If you need help "
"discovering our product, please check %(document_link_start)sour "
"documentation%(document_link_end)s or %(slides_link_start)sour "
"videos%(slides_link_end)s."
msgstr ""
"ໜ້າເສຍດາຍ, ຂ້ອຍເປັນພຽງບັອດ 😞 ຂ້ອຍບໍ່ເຂົ້າໃຈ! ຖ້າເຈົ້າຕ້ອງການຄວາມຊ່ວຍເຫຼືອໃນການຄົ້ນຫາຜະລິດຕະພັນຂອ"
"ງພວກເຮົາ, ກະລຸນາກວດເບິ່ງ %(document_link_start)sເອກະສານຂອງພວກເຮົາ%"
"(document_link_end)s ຫຼື %(slides_link_start)sວິດີໂອຂອງພວກເຮົາ%(slides_link_end)s."

#. module: mail_bot
#: model:ir.model,name:mail_bot.model_res_users
msgid "User"
msgstr "ຜູ້ໃຊ້"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Wonderful! 😇%(new_line)sTry typing %(command_start)s::%(command_end)s to use"
" canned responses. I've created a temporary one for you."
msgstr ""
"ວິເສດຫຼາຍ! 😇%(new_line)sລອງພິມ %(command_start)s::%(command_end)s ເພື່ອໃຊ້ຄຳຕອບແບບ"
"ສຳເລັດຮູບ. ຂ້ອຍໄດ້ສ້າງອັນຊົ່ວຄາວໄວ້ໃຫ້ເຈົ້າແລ້ວ."

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Wow you are a natural!%(new_line)sPing someone with @username to grab their "
"attention. %(bold_start)sTry to ping me using%(bold_end)s "
"%(command_start)s@OdooBot%(command_end)s in a sentence."
msgstr ""
"ໂອ້ໂຫ ເຈົ້າເກັ່ງຫຼາຍ!%(new_line)sແທັກໃຜບາງຄົນດ້ວຍ @ຊື່ຜູ້ໃຊ້ ເພື່ອດຶງດູດຄວາມສົນໃຈຈາກເຂົາເຈົ້າ. %"
"(bold_start)sລອງແທັກຂ້ອຍໂດຍໃຊ້%(bold_end)s %(command_start)s@OdooBot%"
"(command_end)s ໃນປະໂຫຍກເບິ່ງ."

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Yep, I am here! 🎉 %(new_line)sNow, try %(bold_start)ssending an "
