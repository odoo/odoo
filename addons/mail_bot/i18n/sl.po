#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "help"
msgstr "pomoč"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "i love you"
msgstr "ljubim te"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "love"
msgstr "ljubezen"

