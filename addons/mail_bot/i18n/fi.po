msgid "help"
msgstr "ohje"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "i love you"
msgstr "rakastan sinua"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "love"
msgstr "rakas"

