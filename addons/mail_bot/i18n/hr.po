#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Aaaaaw that's really cute but, you know, bots don't work that way. You're "
"too human for me! Let's keep it professional ❤️"
msgstr ""
"Oh, to je stvarno slatko, ali znate, botovi ne rade tako. Vi ste previše "
"ljudsko biće za mene! Ostanimo profesionalni ❤️"

#. module: mail_bot
#: model:ir.model.fields.selection,name:mail_bot.selection__res_users__odoobot_state__disabled
msgid "Disabled"
msgstr "Onemogućen"

#. module: mail_bot
#: model:ir.model,name:mail_bot.model_discuss_channel
msgid "Discussion Channel"
msgstr "Kanal rasprava"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Good, you can customize canned responses in the Discuss application.%"
"(new_line)s%(new_line)s%(bold_start)sIt's the end of this overview%"
"(bold_end)s, you can now %(bold_start)sclose this conversation%(bold_end)s "
"or start the tour again with typing %(command_start)sstart the tour%"
"(command_end)s. Enjoy discovering Odoo!"
msgstr ""

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Great! 👍%(new_line)sTo access special commands, %(bold_start)sstart your "
"sentence with%(bold_end)s %(command_start)s/%(command_end)s. Try getting "
"help."
msgstr ""
"Odlično! 👍%(new_line)sZa pristup posebnim naredbama, %(bold_start)spočnite "
"svoju rečenicu s%(bold_end)s %(command_start)s/%(command_end)s. Pokušajte "
"dobiti pomoć."

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/res_users.py:0
msgid "Hello,"
msgstr "Pozdrav,"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "Hmmm..."
msgstr "Hmmm..."

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "I'm afraid I don't understand. Sorry!"
msgstr "Bojim se da ne razumijem. Žao mi je!"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"I'm not smart enough to answer your question.%(new_line)sTo follow my guide, "
"ask: %(command_start)sstart the tour%(command_end)s."
msgstr ""
"Nisam dovoljno pametan da odgovorim na vaše pitanje.%(new_line)sZa praćenje "
"mog vodiča pitajte: %(command_start)sstart the tour%(command_end)s."

#. module: mail_bot
#: model:ir.model.fields.selection,name:mail_bot.selection__res_users__odoobot_state__idle
msgid "Idle"
msgstr "Prazan"

#. module: mail_bot
#: model:ir.model,name:mail_bot.model_mail_bot
msgid "Mail Bot"
msgstr "Mali robotić"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Not exactly. To continue the tour, send an emoji: %(bold_start)stype%"
"(bold_end)s%(command_start)s :)%(command_end)s and press enter."
msgstr ""
"Ne baš. Za nastavak obilaska, pošaljite emoji: %(bold_start)supišite%"
"(bold_end)s%(command_start)s :)%(command_end)s i pritisnite enter."

#. module: mail_bot
#: model:ir.model.fields.selection,name:mail_bot.selection__res_users__odoobot_state__not_initialized
msgid "Not initialized"
msgstr "Nije inicijaliziran"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Not sure what you are doing. Please, type %(command_start)s/%(command_end)s "
"and wait for the propositions. Select %(command_start)shelp%(command_end)s "
"and press enter."
msgstr ""
"Nisam siguran što radite. Upišite %(command_start)s/%(command_end)s i "
"pričekajte prijedloge. Odaberite %(command_start)shelp%(command_end)s i "
"pritisnite enter."

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Not sure what you are doing. Please, type %(command_start)s:%(command_end)s "
"and wait for the propositions. Select one of them and press enter."
msgstr ""
"Nisam siguran što radite. Upišite %(command_start)s:%(command_end)s i "
"pričekajte prijedloge. Odaberite jedan i pritisnite enter."

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/res_users.py:0
msgid ""
"Odoo's chat helps employees collaborate efficiently. I'm here to help you "
"discover its features."
msgstr ""
"Odoo chat pomaže zaposlenicima da učinkovito surađuju. Ovdje sam da vam "
"pomognem otkriti njegove značajke."

#. module: mail_bot
#: model:ir.model.fields,field_description:mail_bot.field_res_users__odoobot_state
msgid "OdooBot Status"
msgstr "Status OdooBota"

#. module: mail_bot
#: model:ir.model.fields,field_description:mail_bot.field_res_users__odoobot_failed
msgid "Odoobot Failed"
msgstr "Odoobot je neuspješan"

#. module: mail_bot
#: model:ir.model.fields.selection,name:mail_bot.selection__res_users__odoobot_state__onboarding_attachement
msgid "Onboarding attachment"
msgstr "Onboarding privitak"

#. module: mail_bot
#: model:ir.model.fields.selection,name:mail_bot.selection__res_users__odoobot_state__onboarding_canned
msgid "Onboarding canned"
msgstr "Pripremljen predložak za Onboarding"

#. module: mail_bot
#: model:ir.model.fields.selection,name:mail_bot.selection__res_users__odoobot_state__onboarding_command
msgid "Onboarding command"
msgstr "Onboarding naredba"

#. module: mail_bot
#: model:ir.model.fields.selection,name:mail_bot.selection__res_users__odoobot_state__onboarding_emoji
msgid "Onboarding emoji"
msgstr "Uvodni korak: emoji"

#. module: mail_bot
#: model:ir.model.fields.selection,name:mail_bot.selection__res_users__odoobot_state__onboarding_ping
msgid "Onboarding ping"
msgstr "Uvodni korak: ping"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Sorry I'm sleepy. Or not! Maybe I'm just trying to hide my unawareness of "
"human language...%(new_line)sI can show you features if you write: %"
"(command_start)sstart the tour%(command_end)s."
msgstr ""
"Oprostite, pospan sam. Ili ne! Možda samo pokušavam sakriti svoje neznanje "
"ljudskog jezika...%(new_line)sMogu vam pokazati značajke ako napišete: %"
"(command_start)sstart the tour%(command_end)s."

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Sorry, I am not listening. To get someone's attention, %(bold_start)sping "
"him%(bold_end)s. Write %(command_start)s@OdooBot%(command_end)s and select "
"me."
msgstr ""
"Oprostite, ne slušam. Da biste privukli nečiju pažnju, %(bold_start)"
"spingajte ga%(bold_end)s. Napišite %(command_start)s@OdooBot%(command_end)s "
"i odaberite me."

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "Thanks"
msgstr "Hvala"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "Thanks for your feedback. Goodbye!"
msgstr "Hvala na povratnoj informaciji. Doviđenja!"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "That's not nice! I'm a bot but I have feelings... 💔"
msgstr "To nije lijepo! Ja sam bot, ali imam osjećaje... 💔"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "This is a temporary canned response to see how canned responses work."
msgstr ""
"Ovo je privremeni unaprijed pripremljeni odgovor kako bismo vidjeli kako "
"unaprijed pripremljeni odgovori funkcioniraju."

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"To %(bold_start)ssend an attachment%(bold_end)s, click on the %"
"(paperclip_icon)s icon and select a file."
msgstr ""
"Za %(bold_start)sslanje privitka%(bold_end)s, kliknite na ikonu %"
"(paperclip_icon)s i odaberite datoteku."

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "To start, try to send me an emoji :)"
msgstr "Za početak, pokušajte mi poslati emoji :)"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/res_users.py:0
msgid "Try to send me an emoji"
msgstr "Pokušajte mi poslati emoji"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Unfortunately, I'm just a bot 😞 I don't understand! If you need help "
"discovering our product, please check %(document_link_start)sour "
"documentation%(document_link_end)s or %(slides_link_start)sour videos%"
"(slides_link_end)s."
msgstr ""
"Nažalost, ja sam samo bot 😞 ne razumijem! Ako trebate pomoć u istraživanju "
"našeg proizvoda, pogledajte %(document_link_start)snašu dokumentaciju%"
"(document_link_end)s ili %(slides_link_start)snaše videozapise%"
"(slides_link_end)s."

#. module: mail_bot
#: model:ir.model,name:mail_bot.model_res_users
msgid "User"
msgstr "Korisnik"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Wonderful! 😇%(new_line)sTry typing %(command_start)s:%(command_end)s to use "
"canned responses. I've created a temporary one for you."
msgstr ""

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Wow you are a natural!%(new_line)sPing someone with @username to grab their "
"attention. %(bold_start)sTry to ping me using%(bold_end)s %"
"(command_start)s@OdooBot%(command_end)s in a sentence."
msgstr ""
"Vau, imate prirodni dar!%(new_line)sPingajte nekoga s @korisničkoime da "
"privučete pažnju. %(bold_start)sPokušajte me pingati koristeći%(bold_end)s %"
"(command_start)s@OdooBot%(command_end)s u rečenici."

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid ""
"Yep, I am here! 🎉 %(new_line)sNow, try %(bold_start)ssending an attachment%"
"(bold_end)s, like a picture of your cute dog..."
msgstr ""
"Da, ovdje sam! 🎉 %(new_line)sSada, pokušajte %(bold_start)sposlati privitak%"
"(bold_end)s, poput slike vašeg slatkog psa..."

