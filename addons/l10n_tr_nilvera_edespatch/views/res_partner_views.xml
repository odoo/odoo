<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_inherit_l10n_tr_nilvera_edespatch" model="ir.ui.view">
        <field name="name">res.partner.view.form.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='zip']" position="after">
                <field name="company_country_code" invisible="1"/>
                <field name="l10n_tr_nilvera_edespatch_customs_zip" placeholder="Customs ZIP" invisible="company_country_code != 'TR' or country_code == 'TR'"/>
            </xpath>
        </field>
    </record>

</odoo>
