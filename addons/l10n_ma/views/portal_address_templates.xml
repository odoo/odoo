<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="address_form_fields" inherit_id="portal.address_form_fields">
        <div id="div_vat" position="after">
            <t t-set="current_ice" t-value="current_partner._get_additional_identifier('MA_ICE') if current_partner else ''"/>
            <t t-set="ice_readonly" t-value="current_ice and not current_partner.can_edit_vat()"/>
            <div id="div_ma_ice" class="col-xl-6 mb-2"
                t-att-class="(not country or country.code != 'MA') and 'display:none;'">
                <label class="col-form-label label-optional" for="ma_ice">
                ICE
                </label>
                <input
                    type="text"
                    name="ma_ice"
                    t-att-value="current_ice"
                    t-att-readonly="'1' if ice_readonly else None"
                    class="form-control"
                />
                <div t-if="ice_readonly" class="col-12 d-none d-lg-block mb-1">
                    <small class="form-text text-muted">
                        Modifying the ICE number is not allowed once documents have
                        been issued for your account. Please contact us directly if that's what you intend to do.
                    </small>
                </div>
            </div>
        </div>
    </template>
</odoo>
