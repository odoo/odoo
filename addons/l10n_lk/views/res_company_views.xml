<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_l10n_lk_vat_registered" model="ir.ui.view">
        <field name="name">res.company.form.l10n_lk_vat_registered</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <field name="l10n_lk_vat_registered" invisible="country_code != 'LK' and not vat"/>
            </xpath>
        </field>
    </record>
</odoo>
