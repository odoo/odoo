<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="html_builder.FontAwesomeOption">
    <BuilderRow id="'color_opt'" label.translate="Color">
        <BuilderColorPicker styleAction="'color'" enabledTabs="['solid', 'custom', 'gradient']"/>
    </BuilderRow>

    <BuilderRow id="'background_color_opt'" label.translate="Background Color">
        <BuilderColorPicker styleAction="'background-color'" enabledTabs="['solid', 'custom', 'gradient']"/>
    </BuilderRow>

    <BuilderRow id="'font_size_opt'" label.translate="Size">
        <BuilderButtonGroup action="'classAction'">
            <BuilderButton actionParam="''" title.translate="Size 1x">1x</BuilderButton>
            <BuilderButton actionParam="'fa-2x'" title.translate="Size 2x">2x</BuilderButton>
            <BuilderButton actionParam="'fa-3x'" title.translate="Size 3x">3x</BuilderButton>
            <BuilderButton actionParam="'fa-4x'" title.translate="Size 4x">4x</BuilderButton>
            <BuilderButton actionParam="'fa-5x'" title.translate="Size 5x">5x</BuilderButton>
        </BuilderButtonGroup>
    </BuilderRow>
</t>

</templates>
