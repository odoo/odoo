<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="html_builder.VerticalJustifyOption">
    <!--  Box Vertical Alignment -->
    <BuilderRow label.translate="Vert. Alignment" tooltip.translate="Vertical Alignment">
        <BuilderButtonGroup>
            <BuilderButton title.translate="Align Top" classAction="'justify-content-start'"
                    icon="'vertical_align_top'"/>
            <BuilderButton title.translate="Align Middle" classAction="'justify-content-center'"
                    icon="'vertical_align_center'"/>
            <BuilderButton title.translate="Align Bottom" classAction="'justify-content-end'"
                    icon="'vertical_align_bottom'"/>
        </BuilderButtonGroup>
    </BuilderRow>
</t>
</templates>
