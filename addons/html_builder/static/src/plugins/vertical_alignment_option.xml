<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="html_builder.VerticalAlignmentOption">
    <t t-if="!this.isActiveItem('grid_mode')">
        <!-- TODO add title tooltip row Vertical Alignment-->
        <BuilderRow label.translate="Vert. Alignment" tooltip.translate="Vertical Alignment" level="this.props.level">
            <BuilderButtonGroup action="'setVerticalAlignment'">
                <BuilderButton actionParam="'align-items-start'" title.translate="Align Top" icon="'vertical_align_top'"/>
                <BuilderButton actionParam="'align-items-center'" title.translate="Align Middle" icon="'vertical_align_center'"/>
                <BuilderButton actionParam="'align-items-end'" title.translate="Align Bottom" icon="'vertical_align_bottom'"/>
                <BuilderButton t-if="this.props.justify" actionParam="'align-items-stretch'" title.translate="Stretch to Equal Height" icon="'expand'"/>
            </BuilderButtonGroup>
        </BuilderRow>
    </t>
</t>

</templates>
