<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="html_builder.ReplaceMediaOption">
    <BuilderRow label.translate="Media">
        <BuilderButton
            action="'replaceMedia'"
            title="this.state.tooltipName"
            className="'flex-grow-1'"
            type="'success'"
            label.translate="Replace" />
        <BuilderButton icon="'fa-link'"
            t-if="this.state.canSetLink"
            id="'media_link_opt'"
            action="'setLink'"
            title.translate="Redirect the user elsewhere when he clicks on the media."/>
    </BuilderRow>
    <t t-if="this.isActiveItem('media_link_opt')">
        <BuilderRow label.translate="Your URL" level="1">
            <BuilderUrlPicker title.translate="Your URL"
                action="'setUrl'"
                placeholder.translate="e.g. /page or URL"/>
        </BuilderRow>
        <BuilderRow label.translate="Open in New Window" level="1" t-if="this.state.hasHref">
            <BuilderCheckbox action="'setNewWindow'"/>
        </BuilderRow>
    </t>
</t>

</templates>
