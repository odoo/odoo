<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="html_builder.BuilderSelect.search">
    <div class="o_builder_select_searchbox position-sticky start-0 top-0">
        <input type="text"
            class="o_input dropdown-item"
            placeholder="Search..."
            t-on-input="this.debouncedOnSearchInput"
            t-custom-ref="inputRef"
            autocorrect="off"
            spellcheck="false"/>
    </div>
</t>

<t t-name="html_builder.BuilderSelect">
    <BuilderComponent>
        <!-- Render the SelectItem(s) into an invisible node to ensure the label of the
        button is being set. -->
        <div t-custom-ref="root" class="o-hb-select-wrapper">
            <div inert="" class="h-0 w-0 overflow-hidden" t-att-class="this.props.className" t-custom-ref="content"><WithIgnoreItem><t t-call-slot="default" /></WithIgnoreItem></div>
            <Dropdown state="this.dropdown" menuClass="this.props.dropdownClass + (this.props.searchable ? ' o-hb-search-select' : '')" onStateChanged.bind="this.onStateChanged">
                <button 
                    class="o-hb-select-toggle o-hb-btn btn btn-secondary text-start o-dropdown-caret"
                    t-custom-ref="button"
                    t-att-id="this.props.id"
                    t-att-disabled="this.props.disabled ? 'disabled' : undefined"
                    t-att-aria-disabled="this.props.disabled ? 'true' : undefined"
                    >
                    <t t-call-slot="fixedButton"/>
                </button>
                <t t-set-slot="content">
                    <t t-if="this.props.searchable" t-call="html_builder.BuilderSelect.search"/>
                    <div t-att-class="this.props.dropdownContainerClass" data-prevent-closing-overlay="true">
                        <t t-call-slot="default" />
                        <p t-if="this.props.searchable" class="text-muted fst-italic mx-4 my-1 o_builder_select_no_result">No results</p>
                    </div>
                </t>
            </Dropdown>
        </div>
    </BuilderComponent>
</t>

</templates>
