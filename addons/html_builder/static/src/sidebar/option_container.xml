<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="html_builder.OptionsContainer">
    <div class="options-container" t-ref="root" t-att-data-container-title="title" t-on-mouseenter="onMouseEnter" t-on-mouseleave="onMouseLeave">
        <div class="we-bg-darker p-1">
                <!-- TODO change the structure so the clickable surface is bigger -->
            <span t-out="title" role="button" t-on-click="selectElement"/>
                <!-- TODO CSS + remove temporary BS classes -->
            <div class="float-end">
                    <!-- TODO get the buttons from the plugins, so it works with other modules too -->
                <t t-if="props.canHaveAnchor">
                    <button class="fa fa-fw fa-link oe_snippet_anchor o_we_link btn btn-outline-info border-0 px-0 me-1"
                            title="Create and copy a link targeting this block or edit it"
                            aria-label="Create and copy a link targeting this block or edit it"
                            t-on-click="createOrEditAnchorLink"/>
                </t>
                <t t-if="isSavable">
                    <button class="fa fa-fw fa-save oe_snippet_save o_we_link o_we_hover_warning btn btn-outline-warning border-0 px-0 me-1"
                            title="Save this block to use it elsewhere"
                            t-on-click="saveSnippet"/>
                </t>
                <t t-if="props.isRemovable">
                    <button class="fa fa-fw fa-clone oe_snippet_clone o_we_link o_we_hover_success btn btn-outline-success border-0 px-0 me-1"
                            title="Duplicate this block"
                            aria-label="Duplicate this block"
                            t-on-click="cloneElement"/>
                    <button class="fa fa-fw fa-trash oe_snippet_remove o_we_link o_we_hover_danger btn btn-outline-danger border-0 px-0 me-1 "
                            title="Remove this block"
                            aria-label="Remove this block"
                            t-on-click="removeElement"/>
                </t>
            </div>
        </div>
        <div class="we-bg-options-container" t-ref="content">
            <t t-foreach="props.options" t-as="option" t-key="option.id">
                <BuilderContext applyTo="option.applyTo">
                    <t t-if="option.OptionComponent" t-component="option.OptionComponent" t-props="option.props || {}"></t>
                    <t t-else="" t-call="{{option.template}}"/>
                </BuilderContext>
            </t>
        </div>
    </div>
</t>

</templates>
