<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="base.partner_demo_company_ge" model="res.partner" forcecreate="1">
        <field name="name">GE Company</field>
        <field name="vat">GE123456789</field>
        <field name="company_registry">12345678</field>
        <field name="street">1 Shota Rustaveli Ave</field>
        <field name="city">Tbilisi</field>
        <field name="country_id" ref="base.ge"/>
        <field name="zip">0108</field>
        <field name="phone">+995 599 12 34 56</field>
        <field name="email">info@company.geexample.com</field>
        <field name="website">https://www.geexample.com</field>
    </record>

    <record id="base.demo_company_ge" model="res.company" forcecreate="1">
        <field name="name">GE Company</field>
        <field name="partner_id" ref="base.partner_demo_company_ge"/>
    </record>

    <function model="res.company" name="_onchange_country_id">
        <value eval="[ref('base.demo_company_ge')]"/>
    </function>

    <function model="res.users" name="write">
        <value eval="[ref('base.user_root'), ref('base.user_admin'), ref('base.user_demo')]"/>
        <value eval="{'company_ids': [(Command.link(ref('base.demo_company_ge')))]}"/>
    </function>

    <function model="account.chart.template" name="try_loading">
        <value eval="[]"/>
        <value>ge</value>
        <value model="res.company" eval="obj().env.ref('base.demo_company_ge')"/>
        <value name="install_demo" eval="True"/>
    </function>
</odoo>
