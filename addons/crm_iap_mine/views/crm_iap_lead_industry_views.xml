<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="crm_iap_lead_industry_view_search" model="ir.ui.view">
        <field name="name">crm.iap.lead.industry.view.search</field>
        <field name="model">crm.iap.lead.industry</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="division_id"/>
                <filter string="Sector" name="division_id" context="{'group_by': 'division_id'}"/>
            </search>
        </field>
    </record>

    <record id="crm_iap_lead_industry_view_tree" model="ir.ui.view">
        <field name="name">crm.iap.lead.industry.view.tree</field>
        <field name="model">crm.iap.lead.industry</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="division_id"/>
            </list>
        </field>
    </record>
</odoo>
