#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.400
msgid "400: Bad Request"
msgstr "400: ການຮ້ອງຂໍທີ່ບໍ່ຖືກຕ້ອງ"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.403
msgid "403: Forbidden"
msgstr "403: ຖືກຈຳກັດສິດເຂົ້າເຖິງ"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.415
msgid "415: Unsupported Media Type"
msgstr "415: ປະເພດສື່ທີ່ບໍ່ຮອງຮັບ"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.404
msgid ""
"<b>Don't panic.</b> If you think it's our mistake, please send us a message "
"on"
msgstr ""
"<b>ຢ່າຕົກໃຈ.</b> ຖ້າທ່ານຄິດວ່າມັນແມ່ນຄວາມຜິດພາດຂອງພວກເຮົາ, ກະລຸນາສົ່ງຂໍ້ຄວາມຫາພວກເຮົາທີ່"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.error_message
msgid "<strong>Error message:</strong>"
msgstr "<strong>ຂໍ້ຄວາມຜິດພາດ:</strong>"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.500
msgid "Back"
msgstr "ກັບຄືນ"

#. module: http_routing
#: model:ir.model.fields,field_description:http_routing.field_ir_http__display_name
#: model:ir.model.fields,field_description:http_routing.field_ir_qweb__display_name
#: model:ir.model.fields,field_description:http_routing.field_res_lang__display_name
msgid "Display Name"
msgstr "ຊື່ທີ່ສະແດງ"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.http_error_debug
msgid "Error"
msgstr "ຂໍ້ຜິດພາດ"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.404
msgid "Error 404"
msgstr "ຂໍ້ຜິດພາດ 404"

#. module: http_routing
#: model:ir.model,name:http_routing.model_ir_http
msgid "HTTP Routing"
msgstr "ການກຳນົດເສັ້ນທາງ HTTP"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.404
#: model_terms:ir.ui.view,arch_db:http_routing.500
msgid "Home"
msgstr "ໜ້າຫຼັກ"

#. module: http_routing
#: model:ir.model.fields,field_description:http_routing.field_ir_http__id
#: model:ir.model.fields,field_description:http_routing.field_ir_qweb__id
#: model:ir.model.fields,field_description:http_routing.field_res_lang__id
msgid "ID"
msgstr "ໄອດີ"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.415
msgid ""
"It looks like the URL you are accessing doesn't support the format of the "
"request. Take a look at the error message below."
msgstr ""
"ເບິ່ງຄືວ່າ URL ທີ່ທ່ານກຳລັງເຂົ້າເຖິງນັ້ນ ບໍ່ຮອງຮັບຮູບແບບຂອງການຮ້ອງຂໍ. ກະລຸນາກວດເບິ່ງຂໍ້ຄວາມຜິດພາດຢູ່ດ້ານລຸ່"
"ມນີ້."

#. module: http_routing
#: model:ir.model,name:http_routing.model_res_lang
msgid "Languages"
msgstr "ພາສາ"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.404
msgid "Maybe you were looking for one of these <b>popular pages?</b>"
msgstr "ບາງທີທ່ານອາດຈະກຳລັງຊອກຫາໜຶ່ງໃນ <b>ໜ້າຍອດນິຍົມເຫຼົ່ານີ້ບໍ?</b>"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.422
#: model_terms:ir.ui.view,arch_db:http_routing.4xx
msgid "Oops! Something went wrong."
msgstr "ຂໍອະໄພ! ມີບາງຢ່າງຜິດພາດ."

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.http_error_debug
msgid "QWeb"
msgstr "QWeb"

#. module: http_routing
#: model:ir.model,name:http_routing.model_ir_qweb
msgid "Qweb"
msgstr "Qweb"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.422
#: model_terms:ir.ui.view,arch_db:http_routing.4xx
msgid "Take a look at the error message below."
msgstr "ກະລຸນາກວດເບິ່ງຂໍ້ຄວາມຜິດພາດຢູ່ດ້ານລຸ່ມນີ້."

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.http_error_debug
msgid "The error occurred while rendering the template"
msgstr "ເກີດຂໍ້ຜິດພາດຂຶ້ນໃນຂະນະທີ່ກຳລັງສະແດງຜົນແມ່ແບບ"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.403
msgid "The page you were looking for could not be authorized."
msgstr "ໜ້າທີ່ທ່ານກຳລັງຊອກຫາ ບໍ່ໄດ້ຮັບອະນຸຍາດໃຫ້ເຂົ້າເຖິງ."

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.400
msgid ""
"The server couldn't understand the request. Take a look at the error message"
" below."
msgstr ""
"ເຊີເວີບໍ່ສາມາດເຂົ້າໃຈການຮ້ອງຂໍໄດ້. ກະລຸນາກວດເບິ່ງຂໍ້ຄວາມຜິດພາດຢູ່ດ້ານລຸ່ມນີ້."

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.http_error_debug
msgid "Traceback"
msgstr "Traceback"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.404
msgid "We couldn't find the page you're looking for!"
msgstr "ພວກເຮົາບໍ່ພົບໜ້າທີ່ທ່ານກຳລັງຊອກຫາ!"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.http_error_debug
msgid "and evaluating the following expression:"
msgstr "ແລະ ກຳລັງປະເມີນນິພົດຕໍ່ໄປນີ້:"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.404
msgid "this page"
msgstr "ໜ້ານີ້"
