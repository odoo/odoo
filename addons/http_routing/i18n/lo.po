#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.403
msgid "403: Forbidden"
msgstr "403: ຖືກຈຳກັດສິດ"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.404
msgid ""
"<b>Don't panic.</b> If you think it's our mistake, please send us a message "
"on"
msgstr ""
"<b>ບໍ່ຕ້ອງຕົກໃຈ.</b> ຖ້າທ່ານຄິດວ່າມັນແມ່ນຄວາມຜິດພາດຂອງພວກເຮົາ, ກະລຸນາສົ່ງຂໍ້ຄວາມຫາພວກເຮົາທີ່"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.error_message
#: model_terms:ir.ui.view,arch_db:http_routing.http_error_debug
msgid "<strong>Error message:</strong>"
msgstr "<strong>ຂໍ້ຄວາມຜິດພາດ:</strong>"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.500
msgid "Back"
msgstr "ກັບຄືນ"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.http_error_debug
msgid "Error"
msgstr "ພິດພາດ"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.404
msgid "Error 404"
msgstr "ຂໍ້ຜິດພາດ 404"

#. module: http_routing
#: model:ir.model,name:http_routing.model_ir_http
msgid "HTTP Routing"
msgstr "ການກຳນົດເສັ້ນທາງ HTTP"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.404
#: model_terms:ir.ui.view,arch_db:http_routing.500
msgid "Home"
msgstr "ໜ້າຫຼັກ"

#. module: http_routing
#: model:ir.model,name:http_routing.model_res_lang
msgid "Languages"
msgstr "ພາສາ"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.404
msgid "Maybe you were looking for one of these <b>popular pages?</b>"
msgstr "ບາງທີທ່ານກຳລັງຊອກຫາໜຶ່ງໃນ <b>ໜ້າທີ່ເປັນທີ່ນິຍົມເຫຼົ່ານີ້ບໍ?</b>"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.400
msgid "Oops! Something went wrong."
msgstr "ອຸຍ! ມີບາງຢ່າງຜິດພາດ."

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.http_error_debug
msgid "QWeb"
msgstr "QWeb"

#. module: http_routing
#: model:ir.model,name:http_routing.model_ir_qweb
msgid "Qweb"
msgstr "Qweb"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.400
msgid "Take a look at the error message below."
msgstr "ເບິ່ງຂໍ້ຄວາມຜິດພາດຢູ່ດ້ານລຸ່ມນີ້."

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.http_error_debug
msgid "The error occurred while rendering the template"
msgstr "ເກີດຂໍ້ຜິດພາດໃນຂະນະທີ່ກຳລັງປະມວນຜົນຮູບແບບ (template)"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.403
msgid "The page you were looking for could not be authorized."
msgstr "ໜ້າທີ່ທ່ານກຳລັງຊອກຫາບໍ່ໄດ້ຮັບອະນຸຍາດໃຫ້ເຂົ້າເຖິງ."

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.http_error_debug
msgid "Traceback"
msgstr "ການໄລ່ລຽງຄືນ (Traceback)"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.404
msgid "We couldn't find the page you're looking for!"
msgstr "ພວກເຮົາບໍ່ພົບໜ້າທີ່ທ່ານກຳລັງຊອກຫາ!"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.http_error_debug
msgid "and evaluating the following expression:"
msgstr "ແລະ ກຳລັງປະເມີນສຳນວນ (expression) ຕໍ່ໄປນີ້:"

#. module: http_routing
#: model_terms:ir.ui.view,arch_db:http_routing.404
msgid "this page"
msgstr "ໜ້ານີ້"
