#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/app/screens/payment_screen/payment_lines/payment_lines.xml:0
msgid ""
"Consider emptying the cash machine, the following coins/bills are nearly "
"full:"
msgstr "ພິຈາລະນາຖ່າຍເງິນອອກຈາກເຄື່ອງ, ຫຼຽນ/ທະນະບັດ ຕໍ່ໄປນີ້ເກືອບເຕັມແລ້ວ:"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/utils/constants.js:0
msgid "Counting"
msgstr "ກຳລັງນັບ"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/utils/constants.js:0
msgid "Counting replenished cash"
msgstr "ກຳລັງນັບເງິນທີ່ເຕີມເຂົ້າ"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/backend/glory_admin_buttons/glory_admin_buttons.xml:0
msgid "Current cash machine status:"
msgstr "ສະຖານະເຄື່ອງຮັບ-ຈ່າຍເງິນສົດປັດຈຸບັນ:"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/utils/constants.js:0
msgid "Disconnected"
msgstr "ຕັດການເຊື່ອມຕໍ່"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/utils/constants.js:0
msgid "Dispensing"
msgstr "ກຳລັງຈ່າຍເງິນ"

#. module: pos_glory_cash
#: model:ir.model.fields,field_description:pos_glory_cash.field_pos_payment_method__display_name
msgid "Display Name"
msgstr "ຊື່ທີ່ສະແດງ"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/backend/glory_admin_buttons/glory_admin_buttons.xml:0
msgid "Download Logs"
msgstr "ດາວໂຫຼດບັນທຶກ (Logs)"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/utils/constants.js:0
msgid "Error"
msgstr "ຂໍ້ຜິດພາດ"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/utils/constants.js:0
msgid "Failed to authenticate"
msgstr "ການຢືນຢັນຕົວຕົນຫຼົ້ມເຫຼວ"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/app/payment_glory.js:0
msgid ""
"Failed to connect to Glory cash machine, please ensure it is switched on and "
"connected to the network."
msgstr ""
"ບໍ່ສາມາດເຊື່ອມຕໍ່ກັບເຄື່ອງຮັບ-ຈ່າຍເງິນສົດ Glory ໄດ້, ກະລຸນາກວດສອບວ່າເຄື່ອງໄດ້ເປີດຢູ່ ແລະ ເຊື່ອມຕໍ່ກັບເຄືອ"
"ຂ່າຍແລ້ວຫຼືບໍ່."

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/app/payment_glory.js:0
msgid ""
"Failed to login to Glory cash machine, please check the configured username "
"and password."
msgstr ""
"ເຂົ້າສູ່ລະບົບເຄື່ອງຮັບ-ຈ່າຍເງິນສົດ Glory ບໍ່ສຳເລັດ, ກະລຸນາກວດສອບ ຊື່ຜູ້ໃຊ້ ແລະ ລະຫັດຜ່ານ ທີ່ຕັ້ງຄ່າໄວ້."

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/app/payment_glory.js:0
msgid "GLORY TRANSACTION CANCELLED"
msgstr "ທຸລະກຳ GLORY ຖືກຍົກເລີກ"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/app/payment_glory.js:0
msgid "GLORY TRANSACTION SUCCESSFUL"
msgstr "ທຸລະກຳ GLORY ສຳເລັດແລ້ວ"

#. module: pos_glory_cash
#: model_terms:ir.ui.view,arch_db:pos_glory_cash.pos_payment_method_view_form_inherit_pos_glory_cash
msgid "Glory Settings"
msgstr "ການຕັ້ງຄ່າ Glory"

#. module: pos_glory_cash
#: model:ir.model.fields,field_description:pos_glory_cash.field_pos_payment_method__id
msgid "ID"
msgstr "ລະຫັດ (ID)"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/utils/constants.js:0
msgid "Idle"
msgstr "ວ່າງ/ລໍຖ້າ"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/utils/constants.js:0
msgid "Initializing"
msgstr "ກຳລັງເລີ່ມຕົ້ນລະບົບ"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/app/payment_glory.js:0
msgid "Only managers can withdraw cash from the cash machine."
msgstr "ສະເພາະຜູ້ຈັດການເທົ່ານັ້ນທີ່ສາມາດຖອນເງິນຈາກເຄື່ອງຮັບ-ຈ່າຍເງິນສົດໄດ້."

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/backend/glory_admin_buttons/glory_admin_buttons.xml:0
msgid "Open Admin Page"
msgstr "ເປີດໜ້າຜູ້ດູແລລະບົບ"

#. module: pos_glory_cash
#: model:ir.model,name:pos_glory_cash.model_pos_payment_method
msgid "Point of Sale Payment Methods"
msgstr "ວິທີການຊຳລະເງິນຂອງຈຸດຂາຍ (POS)"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/backend/glory_admin_buttons/glory_admin_buttons.xml:0
msgid "Reset Cash Machine"
msgstr "ຮີເຊັດ (Reset) ເຄື່ອງຮັບ-ຈ່າຍເງິນສົດ"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/backend/glory_admin_buttons/glory_admin_buttons.js:0
msgid "Reset complete"
msgstr "ຮີເຊັດສຳເລັດແລ້ວ"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/utils/constants.js:0
msgid "Resetting"
msgstr "ກຳລັງຮີເຊັດ"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/backend/glory_admin_buttons/glory_admin_buttons.js:0
msgid "Resetting cash machine..."
msgstr "ກຳລັງຮີເຊັດເຄື່ອງຮັບ-ຈ່າຍເງິນສົດ..."

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/utils/constants.js:0
msgid "Starting payment"
msgstr "ກຳລັງເລີ່ມຕົ້ນການຊຳລະ"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/app/payment_glory.js:0
msgid "The cash machine has an error, please consult its display for details."
msgstr ""
"ເຄື່ອງຮັບ-ຈ່າຍເງິນສົດມີຂໍ້ຜິດພາດ, ກະລຸນາກວດສອບໜ້າຈໍຂອງເຄື່ອງເພື່ອເບິ່ງລາຍລະອຽດ."

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/app/screens/payment_screen/payment_lines/payment_lines.xml:0
msgid "The cash machine has run out of the following coins/bills:"
msgstr "ເຄື່ອງຮັບ-ຈ່າຍເງິນສົດໝົດຫຼຽນ/ທະນະບັດ ຕໍ່ໄປນີ້:"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/app/payment_glory.js:0
msgid ""
"The cash machine is busy with another operation. Do you want to cancel it?"
msgstr "ເຄື່ອງຮັບ-ຈ່າຍເງິນສົດກຳລັງເຮັດວຽກອື່ນຢູ່. ທ່ານຕ້ອງການຍົກເລີກມັນບໍ່?"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/app/payment_glory.js:0
msgid ""
"The cash machine is currently in collection/replenishment mode, please "
"finish this process on the machine before making a payment."
msgstr ""
"ປັດຈຸບັນເຄື່ອງຮັບ-ຈ່າຍເງິນສົດຢູ່ໃນໂໝດເກັບເງິນ/ເຕີມເງິນ, ກະລຸນາເຮັດຂັ້ນຕອນນີ້ໃຫ້ສຳເລັດຢູ່ເຄື່ອງກ່ອນທີ່ຈະເຮັດກ"
"ານຊຳລະ."

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/app/payment_glory.js:0
msgid "The cash machine is disconnected."
msgstr "ເຄື່ອງຮັບ-ຈ່າຍເງິນສົດຖືກຕັດການເຊື່ອມຕໍ່."

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/app/payment_glory.js:0
msgid "The cash machine is in use by another POS."
msgstr "ເຄື່ອງຮັບ-ຈ່າຍເງິນສົດກຳລັງຖືກນຳໃຊ້ໂດຍ POS ອື່ນ."

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/app/screens/payment_screen/payment_lines/payment_lines.xml:0
msgid "The cash machine is running low on the following coins/bills:"
msgstr "ເຄື່ອງຮັບ-ຈ່າຍເງິນສົດໃກ້ຈະໝົດຫຼຽນ/ທະນະບັດ ຕໍ່ໄປນີ້:"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/app/screens/payment_screen/payment_lines/payment_lines.xml:0
msgid "The cash machine must be emptied, the following coins/bills are full:"
msgstr "ຕ້ອງໄດ້ຖ່າຍເງິນອອກຈາກເຄື່ອງ, ຫຼຽນ/ທະນະບັດ ຕໍ່ໄປນີ້ແມ່ນເຕັມແລ້ວ:"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/app/payment_glory.js:0
msgid ""
"The payment failed due to an unrecoverable error - see the cash machine "
"screen for details."
msgstr ""
"ການຊຳລະຫຼົ້ມເຫຼວຍ້ອນຂໍ້ຜິດພາດທີ່ບໍ່ສາມາດແກ້ໄຂໄດ້ - ເບິ່ງລາຍລະອຽດຢູ່ໜ້າຈໍເຄື່ອງຮັບ-ຈ່າຍເງິນສົດ."

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/app/payment_glory.js:0
msgid "The payment failed for an unknown reason: %s"
msgstr "ການຊຳລະຫຼົ້ມເຫຼວຍ້ອນສາເຫດທີ່ບໍ່ຮູ້ຈັກ: %s"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/app/payment_glory.js:0
msgid "There is insufficient cash in the machine to give change."
msgstr "ມີເງິນສົດໃນເຄື່ອງບໍ່ພຽງພໍທີ່ຈະທອນ."

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/app/payment_glory.js:0
msgid ""
"There is insufficient change in the cash machine to handle the payment. It "
"must be cancelled to continue."
msgstr ""
"ມີເງິນທອນໃນເຄື່ອງບໍ່ພຽງພໍທີ່ຈະດຳເນີນການຊຳລະ. ຕ້ອງຍົກເລີກເພື່ອດຳເນີນການຕໍ່."

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/app/payment_glory.js:0
msgid "Transaction ID: %s"
msgstr "ລະຫັດທຸລະກຳ: %s"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/utils/constants.js:0
msgid "Waiting for cancellation"
msgstr "ກຳລັງລໍຖ້າການຍົກເລີກ"

#. module: pos_glory_cash
#. odoo-javascript
#: code:addons/pos_glory_cash/static/src/utils/constants.js:0
msgid "Waiting for cash to be removed"
msgstr "ກຳລັງລໍຖ້າໃຫ້ເອົາເງິນສົດອອກ"

#. module: pos_glory_cash
#. odoo-javascript
