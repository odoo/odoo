<templates>
    <t t-name="test_convert_inline.DebugConvertInlineDialog">
        <Dialog title.translate="Debug Convert Inline" size="'fs'">
            <div>
                <button t-on-click="() => this.updateLayoutDimensions(!this.state.isMobile)">
                    Switch to <t t-out="this.state.isMobile ? 'Desktop' : 'Mobile'"/>
                </button>
                <input
                    type="range"
                    t-att-min="this.minRange"
                    t-att-max="this.maxRange"
                    t-att-step="this.stepRange"
                    t-att-value="this.state.displayWidth"
                    t-on-change="this.onRangeChange"
                    t-on-input="this.onRangeInput"
                    />
                <output t-out="this.state.displayWidth" class="ms-1"/>
            </div>
            <div class="d-flex">
                <div>
                    <iframe t-custom-ref="outputIframe" t-att-sandbox="this.isBrowserSafari() ? 'allow-same-origin allow-scripts' : 'allow-same-origin'"
                        t-attf-style="
                            display: block !important;
                            width: {{ this.state.width }}px !important;
                            height: {{ this.state.height }}px !important;
                        "/>
                </div>
                <div t-custom-ref="referenceIframe"/>
            </div>
        </Dialog>
    </t>
</templates>
