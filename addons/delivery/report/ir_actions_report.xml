<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_delivery_note" model="ir.actions.report">
        <field name="name">Delivery Note</field>
        <field name="model">delivery.note.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">delivery.report_delivery_note</field>
        <field name="report_file">delivery.report_delivery_note</field>
        <field name="print_report_name">
            "Delivery Note - %s - %s" % (object.partner_id.name or "", object.name)
        </field>
        <field name="binding_model_id" ref="model_delivery_note_wizard"/>
        <field name="binding_type">report</field>
    </record>

</odoo>
