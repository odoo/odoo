#: model:mail.template,body_html:delivery.mail_template_data_delivery_note
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"    <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"        Hello <t t-out=\"object.partner_id.name or ''\">Brandon Freeman</t>,"
"<br/><br/>\n"
"        We are glad to inform you that your order has been shipped.\n"
"        <t t-if=\"object.tracking_ref\">\n"
"            Your tracking reference is\n"
"            <strong>\n"
"                <t t-if=\"object.tracking_url\">\n"
"                    <a t-attf-href=\"{{ object.tracking_url }}\" "
"target=\"_blank\" t-out=\"object.tracking_ref\"/>.\n"
"                </t>\n"
"                <t t-else=\"\">\n"
"                    <t t-out=\"object.tracking_ref\"/>.\n"
"                </t>\n"
"            </strong>\n"
"        </t>\n"
"        <br/><br/>\n"
"        Please find your delivery order attached for more details.<br/><br/"
">\n"
"        Thank you,\n"
"        <t t-if=\"user.signature\">\n"
"            <br/>\n"
"            <div data-o-mail-quote=\"1\">--<br data-o-mail-quote=\"1\"/><t t-"
"out=\"user.signature or ''\">Mitchell Admin</t></div>\n"
"        </t>\n"
"    </p>\n"
"</div>\n"
"            "
