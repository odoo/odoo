<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="mail_template_data_delivery_note" model="mail.template">
            <field name="name">Shipping: Send by Email</field>
            <field name="model_id" ref="model_delivery_note_wizard"/>
            <field name="subject">{{ object.so_id.company_id.name }} Shipping Confirmation (Ref {{ object.so_id.name or 'n/a' }})</field>
            <field name="partner_to">{{ object.partner_id.email and object.partner_id.id or object.partner_id.parent_id.id }}</field>
            <field name="use_default_to" eval="False"/>
            <field name="description">Sent to the customers when orders are shipped.</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Hello <t t-out="object.partner_id.name or ''">Brandon Freeman</t>,<br/><br/>
        We are glad to inform you that your order has been shipped.
        <t t-if="object.tracking_ref">
            Your tracking reference is
            <strong>
                <t t-if="object.tracking_url">
                    <a t-attf-href="{{ object.tracking_url }}" target="_blank" t-out="object.tracking_ref"></a>.
                </t>
                <t t-else="">
                    <t t-out="object.tracking_ref"></t>.
                </t>
            </strong>
        </t>
        <br/><br/>
        Please find your delivery order attached for more details.<br/><br/>
        Thank you,
        <t t-if="user.signature">
            <br />
            <div>--<br/><t t-out="user.signature or ''">Mitchell Admin</t></div>
        </t>
    </p>
</div>
            </field>
            <field name="report_template_ids" eval="[(4, ref('delivery.action_report_delivery_note'))]"/>
            <field name="auto_delete" eval="False"/>
        </record>
    </data>
</odoo>
