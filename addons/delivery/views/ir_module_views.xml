<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="delivery_provider_list_view" model="ir.ui.view">
        <field name="name">delivery.provider.view.list.inherit</field>
        <field name="model">ir.module.module</field>
        <field name="inherit_id" ref="base.module_tree"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <field name="name" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </field>
            <field name="author" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </field>
            <field name="website" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </field>
            <field name="installed_version" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </field>
        </field>
    </record>

    <record id="delivery_provider_kanban_view" model="ir.ui.view">
        <field name="name">delivery.provider.view.kanban.inherit</field>
        <field name="model">ir.module.module</field>
        <field name="inherit_id" ref="base.module_view_kanban"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <button name="button_immediate_install" position="after">
                <button
                    invisible="state != 'installed'"
                    name="action_view_delivery_methods"
                    type="object"
                    class="btn btn-primary btn-sm"
                >
                    Delivery Methods
                </button>
            </button>
            <a id="module_info" position="replace"/>
        </field>
    </record>

</odoo>
