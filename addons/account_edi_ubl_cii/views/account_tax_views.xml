<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_invoice_form_inherit" model="ir.ui.view">
        <field name="name">account.tax.form.inherit</field>
        <field name="model">account.tax</field>
        <field name="inherit_id" ref="account.view_tax_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='advanced_options']" position="after">
                <page string="Electronic Invoicing" name="electronic_invoicing">
                    <group>
                        <field name="ubl_cii_type" widget="radio" string="Type" options="{'horizontal': True}"/>
                        <field name="ubl_cii_is_charge" invisible="ubl_cii_type == 'tax'"/>
                        <field name="ubl_cii_tax_category_code" invisible="ubl_cii_type == 'allowance_charge'"/>
                        <field name="ubl_cii_tax_exemption_reason_code"
                               invisible="ubl_cii_type == 'allowance_charge' or not ubl_cii_requires_exemption_reason"/>
                        <field name="ubl_cii_tax_exemption_reason"
                               invisible="ubl_cii_type == 'allowance_charge' or not ubl_cii_requires_exemption_reason"/>
                        <field name="ubl_cii_allowance_reason_code" invisible="ubl_cii_type == 'tax' or ubl_cii_is_charge"
                               required="ubl_cii_type == 'allowance_charge' and not ubl_cii_is_charge"/>
                        <field name="ubl_cii_charge_reason_code" invisible="ubl_cii_type == 'tax' or not ubl_cii_is_charge"
                               required="ubl_cii_type == 'allowance_charge' and ubl_cii_is_charge"/>
                        <label name="allowance_reason_label" for="ubl_cii_allowance_charge_reason" string="Allowance Reason"
                               invisible="ubl_cii_type == 'tax' or ubl_cii_is_charge"/>
                        <label name="charge_reason_label" for="ubl_cii_allowance_charge_reason" string="Charge Reason"
                               invisible="ubl_cii_type == 'tax' or not ubl_cii_is_charge"/>
                        <field name="ubl_cii_allowance_charge_reason" nolabel="1" invisible="ubl_cii_type == 'tax'"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
