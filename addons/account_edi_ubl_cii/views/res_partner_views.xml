<odoo>
    <record id="view_partner_property_form" model="ir.ui.view">
        <field name="name">res.partner.property.form.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="account.view_partner_property_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@id='invoice_send_settings']" position="inside">
                <field name="available_routing_schemes" invisible="1"/> <!-- Needed for routing_scheme > filterable_selection-->
                <field name="routing_scheme"
                       nolabel="1"
                       placeholder="Routing ID"
                       widget="filterable_selection"
                       options="{'whitelist_fname': 'available_routing_schemes'}"
                       class="o_field_routing_scheme_selection"/>
                <field name="routing_endpoint" nolabel="1"/>
            </xpath>
        </field>
    </record>
</odoo>
