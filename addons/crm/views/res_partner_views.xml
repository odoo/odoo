    <!-- BÚSQUEDA UNIFICADA -->
    <record id="view_partner_search_crm" model="ir.ui.view">
        <field name="name">res.partner.search.crm</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <search string="Buscar Partners">
                <field name="name"/>
                <field name="parent_id" string="Cuenta"/>
                <filter string="Empresas" name="companies" domain="[('is_company', '=', True)]"/>
                <filter string="Contactos" name="contacts" domain="[('is_company', '=', False), ('type', '=', 'contact')]"/>
                <separator/>
                <filter string="Activos" name="active" domain="[('active', '=', True)]"/>
                <filter string="Inactivos" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Mi equipo" name="my_team" domain="[('user_id', '=', uid)]"/>
            </search>
        </field>
    </record>

    <!-- ACCIÓN PARA CUENTAS -->
