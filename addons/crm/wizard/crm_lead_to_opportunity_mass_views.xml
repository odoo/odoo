<?xml version="1.0"?>
<odoo>
    <record id="view_crm_lead2opportunity_partner_mass" model="ir.ui.view">
        <field name="name">crm.lead2opportunity.partner.mass.form</field>
        <field name="model">crm.lead2opportunity.partner.mass</field>
        <field name="arch" type="xml">
            <form string="Convert to Opportunities" class="o_crm_lead_conversion_mass_form">
                <div class="alert alert-info" role="alert" invisible="not duplicated_lead_ids">
                    <span invisible="name != 'convert'">
                        Potential duplicates found. Use "Convert &amp; Merge with duplicates" to clean your data before converting.
                    </span>
                    <span invisible="name != 'convert_and_merge'">
                        Convert the selected Leads to Opportunities and merge all duplicates listed below.
                    </span>
                </div>
                <field name="lead_tomerge_ids" invisible="1"/>
                <group invisible="not duplicated_lead_ids">
                    <field name="name" class="oe_inline" widget="badges_selection" nolabel="1"/>
                </group>
                <group>
                    <group string="Assign these opportunities to">
                        <field name="user_ids" widget="many2many_avatar_user" domain="[('share', '=', False)]" placeholder="Keep current users" options="{'no_create': True}"/>
                        <field name="team_id" context="{'kanban_view_ref': 'sales_team.crm_team_view_kanban'}" placeholder="Keep current teams" options="{'no_create': True}"/>
                        <field name="force_assignment" widget="boolean_toggle" invisible="not team_id and not user_ids"/>
                    </group>
                    <group string="Customers">
                        <div class="o_row">
                            <label for="link_to_matching_customer" class="flex-shrink-0 me-3"/>
                            <field name="link_to_matching_customer" widget="boolean_toggle"/>
                        </div>
                    </group>
                </group>
                <notebook>
                    <page string="Leads/Opportunities to merge" invisible="name != 'convert_and_merge'">
                        <group>
                            <field name="duplicated_lead_ids" nolabel="1" domain="[('id', 'in', duplicated_lead_ids_domain)]">
                                <list create="false" default_order="email_from, contact_name"
                                      decoration-muted="won_status == 'lost'">
                                    <field name="create_date"/>
                                    <field name="name" string="Title"/>
                                    <field name="type" optional="hide"/>
                                    <field name="contact_name" optional="show"/>
                                    <field name="country_id" column_invisible="context.get('invisible_country', True)" options="{'no_open': True, 'no_create': True}"/>
                                    <field name="email_from" optional="show"/>
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                    <field name="team_id" optional="hide"/>
                                    <field name="stage_id"/>
                                </list>
                            </field>
                        </group>
                    </page>
                </notebook>

                <footer>
                    <button string="Convert" name="action_apply" type="object" class="btn-primary" data-hotkey="q"/>
                    <button class="btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_crm_send_mass_convert" model="ir.actions.act_window">
        <field name="name">Convert to Opportunities</field>
        <field name="res_model">crm.lead2opportunity.partner.mass</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_crm_lead2opportunity_partner_mass"/>
        <field name="target">new</field>
        <field name="context">{'dialog_size' : 'large'}</field>
    </record>
</odoo>
