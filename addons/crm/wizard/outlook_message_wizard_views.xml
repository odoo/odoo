<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista del wizard para enviar mensajes por correo -->
    <record id="view_outlook_message_wizard_form" model="ir.ui.view">
        <field name="name">outlook.message.wizard.form</field>
        <field name="model">outlook.message.wizard</field>
        <field name="arch" type="xml">
            <form string="Enviar mensaje por correo electrónico">
                <sheet>
                    <group>
                        <field name="partner_id" invisible="1"/>
                        <field name="partner_name" readonly="1" string="Destinatario"/>
                        <field name="email_to" placeholder="destinatario@ejemplo.com"/>
                        <field name="email_cc" placeholder="cc@ejemplo.com (opcional)"/>
                        <field name="subject" placeholder="Asunto del mensaje"/>
                    </group>
                    <group>
                        <field name="body" widget="html" options="{'style-inline': true}"/>
                    </group>
                    <group>
                        <field name="attachment_ids" widget="many2many_binary" string="Archivos adjuntos"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Enviar" type="object" name="action_send_message" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
