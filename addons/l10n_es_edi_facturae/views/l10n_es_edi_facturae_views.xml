<?xml version="1.0" encoding="UTF-8"?>

<odoo>
    <record id="l10n_es_edi_facturae_certificate_search" model="ir.ui.view">
        <field name="name">l10n_es_edi_facturae.certificate.search</field>
        <field name="model">certificate.certificate</field>
        <field name="inherit_id" ref="certificate.certificate_search_view"/>
        <field name="arch" type="xml">
            <filter name="scope_general" position="after">
                <filter string="Facturae" name="scope_facturae" domain="[('scope','=','facturae')]" help="Facturae certificates"/>
            </filter>
        </field>
    </record>

    <record id="l10n_es_edi_facturae_certificate_action" model="ir.actions.act_window">
        <field name="name">Certificates for Facturae EDI invoices on Spain</field>
        <field name="res_model">certificate.certificate</field>
        <field name="view_mode">tree,form</field>
        <field name="context" eval="{'scope': 'facturae', 'search_default_scope_facturae': 1}"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">Create the first certificate</p>
        </field>
    </record>

    <record id="l10n_es_edi_facturae_certificate_form_view" model="ir.ui.view">
        <field name="name">l10n_es_edi_facturae.certificate.form</field>
        <field name="model">certificate.certificate</field>
        <field name="inherit_id" ref="certificate.certificate_form_view"/>
        <field name="arch" type="xml">
            <field name="scope" position="attributes">
                <attribute name="invisible">False</attribute>
            </field>
        </field>
    </record>
</odoo>
