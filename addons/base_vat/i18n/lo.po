#. module: base_vat
#. odoo-python
#: code:addons/base_vat/models/res_partner.py:0
msgid ""
"The %(vat_label)s number [%(wrong_vat)s] does not seem to be valid. \n"
"Note: the expected format is %(expected_format)s"
msgstr ""
"ເລກ %(vat_label)s [%(wrong_vat)s] ເບິ່ງຄືວ່າບໍ່ຖືກຕ້ອງ. \n"
"ໝາຍເຫດ: ຮູບແບບທີ່ຕ້ອງການແມ່ນ %(expected_format)s"

#. module: base_vat
#. odoo-python
#: code:addons/base_vat/models/res_partner.py:0
msgid ""
"The %(vat_label)s number [%(wrong_vat)s] for %(record_label)s does not seem "
"to be valid. \n"
"Note: the expected format is %(expected_format)s"
msgstr ""
"ເລກ %(vat_label)s [%(wrong_vat)s] ສໍາລັບ %(record_label)s ເບິ່ງຄືວ່າບໍ່ຖືກຕ້ອງ. \n"
"ໝາຍເຫດ: ຮູບແບບທີ່ຕ້ອງການແມ່ນ %(expected_format)s"

