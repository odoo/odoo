<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="confirm_expiry_view" model="ir.ui.view">
        <field name="name">Confirm</field>
        <field name="model">expiry.picking.confirmation</field>
        <field name="arch" type="xml">
            <form string="Confirmation">
                <p>
                    <field name="description"/>
                </p>
                <field name="show_lots" invisible="1"/>
                <field name="show_list" invisible="1"/>
                <field name="move_line_ids" invisible="not show_list">
                    <list string="Expired Lot(s)" no_open="1">
                        <field name="product_id"/>
                        <field name="lot_name" string="Lot/Serial Number" column_invisible="parent.show_lots"/>
                        <field name="lot_id" column_invisible="not parent.show_lots"/>
                    </list>
                </field>
                <footer>
                    <button name="process"
                        string="Confirm"
                        type="object"
                        data-hotkey="q"
                        class="btn-primary"/>
                    <button name="process_no_expired"
                        string="Proceed except expired"
                        type="object"
                        data-hotkey="w"
                        class="btn-secondary"/>
                    <button class="btn-secondary"
                        special="cancel"
                        data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
