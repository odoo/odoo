msgid "%s is not a valid year."
msgstr "%s ບໍ່ແມ່ນປີທີ່ຖືກຕ້ອງ."

#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/accounting_functions.js:0
#, python-format
msgid ""
"'%s' is not a valid period. Supported formats are \"21/12/2022\", "
"\"Q1/2022\", \"12/2022\", and \"2022\"."
msgstr ""
"'%s' ບໍ່ແມ່ນໄລຍະເວລາທີ່ຖືກຕ້ອງ. ຮູບແບບທີ່ຮອງຮັບແມ່ນ \"21/12/2022\", \"Q1/2022\", \"12/"
"2022\", ແລະ \"2022\"."

#. module: spreadsheet_account
#: model:ir.model,name:spreadsheet_account.model_account_account
msgid "Account"
msgstr "ບັນຊີ"

#. module: spreadsheet_account
#: model:ir.model,name:spreadsheet_account.model_res_company
msgid "Companies"
msgstr "ບໍລິສັດ"

#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/accounting_functions.js:0
#, python-format
msgid "Get the total balance for the specified account(s) and period."
msgstr "ດຶງເອົາຍອດເຫຼືອທັງໝົດສຳລັບບັນຊີ ແລະ ໄລຍະເວລາທີ່ລະບຸ."

#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/accounting_functions.js:0
#, python-format
msgid "Get the total credit for the specified account(s) and period."
msgstr "ດຶງເອົາຍອດເງິນມີທັງໝົດສຳລັບບັນຊີ ແລະ ໄລຍະເວລາທີ່ລະບຸ."

#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/accounting_functions.js:0
#, python-format
msgid "Get the total debit for the specified account(s) and period."
msgstr "ດຶງເອົາຍອດເງິນໜີ້ທັງໝົດສຳລັບບັນຊີ ແລະ ໄລຍະເວລາທີ່ລະບຸ."

