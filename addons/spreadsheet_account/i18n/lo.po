#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/accounting_functions.js:0
msgid "Return the partner balance for the specified account(s) and period"
msgstr "ສົ່ງຄ່າຍອດເຫຼືອຄູ່ຄ້າສຳລັບບັນຊີ ແລະ ໄລຍະເວລາທີ່ລະບຸ"

#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/accounting_functions.js:0
msgid "Return the residual amount for the specified account(s) and period"
msgstr "ສົ່ງຄ່າຍອດຄົງເຫຼືອສຳລັບບັນຊີ ແລະ ໄລຍະເວລາທີ່ລະບຸ"

#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/accounting_functions.js:0
msgid "Returns the account codes of a given group."
msgstr "ສົ່ງຄ່າລະຫັດບັນຊີຂອງກຸ່ມທີ່ກຳນົດ."

#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/accounting_functions.js:0
msgid ""
"Returns the ending date of the fiscal year encompassing the provided date."
msgstr "ສົ່ງຄ່າມື້ສິ້ນສຸດຂອງປີງົບປະມານທີ່ກວມເອົາມື້ທີ່ລະບຸ."

#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/accounting_functions.js:0
msgid ""
"Returns the starting date of the fiscal year encompassing the provided date."
msgstr "ສົ່ງຄ່າມື້ເລີ່ມຕົ້ນຂອງປີງົບປະມານທີ່ກວມເອົາມື້ທີ່ລະບຸ."

#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/index.js:0
msgid "See records"
msgstr "ເບິ່ງບັນທຶກ"

#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/accounting_functions.js:0
msgid "Set to TRUE to include unposted entries."
msgstr "ຕັ້ງເປັນ TRUE ເພື່ອລວມເອົາລາຍການທີ່ຍັງບໍ່ທັນໄດ້ຜ່ານບັນຊີ."

#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/plugins/accounting_plugin.js:0
msgid "The balance for given partners could not be computed."
msgstr "ບໍ່ສາມາດຄິດໄລ່ຍອດເຫຼືອສຳລັບຄູ່ຄ້າທີ່ລະບຸໄດ້."

#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/plugins/accounting_plugin.js:0
msgid "The company fiscal year could not be found."
msgstr "ບໍ່ພົບປີງົບປະມານຂອງບໍລິສັດ."

#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/accounting_functions.js:0
msgid "The company to target (Advanced)."
msgstr "ບໍລິສັດເປົ້າໝາຍ (ຂັ້ນສູງ)."

#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/accounting_functions.js:0
msgid "The company."
msgstr "ບໍລິສັດ."

#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/accounting_functions.js:0
msgid ""
"The date range. Supported formats are \"21/12/2022\", \"Q1/2022\", "
"\"12/2022\", and \"2022\"."
msgstr ""
"ໄລຍະວັນທີ. ຮູບແບບທີ່ຮອງຮັບແມ່ນ \"21/12/2022\", \"Q1/2022\", \"12/2022\", ແລະ "
"\"2022\"."

#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/accounting_functions.js:0
msgid "The day from which to extract the fiscal year end."
msgstr "ວັນທີທີ່ຈະດຶງເອົາມື້ສິ້ນສຸດປີງົບປະມານ."

#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/accounting_functions.js:0
msgid "The day from which to extract the fiscal year start."
msgstr "ວັນທີທີ່ຈະດຶງເອົາມື້ເລີ່ມຕົ້ນປີງົບປະມານ."

#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/accounting_functions.js:0
msgid "The partner ids (separated by a comma)."
msgstr "ໄອດີຄູ່ຄ້າ (ແຍກດ້ວຍຈຸດ)."

#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/accounting_functions.js:0
msgid "The prefix of the accounts."
msgstr "ຄຳນຳໜ້າຂອງບັນຊີ."

#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/accounting_functions.js:0
msgid ""
"The prefix of the accounts. If none provided, all receivable and payable "
"accounts will be used."
msgstr "ຄຳນຳໜ້າຂອງບັນຊີ. ຖ້າບໍ່ໄດ້ລະບຸ, ຈະໃຊ້ບັນຊີລູກໜີ້ ແລະ ເຈົ້າໜີ້ທັງໝົດ."

#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/plugins/accounting_plugin.js:0
msgid "The residual amount for given accounts could not be computed."
msgstr "ບໍ່ສາມາດຄິດໄລ່ຍອດຄົງເຫຼືອສຳລັບບັນຊີທີ່ລະບຸໄດ້."

#. module: spreadsheet_account
#. odoo-javascript
#: code:addons/spreadsheet_account/static/src/accounting_functions.js:0
msgid "The technical account type (possible values are: %s)."
msgstr "ປະເພດບັນຊີທາງເຕັກນິກ (ຄ່າທີ່ເປັນໄປໄດ້ແມ່ນ: %s)."
