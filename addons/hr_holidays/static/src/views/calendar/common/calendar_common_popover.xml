<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="hr_holidays.TimeOffCalendarPopover" t-inherit="web.CalendarCommonPopover" t-inherit-mode="primary">
        <xpath expr="//span[hasclass('o_cw_popover_close')]" position="attributes">
            <attribute name="class">o_cw_popover_close position-absolute top-0 end-0 ms-0 mt-2 me-2</attribute>
            <attribute name="data-hotkey">x</attribute>
        </xpath>
    </t>
</templates>
