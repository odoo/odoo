<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="mail.DiscussSidebarChannel" t-inherit-mode="extension">
        <xpath expr="//*[hasclass('o-mail-DiscussSidebarChannel-floatingName')]" position="after">
            <div t-if="this.channel().correspondent?.partner_id?.outOfOfficeDateEndText" class="text-warning smaller px-2" t-out="this.channel().correspondent.persona.outOfOfficeDateEndText"/>
        </xpath>
    </t>
    <t t-inherit="mail.DiscussSidebarChannel.main" t-inherit-mode="extension">
        <xpath expr="//*[hasclass('o-mail-DiscussSidebarChannel-itemName')]" position="inside">
            <div t-if="this.channel().correspondent?.partner_id?.outOfOfficeDateEndText" class="text-warning smaller" t-out="this.channel().correspondent.persona.outOfOfficeDateEndText"/>
        </xpath>
    </t>
</templates>
