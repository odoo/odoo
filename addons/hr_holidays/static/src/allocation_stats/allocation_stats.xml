<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <div t-name="hr_holidays.AllocationStatsComponent" class="o_leave_stats">
        <div t-if="this.state.employee and this.state.allocations.length !== 0" id="o_allocation_stats_employee" class="sub_table px-3 py-2 mb-3">
            <div>
                <div class="d-flex align-items-end">
                    <div class="mx-1">
                        <KanbanMany2OneAvatarEmployeeField
                            record="this.props.record"
                            name="'employee_id'"
                        />
                    </div>
                    <div class="o_hr_leave_subtitle">
                        <t t-out="this.state.employee.display_name"/>'s summary (<t t-out="this.thisYear"/>)
                    </div>
                </div>
            </div>
            <div class="d-flex flex-column mb-1">
                <div t-foreach="this.state.allocations" t-as="alloc" t-key="alloc.id" class="d-flex mb-2 gap-1 o_employee_leave">
                    <span class="col-3 fw-bold" t-out="alloc.work_entry_type_id.display_name"/>
                    <div class="col-5 d-flex gap-2 flex-wrap">
                        <span t-out="alloc.date_from_display"/>
                        <t t-if="alloc.date_to_display">
                            <i class="fa fa-long-arrow-right my-1" aria-label="Arrow icon" title="Arrow"/>
                            <span t-out="alloc.date_to_display"/>
                        </t>
                        <t t-else="">
                            <span class="fst-italic">(No Limit)</span>
                        </t>
                    </div>
                    <div class="col-4 flex-wrap">
                        (
                        <span t-if="alloc.type_request_unit == 'hour'"><t t-out="alloc.number_of_hours_display"/> hours</span>
                        <span t-else=""><t t-out="alloc.number_of_days"/> days</span>
                        )
                        <span t-if="alloc.accrual_plan_id" class="text-muted ms-1">
                            Accrual Plan (<t t-out="alloc.accrual_plan_id.display_name"/>)
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</templates>
