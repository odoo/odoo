<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <div t-name="hr_holidays.LeaveStatsComponent" class="o_leave_stats">
        <div t-if="this.state.employee and this.state.leaves.length !== 0" id="o_leave_stats_employee" class="sub_table px-3 py-2 mb-3">
            <div>
                <h4 class="d-flex">
                    Summary <t t-out="this.thisYear"/>
                </h4>
            </div>
            <div class="d-flex flex-column mb-1">
                <div t-foreach="this.state.leaves" t-as="record_leave" t-key="record_leave.data.id" class="d-flex mb-2 gap-2">
                    <t t-set="leave" t-value="record_leave.data"/>
                    <div t-att-class="'rounded-circle border-0 flex-shrink-0 o_colorlist_toggler o_colorlist_item_color_' + leave.color"
                         style="width: 16px; height: 16px; box-shadow: inset 0 0 0 1px rgba(0,0,0,0.1);"></div>
                    <div t-out="leave.name" class="col-5 fw-bold"/>
                    <div class="d-flex mb-1">
                        <span t-out="record_leave.leaves_approved" class="me-1"/>
                        <div t-if="record_leave.max_leaves">
                            / <span t-out="record_leave.max_leaves" class="mx-1"/>
                        </div>
                        <span t-if="record_leave.unit_of_measure == 'day'">days</span>
                    </div>
                    <div t-if="record_leave.remaining_leaves > 0" class="text-muted ms-2">
                        (<span t-out="record_leave.remaining_leaves" class="mx-1"/>
                        <span t-if="record_leave.unit_of_measure == 'day'">days</span> remaining )
                    </div>
                    <div>
                    </div>
                </div>
            </div>
        </div>

        <div t-if="this.state.department and this.state.nbEmployee > 0" id="o_leave_stats_department" class="alert alert-info px-3 py-2 mt-3" role="alert">
            <div>
                <h4>
                    <t t-out="this.state.department_name"/>
                    Overlaps
                </h4>
            </div>
            <div>
                <b t-out="this.state.nbEmployee"/>
                team members on holiday during this period
                <a class="oe_link fw-bold"
                    href="#"
                    t-on-click="this.action_department_leaves"
                    icon="oi-arrow-right">
                    <i class="oi oi-fw o_button_icon oi-arrow-right"/>
                    View Overlaps
                </a>
            </div>
        </div>
    </div>
</templates>
