<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <div t-name="hr_holidays.TimeOffDashboard" class="o_timeoff_dashboard">
        <div class="d-flex flex-row p-0 justify-content-around">
            <t t-foreach="this.state.holidays" t-as="holiday" t-key="holiday[3]">
                <TimeOffCard
                    name="holiday[0]"
                    data="holiday[1]"
                    requires_allocation="holiday[2]"
                    holidayStatusId="holiday[3]"
                    employeeId="this.props.employeeId"/>
            </t>
            <div t-if="this.state.allocationRequestDaysHours" class="o_timeoff_card text-primary">
                <div class="d-flex align-items-center justify-content-center gap-2">
                    <span class="o_timeoff_duration">
                        <t t-out="this.state.allocationRequestDaysHours"/>
                    </span>
                    <div class="d-flex flex-column align-items-start justify-content-center">
                        <span class="o_timeoff_name">Pending Allocations</span>
                        <a href="#" class="o_timeoff_validity" t-on-click.prevent="this.openNewAllocation">
                            New Request
                        </a>
                    </div>
                </div>
            </div>
            <div t-if="this.hasAccrualAllocation or this.hasFutureAllocation" class="o_timeoff_card text-primary">
                <span class="text-danger o_timeoff_name">Balance at the</span>                
                <div class="d-flex flex-column align-items-start justify-content-center o_timeoff_validity">
                    <DateTimeInput
                            type="'date'"
                            value="this.state.date"
                            onChange="(date) => this.loadDashboardData(date)"
                            minDate="this.state.today"
                            placeholder.translate="Today"/>
                </div>
            </div>
        </div>
    </div>
</templates>
