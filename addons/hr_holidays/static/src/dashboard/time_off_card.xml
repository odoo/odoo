<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <div t-name="hr_holidays.TimeOffCard" class="o_timeoff_card text-primary">
        <t t-set="data" t-value="this.props.data"/>
        <t t-set="duration" t-value="this.props.requires_allocation ? data.virtual_remaining_leaves : data.virtual_leaves_taken"/>
        <t t-set="parsed_duration" t-value="this.formatDuration(duration)"/>
        <div class="d-flex align-items-center justify-content-center gap-2 cursor-pointer o_timeoff_card_inner"
            t-on-click.stop="(ev) => this.onClickInfo(ev)">
            <span class="o_timeoff_duration">
                <span t-att-style="data.holds_changes ? 'color: #B6D369;' : ''">
                    <t t-out="parsed_duration"/>
                </span>
            </span>
            <div class="d-flex flex-column align-items-start justify-content-center" >
                <span class="o_timeoff_name">
                    <t t-out="this.props.name"/>
                    <t name="duration_unit">
                        <t t-if="data.unit_of_measure == 'hour'"> Hours</t>
                        <t t-else=""> Days</t>
                    </t>
                </span>
                <span t-if="this.props.requires_allocation and data.closest_allocation_expire !== false"
                    t-att-class="'o_timeoff_validity' + (this.warning() ? ' text-warning' : '')">
                    Validity <t t-out="data.closest_allocation_expire"/>
                    <i t-if="this.warning()" class="fa fa-exclamation-triangle ms-1"/>
                </span>
                <span t-else="" class="o_timeoff_validity">
                    <t t-if="this.props.requires_allocation" name="duration_type">Available</t>
                    <t t-else="">Taken</t>
                </span>
            </div>
        </div>
    </div>

    <t t-name="hr_holidays.TimeOffCardMobile">
        <t t-set="data" t-value="this.props.data"/>
        <t t-set="duration" t-value="this.props.requires_allocation ? data.virtual_remaining_leaves : data.virtual_leaves_taken" />

        <span class="float-end o_timeoff_card_mobile">
            <t t-if="this.props.requires_allocation" name="duration_type">
                <strong t-out="duration" class="o_timeoff_green text-success"/> / <span t-out="data.max_leaves"/> <t t-if="data.unit_of_measure == 'hour'">Hours</t><t t-else="">Days</t> <span class="o_timeoff_green text-success">Available</span>
            </t>
            <t t-else="">
                <strong t-out="duration"/> <t t-if="data.unit_of_measure == 'hour'">Hours</t><t t-else="">Days</t> <span class="text-primary">Taken</span>
            </t>
        </span>
    </t>

    <t t-name="hr_holidays.TimeOffCardPopover">
        <ul class="list-unstyled p-3 mb-0">
            <li class="d-flex justify-content-between btn-link p-0 cursor-pointer" t-on-click="this.allocatedLeaves">
                Allocated: <span class="ps-1">
                    <t t-out="this.props.allocated"/>
                    <t t-if="this.props.unit_of_measure == 'hour'"> hours</t>
                    <t t-else=""> days</t>
                </span>
            </li>
            <li class="d-flex justify-content-between" t-if="this.props.accrual_bonus != 0">
                Accrual (Future): <span class="ps-1" t-out="this.props.accrual_bonus"/>
                <t t-if="this.props.unit_of_measure == 'hour'"> hours</t>
                <t t-else=""> days</t>
            </li>
            <li class="d-flex justify-content-between btn-link cursor-pointer" t-on-click="() => this.navigateInfo(['validate'])">
                Approved: <span class="ps-1">
                    <t t-out="this.props.approved"/>
                    <t t-if="this.props.unit_of_measure == 'hour'"> hours</t>
                    <t t-else=""> days</t>
                </span>
            </li>
            <li class="d-flex justify-content-between border-bottom btn-link cursor-pointer" t-on-click="() => this.navigateInfo(['confirm','validate1'])">
                Pending: <span class="ps-1">
                    <t t-out="this.props.planned"/>
                    <t t-if="this.props.unit_of_measure == 'hour'"> hours</t>
                    <t t-else=""> days</t>
                </span>
            </li>
            <li class="d-flex justify-content-between">
                Available: <span class="ps-1">
                    <t t-out="this.props.left"/>
                    <t t-if="this.props.unit_of_measure == 'hour'"> hours</t>
                    <t t-else=""> days</t>
                </span>
            </li>
        </ul>
        <div t-if="this.props.warning" class="alert alert-warning mb-0 pb-0 o_time_off_card_popover_warning">
            <span class="d-inline-block m-0 mb-3"
                t-if="this.props.errorLeaves.length">
                Some leaves cannot be linked to any allocation. To see those leaves, 
                <a t-on-click="() => this.openLeaves()" class="cursor-pointer">click here</a>.
            </span>
            <span class="d-inline-block m-0 mb-3"
                t-if="this.props.closest &amp;&amp; this.props.closest &lt; this.props.left">
                <i class="fa fa-warning"/> Only <t t-out="this.props.closest"/>
                <t t-if="this.props.unit_of_measure == 'hour'"> hours</t>
                <t t-else=""> days</t>
                can be used before the allocation expires.
            </span>
            <span class="d-inline-block m-0 mb-3"
                t-if="this.props.accrualExcess">
                The leaves planned in the future are exceeding the maximum value of the allocation.
                It will not be possible to take all of them.
            </span>
        </div>
    </t>
</templates>
