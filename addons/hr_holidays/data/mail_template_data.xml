<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="new_timeoff_request_template" model="mail.template">
            <field name="name">New Time Off Request</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave"/>
            <field name="partner_to" eval="False"/>
            <field name="subject">I'm requesting {{ object.duration_display }} of {{ object.work_entry_type_id.name }} from {{ object.request_date_from }} to {{ object.request_date_to }}</field>
            <field name="use_default_to" eval="True"/>
            <field name="description">Mail for new leave request</field>
            <field name="body_html" type="html">
                <div>
                    Dear <b><t t-out="object.env.context.get('manager')"/></b>,
                    <br/><br/>
                    <p>I'm requesting a Time Off. I would appreciate if you could approve it whenever possible!</p>
                    <ul>
                        <li>Time Type: <t t-out="object.work_entry_type_id.name"/></li>
                        <li><t t-out="object.request_date_from"/> → <t t-out="object.request_date_to"/> (<t t-out="object.duration_display"/>)</li>
                        <li t-if="object.name">Reason: <t t-out="object.name"/></li>
                    </ul>
                </div>
            </field>
            <field name="lang">{{ object.user_id.lang }}</field>
        </record>

        <record id="mail_template_allocation_confirmed" model="mail.template">
            <field name="name">Time Off Allocation Confirmed</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave_allocation"/>
            <field name="subject">Time Off Allocation Confirmed: {{ object.work_entry_type_id.name }} ({{ object.number_of_days_display }} {{ 'hours' if object.type_request_unit == 'hour' else 'days' }})</field>
            <field name="description">Sent to employee when their time off allocation is confirmed</field>
            <field name="body_html" type="html">
                <div>
                    Dear <t t-out="object.employee_id.name or 'Employee'"/>,<br/><br/>
                    Your time off allocation has been confirmed.<br/><br/>
                    Details:<br/>
                    - Time Type: <t t-out="object.work_entry_type_id.name or ''"/><br/>
                    - Allocation: <t t-out="object.number_of_days_display or ''"/> <t t-if="object.type_request_unit == 'hour'">Hours</t><t t-else="">Days</t><br/>
                    - Valid From: <t t-out="object.date_from or ''"/> <t t-if="not object.date_to">(No Expiry)</t><t t-else=""> to <t t-out="object.date_to or ''"/></t><br/>
                    <t t-if="object.accrual_plan_id">
                    - Accrual Plan: <t t-out="object.accrual_plan_id.name or ''"/><br/>
                    </t>
                    <br/>
                    For any questions, contact HR Responsible.<br/><br/>
                    Regards,<br/>
                    <t t-out="object.env.user.name or ''"/>
                </div>
            </field>
            <field name="lang">{{ object.employee_id.user_id.lang }}</field>
        </record>
    </data>
</odoo>
