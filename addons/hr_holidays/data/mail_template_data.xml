<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="new_timeoff_request_template" model="mail.template">
            <field name="name">New Time Off Request</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave"/>
            <field name="partner_to" eval="False"/>
            <field name="subject">I'm requesting {{ object.duration_display }} of {{ object.work_entry_type_id.name }} from {{ object.request_date_from }} to {{ object.request_date_to }}</field>
            <field name="use_default_to" eval="True"/>
            <field name="description">Mail for new leave request</field>
            <field name="body_html" type="html">
                <div>
                    Dear <t t-out="object.sudo()._get_responsible_for_approval().partner_id.name or ''"/>,
                    <br/><br/>
                    <p><span style="font-weight:bold;" t-out="object.employee_id.name"/> is requesting <span style="font-weight:bold;" t-out="object.duration_display"/> of <span style="font-weight:bold;">Time off</span></p>
                    <ul>
                        <li>
                            <span style="font-weight:bold; display:inline-block; width:80px">When</span>
                            <t t-if="object.request_date_from.month != object.request_date_to.month or object.request_date_from.year != object.request_date_to.year">
                                <span>
                                    <t t-out="object.request_date_from" t-options='{"widget": "date", "format": "long"}'/>
                                     to <t t-out="object.request_date_to" t-options='{"widget": "date", "format": "long"}'/>
                                </span>
                            </t>
                            <t t-else="">
                                <span>
                                <t t-out="object.request_date_from.strftime('%B')"/>  <t t-out="object.request_date_from.day"/>
                                <t t-if="object.request_date_from != object.request_date_to"> to  <t t-out="object.request_date_to.day"/></t>, <t t-out="object.request_date_to.year"/>
                                </span>
                            </t>
                        </li>
                        <li>
                            <span style="font-weight:bold; display:inline-block; width:80px">Type</span>
                            <span t-out="object.work_entry_type_id.name"/>
                        </li>
                        <li>
                            <span style="font-weight:bold; display:inline-block; width:80px">Remaining</span>
                            <span><t t-out="object.virtual_remaining_leaves"/> days</span>
                        </li>
                    </ul>
                    <br/>
                    Please approve the time off at your disposal.
                    <br/>
                </div>
            </field>
            <field name="lang">{{ object.user_id.lang }}</field>
        </record>
    </data>
</odoo>
