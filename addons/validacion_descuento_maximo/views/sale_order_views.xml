<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sale_order_form_discount_limit" model="ir.ui.view">
        <field name="name">sale.order.form.discount.limit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>

        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_approve_discount"
                        string="Aprobar descuento"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'requires_review'"
                        groups="validacion_descuento_maximo.group_discount_supervisor"/>
            </xpath>
            <xpath expr="//sheet" position="inside">
                <group string="Control de Descuentos">
                    <field name="descuento_maximo_permitido" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>