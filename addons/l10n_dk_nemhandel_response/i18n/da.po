#. module: l10n_dk_nemhandel_response
#: model_terms:ir.ui.view,arch_db:l10n_dk_nemhandel_response.nemhandel_rejection_wizard_view_form
msgid ""
"<span>The following note will be sent with your rejection response. Enter "
"any issue you have with this bill/invoice.</span>"
msgstr ""
"<span>Følgende bemærkning vil blive vedlagt dit afslag. Angiv eventuelle "
"problemer med denne regning/faktura.</span>"

#. module: l10n_dk_nemhandel_response
#. odoo-python
#: code:addons/l10n_dk_nemhandel_response/models/account_edi_proxy_user.py:0
msgid ""
"A Nemhandel response was sent to the Nemhandel Access Point declaring you "
"accepted this document."
msgstr ""
"Der er sendt et Nemhandel-svar til Nemhandel-adgangspunkt, hvor du har "
"bekræftet, at du har accepteret dette dokument."

#. module: l10n_dk_nemhandel_response
#. odoo-python
#: code:addons/l10n_dk_nemhandel_response/models/account_edi_proxy_user.py:0
msgid ""
"A Nemhandel response was sent to the Nemhandel Access Point declaring you "
"rejected this document."
msgstr ""
"Der er sendt et Nemhandel-svar til Nemhandel-adgangspunkt, hvor du har "
"bekræftet, at du har afvist dette dokument."

