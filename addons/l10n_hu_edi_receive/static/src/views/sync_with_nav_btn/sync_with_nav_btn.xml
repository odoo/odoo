<templates>

    <t t-name="l10n_hu_edi_receive.ListView.Buttons" t-inherit="account.AccountMoveListView.Buttons" t-inherit-mode="primary">
        <xpath expr="." position="inside">
            <SyncWithNavBtn/>
        </xpath>
    </t>

    <t t-name="l10n_hu_edi_receive.SyncWithNavBtn">
        <t t-if="this.showButton">
            <button class="btn btn-secondary" t-on-click="openWizard">Sync with NAV</button>
        </t>
    </t>

</templates>
