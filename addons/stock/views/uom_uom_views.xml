<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="uom_uom_view_list" model="ir.ui.view">
        <field name="name">uom.uom.view.list.inherit.stock</field>
        <field name="model">uom.uom</field>
        <field name="inherit_id" ref="uom.uom_uom_view_list"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="package_type_id" groups="stock.group_tracking_lot"/>
            </field>
        </field>
    </record>

    <record id="uom_uom_view_form" model="ir.ui.view">
        <field name="name">uom.uom.view.form.inherit.stock</field>
        <field name="model">uom.uom</field>
        <field name="inherit_id" ref="uom.uom_uom_view_form"/>
        <field name="arch" type="xml">
            <div name="relative_factor" position="after">
                <field name="package_type_id"
                    groups="stock.group_tracking_lot"
                    readonly="(context.get('product_id') or context.get('product_ids')) and id"
                />
                <field 
                    name="product_uom_ids"
                    invisible="not (context.get('product_id') and id)"
                    widget="many2many_barcode_tags"
                    options="{'no_create_edit': True, 'no_open': True}"
                    domain="[('uom_id', '=', id), '|', ('product_id', '=', context.get('product_id')), ('product_id', 'in', context.get('product_ids'))]"
                    readonly="not context.get('product_id')"
                    force_save="1"
                    context="{'default_uom_id': id, 'default_product_id': context.get('product_id')}"/>
                <field name="route_ids" groups="stock.group_adv_location" widget="many2many_tags" invisible="not route_ids"/>
            </div>
        </field>
    </record>
</odoo>
