msgstr "ນຳເຂົ້າເລກລັອດ"

#. module: stock
#. odoo-javascript
#: code:addons/stock/static/src/widgets/generate_serial.js:0
msgid "Import Serials"
msgstr "ນຳເຂົ້າເລກຊີຣີ"

#. module: stock
