<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_lot_label_meta_block">
            <div class="o_label_meta_block"/>
        </template>

        <template id="report_simple_label4x12_standard" inherit_id="product.report_simple_label4x12" primary="True">
            <xpath expr="//div[hasclass('o_label_centered_content')]/div[hasclass('o_label_table')][1]/div[hasclass('o_label_meta_block')]" position="replace">
                <t t-call="stock.report_lot_label_meta_block"/>
            </xpath>
        </template>

        <template id="report_simple_label4x12_gs1" inherit_id="product.report_simple_label4x12_gs1" primary="True">
            <xpath expr="//div[hasclass('o_label_info_bottom')]/div[hasclass('o_label_meta_block')]" position="replace">
                <t t-call="stock.report_lot_label_meta_block"/>
            </xpath>
        </template>

        <template id="report_lot_simple_label4x12">
            <t t-if="env.user.has_group('stock.group_stock_lot_print_gs1')">
                <t t-call="stock.report_simple_label4x12_gs1"/>
            </t>
            <t t-else="">
                <t t-call="stock.report_simple_label4x12_standard"/>
            </t>
        </template>

        <template id="report_lot_label">
            <t t-call="web.basic_layout">
                <div class="oe_structure"></div>
                <div t-foreach="label_pages" t-as="page_rows" class="o_label_sheet" t-att-style="'padding: 20mm 8mm'">
                    <table class="my-0 table table-sm table-borderless">
                        <t t-foreach="page_rows" t-as="label_row">
                            <tr>
                                <t t-foreach="label_row" t-as="label">
                                    <t t-call="stock.report_lot_simple_label4x12"/>
                                </t>
                            </tr>
                        </t>
                    </table>
                    <div class="oe_structure"></div>
                </div>
            </t>
        </template>
    </data>
</odoo>
