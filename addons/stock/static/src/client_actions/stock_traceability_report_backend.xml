<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="stock.TraceabilityReport">
        <div class="o_action">
            <Layout display="this.display">
                <t t-set-slot="control-panel-buttons">
                    <div class="o_cp_buttons" role="toolbar" aria-label="Control panel buttons" t-custom-ref="buttons">
                        <button type="button" class="btn btn-primary" t-on-click="() => this.onClickPrint()">Print</button>
                        <t t-if="this.hasUnfoldableLines">
                            <button t-if="this.hasFoldedLines" type="button" class="btn btn-secondary ms-1" t-on-click="() => this.onClickUnfold()">Unfold</button>
                            <button t-else="" type="button" class="btn btn-secondary ms-1" t-on-click="() => this.onClickFold()">Fold</button>
                        </t>
                    </div>
                </t>

                <div class="container-fluid o_stock_reports_page o_stock_reports_no_print">
                    <t t-if="this.state.lines.length">
                        <h1 class="o_report_heading text-start">Traceability Report</h1>
                        <div class="o_stock_reports_table table-responsive">
                            <table class="table">
                                <thead>
                                    <tr class="o_report_header">
                                        <th class="o_report_line_header" data-column="reference">Reference</th>
                                        <th class="o_report_line_header" data-column="product">Product</th>
                                        <th class="o_report_line_header" data-column="date">Date</th>
                                        <th class="o_report_line_header" data-column="lot_name">Lot/Serial #</th>
                                        <th class="o_report_line_header" data-column="location_source">From</th>
                                        <th class="o_report_line_header" data-column="location_destination">To</th>
                                        <th class="o_report_line_header" data-column="quantity">Quantity</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-call="stock.ReportMRPLines" lines="this.state.lines" hasUpDown="true"/>
                                </tbody>
                            </table>
                        </div>
                    </t>
                    <h1 t-else="" class="text-center">No operation made on this lot.</h1>
                </div>
            </Layout>
        </div>
    </t>

    <t t-name="stock.ReportMRPLines">
        <t t-foreach="lines" t-as="line" t-key="line.id">
            <t t-if="!line.isFolded and line.line_type=='child' and line.lines.length" t-call="stock.ReportMRPLines"
                lines="line.lines"/>
            <tr t-att-class="line.model_name === 'stock.move.line' ? 'o_stock_reports_level0' : 'o_stock_reports_default_style'">
                <t t-foreach="line.columns" t-as="col" t-key="col.name">
                    <td t-att-class="line.unfoldable ? 'o_stock_reports_unfoldable' : ''">
                        <t t-if="col_first">
                            <span t-attf-style="margin-left: {{line.level}}px"/>
                            <t t-if="line.line_type == 'child' and line.unfoldable">
                                <span class="o_stock_reports_unfoldable o_stock_reports_caret_icon" t-on-click="() => this.toggleLine(line, 'child')">
                                    <i class="fa fa-fw fa-level-up" t-att-class="line.isFolded ? '' : 'fa-rotate-270'" role="img" aria-label="Expand" t-att-title="line.isFolded ? 'Expand' : 'Fold'"/>
                                </span>
                            </t>
                            <t t-elif="line.line_type == 'parent' and line.unfoldable">
                                <span class="o_stock_reports_unfoldable o_stock_reports_caret_icon" t-on-click="() => this.toggleLine(line, 'parent')">
                                    <i class="fa fa-fw" t-att-class="line.isFolded ? 'fa-caret-right' : 'fa-caret-down'" role="img" aria-label="Unfold" t-att-title="line.isFolded ? 'Unfold' : 'Fold'"/>
                                </span>
                            </t>
                        </t>

                        <span t-if="col.value and line.reference === col.value" t-att-class="!line.unfoldable ? 'o_stock_reports_nofoldable' : ''">
                            <a class="o_stock_reports_web_action" href="#" t-on-click.prevent="() => this.onClickBoundLink(line)" t-out="col.value"/>
                        </span>
                        <span t-elif="col.value and ((line.picking_type_code == 'incoming' and line.source_name === col.value) or (line.picking_type_code == 'outgoing' and line.destination_name === col.value))">
                            <a class="o_stock_report_partner_action" href="#" t-on-click.prevent="() => this.onClickPartner(line)" t-out="col.value"/>
                        </span>
                        <span t-elif="col.value and line.lot_name === col.value">
                            <a class="o_stock_report_lot_action" href="#" t-on-click.prevent="() => this.onClickOpenLot(line)" t-out="col.value"/>
                        </span>
                        <t t-elif="col.value" t-out="col.value"/>
                    </td>
                </t>
            </tr>

            <t t-if="!line.isFolded and line.line_type=='parent' and line.lines.length" t-call="stock.ReportMRPLines"
                lines="line.lines"/>
        </t>
    </t>

</templates>
