<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="stock.AllocationReport.OutLine">
        <td class="o_quantity ps-3"
            t-att-class="this.quantityCSSClass">
            <t t-if="this.quantityToDisplay &amp;&amp; this.quantityToDisplay != this.demandQuantity()">
                <t t-out="this.quantityToDisplay"/> /
            </t>
            <t t-out="this.demandQuantity()"/> <t t-out="this.props.productUom.display_name"/>
        </td>
        <td class="o_reserved text-center">
            <CheckBox t-props="this.getCheckBoxProps(this.line, this.out_line)"/>
        </td>
        <td class="o_allocation_for">
            <span class="o_field_widget me-2">
                <span class="o_priority">
                    <span
                        class="o_priority_star fa fa-star"
                        t-att-class="this.favorite() ? '' : 'opacity-0'"
                        tabindex="0"
                        t-att-checked="this.favorite()"
                    />
                </span>
            </span>
            <span class="o_source_operation">
                <t t-if="this.picking">
                    <a href="#" view-type="form" t-out="this.picking.display_name"
                        t-on-click.prevent="() => this.env.bus.trigger('open_record', this.picking)"/>
                    <t t-if="this.source"> (<t t-call="stock.AllocationReport.OutLine.SourceLink"/>)</t>
                </t>
                <t t-elif="this.source" t-call="stock.AllocationReport.OutLine.SourceLink"/>
            </span>
            <t t-if="this.partner">:
                <a href="#" view-type="form" class="o_partner" t-out="this.partner.display_name"
                    t-on-click.prevent="() => this.env.bus.trigger('open_record', this.partner)"/>
            </t>
        </td>
        <td t-attf-class="o_date {{this.dateColor()}}">
            <span t-if="this.date()" t-out="this.displayDate(this.date())"/>
        </td>
        <td>
            <button t-attf-class="btn btn-secondary {{this.props.reservedQuantity() ? '' : 'opacity-0 pe-none'}}"
                    t-on-click.prevent="() => this.onPrintLabels()">
                Print Labels
            </button>
            <!-- Dummy invisible button to occupy the same space even when there is no button to display -->
        </td>
    </t>

    <t t-name="stock.AllocationReport.OutLine.SourceLink">
        <a href="#" view-type="form" t-out="this.source.display_name"
           t-on-click.prevent="() => this.env.bus.trigger('open_record', this.source)"/>
    </t>
</templates>
