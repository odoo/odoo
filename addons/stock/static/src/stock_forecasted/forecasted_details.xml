<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="stock.ForecastedDetails">
        <table class="table table-bordered bg-view">
            <thead>
                <tr class="bg-light">
                    <th scope="col">Stock &amp; Incoming</th>
                    <th scope="col">Outgoing</th> <!--<t t-out="props.docs.uom"/>-->
                    <th scope="col" class="border-end-0">Used by</th>
                    <th scope="col" class="border-start-0"></th> <!-- Action Button -->
                    <th scope="col">Delivery Date</th>
                </tr>
            </thead>
<!-- If Product Variants : Specify each variant as title (One line cell) and allow to collapse/expand
Link with data-toggle="collapse" href="#collapseGroup_x" and Tbody with class="collapse multi-collapse" id="collapseGroup_x"
We may use href=".collapseGroup_y" with class="collapseGroup_y" to avoid using id
    e.g.
    <tr t-if="props.docs.multiple_product" t-out="line.product.display_name"/>


-->
            <tbody>
                <tr t-if="onHandCondition">
                    <td>Inventory On Hand</td>
                    <td class="text-end">0</td>
                    <td/>
                    <td/>
                    <td/>
                </tr>
                <t t-set="last_line_index" t-value="props.docs.lines.length - 1"/>
                <t t-foreach="props.docs.lines" t-as="line" t-key="line_index">
                    <t t-if="multipleProducts and (line_index === 0 or line.product.id !== props.docs.lines[line_index - 1].product.id)">
                        <tr t-attf-class="#{line.is_matched and 'table-info' or ''}">
                            <td colspan="5" class="fw-bold text-uppercase border-0">
                                <button class="btn btn-sm btn-secondary me-2"
                                    data-bs-toggle="collapse"
                                    t-attf-data-bs-target=".collapseGroup_#{line.product.id}"
                                    aria-expanded="true" t-attf-aria-controls=".collapseGroup_#{line.product.id}">
                                    <i class="icon fa"/>
                                </button>
                                <span t-out="line.product.display_name"/>
                            </td>
                        </tr>
                    </t>
                    <tr t-attf-class="#{line.is_matched and 'table-info' or ''} #{multipleProducts and 'collapse show' or ''} collapseGroup_#{line.product.id}" >
                        <t t-if="skip_row > 1" t-set="skip_row" t-value="skip_row - 1"/>
                        <t t-else="">
                            <t t-if="splittedIncomingLines[line_index]" t-set="skip_row" t-value="splittedIncomingLines[line_index]['rowcount']"/>
                            <td t-attf-class="#{line.is_late and 'table-danger' or classForLine(line)}" t-attf-rowspan="#{skip_row > 0 and skip_row}">
                                <t t-if="line.document_in">
                                    <a t-if="line.document_in"
                                        href="#"
                                        t-on-click.prevent="() => this.props.openView(line.document_in._name, 'form', line.document_in.id)"
                                        t-out="line.document_in.name"
                                        class="fw-bold"/>
                                    <span t-if="line.receipt_date">: <t t-out="_formatFloat(skip_row > 0 ? splittedIncomingLines[line_index].tot_qty : line.quantity)"/> <t t-out="line.uom_id.display_name"/> expected on <t t-out="line.receipt_date"/></span>
                                </t>
                                <t t-elif="line.reservation">
                                    <a t-out="line.reservation.name" href="#" class="fw-bold"
                                    t-on-click.prevent="() => this.props.openView(line.reservation._name, 'form', line.reservation.id)"
                                        /> reserved
                                </t>
                                <t t-elif="line.in_transit">
                                    <t t-if="line.move_out">
                                        <span>Stock In Transit</span>
                                    </t>
                                    <t t-else="">
                                        <span>Free Stock in Transit</span>
                                    </t>
                                </t>
                                <t t-elif="line.replenishment_filled">
                                    <t t-if="line.document_out">
                                        <!-- <t t-out="_formatFloat(skip_row > 0 ? splittedIncomingLines[line_index].tot_qty : line.quantity)"/> -->
                                        <t t-out="_formatFloat(reservedOnHandTotalQty)"/> <t t-out="line.uom_id.display_name"/> On Hand
                                    </t>
                                    <t t-else="" t-out="freeStockLabel"/>
                                </t>
                                <span t-else="" class="text-muted">Not Available</span>
                            </td>
                        </t>
                        <td class="text-end" t-att-class="classForLine(line)"><t t-if="! line.replenishment_filled">- </t><t t-out="_formatFloat(line.quantity)"/> <t t-out="line.uom_id.display_name"/></td>
                        <td class="border-end-0" t-attf-class="#{! line.replenishment_filled and 'table-danger'}" name="usedby_cell">
                            <button t-if="line.move_out and line.move_out.picking_id"
                                t-attf-class="o_priority o_priority_star me-1 fa fa-star#{line.move_out.picking_id.priority=='1' ? '' : '-o'}"
                                t-on-click="() => this._onClickChangePriority('stock.picking', line.move_out.picking_id)"
                                name="change_priority_link"/>
                            <a t-if="line.document_out"
                                href="#"
                                t-on-click.prevent="() => this.props.openView(line.document_out._name, 'form', line.document_out.id)"
                                t-out="line.document_out.name"
                                class="fw-bold"/>
                        </td>
                        <td class="p-0 text-center border-start-0">
                            <t t-if="displayReserve(line)">
                                <button t-if="line.reservation"
                                            class="btn btn-sm btn-primary o_report_replenish_unreserve"
                                            name="unreserve_link"
                                            t-on-click="() => this._unreserve(line.move_out.id)">
                                            Unreserve
                                </button>
                                <button t-elif="line.replenishment_filled"
                                    class="btn btn-sm btn-primary"
                                    name="reserve_link"
                                    t-on-click="() => this._reserve(line.move_out.id)">
                                    Reserve
                                </button>
                            </t>
                        </td>
                        <td t-out="line.delivery_date or ''"
                            t-attf-class="#{! line.replenishment_filled and 'table-danger'}"/>
                    </tr>
                    <t t-if="line_index === last_line_index or line.product.id !== props.docs.lines[line_index + 1].product.id">
                        <tr t-if="this.props.docs.product[line.product.id].qty_to_order" t-attf-class="#{multipleProducts and 'collapse show' or ''} collapseGroup_#{line.product.id}">
                            <td>To Order</td>
                            <td class="text-end">
                                <t t-out="_formatFloat(this.props.docs.product[line.product.id].qty_to_order)"/> <t t-out="line.uom_id.display_name"/>
                            </td>
                        </tr>
                        <tr t-if="this.props.docs.product[line.product.id].qty_to_order !== this.props.docs.product[line.product.id].qty_to_order_with_visibility_days" t-attf-class="#{multipleProducts and 'collapse show' or ''} collapseGroup_#{line.product.id}">
                            <td>To Order with Visibility Days</td>
                            <td class="text-end">
                                <t t-out="_formatFloat(this.props.docs.product[line.product.id].qty_to_order_with_visibility_days)"/> <t t-out="line.uom_id.display_name"/>
                            </td>
                        </tr>
                        <tr class="o_forecasted_row fw-bold table-secondary" t-attf-class="#{multipleProducts and 'collapse show' or ''} collapseGroup_#{line.product.id}">
                            <td class="border-end-0">Forecasted Inventory</td>
                            <td class="text-end border-start-0 border-end-0">
                                <t t-out="_formatFloat(this.props.docs.product[line.product.id].virtual_available)"/> <t t-out="line.uom_id.display_name"/>
                            </td>
                            <td class="border-start-0" colspan="3"/>
                        </tr>
                        <tr t-if="props.docs.product[line.product.id].draft_picking_qty.in" name="draft_picking_in" t-attf-class="#{multipleProducts and 'collapse show' or ''} collapseGroup_#{line.product.id}">
                            <td>Incoming Draft Transfer</td>
                            <td class="text-end">
                                <t t-out="_formatFloat(props.docs.product[line.product.id].draft_picking_qty.in)"/> <t t-out="line.uom_id.display_name"/>
                            </td>
                        </tr>
                        <tr t-if="props.docs.product[line.product.id].draft_picking_qty.out" name="draft_picking_out" t-attf-class="#{multipleProducts and 'collapse show' or ''} collapseGroup_#{line.product.id}">
                            <td>Outgoing Draft Transfer</td>
                            <td class="text-end">
                                <t t-out="_formatFloat(-props.docs.product[line.product.id].draft_picking_qty.out)"/> <t t-out="line.uom_id.display_name"/>
                            </td>
                        </tr>
                        <tr class="o_forecasted_row fw-bold table-secondary" t-attf-class="#{multipleProducts and 'collapse show' or ''} collapseGroup_#{line.product.id}">
                            <td class="border-end-0">Forecasted with Pending</td>
                            <td class="text-end border-start-0 border-end-0">
                                <t t-out="_formatFloat(futureVirtualAvailable(line))"/> <t t-out="line.uom_id.display_name"/>
                            </td>
                            <td class="border-start-0" colspan="3"/>
                        </tr>
                    </t>
                </t>
            </tbody>
        </table>
    </t>
</templates>
