<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="account_journal_form_inherit_l10n_vn" model="ir.ui.view">
            <field name="name">account.journal.form.inherit.l10n.vn</field>
            <field name="model">account.journal</field>
            <field name="inherit_id" ref="account.view_account_journal_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='advanced_settings']/group" position="inside">
                    <group string="E-Invoice" invisible="type != 'sale' or country_code != 'VN'">
                        <field name="l10n_vn_default_invoice_symbol_id"
                               string="Default E-Invoice Symbol"
                               domain="[('company_id', '=', company_id), ('usage', '=', 'invoice')]"
                               context="{'default_company_id': company_id, 'default_usage': 'invoice'}"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
