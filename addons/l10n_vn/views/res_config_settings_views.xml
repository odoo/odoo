<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_l10n_vn" model="ir.ui.view">
        <field name="name">res.config.settings.form.inherit.l10n.vn</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='account']" position="inside">
                <block title="Vietnamese E-invoice" id="vn_localization" invisible="country_code != 'VN'">
                    <setting id="l10n_vn_edi_symbol_setting"
                             string="Set up Symbol"
                             help="Manage E-invoice."
                             company_dependent="1">
                        <div id="l10n_vn_edi_symbol_content" class="content-group mb-3">
                            <div class="row align-items-end" title="Used for all non-POS invoices unless a specific symbol is defined in each invoice journal.">
                                <label for="l10n_vn_default_invoice_symbol_id" class="col-3 col-lg-3 o_light_label"/>
                                <field name="l10n_vn_default_invoice_symbol_id"
                                       nolabel="1"
                                       domain="[('company_id', '=', company_id), ('usage', '=', 'invoice')]"
                                       context="{'default_company_id': company_id, 'default_usage': 'invoice'}"/>
                            </div>
                        </div>
                        <div id="l10n_vn_edi_symbol_actions" class="d-flex flex-wrap align-items-center gap-2">
                            <button string="View Invoice Symbol List"
                                    type="action"
                                    name="%(l10n_vn.action_l10n_vn_sinvoice_symbol)d"
                                    class="btn btn-link"
                                    icon="oi-arrow-right"/>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
