msgstr ""
"Odpovídající MSH označuje, že na zpětnou zprávu aplikuje alternativní vazbu "
"MEP."

#. module: account_peppol
#. odoo-python
#: code:addons/account_peppol/exceptions.py:0
msgid ""
"A value is set for FragmentCount, but a previously received fragment had a "
"greature value."
msgstr ""
"Pro FragmentCount je nastavena hodnota, ale dříve přijatý fragment měl vyšší "
"hodnotu."

