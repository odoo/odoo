<odoo>
    <template id="portal_my_details" inherit_id="portal.portal_my_details">
        <select name="invoice_sending_method" position="after">
            <div t-if="routing_scheme_list" class="col-xl-6 portal_peppol_toggle">
                <t t-set="current_eas" t-value="(partner_sudo.routing_identifier or '').partition(':')[0]"/>
                <t t-set="current_endpoint" t-value="(partner_sudo.routing_identifier or '').partition(':')[2]"/>
                <label class="col-form-label label-optional" for="routing_scheme">
                    Peppol e-Address (EAS)
                </label>
                <select name="routing_scheme">
                    <option
                        t-foreach="routing_scheme_list"
                        t-as="eas"
                        t-att-value="eas"
                        t-att-selected="(routing_scheme or current_eas) == eas"
                        t-out="eas_value"
                    />
                </select>
                <label class="col-form-label label-optional" for="routing_endpoint">
                    Peppol Endpoint
                </label>
                <input
                    type="text"
                    name="routing_endpoint"
                    t-att-value="routing_endpoint or current_endpoint"
                />
            </div>
        </select>
    </template>
</odoo>
