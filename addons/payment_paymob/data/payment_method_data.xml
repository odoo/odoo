<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- https://developers.paymob.com/egypt/payment-methods -->

    <!-- === PRIMARY PAYMENT METHODS === -->

    <record id="payment_method_aman" model="payment.method">
        <field name="name">Aman</field>
        <field name="code">aman</field>
        <field name="provider_id" ref="payment.payment_provider_paymob"/>
        <field name="image" type="bytes" file="payment/static/img/aman.png"/>
        <field name="supported_country_ids" eval="[Command.set([ref('base.eg')])]"/>
        <field name="supported_currency_ids" eval="[Command.set([ref('base.EGP')])]"/>
    </record>

