<?xml version="1.0" ?>
<odoo>

    <template id="used_gift_card">
        <div class="d-md-block mb-2 small text-muted"
            t-if="line.coupon_id and line.order_id != line.coupon_id.order_id and not line.coupon_id.program_id.is_nominative">
            <span>
                Code:
                <t t-out="line.coupon_id.code[-4:].rjust(14, '⋆')"/>
            </span>
            <t t-if="line.coupon_id.expiration_date">
                <br/>
                <span>
                    Expired Date:
                    <t t-out="line.coupon_id.expiration_date"/>
                </span>
            </t>
        </div>
    </template>

    <template id="sale_purchased_gift_card">
        <t t-set="gift_cards" t-value="order.coupon_point_ids.filtered(lambda pe: pe.coupon_id.program_id.program_type == 'gift_card').coupon_id"/>
        <div class="card mt-3" t-if="gift_cards and order.state in ('sale', 'done')">
            <div class="card-body">
                <h6 t-if="not hide_intro" class="mb-3">
                    Your gift card<t t-if="len(gift_cards) > 1">s are</t><t t-else=""> is</t> ready to use
                </h6>
                <div class="o_purchased_gift_cards row row-cols-2">
                    <t t-foreach="gift_cards" t-as="gift_card">
                        <small t-attf-class="o_purchased_gift_card_label col-12 mb-1 text-muted #{' mt-4' if not gift_card_first else ''}">
                            Gift card <t t-out="gift_card_index + 1"/>:
                            <span class="fw-bold" t-out="gift_card._format_points(order._get_real_points_for_coupon(gift_card, post_confirm=True))"/>
                        </small>
                        <div class="o_purchased_gift_card col-12 col-md-4 col-lg-5 col-xl-4 gap-2 pe-md-0">
                            <div class="d-flex align-items-center justify-content-between border px-2 pe-0 rounded">
                                <span class="mb-0 fs-6 text-nowrap opacity-50" t-out="gift_card.code"/>
                                <button
                                    type="button"
                                    class="copy-to-clipboard btn m-1 border-0 p-0"
                                    t-att-data-clipboard-text="gift_card.code"
                                    title="Copy code"
                                    aria-label="Copy code"
                                >
                                    <i class="fa fa-clone"/>
                                </button>
                            </div>
                        </div>
                        <form class="o_gift_card_send_form col-12 col-md mt-2 mt-md-0">
                            <input
                                type="hidden"
                                name="code"
                                t-att-value="gift_card.code"
                            />
                            <div class="input-group h-100">
                                <input
                                    name="email"
                                    class="form-control"
                                    type="email"
                                    placeholder="Email Address"
                                    required="required"
                                />
                                <button type="submit" class="btn btn-primary text-nowrap">Send as gift</button>
                            </div>
                        </form>
                    </t>
                </div>
            </div>
        </div>
    </template>

    <template id="sale_order_portal_loyalty_content">
        <t t-set="loyalty_data" t-value="sale_order._get_loyalty_data()"/>
        <div t-if="loyalty_data" class="col-xs-5 col-md-6 col-lg-5">
            <table class="table table-sm">
                <tr>
                    <td><strong>Loyalty Card</strong></td>
                </tr>
                <tr t-if="loyalty_data['issued']">
                    <td>Issued</td>
                    <td class="text-end">
                        +<span t-out="loyalty_data['issued']"/>
                        <span class="d-none d-md-inline" t-out="loyalty_data['point_name']"/>
                    </td>
                </tr>
                <tr t-if="loyalty_data['cost']">
                    <td>Used</td>
                    <td class="text-end">
                        -<span t-out="loyalty_data['cost']"/>
                        <span class="d-none d-md-inline" t-out="loyalty_data['point_name']"/>
                    </td>
                </tr>
            </table>
        </div>
    </template>

    <template id="sale_order_portal_content_inherit"
              name="Gift Card Products Portal"
              inherit_id="sale.sale_order_portal_content">
        <xpath expr="//section[@id='details']//td[@name='td_product_name']/*[last()]" position="after">
            <t t-if="line.coupon_id and line.coupon_id.program_id.program_type == 'gift_card'"
               t-call="sale_loyalty.used_gift_card"/>
        </xpath>
        <xpath expr="//div[@id='total']" position="after">
            <t t-call="sale_loyalty.sale_purchased_gift_card" order="sale_order" hide_intro="1"/>
        </xpath>
        <xpath expr="//div[@id='total']/*" position="after">
            <t t-call="sale_loyalty.sale_order_portal_loyalty_content" />
        </xpath>
    </template>

</odoo>
