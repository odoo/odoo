<?xml version="1.0" ?>
<odoo>

    <template id="used_gift_card">
        <div class="d-md-block mb-2 small text-muted"
            t-if="line.coupon_id and line.order_id != line.coupon_id.order_id and not line.coupon_id.program_id.is_nominative">
            <span>
                Code:
                <t t-out="line.coupon_id.code[-4:].rjust(14, '⋆')"/>
            </span>
            <t t-if="line.coupon_id.expiration_date">
                <br/>
                <span>
                    Expired Date:
                    <t t-out="line.coupon_id.expiration_date"/>
                </span>
            </t>
        </div>
    </template>

    <template id="sale_purchased_gift_card">
        <t t-set="gift_cards" t-value="order.coupon_point_ids.filtered(lambda pe: pe.coupon_id.program_id.program_type == 'gift_card').coupon_id"/>
        <div class="card mt-3 " t-if="gift_cards and order.state in ('sale', 'done')">
            <div class="card-body">
                <span t-if="not hide_intro">You will find below your gift cards code. An email has been sent with it. You can use it starting right now.</span>
                <table class="table text-center table-borderless">
                    <thead>
                        <tr>
                            <th class="fw-normal">Gift Card Code</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="range(len(gift_cards))" t-as="gift_card_idx">
                            <t t-set="gift_card" t-value="gift_cards[gift_card_idx]"/>
                            <td class="o_purchased_gift_card">
                                Gift #<t t-out="gift_card_idx + 1"/>
                                (<span t-out="gift_card._format_points(order._get_real_points_for_coupon(gift_card, post_confirm=True))"/>)
                                <strong t-out="gift_card.code"/>
                                <button class="btn btn-sm btn-secondary copy-to-clipboard" t-att-data-clipboard-text="gift_card.code">
                                    <span class="fa fa-clipboard"/> Copy
                                </button>
                            </td>
                        </t>
                    </tbody>
                </table>
            </div>
        </div>
    </template>

    <template id="sale_order_portal_loyalty_content">
        <t t-set="loyalty_data" t-value="sale_order._get_loyalty_data()"/>
        <t t-set="has_issued" t-value="loyalty_data and loyalty_data['issued']"/>
        <t t-set="has_cost" t-value="loyalty_data and loyalty_data['cost']"/>
        <!-- Only issued -->
        <div t-if="has_issued and not has_cost" class="d-flex flex-column gap-1">
            <hr/>
            <strong class="smaller text-uppercase text-muted">Loyalty Card</strong>
            <div class="small">
                <span class="text-success fs-5">
                    +<t t-out="loyalty_data['issued']"/> 
                </span>
                <span class="text-muted"><t t-out="loyalty_data['point_name']"/></span>
            </div>
        </div>
        <!-- Only used -->
        <div t-elif="has_cost and not has_issued" class="d-flex flex-column gap-1">
            <hr/>
            <strong class="smaller text-uppercase text-muted">Loyalty Card</strong>
            <div class="small">
                <span class="text-danger fs-5">
                    −<t t-out="loyalty_data['cost']"/>
                </span>
                <span class="text-muted small"><t t-out="loyalty_data['point_name']"/></span>
            </div>
        </div>
        <!-- Both issued and used -->
        <div t-elif="has_issued and has_cost" class="d-flex flex-column gap-1">
            <hr/>
            <strong class="smaller text-uppercase text-muted">Loyalty Card</strong>
            <div class="d-flex justify-content-between align-items-baseline">
                <small class="text-muted">Issued</small>
                <small class="text-reset">
                    <t t-out="loyalty_data['issued']"/> <t t-out="loyalty_data['point_name']"/>
                </small>
            </div>
            <div class="d-flex justify-content-between align-items-baseline">
                <small class="text-muted">Used</small>
                <small class=" text-danger">
                    −<t t-out="loyalty_data['cost']"/> <t t-out="loyalty_data['point_name']"/>
                </small>
            </div>
            <t t-set="net" t-value="round(loyalty_data['issued'] - loyalty_data['cost'], 2)"/>
            <div class="d-flex justify-content-between align-items-baseline">
                <small class="fw-bold">Total</small>
                <small t-attf-class=" {{ 'text-success' if net >= 0 else 'text-danger' }}">
                    <t t-if="net >= 0"></t><t t-out="net"/> <t t-out="loyalty_data['point_name']"/>
                </small>
            </div>
        </div>
    </template>

    <template id="sale_order_portal_content_inherit"
              name="Gift Card Products Portal"
              inherit_id="sale.sale_order_portal_content">
        <xpath expr="//section[@id='details']//td[@name='td_product_name']/*[last()]" position="after">
            <t t-if="line.coupon_id and line.coupon_id.program_id.program_type == 'gift_card'"
               t-call="sale_loyalty.used_gift_card"/>
        </xpath>
        <xpath expr="//div[@id='total']" position="after">
            <t t-call="sale_loyalty.sale_purchased_gift_card" order="sale_order" hide_intro="1"/>
        </xpath>
    </template>

    <template id="sale_order_portal_template_inherit_loyalty"
              name="Loyalty Points Sidebar"
              inherit_id="sale.sale_order_portal_template">
        <xpath expr="//div[@id='sidebar_loyalty_anchor']" position="after">
            <t t-call="sale_loyalty.sale_order_portal_loyalty_content"/>
        </xpath>
    </template>

    <template id="sale_order_portal_template_inherit_loyalty_mobile"
              name="Loyalty Points Mobile Bar"
              inherit_id="sale.sale_order_portal_template">
        <xpath expr="//div[@id='mobile_action_bar']//span[hasclass('fw-bold') and hasclass('fs-5')]" position="after">
            <t t-set="mobile_loyalty" t-value="sale_order._get_loyalty_data()"/>
            <t t-if="mobile_loyalty">
                <t t-set="mobile_loyalty_net" t-value="round(mobile_loyalty['issued'] - mobile_loyalty['cost'], 2)"/>
                <t t-if="mobile_loyalty_net">
                    <span class="ms-auto d-inline-flex align-items-center gap-1 small text-nowrap">
                        <i class="fa fa-star text-warning"/>
                        <span t-attf-class="fw-semibold {{ 'text-success' if mobile_loyalty_net > 0 else 'text-danger' }}">
                            <t t-if="mobile_loyalty_net > 0">+</t><t t-out="mobile_loyalty_net"/>
                        </span>
                        <span class="text-muted"><t t-out="mobile_loyalty['point_name']"/></span>
                    </span>
                </t>
            </t>
        </xpath>
    </template>

</odoo>
