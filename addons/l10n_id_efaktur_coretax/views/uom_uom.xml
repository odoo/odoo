<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="uom_uom_view_form" model="ir.ui.view">
        <field name="name">uom.uom.view.form.inherit.l10n.id.efaktur.coretax</field>
        <field name="model">uom.uom</field>
        <field name="inherit_id" ref="uom.uom_uom_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='relative_factor']" position="after">
                <field name="l10n_id_uom_code" invisible="'ID' not in fiscal_country_codes"/>
            </xpath>
        </field>
    </record>
</odoo>
