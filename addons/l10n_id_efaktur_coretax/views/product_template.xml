<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_inherit" model="ir.ui.view">
        <field name="name">product.template.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='invoicing']//group[@name='accounting']" position="inside">
                <group name="l10n_id_product" string="E-Faktur" invisible="'ID' not in fiscal_country_codes">
                    <field name="l10n_id_product_code"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
