<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_move_form" model="ir.ui.view">
            <field name="name">account.view.move.form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <div name="journal_div" position="after">
                    <label for="l10n_sa_invoice_type"
                           string="Invoice Type"
                           invisible="move_type not in ['out_invoice', 'out_refund'] or not l10n_sa_compliance_checks_passed or not l10n_sa_is_csid_ready"/>
                    <div name="invoice_type"
                         class="d-flex"
                         invisible="move_type not in ['out_invoice', 'out_refund'] or not l10n_sa_compliance_checks_passed or not l10n_sa_is_csid_ready">
                        <field name="l10n_sa_invoice_type" style="width: 150px;" readonly="state != 'draft'"/>
                        <span class="o_form_label mx-3 oe_edit_only text-center" style="width: 6ch;"
                              invisible="state != 'draft' and not l10n_sa_edi_transaction_type_ids">with</span>
                        <field name="l10n_sa_edi_transaction_type_ids"
                               string="Transaction Type"
                               widget="many2many_tags"
                               options="{'no_create': True, 'no_open': True, 'no_edit': True}"
                               placeholder="Leave empty if not applicable"
                               readonly="state != 'draft'"/>
                    </div>
                </div>
                <field name="l10n_sa_confirmation_datetime" position="before">
                    <field name="l10n_sa_edi_supply_end_date"
                           string="Supply End Date"
                           readonly="state != 'draft'"
                           invisible="not show_delivery_date or country_code != 'SA'"/>
                </field>
                <notebook position="inside">
                    <page string="ZATCA" name="l10n_sa_edi_zatca_page" invisible="not l10n_sa_edi_log_ids">
                        <field name="l10n_sa_edi_log_ids">
                            <list editable="bottom" open_form_view="False">
                                <field name="message" column_invisible="1"/>
                                <field name="create_date" string="Date"/>
                                <field name="state" widget="account_document_state"/>
                                <field name="attachment_name" string="File"/>
                                <button name="action_retry" string="Retry" type="object"
                                    invisible="
                                        state != 'rejected'
                                        or parent.state == 'draft'
                                        or l10n_sa_edi_document_id != parent.l10n_sa_edi_document_id
                                    "/>
                                <button name="action_retry" string="Process" type="object" invisible="document_state != 'unknown' or parent.state == 'draft'"/>
                                <field name="is_test" optional="True"/>
                            </list>
                        </field>
                    </page>
                </notebook>
            </field>
        </record>

        <record id="view_invoice_tree" model="ir.ui.view">
            <field name="name">account.invoice.list</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_invoice_tree"/>
            <field name="arch" type="xml">
                <field name="status_in_payment" position="before">
                    <field name="l10n_sa_edi_state" optional="hide"/>
                </field>
            </field>
        </record>

        <record id="view_account_invoice_filter" model="ir.ui.view">
            <field name="name">account.invoice.select</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_account_invoice_filter"/>
            <field name="arch" type="xml">
                <filter name="group_by_company" position="after">
                    <filter string="ZATCA State" name="group_by_l10n_sa_edi_state" domain="[]" context="{'group_by': 'l10n_sa_edi_state'}"/>
                </filter>
                <filter name="late" position="after">
                    <separator/>
                    <filter string="ZATCA Test" name="l10n_sa_edi_test" domain="[('l10n_sa_is_test', '=', True)]"/>
                </filter>
            </field>
        </record>
    </data>
</odoo>
