<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_payment_method_view_form_inherit_bancontact_pay" model="ir.ui.view">
        <field name="name">pos.payment.method.form.inherit.bancontact_pay</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <notebook invisible="payment_provider != 'bancontact_pay'">
                    <page name="settings" string="Bancontact Pay">
                        <group>
                            <field name="bancontact_api_key" password="True" invisible="payment_provider != 'bancontact_pay'" required="payment_provider == 'bancontact_pay'"/>
                            <field name="bancontact_ppid" invisible="payment_provider != 'bancontact_pay'" required="payment_provider == 'bancontact_pay'"/>
                            <field name="bancontact_usage" invisible="payment_provider != 'bancontact_pay'"/>
                            <field name="bancontact_test_mode" invisible="payment_provider != 'bancontact_pay'" required="payment_provider == 'bancontact_pay'"/>
                            <button name="download_bancontact_sticker" type="object" string="Download Sticker" class="btn btn-primary" invisible="payment_provider != 'bancontact_pay' or bancontact_usage != 'sticker'"/>
                        </group>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>
</odoo>
