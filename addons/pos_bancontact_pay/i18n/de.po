#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/errors/http.py:0
msgid "Bancontact is currently unavailable. Please try again later."
msgstr ""
"Bancontact ist derzeit nicht verfügbar. Bitte versuchen Sie es später erneut."

#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/models/pos_payment_method.py:0
msgid ""
"Bancontact payments can only be cancelled for payment methods using "
"Bancontact Pay as provider."
msgstr ""
"Bancontact-Zahlungen können nur für Zahlungsmethoden storniert werden, die "
"Bancontact Pay als Anbieter verwenden."

#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/models/pos_payment_method.py:0
msgid ""
"Bancontact payments can only be created for payment methods using Bancontact "
"Pay as provider."
msgstr ""
"Bancontact-Zahlungen können nur für Zahlungsmethoden erstellt werden, die "
"Bancontact Pay als Anbieter verwenden."

#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/models/pos_payment_method.py:0
msgid ""
"Bancontact sticker URL can only be generated for payment methods configured "
"with 'Static Sticker' usage."
msgstr ""
"Die Bancontact-Aufkleber-URL kann nur für Zahlungsmethoden generiert werden, "
"die für die Verwendung von „Static Sticker“ konfiguriert sind."

#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/models/pos_payment_method.py:0
msgid ""
"Bancontact sticker URL can only be generated for payment methods using "
"Bancontact Pay as provider."
msgstr ""
"Die Bancontact-Aufkleber-URL kann nur für Zahlungsmethoden generiert werden, "
"die Bancontact Pay als Anbieter verwenden."

