#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/models/pos_payment_method.py:0
msgid ""
"Bancontact payments can only be cancelled for payment methods using "
"Bancontact Pay as provider."
msgstr ""
"Os pagamentos Bancontact só podem ser cancelados para métodos de pagamento "
"que utilizem o Bancontact Pay como provedor."

#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/models/pos_payment_method.py:0
msgid ""
"Bancontact payments can only be created for payment methods using Bancontact "
"Pay as provider."
msgstr ""
"Os pagamentos Bancontact só podem ser criados para métodos de pagamento que "
"utilizem o Bancontact Pay como provedor."

#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/models/pos_payment_method.py:0
msgid ""
"Bancontact sticker URL can only be generated for payment methods configured "
"with 'Static Sticker' usage."
msgstr ""
"A URL do adesivo Bancontact só pode ser gerada para métodos de pagamento "
"configurados com o uso de 'Adesivo Estático'."

#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/models/pos_payment_method.py:0
msgid ""
"Bancontact sticker URL can only be generated for payment methods using "
