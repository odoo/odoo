#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/models/res_company.py:0
msgid ""
"A Bancontact Pay payment method is linked to a journal that uses the "
"company's default currency.\n"
"This currency is not supported.\n"
"Supported currencies: %(currencies)s."
msgstr ""
"Bancontact Payの支払い方法は、会社のデフォルト通貨を使用する仕訳帳に紐付けら"
"れています。\n"
"この通貨はサポートされていません。\n"
"サポートされている通貨：%(currencies)s 。"

#. module: pos_bancontact_pay
#. odoo-javascript
#: code:addons/pos_bancontact_pay/static/src/app/pos_store.js:0
msgid "A payment for order %s has expired."
msgstr "オーダ%s に対する支払期限が切れています。"

#. module: pos_bancontact_pay
#. odoo-javascript
#: code:addons/pos_bancontact_pay/static/src/app/pos_store.js:0
msgid "A payment for order %s has failed."
msgstr "オーダ%s に対する支払いに失敗しました。"

#. module: pos_bancontact_pay
#. odoo-javascript
#: code:addons/pos_bancontact_pay/static/src/app/pos_store.js:0
msgid "A payment for order %s was cancelled."
msgstr "オーダ%s に対する支払いがキャンセルされました。"

#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/errors/http.py:0
msgid "Access denied. Please check your Bancontact permissions."
msgstr "アクセスが拒否されました。Bancontactの権限設定をご確認ください。"

#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/errors/http.py:0
msgid "Authentication with Bancontact failed. Please verify your API key."
msgstr "Bancontact による認証が失敗しました。API キーを確認してください。"

#. module: pos_bancontact_pay
#: model:ir.model.fields,field_description:pos_bancontact_pay.field_pos_payment_method__bancontact_api_key
msgid "Bancontact API Key"
msgstr "Bancontact API キー"

#. module: pos_bancontact_pay
#: model:ir.model.fields,field_description:pos_bancontact_pay.field_pos_payment__bancontact_id
msgid "Bancontact ID"
msgstr "Bancontact ID"

