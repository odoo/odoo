#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/models/pos_payment_method.py:0
msgid ""
"One Bancontact Pay sticker payment method can only be linked to one POS "
"configuration."
msgstr ""
"1つのBancontact Payステッカーの支払い方法は、1つのPOS設定にのみリンクできます"
"。"

#. module: pos_bancontact_pay
#. odoo-javascript
#: code:addons/pos_bancontact_pay/static/src/app/payment_bancontact.js:0
