#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/errors/http.py:0
msgid ""
"Merchant profile not found on Bancontact. Please check your Payment Profile "
"ID (ppid)."
msgstr ""
"Bancontact に販売者プロファイルが見つかりません。お支払いプロファイル ID "
"(ppid) をご確認ください。"

#. module: pos_bancontact_pay
#. odoo-javascript
#: code:addons/pos_bancontact_pay/static/src/app/payment_bancontact.js:0
msgid "Oh snap !"
msgstr "ご確認ください!"

#. module: pos_bancontact_pay
#: model:ir.model.fields.selection,name:pos_bancontact_pay.selection__pos_payment_method__bancontact_usage__display
