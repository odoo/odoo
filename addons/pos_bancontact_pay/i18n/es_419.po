#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/errors/http.py:0
msgid "Bancontact is currently unavailable. Please try again later."
msgstr ""
"Bancontact no está disponible por el momento. Inténtalo de nuevo más tarde."

#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/models/pos_payment_method.py:0
msgid ""
"Bancontact payments can only be cancelled for payment methods using "
"Bancontact Pay as provider."
msgstr ""
"Los pagos con Bancontact solo pueden cancelarse en los métodos de pago que "
"usan Bancontact Pay como proveedor."

#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/models/pos_payment_method.py:0
msgid ""
"Bancontact payments can only be created for payment methods using Bancontact "
"Pay as provider."
msgstr ""
"Los pagos con Bancontact solo pueden crearse en los métodos de pago que usan "
"Bancontact Pay como proveedor."

#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/models/pos_payment_method.py:0
msgid ""
"Bancontact sticker URL can only be generated for payment methods configured "
"with 'Static Sticker' usage."
msgstr ""
"Solo es posible generar la URL de la etiqueta de Bancontact para los métodos "
"de pago configurados con el uso \"Etiqueta estática\"."

#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/models/pos_payment_method.py:0
msgid ""
"Bancontact sticker URL can only be generated for payment methods using "
"Bancontact Pay as provider."
msgstr ""
"Solo es posible generar la URL de la etiqueta de Bancontact para los métodos "
"de pago que usen Bancontact Pay como proveedor."

