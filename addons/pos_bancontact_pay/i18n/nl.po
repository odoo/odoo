#. odoo-python
#: code:addons/pos_bancontact_pay/errors/http.py:0
msgid "Bancontact is currently unavailable. Please try again later."
msgstr "Bancontact is momenteel niet beschikbaar. Probeer het later nog eens."

#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/models/pos_payment_method.py:0
msgid ""
"Bancontact payments can only be cancelled for payment methods using "
"Bancontact Pay as provider."
msgstr ""
"Bancontact-betalingen kunnen alleen worden geannuleerd voor betaalmethoden "
"die Bancontact Pay als provider gebruiken."

#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/models/pos_payment_method.py:0
msgid ""
"Bancontact payments can only be created for payment methods using Bancontact "
"Pay as provider."
msgstr ""
"Bancontact-betalingen kunnen alleen worden aangemaakt voor betaalmethoden "
"die Bancontact Pay als provider gebruiken."

#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/models/pos_payment_method.py:0
msgid ""
"Bancontact sticker URL can only be generated for payment methods configured "
"with 'Static Sticker' usage."
msgstr ""
"De URL van de Bancontact-sticker kan alleen worden gegenereerd voor "
"betaalmethoden die zijn geconfigureerd met het gebruik van 'Vaste sticker'."

#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/models/pos_payment_method.py:0
msgid ""
"Bancontact sticker URL can only be generated for payment methods using "
"Bancontact Pay as provider."
msgstr ""
"De URL voor de Bancontact-sticker kan alleen worden gegenereerd voor "
"betaalmethoden die Bancontact Pay als provider gebruiken."

