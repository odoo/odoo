msgstr ""
"Bancontact est actuellement indisponible. Veuillez réessayer plus tard."

#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/models/pos_payment_method.py:0
msgid ""
"Bancontact payments can only be cancelled for payment methods using "
"Bancontact Pay as provider."
msgstr ""
"Les paiements Bancontact peuvent uniquement être annulés pour les méthodes "
"de paiement utilisant Bancontact Pay comme fournisseur."

#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/models/pos_payment_method.py:0
msgid ""
"Bancontact payments can only be created for payment methods using Bancontact "
"Pay as provider."
msgstr ""
"Les paiements Bancontact peuvent uniquement être créés pour les méthodes de "
"paiement utilisant Bancontact Pay comme fournisseur."

#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/models/pos_payment_method.py:0
msgid ""
"Bancontact sticker URL can only be generated for payment methods configured "
"with 'Static Sticker' usage."
msgstr ""
"L'URL du sticker Bancontact peut uniquement être générée pour les méthodes "
"de paiement configurées avec l'utilisation \"Sticker statique\"."

#. module: pos_bancontact_pay
#. odoo-python
#: code:addons/pos_bancontact_pay/models/pos_payment_method.py:0
msgid ""
"Bancontact sticker URL can only be generated for payment methods using "
"Bancontact Pay as provider."
msgstr ""
"L'URL du sticker Bancontact peut uniquement être générée pour les méthodes "
"de paiement utilisant Bancontact Pay comme fournisseur."

