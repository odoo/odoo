"        <span style=\"display: block; margin-bottom: 8px;\">Hello <t t-"
"out=\"object.common_name or ''\">Wood Corner</t>,</span>\n"
"\n"
"        <t t-if=\"not target_responsible\">\n"
"            <t t-if=\"not object.event_id.user_id.active\">\n"
