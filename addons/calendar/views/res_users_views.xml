<?xml version="1.0"?>
<odoo>
    <data>
        <record id="res_users_form_view_calendars" model="ir.ui.view">
            <field name="name">res.users.preferences.form.inherit</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form_simple_modif"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@name='calendar_preferences']" position="inside">
                    <field name="calendar_ids" options='{"no_open": True, "no_create": True}'
                           invisible="share" nolabel="1" colspan="2"/>
                </xpath>
            </field>
        </record>
        <!-- Update User form !-->
        <record id="res_users_form_view" model="ir.ui.view">
            <field name="name">res.users.form.calendar</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@name='calendar_preferences']" position="inside">
                    <field name="calendar_ids" options='{"no_open": True, "no_create": True}'
                           invisible="share" nolabel="1" colspan="2"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
