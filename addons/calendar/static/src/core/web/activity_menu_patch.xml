<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="mail.ActivityMenu" t-inherit-mode="extension">
        <xpath expr="//*[@name='activityTitle']" position="after">
            <div t-if="group.type === 'meeting'">
                <t t-foreach="group.meetings" t-as="meeting" t-key="meeting.id">
                    <div class="o-calendar-meeting d-flex px-2 gap-2">
                        <span class="flex-grow-1 text-muted text-truncate" t-out="meeting.name"/>
                        <span t-if="meeting.formattedStart" class="btn btn-link p-0 text-nowrap"
                            t-custom-click.stop="(ev, isMiddleClick) => this.openCalendarMeeting(meeting.id, isMiddleClick)">
                            <t t-if="meeting.allday">All Day</t>
                            <t t-else=''>
                                <t t-out="meeting.formattedStart"/>
                            </t>
                        </span>
                    </div>
                </t>
            </div>
        </xpath>
    </t>
</templates>
