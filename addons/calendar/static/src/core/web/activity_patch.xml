<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-inherit="mail.Activity" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o-mail-Activity-note')]" position="attributes">
            <attribute name="t-if">!this.props.activity.calendar_event_id</attribute>
        </xpath>
        <xpath expr="//div[hasclass('o-mail-Activity-note')]" position="after">
            <div t-if="this.meeting" class="mt-1">
                <t t-set="startToday" t-value="this.isToday(this.meeting.start)"/>
                <t t-set="stopToday" t-value="this.isToday(this.meeting.stop)"/>
                <div t-if="!startToday || !stopToday">
                    <t t-if="startToday">Today</t>
                    <t t-else="" t-out="this.meeting.start.toLocaleString(this.dateFormat)"/>
                    <t t-if="this.meeting.stop > this.meeting.start.startOf('day').plus({days: 1})">
                        -
                        <t t-if="stopToday">Today</t>
                        <t t-else="" t-out="this.meeting.stop.toLocaleString(this.dateFormat)"/>
                    </t>
                </div>
                <div class="d-flex flex-nowrap gap-4">
                    <t t-out="this.meeting.start.toLocaleString(this.timeFormat)"/> - <t t-out="this.meeting.stop.toLocaleString(this.timeFormat)"/>
                    <span t-if="this.attendeeNames" t-out="this.truncatedAttendeeNames" t-att-title="this.attendeeNames" class="text-muted"/>
                </div>
                <t t-if="this.meeting.location" t-out="this.meeting.location"/>
                <t t-else="">Online</t>
            </div>
        </xpath>
        <xpath expr="//button[hasclass('o-mail-Activity-edit')]" position="attributes">
            <attribute name="t-if">!this.props.activity.calendar_event_id</attribute>
        </xpath>
        <xpath expr="//button[hasclass('o-mail-Activity-edit')]" position="after">
            <button t-if="this.props.activity.calendar_event_id" class="btn btn-link p-0 me-3" t-on-click="this.onClickReschedule">
                <i class="oi oi-filled" data-icon="calendar_today"/> View
            </button>
        </xpath>
    </t>

</templates>
