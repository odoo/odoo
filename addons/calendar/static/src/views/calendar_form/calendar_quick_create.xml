<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="calendar.CalendarQuickCreateHeader" t-inherit="web.Dialog.header" t-inherit-mode="extension">
        <xpath expr="//button[hasclass('o_expand_button')]" position="replace"/>
    </t>
    <t t-name="calendar.CalendarQuickCreateButtons" t-inherit="web.FormViewDialog.ToOne.buttons">
        <xpath expr="//button[hasclass('o_form_button_save')]" position="after">
            <button class="btn btn-secondary" t-on-click="this.goToFullEvent">More Options</button>
        </xpath>
        <xpath expr="//button[hasclass('o_form_button_cancel')]" position="attributes">
            <attribute name="class" add="ms-auto" separator=" "/>
        </xpath>
        <xpath expr="//button[hasclass('o_form_button_remove')]" position="replace"/>
    </t>
</templates>
