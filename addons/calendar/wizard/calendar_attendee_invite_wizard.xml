<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="calendar_attendee_invite_wizard_view_form" model="ir.ui.view">
        <field name="name">calendar.attendee.invite.wizard.form</field>
        <field name="model">calendar.attendee.invite.wizard</field>
        <field name="arch" type="xml">
            <form string="Send Invitations">
                Would you like to send invitation emails to attendees?
                <field name="calendar_attendee_ids" invisible="1"/>
                <footer>
                    <button string="Send" name="action_send" type="object" class="btn-primary"/>
                    <button string="Don't send" name="action_close" type="object" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
