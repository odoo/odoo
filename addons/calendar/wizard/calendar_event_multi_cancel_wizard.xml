<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="calendar_event_multi_cancel_wizard_view_form" model="ir.ui.view">
        <field name="name">calendar_event_multi_cancel_wizard_view_form</field>
        <field name="model">calendar.event.multi.cancel.wizard</field>
        <field name="arch" type="xml">
            <form string="Cancel Events">
                <p class="alert alert-warning" role="alert">Are you sure you want to <field name="requested_action" readonly="1"/> those events?</p>
                Notify attendees of<span invisible="is_user_admin"> events you organized</span> that the event was canceled?
                <field name="cancel_wizard_ids" invisible="1">
                    <list>
                        <field name="body"/>
                        <field name="calendar_event_id"/>
                        <field name="recipient_ids"/>
                        <field name="subject"/>
                    </list>
                </field>
                <footer>
                    <button string="Send and delete" name="action_send_mails_and_delete" type="object" class="btn-primary" invisible="requested_action != 'delete'"/>
                    <button string="Delete" name="action_delete" type="object" class="btn-primary" invisible="requested_action != 'delete'"/>
                    <button string="Send and cancel" name="action_send_mails_and_cancel" type="object" class="btn-primary" invisible="requested_action != 'cancel'"/>
                    <button string="Cancel" name="action_cancel" type="object" class="btn-primary" invisible="requested_action != 'cancel'"/>
                    <button special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
