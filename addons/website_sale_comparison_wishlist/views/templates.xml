<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="product_wishlist" inherit_id="website_sale_wishlist.product_wishlist">
        <xpath
            expr="//div[hasclass('o_wsale_wish_list_content')]//t[@t-call='website_sale_wishlist.product_wishlist_cta']"
            position="after"
        >
            <t
                t-set="categories"
                t-value="wish.product_id.product_tmpl_id.valid_product_template_attribute_line_ids._prepare_categories_for_display()"
            />
            <t
                t-set="product_variant_id"
                t-value="wish.product_id.product_tmpl_id._get_first_possible_variant_id()"
            />
            <button
                t-if="is_view_active('website_sale_comparison.add_to_compare') and product_variant_id and categories"
                type="button"
                title="Add to compare"
                class="btn btn-outline-primary o_add_to_compare"
                t-att-data-product-id='wish.product_id.id'>
                <i class="fa fa-exchange" role="img"/>
            </button>
        </xpath>
        <xpath
            expr="//div[hasclass('o_wsale_wish_grid_content')]//div[@t-call='website_sale_wishlist.product_wishlist_cta']"
            position="before"
        >
            <t
                t-set="categories"
                t-value="wish.product_id.product_tmpl_id.valid_product_template_attribute_line_ids._prepare_categories_for_display()"
            />
            <t
                t-set="product_variant_id"
                t-value="wish.product_id.product_tmpl_id._get_first_possible_variant_id()"
            />
            <button
                t-if="is_view_active('website_sale_comparison.add_to_compare') and product_variant_id and categories"
                type="button"
                title="Add to compare"
                class="btn btn-outline-primary o_add_to_compare w-100"
                t-att-data-product-id='wish.product_id.id'>
                    <i class="fa fa-exchange me-2" role="img"/>Compare
            </button>
        </xpath>
    </template>
</odoo>
