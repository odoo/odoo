<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_payment_register_form" model="ir.ui.view">
        <field name="name">account.payment.register.form</field>
        <field name="model">account.payment.register</field>
        <field name="inherit_id" ref="l10n_account_withholding_tax.view_account_payment_register_form"/>
        <field name="arch" type="xml">
            <label for="withholding_net_amount" position="replace">
                <label string="Net Amount" for="withholding_net_amount" invisible="l10n_latam_move_check_ids or l10n_latam_new_check_ids"/>
                <label string="Check amount" for="withholding_net_amount" invisible="not l10n_latam_move_check_ids and not l10n_latam_new_check_ids"/>
            </label>
        </field>
    </record>
</odoo>
