<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tax_form-l10n_ar" model="ir.ui.view">
        <field name="name">account.tax.form.l10n_ar.inherit</field>
        <field name="model">account.tax</field>
        <field name="inherit_id" ref="account.view_tax_form"/>
        <field name="arch" type="xml">
            <field name="amount_type" position="attributes">
                <attribute name="invisible" separator="or" add="l10n_ar_tax_type == 'earnings_scale'"/>
            </field>
            <label for="amount" position="attributes">
                <attribute name="invisible" separator="or" add="l10n_ar_tax_type == 'earnings_scale'"/>
            </label>
            <xpath expr="//field[@name='amount']/.." position="attributes">
                <attribute name="invisible" separator="or" add="l10n_ar_tax_type == 'earnings_scale'"/>
            </xpath>
            <field name="name" position="after">
                <field name="l10n_ar_tax_type" invisible="not is_withholding_tax_on_payment or country_code != 'AR'"/>
                <field name="l10n_ar_scale_id" invisible="l10n_ar_tax_type != 'earnings_scale'" required="l10n_ar_tax_type == 'earnings_scale'" options="{'no_create': True}"/>
            </field>
            <xpath expr="//field[@name='amount']/.." position="after">
                <field name="l10n_ar_state_id" invisible="l10n_ar_tax_type not in ['iibb_untaxed', 'iibb_total']" required="l10n_ar_tax_type in ['iibb_untaxed', 'iibb_total']" options="{'no_create': True}"/>
                <field name="l10n_ar_non_taxable_amount" invisible="country_code != 'AR' or not is_withholding_tax_on_payment or type_tax_use != 'purchase'"/>
                <field name="l10n_ar_minimum_threshold" invisible="country_code != 'AR' or not is_withholding_tax_on_payment or type_tax_use != 'purchase'"/>
                <field name="l10n_ar_code" invisible="l10n_ar_tax_type not in ['earnings', 'earnings_scale'] or not is_withholding_tax_on_payment or type_tax_use != 'purchase'" required="l10n_ar_tax_type in ['earnings', 'earnings_scale'] and is_withholding_tax_on_payment and type_tax_use == 'purchase'"/>
            </xpath>
        </field>
    </record>
</odoo>
