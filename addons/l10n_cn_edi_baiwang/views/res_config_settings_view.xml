<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_l10n_cn_baiwang" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.l10n_cn_baiwang</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='account_vendor_bills']" position="after">
                <block title="China Electronic Invoicing (Baiwang)" id="china_edi" invisible="country_code != 'CN'">
                    <setting string="Baiwang Integration Mode" company_dependent="1" help="Configure Baiwang e-Fapiao integration for automated invoice issuance.">
                        <div class="content-group">
                            <field name="l10n_cn_edi_mode" widget="radio"/>
                        </div>
                        <div class="mt8 text-muted" invisible="l10n_cn_edi_mode == 'prod'">
                            In Test mode, e-Fapiao requests are sent to the Baiwang sandbox environment.
                        </div>
                        <div class="content-group mt16" invisible="not l10n_cn_edi_mode">
                            <div class="row mt8">
                                <label for="l10n_cn_baiwang_app_key" class="col-lg-4 o_light_label"/>
                                <field name="l10n_cn_baiwang_app_key" placeholder="10000000"/>
                            </div>
                            <div class="row mt8">
                                <label for="l10n_cn_baiwang_app_secret" class="col-lg-4 o_light_label"/>
                                <field name="l10n_cn_baiwang_app_secret" password="True" placeholder="0e32b1ce-b0e7-4b45-a4de-07a2fbc3147a"/>
                            </div>
                            <div class="row mt8">
                                <label for="l10n_cn_baiwang_username" class="col-lg-4 o_light_label"/>
                                <field name="l10n_cn_baiwang_username" placeholder="user"/>
                            </div>
                            <div class="row mt8">
                                <label for="l10n_cn_baiwang_password" class="col-lg-4 o_light_label"/>
                                <field name="l10n_cn_baiwang_password" password="True" placeholder="password (hashed automatically)"/>
                            </div>
                            <div class="row mt8">
                                <label for="l10n_cn_baiwang_salt" class="col-lg-4 o_light_label"/>
                                <field name="l10n_cn_baiwang_salt" password="True" placeholder="0895205868F79DAF65C08C97A44302BB "/>
                            </div>
                            <div class="row mt8">
                                <label for="l10n_cn_baiwang_org_auth_code" class="col-lg-4 o_light_label"/>
                                <field name="l10n_cn_baiwang_org_auth_code" placeholder="c7ed317328e8888afeeb2ac59c1b5436"/>
                            </div>
                            <div class="row mt8">
                                <label for="l10n_cn_baiwang_invoice_terminal_code" class="col-lg-4 o_light_label"/>
                                <field name="l10n_cn_baiwang_invoice_terminal_code" placeholder="532dzp"/>
                            </div>
                            <div class="mt16">
                                <button name="action_l10n_cn_baiwang_test_connection"
                                        type="object"
                                        string="Test Connection"
                                        class="btn-primary"
                                        icon="fa-plug"/>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
