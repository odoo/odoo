<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_inherit_baiwang" model="ir.ui.view">
        <field name="name">product.template.form.inherit.baiwang</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_information']" position="inside">
                <group string="China Golden Tax (Baiwang)">
                    <label for="l10n_cn_tax_category_code"/>
                    <div class="o_row">
                        <field name="l10n_cn_tax_category_code" placeholder="1090522050000000000"/>
                        <button name="action_fetch_baiwang_tax_code" 
                                type="object" 
                                string="Fetch Category from Baiwang" 
                                class="btn-secondary"/>
                    </div>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
