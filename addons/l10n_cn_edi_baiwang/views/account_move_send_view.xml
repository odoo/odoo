<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_move_send_inherit_baiwang" model="ir.ui.view">
        <field name="name">account.move.send.inherit.baiwang</field>
        <field name="model">account.move.send</field>
        <field name="inherit_id" ref="account.account_move_send_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='option_send_mail']" position="after">
                <field name="enable_l10n_cn_baiwang" invisible="1"/>
                <div name="option_baiwang" 
                     invisible="not enable_l10n_cn_baiwang">
                    <field name="checkbox_l10n_cn_baiwang"/>
                    <label for="checkbox_l10n_cn_baiwang"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
