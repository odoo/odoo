<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_move_form_inherit_l10n_cn_baiwang" model="ir.ui.view">
        <field name="name">account.move.form.inherit.l10n_cn_baiwang</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            
            <xpath expr="//header" position="inside">
                <button name="action_request_baiwang_red_form" 
                        string="Request Baiwang Red Form" 
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'draft' or move_type != 'out_refund' or country_code != 'CN'"/>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="China E-Fapiao" 
                      name="china_e_fapiao" 
                      invisible="country_code != 'CN' or move_type not in ('out_invoice', 'out_refund')">
                    
                    <group invisible="move_type != 'out_invoice'">
                        <group string="Standard Fapiao Details">
                            <field name="l10n_cn_fapiao_number" readonly="1"/>
                            <field name="l10n_cn_fapiao_date" readonly="1"/>
                        </group>
                    </group>

                    <group string="Red Form (Credit Note) Requests" invisible="move_type != 'out_refund'">
                        <field name="l10n_cn_edi_document_ids" nolabel="1" readonly="1">
                            <list decoration-success="state == 'red_form_confirmed'" 
                                  decoration-warning="state == 'red_form_pending'" 
                                  decoration-danger="state == 'failed'">
                                <field name="create_date" string="Requested On"/>
                                <field name="baiwang_uuid"/>
                                <field name="baiwang_red_form_number"/>
                                <field name="state" widget="badge"/>
                                <field name="error_message" optional="hide"/>
                            </list>
                        </field>
                    </group>

                </page>
            </xpath>

        </field>
    </record>
</odoo>
