<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_move_form_inherit_l10n_cn_baiwang" model="ir.ui.view">
        <field name="name">account.move.form.inherit.l10n_cn_baiwang</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//widget[@name='web_ribbon']" position="before">
                <widget name="web_ribbon" title="Red Form Requested" bg_color="text-bg-info"
                        invisible="move_type != 'out_refund' or l10n_cn_baiwang_state != 'sent'"/>
                <widget name="web_ribbon" title="Red Form Rejected" bg_color="text-bg-warning"
                        invisible="move_type != 'out_refund' or l10n_cn_baiwang_state != 'failed'"/>
            </xpath>

            <!-- Header button: Request Red Form for Credit Notes -->
            <xpath expr="//header" position="inside">
                <button name="action_request_baiwang_red_form"
                        string="Send Red Form"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'draft' or move_type != 'out_refund' or not l10n_cn_baiwang_red_form_required or l10n_cn_baiwang_state in ('sent', 'issued')"/>
            </xpath>

            <xpath expr="//button[@name='action_post']" position="attributes">
                <attribute name="invisible">hide_post_button or move_type == 'entry' or display_inactive_currency_warning or (l10n_cn_baiwang_red_form_required and l10n_cn_baiwang_state != 'issued')</attribute>
            </xpath>

            <!-- Baiwang E-Fapiao tab in notebook -->
            <xpath expr="//field[@name='l10n_cn_fapiao']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='l10n_cn_fapiao']" position="after">
                <field name="l10n_cn_baiwang_invoice_type_code" 
                       invisible="country_code != 'CN' or move_type not in ('out_invoice', 'out_refund')"/>
            </xpath>

            <xpath expr="//header" position="inside">
                <button name="action_request_baiwang_red_form"
                        string="Cancel"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'draft' or move_type != 'out_refund' or not l10n_cn_baiwang_red_form_required or l10n_cn_baiwang_red_form_status == 'red_form_confirmed'"/>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Baiwang E-Fapiao" name="china_e_fapiao" invisible="country_code != 'CN' or move_type not in ('out_invoice', 'out_refund')">
                    <group>
                        <group string="E-Fapiao Details">
                            <field name="l10n_cn_baiwang_invoice_no"/>
                            <field name="l10n_cn_baiwang_invoice_date"/>
                            <field name="l10n_cn_baiwang_state" widget="badge"
                                   decoration-success="l10n_cn_baiwang_state == 'issued'"
                                   decoration-warning="l10n_cn_baiwang_state == 'sent'"
                                   decoration-danger="l10n_cn_baiwang_state == 'failed'"/>
                            <field name="l10n_cn_baiwang_date_consistency_warning" readonly="1" invisible="not l10n_cn_baiwang_date_consistency_warning"/>
                            <field name="l10n_cn_baiwang_serial_no" invisible="not l10n_cn_baiwang_serial_no"/>
                        </group>

                        <group string="Red Form Requests" invisible="move_type != 'out_refund'">
                            <field name="l10n_cn_baiwang_red_form_type"/>
                            <field name="l10n_cn_baiwang_red_form_number"/>
                            <field name="l10n_cn_baiwang_red_form_status" widget="badge"
                                   decoration-success="l10n_cn_baiwang_red_form_status == 'red_form_confirmed'"
                                   decoration-warning="l10n_cn_baiwang_red_form_status == 'red_form_pending'"
                                   decoration-danger="l10n_cn_baiwang_red_form_status == 'failed'"/>
                            
                            <label for="l10n_cn_baiwang_red_form_uuid"/>
                            <div class="o_row">
                                <field name="l10n_cn_baiwang_red_form_uuid"/>
                                <button name="action_request_baiwang_red_form"
                                        string="Cancel"
                                        type="object"
                                        class="btn-primary"
                                        icon="fa-times-circle"
                                        invisible="state != 'draft' or l10n_cn_baiwang_red_form_status == 'red_form_confirmed'"/>
                            </div>
                        </group>

                        <group string="System Error Log" invisible="not l10n_cn_baiwang_error_message">
                            <field name="l10n_cn_baiwang_error_message" nolabel="1" colspan="2"/>
                        </group>
                    </group>
                </page>
            </xpath>

            <xpath expr="//page[@name='other_info']//field[@name='partner_bank_id']" position="before">
                <field name="l10n_cn_buyer_bank_id" 
                       invisible="country_code != 'CN'"
                       options="{'no_create': True, 'no_open': True}"
                       placeholder="Select customer bank account..."/>
            </xpath>

            <!-- Add the classification code to the invoice lines -->
            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='name']" position="after">
                <field name="l10n_cn_tax_category_id" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
