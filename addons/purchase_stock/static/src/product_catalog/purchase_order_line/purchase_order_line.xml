<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="purchase_stock.ProductCatalogOrderLineSuggestedQty"
       t-inherit="product.ProductCatalogOrderLine"
       t-inherit-mode="extension">
        <xpath expr="//div[@class='d-flex justify-content-end align-items-center m-2']"
               position="inside">

            <span t-if="props.suggested_qty">
                Suggested 2: <t t-esc="props.suggested_qty"/>
            </span>
        </xpath>
    </t>
</templates>