<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="purchase_stock.ProductCatalogPurchaseSuggestOrderLine"
       t-inherit="product.ProductCatalogOrderLine"
       t-inherit-mode="primary">
        <xpath expr="//i[contains(@class, 'fa-shopping-cart')]"
               position="replace">
            <i t-att-class="'fa fa-' + (props.suggested_qty ? '' : 'shopping-cart')"/>
        </xpath>
    </t>
</templates>
