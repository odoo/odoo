<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="stock_reference_purchase_view_form" model="ir.ui.view">
        <field name="name">stock.reference.purchase</field>
        <field name="model">stock.reference</field>
        <field name="inherit_id" ref="stock.view_stock_reference_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='picking_ids']" position="after">
                <field name="purchase_ids" widget="many2many_tags" readonly="True" />
            </xpath>
        </field>
    </record>

</odoo>