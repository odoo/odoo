<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="website_sale_collect.ClickAndCollectAvailability">
        <div name="delivery_availability">
            <div class="btn border border-1 mb-3 text-start p-3 cursor-default">
                <div name="o_click_and_collect_availability">
                    <h6>
                        <i class="fa fa-fw fa-map-marker text-muted"/>
                        <t t-if="this.state.selectedWhLocation.id">
                            <t t-out="this.state.selectedWhLocation.name"/>
                        </t>
                        <t t-else="">Click and Collect</t>
                    </h6>
                    <div class="d-flex gap-5">
                        <t t-if="this.state.inStoreStock.in_stock">
                            <div
                                t-if="this.state.inStoreStock.show_quantity &amp;&amp; this.state.selectedWhLocation.id"
                                class="text-muted"
                            >
                                <i class="fa fa-fw fa-circle text-warning"/>
                                Only <t t-out="this.state.inStoreStock.quantity"/> available
                            </div>
                            <div t-else="" class="text-muted">
                                <i class="fa fa-fw fa-circle text-success"/> Available
                            </div>
                        </t>
                        <div t-else="" class="text-muted">
                            <i class="fa fa-fw fa-circle text-danger"/> Not available
                        </div>
                        <a role="button" href="#" t-on-click="openLocationSelector">
                            <t t-if="this.state.selectedWhLocation.id">Change a store</t>
                            <t t-elif="this.state.inStoreStock.in_stock">Select a store</t>
                        </a>
                    </div>
                </div>
                <hr />
                <div t-if="this.state.deliveryStock" class="flex-row">
                    <h6>
                        <i class="fa fa-fw fa-truck text-muted"/>
                        Delivery
                        <i
                            class="fa fa-info-circle cursor-pointer"
                            data-tooltip="Restrictions may apply"
                            data-tooltip-delay="0"
                        />
                    </h6>
                    <div t-if="this.state.deliveryStock.in_stock">
                        <div
                            t-if="this.state.deliveryStock.show_quantity"
                            class="text-muted"
                        >
                            <i class="fa fa-fw fa-circle text-warning"/>
                            Only <t t-out="this.state.deliveryStock.quantity"/> available
                        </div>
                            <div t-else="" class="text-muted">
                            <i class="fa fa-fw fa-circle text-success"/> Available
                        </div>
                    </div>
                    <div t-else="" class="text-muted">
                        <i class="fa fa-fw fa-circle text-danger"/> Not available
                    </div>
                </div>
            </div>
        </div>
    </t>

</templates>
