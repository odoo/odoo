<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="website_sale_collect.ClickAndCollectAvailability">
        <div class="border rounded p-3 w-100">
            <div
                name="click_and_collect_availability"
                t-on-click="() => this.state.inStoreStockData?.in_stock ? this.openLocationSelector() : null"
                t-att-class="this.state.inStoreStockData?.in_stock ? 'cursor-pointer' : ''"
            >
                <div class="h6">
                    <i class="oi oi-fw text-muted" data-icon="location_on"/>
                    <t
                        t-if="this.state.selectedLocationData.id"
                        t-out="this.state.selectedLocationData.name"
                    />
                    <t t-else="" t-out="this.props.deliveryMethodName"/>
                </div>
                <div class="d-flex justify-content-between">
                    <t t-if="this.state.inStoreStockData?.in_stock">
                        <div
                            t-if="this.state.inStoreStockData.show_quantity &amp;&amp; this.state.selectedLocationData.id"
                            class="text-muted"
                        >
                            <i class="oi oi-fw oi-filled text-warning me-1" data-icon="circle"/>
                            <t t-out="this.state.inStoreStockData.quantity"/> <t t-out="this.state.deliveryStockData.uom_name"/>
                            in stock
                        </div>
                        <div t-else="" class="text-muted">
                            <i class="oi oi-fw oi-filled text-success" data-icon="circle"/> Available
                        </div>
                    </t>
                    <div t-else="" class="text-muted">
                        <i class="oi oi-fw oi-filled text-danger" data-icon="circle"/> Not available
                    </div>
                    <a t-if="this.props.showSelectStoreButton and this.state.inStoreStockData?.in_stock" role="button" href="#">
                        <t t-if="this.state.selectedLocationData.id">Change store</t>
                        <t t-elif="this.state.inStoreStockData.in_stock">Select store</t>
                    </a>
                </div>
            </div>
            <div
                name="delivery_availability"
                t-if="Object.keys(this.state.deliveryStockData || {}).length !== 0"
                class="flex-row"
            >
                <hr/>
                <div class="h6">
                    <i class="oi oi-fw text-muted" data-icon="local_shipping"/>
                    Delivery
                    <i
                        class="oi cursor-pointer ms-1"
                        data-icon="info"
                        data-tooltip="Restrictions may apply"
                        data-tooltip-delay="0"
                    />
                </div>
                <div t-if="this.state.deliveryStockData.in_stock">
                    <div
                        t-if="this.state.deliveryStockData.show_quantity"
                        class="text-muted"
                    >
                        <i class="oi oi-fw oi-filled text-warning me-1" data-icon="circle"/>
                        <t t-out="this.state.deliveryStockData.quantity"/> <t t-out="this.state.deliveryStockData.uom_name"/>
                        in stock
                    </div>
                    <div t-else="" class="text-muted">
                        <i class="oi oi-fw oi-filled text-success" data-icon="circle"/> Available
                    </div>
                </div>
                <div t-else="" class="text-muted">
                    <i class="oi oi-fw oi-filled text-danger" data-icon="circle"/> Not available
                </div>
            </div>
        </div>
    </t>

</templates>
