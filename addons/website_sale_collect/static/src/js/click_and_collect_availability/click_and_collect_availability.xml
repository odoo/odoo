<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t
        t-name="website_sale_collect.ClickAndCollectAvailability"
        t-inherit="website_sale.DeliveryAvailability"
        t-inherit-mode="extension"
    >
        <xpath expr="//*[@name='delivery_availability']" position="before">
            <div
                name="click_and_collect_availability"
                t-if="this.state.deliveryMethodId"
                t-on-click="this.openLocationSelector"
                t-att-class="this.state.inStoreStockData?.in_stock ? 'cursor-pointer' : ''"
            >
                <div class="h6">
                    <i class="fa fa-fw fa-map-marker text-muted"/>
                    <t
                        t-if="this.state.selectedLocationData.id"
                        t-out="this.state.selectedLocationData.name"
                    />
                    <t t-else="" t-out="this.props.deliveryMethodName"/>
                </div>
                <div class="d-flex justify-content-between">
                    <t t-if="this.state.inStoreStockData?.in_stock">
                        <div
                            t-if="this.state.inStoreStockData.show_quantity &amp;&amp; this.state.selectedLocationData.id"
                            class="text-muted"
                        >
                            <i class="fa fa-fw fa-circle text-warning me-1"/>
                            <t t-out="this.state.inStoreStockData.quantity"/> <t t-out="this.state.uomName"/>
                            in stock
                        </div>
                        <div t-else="" class="text-muted">
                            <i class="fa fa-fw fa-circle text-success"/> Available
                        </div>
                    </t>
                    <div t-else="" class="text-muted">
                        <i class="fa fa-fw fa-circle text-danger"/> Not available
                    </div>
                    <a t-if="this.props.showSelectStoreButton and this.state.inStoreStockData?.in_stock" role="button" href="#">
                        <t t-if="this.state.selectedLocationData.id">Change store</t>
                        <t t-elif="this.state.inStoreStockData.in_stock">Select store</t>
                    </a>
                </div>
                <hr t-if="Object.keys(this.state.deliveryStockData || {}).length !== 0"/>
            </div>
        </xpath>
    </t>

</templates>
