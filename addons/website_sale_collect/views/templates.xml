<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <template
        id="payment_confirmation_status"
        inherit_id="website_sale.payment_confirmation_status"
    >
        <t t-set="alert_class" position="after">
            <t
                t-if="tx_sudo.state == 'pending' and tx_sudo.provider_id.custom_mode == 'on_site'"
                t-set="alert_class"
                t-value="'alert-success'"
            />
        </t>
        <div id="order_reference" position="replace">
            <t t-if="tx_sudo.provider_id.custom_mode == 'on_site'">
                <div class="mt-2 mb-3">
                    <div class="o_body_carrier_message">
                        <t t-out="order.carrier_id.website_description"/>
                    </div>
                </div>
            </t>
            <t t-else="">
                <t>$0</t> <!-- Replaced by old content. -->
            </t>
        </div>
    </template>

    <template
        id="website_sale_collect.delivery_availability_widget"
        inherit_id="website_sale.delivery_availability_widget"
    >
        <t t-set="props" position="after">
            <t t-set="nothing" t-value="props.update({
                'productId': product_variant.id,
                'zipCode': zip_code,
                'countryCode': country_code,
                'showSelectStoreButton': show_select_store_button,
                'selectedLocationData': selected_location_data or {},
                'inStoreStockData': combination_info.get('in_store_stock_data', {}),
                'deliveryMethodId': delivery_method and delivery_method.id,
                'deliveryMethodType': delivery_method and delivery_method.delivery_type,
                'deliveryMethodName': delivery_method and delivery_method.name,
            })"/>
        </t>
    </template>

</odoo>
