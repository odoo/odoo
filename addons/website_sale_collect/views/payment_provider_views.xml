<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="payment_provider_form" model="ir.ui.view">
        <field name="name">On Site Provider Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment_custom.payment_provider_form"/>
        <field name="arch" type="xml">
            <page name="configuration" position="attributes">
                <attribute name="invisible" separator="or" add="custom_mode == 'on_site'"/>
            </page>
            <page name="messages" position="attributes">
                <attribute name="invisible" separator="or" add="custom_mode == 'on_site'"/>
            </page>
        </field>
    </record>

</odoo>
