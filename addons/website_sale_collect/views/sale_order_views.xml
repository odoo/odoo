<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_view_form" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.website.sale.collect</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="website_sale_stock.sale_order_view_form"/>
        <field name="arch" type="xml">
            <field name="carrier_id" position="after">
                <field name="delivery_type" invisible="1"/> <!-- Needed for pickup_location_many2one widget -->
            </field>
        </field>
    </record>
</odoo>
