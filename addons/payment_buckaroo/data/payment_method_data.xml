    <!-- https://docs.buckaroo.io/docs/payment-methods -->

    <!-- === PRIMARY PAYMENT METHODS === -->

    <record id="payment_method_afterpay_riverty" model="payment.method">
        <field name="name">AfterPay</field>
        <field name="code">afterpay_riverty</field>
        <field name="provider_id" ref="payment.payment_provider_buckaroo"/>
        <field name="image" type="bytes" file="payment/static/img/afterpay_riverty.png"/>
        <field
            name="supported_country_ids"
            eval="[Command.set([
                        ref('base.at'),
                        ref('base.be'),
                        ref('base.de'),
                        ref('base.fi'),
                        ref('base.nl'),
                ])]"
        />
        <field name="supported_currency_ids" eval="[Command.set([ref('base.EUR')])]"/>
    </record>

