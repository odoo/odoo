<odoo>
    <template id="report_purchasequotation_document_portal_connect" inherit_id="purchase.report_purchasequotation_document">
        <xpath expr="//div[hasclass('page')]" position="inside">
            <t t-set="base_address" t-value="o.env['ir.config_parameter'].sudo().get_param('web.base.url')"/>
            <t t-set="portal_url" t-value="base_address + '/my/purchase/' + str(o.id) + '#portal_connect_software_modal_btn'"/>
            <div t-if="any(u._is_portal() for u in o.partner_id.user_ids)" class="text-center">
                <a t-att-href="portal_url">Connect your software</a> with <t t-out="o.company_id.name"/> to create quotes automatically.
            </div>
        </xpath>
    </template>

    <template id="report_purchaseorder_document_portal_connect" inherit_id="purchase.report_purchaseorder_document">
        <xpath expr="//div[hasclass('page')]" position="inside">
            <t t-set="base_address" t-value="o.env['ir.config_parameter'].sudo().get_param('web.base.url')"/>
            <t t-set="portal_url" t-value="base_address + '/my/purchase/' + str(o.id) + '#portal_connect_software_modal_btn'"/>
            <div t-if="any(u._is_portal() for u in o.partner_id.user_ids)" class="text-center">
                <a t-att-href="portal_url">Connect your software</a> with <t t-out="o.company_id.name"/> to create quotes automatically.
            </div>
        </xpath>
    </template>
</odoo>
