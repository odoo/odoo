#. module: account_debit_note_sequence
#: model:ir.model.fields,help:account_debit_note_sequence.field_account_journal__debit_sequence
msgid ""
"Check this box if you don't want to share the same sequence for invoices and"
" debit notes made from this journal"
msgstr ""
"ໝາຍເອົາຫ້ອງນີ້ ຖ້າທ່ານບໍ່ຕ້ອງການໃຊ້ເລກລຳດັບດຽວກັນສຳລັບໃບເກັບເງິນ ແລະ ໃບບິນເພີ່ມໜີ້ ທີ່ສ້າງຂຶ້ນຈາກປຶ້ມບັນຊີ"
"ນີ້"

#. module: account_debit_note_sequence
#: model:ir.model.fields,field_description:account_debit_note_sequence.field_account_journal__debit_sequence
msgid "Dedicated Debit Note Sequence"
msgstr "ກຳນົດເລກລຳດັບໃບບິນເພີ່ມໜີ້ສະເພາະ"

#. module: account_debit_note_sequence
#: model:ir.model,name:account_debit_note_sequence.model_account_journal
msgid "Journal"
msgstr "ປຶ້ມບັນຊີ"

#. module: account_debit_note_sequence
