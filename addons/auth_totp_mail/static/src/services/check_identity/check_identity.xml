<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="auth_totp_mail.CheckIdentityFormTOTPMail">
        <i class="fa fa-envelope fa-2x mt-2 mb-3" aria-hidden="true"/>
        <h3>Check your mailbox</h3>
        <p>We sent a 6-digit code to your email address.</p>
        <div class="d-flex flex-column align-items-center gap-4">
            <input
                name="token"
                type="text"
                inputmode="numeric"
                maxlength="6"
                pattern="[0-9]{6}"
                class="o_totp_mail_code_input form-control rounded w-50 fs-2 text-center font-monospace"
                placeholder="••••••"
                autocomplete="one-time-code"
                aria-label="Six-digit authentication code"
            />
            <button type="submit" class="btn btn-primary align-self-stretch">Verify</button>
        </div>
    </t>
    <t t-name="auth_totp_mail.CheckIdentityLinkStringTOTPMail">Use an authentication code sent by email</t>

</templates>
