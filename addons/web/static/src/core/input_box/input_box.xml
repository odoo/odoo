<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="web.InputBox">
        <div t-attf-class="o_input_box">
            <input
                t-attf-class="o_input w-100"
                t-att-id="this.props.id"
                t-att-type="this.props.type"
                autocomplete="off"
                t-att-placeholder="this.props.placeholder"
                t-att-required="this.props.required"
                t-custom-ref="input"
            />
            <t t-if="this.overlayButtons.length">
                <t t-if="!this.hasTouch">
                    <t t-foreach="this.overlayButtons" t-as="link" t-key="link.name">
                        <button t-att-class="this.buttonClass" t-on-click="link.onSelected" t-att-data-tooltip="link.name">
                            <i t-attf-class="fa {{ link.icon }}" />
                        </button>
                    </t>
                </t>
                <t t-else="">
                    <Dropdown t-if="this.overlayButtons.length > 1">
                        <button t-att-class="this.buttonClass">
                            <i class="oi oi-ellipsis-v"/>
                        </button>
                            <t t-set-slot="content">
                                <t t-foreach="this.overlayButtons" t-as="link" t-key="link.name">
                                    <DropdownItem onSelected="link.onSelected">
                                        <i t-attf-class="fa {{ link.icon }}" class="me-2"/>
                                        <t t-esc="link.name"/>
                                    </DropdownItem>
                                </t>
                            </t>
                    </Dropdown>
                    <t t-else="">
                        <t t-set="link" t-value="this.overlayButtons[0]" />
                        <button t-att-class="this.buttonClass" t-on-click="link.onSelected" t-att-data-tooltip="link.name">
                            <i t-attf-class="fa {{ link.icon }}"/>
                        </button>
                    </t>
                </t>
            </t>
        </div>
    </t>

</templates>
