<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="web.CheckIdentityDialog">
        <Dialog title.translate="Verify your identity" size="'sm'" contentClass="'o_error_dialog'" footer="false">
            <CheckIdentityForm t-props="this.formProps"/>
        </Dialog>
    </t>

    <t t-name="web.CheckIdentityForm">
        <p role="alert" class="alert alert-danger" t-if="this.state.error" t-out="this.state.error"/>
        <div class="d-flex align-items-center gap-2 mb-3 border rounded p-2 bg-100">
            <img t-attf-src="/web/image/res.users/{{this.user.userId}}/avatar_128" class="o_avatar rounded" style="--Avatar-size: 2.5rem;"/>
            <div class="d-flex justify-content-between w-100">
                <span class="h5 mb-0" t-out="this.user.name"/>
                <span class="badge rounded-pill text-bg-info">Active</span>
            </div>
        </div>
        <form t-att-id="this.state.authMethod" t-on-submit.prevent="this.onSubmit" class="o_check_identity_form mb-3 text-center">
            <input type="hidden" name="type" t-att-value="this.state.authMethod"/>
            <t t-call="{{ this.getAuthMethodFormTemplate(this.state.authMethod) }}"/>
        </form>
        <div t-if="this.authMethods.length > 1" class="text-center">
            <span class="h6 d-inline-block">Trouble signing in?</span>
            <ul class="d-flex justify-content-center flex-wrap column-gap-3 row-gap-1 list-unstyled">
                <t t-foreach="this.authMethods" t-as="authMethod" t-key="authMethod_index">
                    <li t-if="this.state.authMethod !== authMethod" class="text-nowrap">
                        <a href="#" t-on-click="this.onChangeAuthMethod" t-att-data-auth-method="authMethod">
                            <t t-call="{{ this.getAuthMethodLinkStringTemplate(authMethod) }}"/>
                        </a>
                    </li>
                </t>
            </ul>
        </div>
    </t>

    <t t-name="web.CheckIdentityFormPassword">
        <div class="d-flex justify-content-between align-items-start">
            <label for="password" class="form-label">Password</label>
            <a href="/web/reset_password">Forgot password?</a>
        </div>
        <input name="password" type="password" class="form-control mb-2" placeholder="Enter your password"/>
        <button type="submit" class="btn btn-primary w-100">Confirm</button>
    </t>
    <t t-name="web.CheckIdentityLinkStringPassword">Use your password</t>

</templates>
