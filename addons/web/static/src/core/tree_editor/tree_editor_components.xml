<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="web.TreeEditor.Input">
        <input  t-att-type="this.props.type ?? 'text'" class="o_input" t-att-value="this.props.startEmpty ? '' : this.props.value" t-att-placeholder="this.props.placeholder" t-on-change="(ev) => this.update(ev.target.value)" />
    </t>

    <t t-name="web.TreeEditor.Select">
        <select class="o_input pe-3 text-truncate" t-on-change="(ev) => this.props.update(this.deserialize(ev.target.value))" t-att-title="this.selectedTooltip">
            <option class="o_select_placeholder" t-if="this.props.addBlankOption" hidden="true" t-out="this.props.placeholder ? this.props.placeholder : ''"/>
            <t t-foreach="this.props.options" t-as="option" t-key="this.serialize(option[0])">
                <option
                    class="text-black"
                    t-att-value="this.serialize(option[0])"
                    t-att-selected="!this.props.addBlankOption and option[0] === this.props.value"
                    t-att-title="option[2]?.title || false"
                    t-out="option[1]"
                />
            </t>
        </select>
    </t>

    <t t-name="web.TreeEditor.Range">
        <div class="d-flex align-items-center">
            <t t-call="web.TreeEditor.Editor"
                _classes="'overflow-hidden'"
                info="this.props.editorInfo"
                value="this.props.value[0]"
                update="(val) => this.update(0, val)">
            </t>
            <i class="fa fa-long-arrow-right mx-2" aria-label="Arrow icon" title="Arrow" />
            <t t-call="web.TreeEditor.Editor"
                _classes="'overflow-hidden'"
                info="this.props.editorInfo"
                value="this.props.value[1]"
                update="(val) => this.update(1, val)">
            </t>
        </div>
    </t>

    <t t-name="web.TreeEditor.InRange">
        <div class="d-flex gap-4">
            <t t-call="web.TreeEditor.Editor"
                _classes="'overflow-hidden'"
                info="this.props.valueTypeEditorInfo"
                value="this.props.value[1]"
                update="(val) => this.updateValueType(val)">
            </t>
            <t t-if="this.props.value[1] === 'dateRange'">
                <t t-call="web.TreeEditor.Editor"
                    _classes="'overflow-hidden'"
                    info="this.props.betweenEditorInfo"
                    value="this.props.value.slice(2)"
                    update="(val) => this.updateValues(val)">
                </t>
            </t>
            <t t-if="this.props.value[1] === 'relativeRange'">
                <t t-call="web.TreeEditor.Editor"
                    _classes="'overflow-hidden'"
                    info="this.props.relativeEditorInfo"
                    value="this.props.value.slice(2)"
                    update="(val) => this.updateValues(val)">
                </t>
            </t>
        </div>
    </t>

    <t t-name="web.TreeEditor.relativeRange">
        <div class="d-flex gap-4">
            <div style="width: 60px;">
                <t t-call="web.TreeEditor.Editor"
                    info="this.props.relativeInput"
                    value="this.props.value[0]"
                    update="(val) => this.update(0, val)">
                </t>
            </div>
            <t t-call="web.TreeEditor.Editor"
                _classes="'overflow-hidden'"
                info="this.props.relativeSelect"
                value="this.props.value[1]"
                update="(val) => this.update(1, val)">
            </t>
        </div>
    </t>

    <t t-name="web.TreeEditor.List">
        <div class="o_input d-flex flex-wrap gap-1">
            <t t-foreach="this.tags" t-as="tag" t-key="tag_index">
                <BadgeTag t-props="tag"/>
            </t>
            <div class="flex-grow-1">
                <t t-call="web.TreeEditor.Editor"
                    info="this.props.editorInfo"
                    value="this.props.editorInfo.defaultValue()"
                    update="(val) => this.update(val)"
                    displayPlaceholder="!this.tags.length">
                </t>
            </div>
        </div>
    </t>

</templates>
