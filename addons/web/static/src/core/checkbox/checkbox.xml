<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

<t t-name="web.CheckBox">
    <div class="o-checkbox form-check" t-att-class="this.props.className" t-on-click="this.onClick" t-ref="this.rootRef">
        <input
            t-att-id="this.props.id or this.id"
            type="checkbox"
            class="form-check-input"
            t-att-disabled="this.props.disabled"
            t-att-checked="this.props.value"
            t-att-name="this.props.name"
            t-att-indeterminate="this.props.indeterminate"
            t-att-title="this.props.title"
            t-att-aria-label="this.props.ariaLabel"
            t-on-change="this.onChange"
        />
        <label t-att-for="this.props.id or this.id" class="form-check-label">
            <t t-call-slot="default"/>
        </label>
    </div>
</t>

</templates>
