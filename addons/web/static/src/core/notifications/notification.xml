<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="web.NotificationWowl">
        <div t-on-mouseenter="this.freeze" t-on-mouseleave="this.refresh" t-attf-class="o_notification {{this.notification.className}} d-flex mb-2 position-relative rounded shadow-lg" role="alert" aria-live="assertive" aria-atomic="true">
            <span t-attf-class="o_notification_bar bg-{{this.notification.type}} rounded-start"/>
            <div class="d-flex align-items-start w-100 py-2 ps-2 border border-start-0 rounded-end text-break">
                <div class="o_notification_body d-flex flex-wrap flex-md-nowrap flex-grow-1 justify-content-between justify-content-md-normal">
                    <span class="o_notification_content o_line_clamp w-auto w-md-100 align-self-start" t-att-title="this.notification.message">
                        <!-- TODO-IPB: at the end, title has to be removed, but the change is too important to do all in once now -->
                        <t t-if="this.notification.title"><t t-out="this.notification.title"/>. </t>
                        <t t-out="this.notification.message"/>
                    </span>
                    <div t-if="this.notification.buttons.length" class="o_notification_buttons align-self-start justify-content-end d-flex gap-3 flex-wrap flex-md-nowrap mw-100 w-md-auto ms-auto ms-md-2">
                        <button t-foreach="this.notification.buttons" t-as="button" type="button" t-key="button_index" t-attf-class="btn btn-link text-nowrap p-0 border-0" t-on-click="button.onClick">
                            <t t-if="button.icon">
                                <i t-if="button.icon.indexOf('fa-') === 0" role="img" t-att-aria-label="button.name" t-att-title="button.name" t-attf-class="fa fa-fw {{button.icon}} me-1"/>
                                <img t-else="" t-att-src="button.icon" t-att-alt="button.name"/>
                            </t>
                            <span class="fw-bolder" t-out="button.name"/>
                        </button>
                    </div>
                </div>
                <button type="button" class="o_notification_close flex-shrink-0 btn-close mx-1" aria-label="Close" t-on-click="this.close" data-available-offline=""/>
                <div t-ref="this.autocloseProgress"  t-attf-class="o_notification_progress opacity-75 bg-{{this.notification.type}}"/>
            </div>
        </div>
    </t>

</templates>
