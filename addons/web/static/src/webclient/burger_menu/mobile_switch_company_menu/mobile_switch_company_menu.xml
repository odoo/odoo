<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

<t t-name="web.MobileSwitchCompanyMenu">
    <div class="o_burger_menu_companies p-3 pb-0">
        <div class="w-100" t-on-click="() => this.toggleCollapsible()">
            <i t-if="this.hasLotsOfCompanies" class="oi me-2" style="width: 10px" t-attf-data-icon="{{ this.state.isOpen ? 'arrow_drop_down' : 'arrow_right' }}"/>
            <span class="fw-bolder">Companies</span>
        </div>
        <div t-if="this.show" class="mt-2">
            <t t-call="web.SwitchCompanyMenu.Items"/>
        </div>
    </div>
</t>

</templates>
