<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="web.OfflineSystray">
        <Dropdown
            t-if="this.offlineService.offline or this.offlineService.hasScheduledCalls"
            navigationOptions="{ 'shouldFocusChildInput': false }"
            disabled="!this.offlineService.hasScheduledCalls">
            <div
                t-if="this.env.isSmall"
                t-on-click="() => this.offlineService.checkConnection()"
                class="o_nav_entry o_offline_systray">
                    <i t-attf-class="{{ this.labelIcon }} {{ this.labelColor }}"
                    role="img"
                    t-att-aria-label="this.labelText"
                    t-att-data-tooltip="this.labelText"/>
            </div>
            <button t-else=""
                t-attf-class="o_nav_entry px-2 o_tag {{ this.labelColor }} o_offline_systray"
                data-available-offline=""
                t-on-click="() => this.offlineService.checkConnection()"
                data-tooltip="Click to check connection and Sync">
                <i t-attf-class="{{ this.labelIcon }} me-1"/><t t-esc="this.labelText"></t><i t-if="this.offlineService.hasScheduledCalls" class="fa fa-caret-down ms-2"/>
            </button>
            <t t-set-slot="content">
                <div class="o_offline_systray_content px-2">
                    <t t-foreach="this.groupEntries" t-as="entry" t-key="entry[0]">
                        <div class="o_horizontal_separator text-uppercase fw-bolder small mb-1">
                            <span t-esc="entry[0]"/> 
                        </div>
                        <t t-foreach="entry[1]" t-as="element" t-key="element.id">
                            <DropdownItem
                                onSelected="() => element.clickable and this.openView(element.id)"
                                closingMode="element.clickable ? 'all' : 'none'"
                                class="{
                                    'pe-1': true,
                                    'px-0': true,
                                    'd-flex': true,
                                    'o_cursor_auto': !element.clickable,
                                    'o_disabled_while_sync': this.offlineService.syncingORM,
                                    'mb-2': element_last,
                                 }">
                                <div t-attf-class="text-truncate {{element.error ? 'text-danger': ''}} {{ element.clickable ? '' : 'text-muted'}}">
                                    <i t-if="element.error" class="o_button_icon fa fa-fw fa-exclamation-circle text-danger me-1"/>
                                    <span
                                        t-att-title="element.displayName"
                                        t-esc="element.displayName"/>
                                </div>
                                <div
                                    class="ms-auto"
                                    t-att-data-tooltip-template="'web.OfflineSystrayTooltip'"
                                    t-att-data-tooltip-info="element.tooltip">
                                    <span t-attf-class="o_tag mw-100 o_badge badge rounded-pill {{ 'o_tag_color_' + element.statusColor }}">
                                        <t class="o_tag_badge_text o_badge_text" t-esc="element.status"/>
                                    </span>
                                </div>
                                <div>
                                    <button
                                        class="btn btn-link text-danger fa fa-trash py-0"
                                        title="Discard offline changes"
                                        data-available-offline=""
                                        t-on-click.stop="() => this.discard(element.id)"/>
                                </div>
                            </DropdownItem>
                        </t>
                    </t>
                </div>
            </t>
        </Dropdown>
    </t>

    <t t-name="web.OfflineSystrayTooltip">
        <div>
            On <t t-esc="this.timeStamp"/>
        </div>
        <t t-foreach="this.details" t-as="entry" t-key="entry[0]">
            <div>
                - <t t-esc="entry[0]"/>: <t t-esc="entry[1]"/><t t-if="entry[2]"> → <t t-esc="entry[2]"/></t>
            </div>
        </t>
    </t>
</templates>
