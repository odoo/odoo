<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="web.CalendarCardRenderer">
        <div t-if="this.templates[this.constructor.HEADER_ATTRIBUTE]"
            class="o_popover_header d-flex justify-content-between p-3 fs-4 fw-bold border-bottom">
            <t t-call="{{ this.templates[this.constructor.HEADER_ATTRIBUTE] }}"
                t-call-context="this.renderingContext"/>
        </div>
        <div class="o_popover_body p-3 o_cw_body">
            <t t-call="web.CardRenderer"/>
        </div>
        <div class="o_popover_footer d-flex gap-1 p-3 border-top">
            <t t-call-slot="defaultFooter"/>
            <t t-if="this.templates[this.constructor.FOOTER_ATTRIBUTE]">
                <t t-call="{{ this.templates[this.constructor.FOOTER_ATTRIBUTE] }}"
                    t-call-context="this.renderingContext"/>
            </t>
        </div>
    </t>

    <t t-name="web.CalendarCommonPopover">
        <t t-if="this.env.isSmall">
            <Dialog title="this.title">
                <CalendarCard t-props="this.cardProps">
                    <t t-set-slot="defaultFooter">
                        <t t-if="this.displayDefaultFooter"
                            t-call="{{ this.constructor.defaultFooterButtonsTemplate }}"/>
                    </t>
                </CalendarCard>
            </Dialog>
        </t>
        <t t-else="">
            <div class="o_cw_popover position-relative">
                <div class="p-1 cursor-pointer d-flex justify-content-center position-absolute top-0 end-0"
                    t-on-click.stop="this.props.close">
                    <i class="oi oi-close"></i>
                </div>
                <CalendarCard t-props="this.cardProps">
                    <t t-set-slot="defaultFooter">
                        <t t-if="this.displayDefaultFooter"
                            t-call="{{ this.constructor.defaultFooterButtonsTemplate }}"/>
                    </t>
                </CalendarCard>
            </div>
        </t>
    </t>

    <t t-name="web.CalendarCommonPopover.DefaultFooterButtons">
        <t t-if="this.isEventEditable or this.isEventViewable">
            <a href="#" class="btn btn-primary o_cw_popover_edit" t-on-click="this.onEditEvent">
                <t t-if="this.isEventEditable">Edit</t>
                <t t-else="">View</t>
            </a>
        </t>
        <t t-if="this.isEventDeletable">
            <a href="#" class="btn btn-danger o_cw_popover_delete" t-on-click="this.onDeleteEvent">
                Delete
            </a>
        </t>
    </t>

</templates>
