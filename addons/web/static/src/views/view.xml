<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="web.View">
        <WithSearch t-props="withSearchProps" t-slot-scope="search">
            <Layout t-if="displayBlankCP" display="search.display">
                <t t-set-slot="layout-actions">
                    <SearchBar toggler="searchBarToggler"/>
                </t>
                <t t-set-slot="control-panel-navigation-additional">
                    <t t-component="searchBarToggler.component" t-props="searchBarToggler.props"/>
                </t>
            </Layout>
            <t t-component="Controller" t-else="" t-on-click="handleActionLinks" t-props="componentProps" context="search.context" domain="search.domain" groupBy="search.groupBy" orderBy="search.orderBy" display="search.display"/>
        </WithSearch>
    </t>

</templates>
