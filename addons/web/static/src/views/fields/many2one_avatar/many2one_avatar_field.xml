<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="web.Many2OneAvatarField">
        <Many2One t-props="m2oProps">
            <t t-set-slot="start">
                <span class="o_avatar o_m2o_avatar">
                    <t t-if="m2o.value !== false">
                        <img class="rounded" t-attf-src="/web/image/{{m2o.relation}}/{{m2o.value[0]}}/avatar_128"/>
                    </t>
                    <t t-elif="!props.readonly">
                        <span class="o_avatar_empty o_m2o_avatar_empty"/>
                    </t>
                </span>
            </t>
            <t t-set-slot="items" t-slot-scope="itemsScope">
                <span class="o_avatar o_m2o_avatar">
                    <img class="rounded me-1" t-attf-src="/web/image/{{m2o.relation}}/{{itemsScope.record.id}}/avatar_128"/>
                    <t t-esc="itemsScope.record.display_name"/>
                </span>
            </t>
        </Many2One>
    </t>

</templates>
