<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="web.PhoneField">
        <div class="o_input_box">
            <t t-if="props.readonly">
                <a t-if="props.record.data[props.name]" t-att-href="this.phoneHref" class="o_form_uri" t-custom-click.prevent.stop="() => this.onLinkClicked()" t-out="props.record.data[props.name]"/>
                <t t-foreach="this.inlineButtons" t-as="btn" t-key="btn.name">
                    <button t-attf-class="btn btn-link o_input_box_overlay_end" t-on-click.stop="btn.onSelected" t-att-data-tooltip="btn.name">
                        <i t-attf-class="i fa {{ btn.icon }}" />
                    </button>
                </t>
            </t>
            <t t-else="">
                <t t-set="_overlayButtons" t-value="this.props.record.data[this.props.name] ? this.overlayButtons : []" />
                <InputBox
                    placeholder="this.props.placeholder"
                    overlayButtons="_overlayButtons"
                    type="'tel'"
                    id="props.id"
                    input="input"
                />
            </t>
        </div>
    </t>

</templates>
