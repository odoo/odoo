<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="web.PhoneField">
        <div class="d-inline-flex align-items-baseline w-100">
            <t t-if="this.props.readonly">
                <span t-out="this.props.record.data[this.props.name]"/>
                <t t-call="web.PhoneFieldActions"/>
            </t>
            <t t-else="">
                <input
                    class="o_input"
                    t-att-id="this.props.id"
                    type="tel"
                    autocomplete="off"
                    t-att-placeholder="this.props.placeholder"
                    t-custom-ref="input"
                />
                <t t-call="web.PhoneFieldActions"/>
            </t>
        </div>
    </t>

    <t t-name="web.PhoneFieldActions">
        <span class="d-flex flex-nowrap">
            <t t-foreach="this.actionButtons" t-as="btn" t-key="btn.name">
                <button
                    t-if="props.record.data[props.name]"
                    t-on-click.stop="btn.onSelected"
                    class="o_phone_form_link btn btn-sm btn-link p-1 py-0 text-nowrap"
                >
                    <i t-attf-class="fa {{ btn.icon }}"/><small class="fw-bold ms-1"><t t-out="btn.name"/></small>
                </button>
            </t>
        </span>
        <Dropdown>
            <button class="btn fa fa-ellipsis-v"/>
            <t t-set-slot="content">
                    <t t-foreach="this.actionButtons" t-as="btn" t-key="btn.name">
                        <DropdownItem class="'o_phone_form_link d-flex align-items-baseline gap-1'" onSelected="(ev) => btn.onSelected()">
                            <i t-attf-class="fa {{ btn.icon }}" /><t t-out="btn.name"/>
                        </DropdownItem>
                    </t>
                </t>
            </Dropdown>
    </t>

</templates>
