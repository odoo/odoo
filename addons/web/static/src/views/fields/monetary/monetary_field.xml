<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="web.MonetaryField">
        <span t-if="this.props.readonly" t-out="this.formattedValue" />
        <div t-else="" class="o_input_box">
            <span t-if="!this.props.hideSymbol and this.currency" t-attf-class="o_input_box_overlay_{{ this.currency.position === 'before' ? 'start' : 'end' }}" t-out="this.currencySymbol"/>
            <input t-custom-ref="numpadDecimal" t-on-input="this.onInput" t-att-id="this.props.id" t-att-type="this.props.inputType" class="o_input flex-grow-1 flex-shrink-1" autocomplete="off"/>
        </div>
    </t>

</templates>
