<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="web.MonetaryField">
        <span t-if="props.readonly" t-out="formattedValue" />
        <div t-else="" class="o_input_box">
            <span t-if="!props.hideSymbol and currency" t-attf-class="o_input_box_overlay_{{ currency.position === 'before' ? 'start' : 'end' }}" t-out="currencySymbol"/>
            <input t-custom-ref="numpadDecimal" t-on-input="onInput" t-att-id="props.id" t-att-type="props.inputType" class="o_input flex-grow-1 flex-shrink-1" autocomplete="off"/>
        </div>
    </t>

</templates>
