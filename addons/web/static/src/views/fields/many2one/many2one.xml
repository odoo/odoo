<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="web.KanbanMany2One">
        <div>
            <t t-if="this.props.value">
                <t t-slot="avatar"/>
            </t>
            <t t-elif="!this.props.readonly">
                <span class="o_avatar o_m2o_avatar d-flex">
                    <a class="o_quick_assign btn-link d-flex align-items-center text-dark" href="#" role="button" tabindex="-1" aria-label="Assign" data-tooltip="Assign" t-on-click.stop.prevent="(e) => this.openAssignPopover(e.currentTarget)">
                        <i class="fa fa-user-plus"/>
                    </a>
                </span>
            </t>
        </div>
    </t>

    <t t-name="web.Many2One">
        <div class="o_many2one o_input_box" t-att-class="this.props.cssClass">
            <t t-if="this.props.readonly">
                <t t-if="this.props.value">
                    <t t-if="this.props.canOpen">
                        <a class="o_form_uri text-truncate d-inline-block w-100 align-bottom" t-att-class="this.props.linkCssClass" t-att-href="this.linkHref" t-on-click.prevent.stop="() => this.openRecord('action')" t-out="this.displayName" t-att-title="this.displayName"/>
                    </t>
                    <t t-else="">
                        <span t-out="this.displayName" t-att-title="this.displayName" class="text-truncate d-inline-block w-100 align-bottom"/>
                    </t>
                </t>
            </t>
            <t t-else="">
                <div class="o_field_many2one_selection" t-custom-ref="root">
                    <Many2XAutocomplete t-props="this.many2XAutocompleteProps"/>
                    <InternalLinkButton t-if="this.hasLinkButton" onClick.bind="(_, isMiddleClick) => this.openRecord(isMiddleClick ? 'tab' : this.env.inDialog ? 'dialog' : 'action')" />
                    <t t-if="this.hasBarcodeButton">
                        <button class="o_barcode o_input_box_overlay_end btn btn-secondary" draggable="false" tabindex="-1" type="button" aria-label="Scan barcode" data-tooltip="Scan barcode" t-on-click="() => this.openBarcodeScanner()"/>
                    </t>
                </div>
            </t>
            <t t-set="lines" t-value="this.extraLines"/>
            <t t-if="lines.length">
                <div class="o_field_many2one_extra" t-on-click="this.onExtraLinesClick">
                    <t t-foreach="lines" t-as="line" t-key="line_index">
                        <div t-out="line" t-att-title="line"  class="text-truncate"/>
                    </t>
                </div>
            </t>
        </div>
    </t>

</templates>
