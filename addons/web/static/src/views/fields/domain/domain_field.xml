<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="web.DomainField">
        <div t-att-class="{ o_inline_mode: !this.props.editInDialog }">
            <t t-set="resModel" t-value="this.getResModel()"/>
            <t t-if="resModel">
                <t t-if="this.props.isFoldable and this.state.folded and this.state.isValid !== false">
                    <div class="d-flex align-items-center" t-on-click="() => this.state.folded = false">
                        <i data-tooltip="Modify filter" class="oi oi-lg pe-2" data-icon="arrow_right"/>
                        <div class="d-print-contents">
                            <t t-if="!this.state.facets.length">
                                <span>Match <strong>all records</strong></span>
                                <t t-if="!this.props.readonly">
                                    <button class="btn btn-sm btn-primary o_domain_add_first_node_button mx-2" t-on-click.stop="() => this.addCondition()">
                                        <i class="oi" data-icon="add"/> Add condition
                                    </button>
                                </t>
                            </t>
                            <t t-foreach="this.state.facets" t-as="facet" t-key="facet_index">
                                <div class="d-inline-flex align-items-stretch text-nowrap px-1 position-relative"
                                    role="listitem"
                                    tabindex="0"
                                    >
                                    <div class="o_searchview_facet_label rounded-start-2 btn btn-primary rounded-end-0 p-0" role="button">
                                        <i class="px-1 small oi oi-filled" data-icon="filter_alt" role="image"/>
                                    </div>
                                    <div class="o_facet_values d-flex align-items-center px-2 bg-200 rounded-end-2 text-wrap">
                                        <small class="o_facet_value" t-out="facet"/>
                                    </div>
                                </div>
                            </t>
                            <t t-if="this.state.isValid">
                                <button class="btn btn-sm btn-link o_domain_show_selection_button" data-tooltip="Show matching records" type="button" t-on-click.stop="this.onButtonClick">
                                    <t t-out="this.state.recordCount" /><t t-if="this.state.hasLimitedCount">+</t> record(s)
                                </button>
                            </t>
                        </div>
                    </div>
                </t>
                <t t-else="">
                    <div class="d-flex">
                        <a t-if="this.props.isFoldable and this.state.isValid" t-on-click="this.fold">
                            <i class="oi oi-lg pe-2" data-icon="arrow_drop_down"></i>
                        </a>
                        <DomainSelector
                            resModel="resModel"
                            domain="this.getDomain()"
                            readonly="this.props.readonly or this.props.editInDialog"
                            debugUpdate.bind="this.debugUpdate"
                            update.bind="this.update"
                            isDebugMode="!!this.env.debug"
                            className="this.props.readonly ? 'o_read_mode' : 'o_edit_mode'"
                        />
                    </div>
                    <div class="o_field_domain_panel d-flex align-items-center gap-2 mt-1">
                        <i class="oi" data-icon="east" role="img" aria-label="Domain" title="Domain" />
                        <t t-if="this.state.isValid === null and this.state.recordCount === null">
                            <i class="oi oi-spin ms-2" data-icon="autorenew" role="img" aria-label="Loading" title="Loading" />
                        </t>
                        <t t-else="">
                            <t t-if="this.state.isValid">
                                <button class="btn btn-sm btn-link o_domain_show_selection_button" type="button" t-on-click.stop="this.onButtonClick">
                                    <t t-out="this.state.recordCount" /><t t-if="this.state.hasLimitedCount">+</t> record(s)
                                </button>
                            </t>
                            <t t-else="">
                                <span class="text-warning" role="alert">
                                    <i class="oi" data-icon="warning" role="img" aria-label="Warning" title="Warning" /> Invalid domain
                                </span>
                            </t>
                            <t t-if="!!this.env.debug and !this.props.readonly">
                                <button
                                    class="btn btn-sm btn-icon oi o_refresh_count"
                                    data-icon="refresh"
                                    role="img"
                                    aria-label="Refresh"
                                    title="Refresh"
                                    t-on-click="() => this.checkProps()"
                                />
                            </t>
                        </t>
                        <t t-if="this.props.editInDialog and !this.props.readonly">
                            <button class="btn btn-sm btn-primary o_field_domain_dialog_button" t-on-click.prevent="this.onEditDialogBtnClick">Edit Domain</button>
                        </t>
                    </div>
                </t>
            </t>
            <t t-else="">
                <div>Select a model to add a filter.</div>
            </t>
        </div>
    </t>

</templates>
