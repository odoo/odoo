<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="web.ContactStatisticsField">
        <div class="d-inline-flex flex-wrap gap-3">
            <span t-foreach="this.list" t-as="data" t-key="data_index" t-att-aria-label="data.label" t-att-title="data.label" t-att-data-tooltip="data.label">
                <i class="oi oi-fw me-1 pe-none" t-att-class="data.iconClass" t-att-data-icon="data.icon" role="img"/>
                <t t-out="data.value"/>
            </span>
        </div>
    </t>

</templates>
