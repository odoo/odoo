<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="web.EmailField">
        <t t-if="props.readonly">
            <div class="d-grid">
                <a class="o_form_uri o_text_overflow" t-on-click.stop="" t-att-href="props.record.data[props.name] ? 'mailto:'+props.record.data[props.name] : undefined" t-out="props.record.data[props.name] || ''"/>
            </div>
        </t>
        <t t-else="">
            <t t-set="_overlayButtons" t-value="this.props.record.data[this.props.name] ? this.overlayButtons : []" />
            <InputBox
                placeholder="this.props.placeholder"
                overlayButtons="_overlayButtons"
                type="'email'"
                id="props.id"
                input="input"
                required="props.required"
            />
        </t>
    </t>

</templates>
