<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="web.BooleanIconField">
        <button t-attf-class="btn {{props.record.data[props.name] ? 'btn-primary' : 'btn-outline-primary'}}" t-att-data-tooltip="props.label" t-on-click.prevent.stop="update">
            <i t-attf-class="fa {{props.icon}}" />
        </button>
    </t>

</templates>
