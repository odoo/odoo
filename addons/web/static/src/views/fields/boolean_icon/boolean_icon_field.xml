<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="web.BooleanIconField">
        <button t-attf-class="btn {{this.props.record.data[this.props.name] ? 'btn-primary' : 'btn-outline-primary'}}" t-att-data-tooltip="this.props.label" t-on-click.prevent.stop="this.update" data-available-offline="">
            <i t-attf-class="fa {{this.props.icon}}" />
        </button>
    </t>

</templates>
