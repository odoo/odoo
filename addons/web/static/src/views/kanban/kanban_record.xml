<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="web.KanbanRecord" t-inherit="web.CardRenderer">
        <xpath expr="article" position="attributes">
            <attribute name="t-custom-ref">root</attribute>
            <attribute name="t-custom-click">this.onGlobalClick</attribute>
            <attribute name="t-on-touchstart">this.onTouchStart</attribute>
            <attribute name="t-on-touchmove">this.onTouchMoveOrCancel</attribute>
            <attribute name="t-on-touchcancel">this.onTouchMoveOrCancel</attribute>
            <attribute name="t-on-touchend">this.onTouchEnd</attribute>
        </xpath>
        <xpath expr="article" position="inside">
            <span
                t-if="this.props.selectionAvailable" 
                class="o_record_selection_tooltip d-none position-absolute p-2 rounded-3 start-50 top-50">
                    Click to select
            </span>
            <t t-call="{{ this.constructor.menuTemplate }}"/>
        </xpath>
    </t>

    <t t-name="web.KanbanMenu">
        <div t-if="this.showMenu and !this.props.readonly" class="o_dropdown_kanban bg-transparent position-absolute end-0 top-0 w-auto">
            <Dropdown menuClass="'o-dropdown--kanban-record-menu'" position="'bottom-end'">
                <button class="btn o-no-caret rounded-0 px-1" title="Dropdown menu">
                    <span class="oi oi-ellipsis-v"/>
                </button>
                <t t-set-slot="content">
                    <KanbanDropdownMenuWrapper>
                        <t t-call="{{ this.templates[this.constructor.MENU_ATTRIBUTE] }}" t-call-context="this.renderingContext"/>
                    </KanbanDropdownMenuWrapper>
                </t>
            </Dropdown>
        </div>
    </t>

</templates>
