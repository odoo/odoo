<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="web.FormLabel">
        <label class="o_form_label" t-att-for="this.props.id" t-att-class="this.className" >
            <t t-out="this.props.string" />
            <sup
                t-if="this.hasTooltip"
                class="d-print-none text-info p-1 ms-1"
                t-att="{
                    'data-tooltip-template': 'web.FieldTooltip',
                    'data-tooltip-info': this.tooltipInfo,
                    'data-tooltip-touch-tap-to-show': 'true'
                }"
                t-translation="off"
            >?</sup>
        </label>
    </t>

</templates>
