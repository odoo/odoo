<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="web.Layout">
        <Portal t-if="this.env.inDialog" target="this.footerTarget" t-key="this.rev">
            <t t-call-slot="control-panel-buttons"/>
        </Portal>
        <t t-component="this.components.ControlPanel" slots="this.controlPanelSlots" t-if="this.props.display.controlPanel" display="this.props.display.controlPanel"/>
        <main t-custom-ref="content" class="o_content" t-attf-class="{{this.props.className}}" t-att-class="{ 'o_component_with_search_panel': this.props.display.searchPanel }">
            <t t-component="this.components.SearchPanel" t-if="this.props.display.searchPanel"/>
            <t t-call-slot="default" contentRef="this.contentRef" />
        </main>
    </t>

</templates>
