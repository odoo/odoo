<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="web.ControlPanel">
        <div class="o_control_panel d-flex flex-column gap-3 px-3 pt-2 pb-3" t-custom-ref="root" data-command-category="actions">
            <EmbeddedActionsPanel t-if="!this.env.isSmall" state="this.embeddedPanelState"/>
            <div class="o_control_panel_main d-flex flex-wrap flex-lg-nowrap justify-content-between align-items-lg-start gap-2 gap-lg-3 flex-grow-1">
                <div class="o_control_panel_breadcrumbs d-flex align-items-center gap-1 order-0 h-lg-100">
                    <div class="o_control_panel_main_buttons d-flex gap-1 d-empty-none d-print-none text-nowrap" t-on-keydown="this.onMainButtonsKeydown">
                        <t t-if="this.display.buttons" t-call-slot="control-panel-buttons"/>
                        <Dropdown t-if="this.env.isSmall" menuClass="'o-control-panel-adaptive-dropdown'" onOpened.bind="this.dropdownifyButtons">
                            <button class="btn btn-secondary o-control-panel-adaptive-dropdown" title="More">
                                <i class="oi oi-fw oi-ellipsis-v" />
                            </button>
                            <t t-set-slot="content">
                                <t t-if="this.display.buttons" t-call-slot="control-panel-buttons"/>
                            </t>
                        </Dropdown>
                    </div>
                    <t t-if="this.env.config.noBreadcrumbs">
                        <section class="o_control_panel_breadcrumbs_actions d-contents d-print-none">
                            <t t-call-slot="control-panel-additional-actions"/>
                            <t t-call-slot="control-panel-status-indicator" />
                        </section>
                    </t>
                    <t t-elif="this.env.isSmall">
                        <!--
                            Here be dragons...
                            REFACTORME: this `t-portal` introduces an implicit
                            dependency between the ControlPanel and the NavBar,
                            which the impact is only mitigated by the fallback
                            below. This is a call to refactor the breadcrumbs
                            management to allow the proper instanciation of the
                            Breadcrumbs component in the NavBar.
                        -->
                        <div class="o_fallback_breadcrumbs d-contents"/>
                        <t t-custom-portal="'.o_navbar_breadcrumbs, .o_fallback_breadcrumbs'">
                            <Breadcrumbs breadcrumbs="this.breadcrumbs"/>
                        </t>
                        <section class="o_control_panel_breadcrumbs_actions d-contents">
                            <t t-call-slot="control-panel-additional-actions"/>
                            <t t-call-slot="control-panel-status-indicator" />
                        </section>
                    </t>
                    <t t-else="">
                        <Breadcrumbs breadcrumbs="this.breadcrumbs">
                            <t t-set-slot="breadcrumb-status-indicator">
                                <t t-call-slot="control-panel-status-indicator" />
                            </t>
                            <t t-set-slot="breadcrumb-additional-actions">
                                <t t-call-slot="control-panel-additional-actions"/>
                            </t>
                        </Breadcrumbs>
                    </t>
                    <div t-if="!this.env.isSmall" class="me-auto"/> <!-- Spacer -->
                </div>

                <div class="o_control_panel_actions d-empty-none d-flex align-items-center justify-content-start justify-content-lg-around order-2 order-lg-1 w-100 mw-100 w-lg-auto">
                    <t t-if="this.display.actions" t-call-slot="control-panel-actions"/>
                    <t t-call-slot="control-panel-selection-actions"/>
                </div>

                <div class="o_control_panel_navigation d-flex flex-wrap flex-md-nowrap justify-content-end gap-1 gap-xl-3 order-1 order-lg-2 flex-grow-1">
                    <t t-if="this.env.isSmall">
                        <EmbeddedActionsPanel id="embedded-actions-panel-mobile" state="this.embeddedPanelState"/>
                    </t>
                    <div t-if="this.pagerProps and this.pagerProps.total > 0" class="o_cp_pager text-nowrap " role="search">
                        <Pager t-props="this.pagerProps"/>
                    </div>
                    <button t-if="this.embeddedPanelState.embeddedInfos.embeddedActions?.length and !this.env.isSmall" name="embedded_actions" class="btn btn-secondary"
                            t-att-class="{active: this.embeddedPanelState.embeddedInfos.showEmbedded}"
                            t-on-click="() => this.embeddedPanelState.onClickShowEmbedded()"
                            title="View related documents">
                        <i class="fa fa-sliders" />
                    </button>
                    <t t-if="this.env.config.viewSwitcherEntries?.length > 1">
                        <div t-if="this.env.isSmall" class="o_cp_switch_buttons btn-group d-print-none">
                            <Dropdown menuClass="{o_cp_switch_buttons: true, o_custom_bottom_sheet: true }">
                                <button class="btn btn-secondary" data-available-offline="">
                                    <t t-set="activeView" t-value="this.env.config.viewSwitcherEntries.find((view) => view.active)"/>
                                    <i class="oi-fw" t-att-class="activeView.icon" data-tooltip="Switch view" />
                                </button>
                                <t t-set-slot="content">
                                    <t t-foreach="this.env.config.viewSwitcherEntries" t-as="view" t-key="view.type">
                                        <DropdownItem 
                                            tag="'button'"
                                            attrs="{ 'data-available-offline': this.isViewAvailable(view)}"
                                            onSelected="() => this.switchView(view.type)"
                                            class="{ 'selected': view.active }">
                                                <i class="oi-fw" t-att-class="view.icon"/>
                                                <span class="ms-1" t-out="view.name"/>
                                        </DropdownItem>
                                    </t>
                                </t>
                            </Dropdown>
                        </div>
                        <nav t-else="" class="o_cp_switch_buttons d-print-none d-inline-flex btn-group">
                            <t t-foreach="this.env.config.viewSwitcherEntries" t-as="view" t-key="view.type">
                                <button class="btn btn-secondary o_switch_view "
                                    t-att-class="{ 'active': view.active }"
                                    t-attf-class="o_{{view.type}}"
                                    t-att-data-available-offline="this.isViewAvailable(view)"
                                    t-att-data-tooltip="view.name"
                                    t-custom-click="(ev, isMiddleClick) => this.switchView(view.type, isMiddleClick)"
                                    t-att-aria-label="view.name + ' View'"
                                >
                                    <i class="oi-fw" t-att-class="view.icon" />
                                </button>
                            </t>
                        </nav>
                    </t>
                    <t t-call-slot="control-panel-navigation-additional"/>
                </div>
            </div>
        </div>
    </t>
</templates>
