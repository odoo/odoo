{
    "name": "odoo-js-config",
    "version": "2.0.0",
    "description": "JS Config for better DX in javascript",
    "type": "module",
    "scripts": {
        "format-all": "eslint --fix '**/*.js'",
        "lint-all": "eslint '**/*.js'",
        "lint-web": "eslint '**/web/**/*.js'",
        "format-staged": "lint-staged",
        "typecheck": "tsc -p jsconfig.json --noEmit",
        "typecheck:watch": "tsc -p jsconfig.json --noEmit --watch"
    },
    "devDependencies": {
        "eslint": "^10.0.2",
        "@eslint/js": "^10.0.0",
        "globals": "^16.0.0",
        "eslint-config-prettier": "^10.1.0",
        "eslint-plugin-prettier": "^5.5.5",
        "lint-staged": "^15.4.0",
        "prettier": "^3.5.0",
        "@types/jquery": "^3.5.14",
        "@types/luxon": "^3.1.0",
        "@types/qunit": "^2.19.3",
        "@odoo/o-spreadsheet": "alpha",
        "@odoo/owl": "^2.0.1",
        "typescript": "~5.7"
    },
    "lint-staged": {
        "*.js": [
            "eslint --fix"
        ]
    },
    "engines": {
        "node": ">=20.19.0"
    }
}
