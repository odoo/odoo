<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="other_profiles_config_wizard">
        <link rel="stylesheet" href="/web/assets/any/web.assets_web.min.css" />
        <script src="/web/assets/any/web.assets_web.min.js" type="text/javascript"/>
        
        <div class="container-md p-0">
            <div class="o_form_view" style="align-items: center;">
                <div class="o_form_sheet">
                    <!-- Single Form -->
                    <form id="dynamicForm" method="get" t-attf-action="/web/other_profiles/{{profile_str}}">
                        <h4>Options</h4>
                        
                        <div class="mt-3">
                            <label for="memory_limit">Memory limit</label>
                            <input type="number" id="memory_limit" name="memory_limit" class="form-control" value="1024"/>
                        </div>

                        <input type="hidden" name="profile_id" t-att-value="profile_str" />
                        
                        <div class="mt-3">
                            <button type="submit" class="btn btn-primary" name="action" value="memory">Memory</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </template>
</odoo>
