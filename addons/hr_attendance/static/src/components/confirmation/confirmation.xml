<templates xml:space="preserve">

    <t t-name="hr_attendance.KioskConfirmation">
        <t t-if="this.attendance">
            <div class="o_hr_kiosk_mode_main d-flex flex-grow-1 justify-content-center align-items-center">
                <div class="o_hr_attendance_kiosk_card card shadow-sm rounded-4 w-100" style="max-width: 420px;">
                    <div class="card-body p-4">
                        <div class="d-flex flex-column align-items-center text-center w-100">
                            <div class="m-4">
                                <t t-if="this.showVideoStream">
                                    <div class="w-100 d-flex justify-content-center mb-3">
                                        <div class="w-100" style="max-width: 240px;">
                                            <AttendanceVideoStream
                                                height="200"
                                                width="250"
                                                exposeCameraCapture.bind="this.props.exposeCameraCapture"
                                                onStreamStateChange.bind="this.setStreamAvailable"
                                            />
                                        </div>
                                    </div>
                                </t>
                                <t t-else="">
                                    <t t-call="hr_attendance.EmployeeBadge">
                                        <t t-set="employeeAvatar" t-value="this.employeeAvatar"/>
                                    </t>
                                </t>
                            </div>
                            <h5 class="text-muted mb-2">
                                Confirm
                                <t t-if="this.isCheckedIn">check-out</t>
                                <t t-else="">check-in</t>
                                for
                            </h5>
                            <div class="fw-bold mb-3">
                                <h2 t-out="this.employeeName+'?'"/>
                            </div>
                            <div class="alert alert-info w-100 text-center mb-3">
                                <span class="text-muted">Hours today: </span>
                                <strong><t t-out="this.hoursToday"/></strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="o_hr_kiosk_mode_bottom my-4 text-center d-flex justify-content-center gap-3">
                <button class="btn btn-primary btn-lg rounded-pill px-5"
                        t-on-click="() => this.props.kioskConfirm(this.props.employeeData.id, false)">
                    <t t-if="this.isCheckedIn">check-out</t>
                    <t t-else="">check-in</t>
                </button>
            </div>
        </t>
        <t t-else="">
            <div class="o_hr_kiosk_mode_main d-flex flex-grow-1 justify-content-center align-items-center">
                <div class="alert alert-warning text-center px-4 py-3">
                    <h4 class="mb-2">Invalid request</h4>
                    <p class="mb-0">Please return to the main menu.</p>
                </div>
            </div>
            <div class="o_hr_kiosk_mode_bottom my-4 text-center">
                <button class="btn btn-primary btn-lg rounded-pill px-5"
                        t-on-click="this.props.backToManualSelection">
                    <i class="oi oi-chevron-left me-2"/>
                    Go back
                </button>
            </div>
        </t>
    </t>

</templates>
