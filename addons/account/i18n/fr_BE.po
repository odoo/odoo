#: model_terms:ir.ui.view,arch_db:account.report_invoice_document
msgid "Vendor Credit Note"
msgstr "Note de crédit de fournisseur"

#. module: account
#. odoo-python
#: code:addons/account/models/account_move.py:0
msgid ""
"You cannot validate an invoice with a negative total amount. You should "
"create a credit note instead. Use the action menu to transform it into a "
"credit note or refund."
msgstr ""
"Vous ne pouvez pas valider une facture avec un montant total négatif. Vous "
"devriez plutôt créer une note de crédit. Utilisez le menu Action pour le "
"transformer en une note de crédit ou un remboursement."
