"                    on the account <strong t-"
"out=\"object.partner_bank_id.account_number\"/>\n"
"                </t>\n"
"                .\n"
"            </t>\n"
"        </t>\n"
"        <t t-if=\"hasattr(object, 'display_timesheet_portal_link') and "
"object.display_timesheet_portal_link\">\n"
"            <br/><br/>\n"
"            PS: you can review your timesheets <a t-att-href=\"'/my/"
"timesheets?search_in=invoice&amp;search=%s' % object.name\">from the portal."
"</a>\n"
"        </t>\n"
"        <br/><br/>\n"
"        Do not hesitate to contact us if you have any questions.\n"
"        <t t-if=\"not is_html_empty(object.invoice_user_id.signature)\">\n"
"            <br/><br/>\n"
"            <div data-o-mail-quote=\"1\">--<br data-o-mail-quote=\"1\"/><t t-"
"out=\"object.invoice_user_id.signature or ''\">Mitchell Admin</t></div>\n"
"        </t>\n"
"    </p>\n"
"</div>\n"
"            "
msgstr ""

