"                                </tr>\n"
"                            </table>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td colspan=\"2\" style=\"padding:34px 38px;\">\n"
"                            <table cellpadding=\"0\" cellspacing=\"0\" "
