"                                    Prefer to stop receiving these? <a t-"
"attf-href=\"{{ unsubscribe_url }}\" style=\"color:#8f8596; text-"
"decoration:underline;\" target=\"_blank\">Unsubscribe here</a>.\n"
"                                </t>\n"
"                            </p>\n"
"                        </td>\n"
"                    </tr>\n"
"                </table>\n"
"            </td>\n"
"        </tr>\n"
"    </table>\n"
"</div>\n"
