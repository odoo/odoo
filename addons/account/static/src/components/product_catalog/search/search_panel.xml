<?xml version="1.0" encoding="UTF-8"?>

<templates id="template" xml:space="preserve">
    <t
        t-name="account.ProductCatalogSearchPanelContent"
        t-inherit="web.SearchPanelContent"
        t-inherit-mode="primary"
    >
        <div t-custom-ref="root" position="attributes">
            <attribute name="class" add="o_product_catalog_search_panel" separator=" "/>
        </div>

        <xpath expr="//header/i" position="replace"/>

        <section position="before">
            <section t-if="this.showSections" class="o_search_panel_sections mt-4 pb-4 border-bottom">
                <header class="d-flex align-items-center cursor-default mb-3 ps-2">
                    <b class="text-uppercase mx-2">Sections</b>
                    <i
                        class="fa fa-fw fa-plus-square cursor-pointer"
                        t-on-click="() => this.enableSectionInput('bottom')"
                    />
                    <div class="d-flex align-items-center ms-auto">
                        <span class="me-2">Filter</span>
                        <div class="form-check form-switch mb-0">
                            <input
                                class="form-check-input"
                                type="checkbox"
                                role="switch"
                                t-att-checked="this.selectedSection.filtered ? true : false"
                                t-on-click="() => this.setSelectedSection(
                                    this.selectedSection.sectionId, !this.selectedSection.filtered
                                )"
                            />
                        </div>
                    </div>
                </header>
                <ul class="list-group d-block" t-ref="mainTree">
                    <t t-foreach="this.state.sections" t-as="section" t-key="section.id">
                        <SectionRow
                            section="section"
                            state="this.state"
                        />
                    </t>
                </ul>
                <input
                    t-if="this.state.isAddingSection === 'bottom'"
                    class="o_section_input py-1"
                    type="text"
                    placeholder="Enter a description"
                    t-custom-model="this.state.newSectionName"
                    t-on-keydown="(ev) => this.onSectionInputKeydown(ev)"
                    t-on-blur="() => this.createSection()"
                />
            </section>
        </section>

        <div class="o_search_panel_empty_state me-3" position="attributes">
            <attribute name="class" add="d-none" separator=" "/>
        </div>
    </t>

