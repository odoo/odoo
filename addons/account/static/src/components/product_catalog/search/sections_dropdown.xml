<?xml version="1.0" encoding="UTF-8"?>

<templates>
    <t t-name="account.SectionsDropdown">
        <Dropdown class="'ms-auto'">
            <button class="btn p-0 border-0 bg-transparent">
                <i class="fa fa-ellipsis-v text-muted"/>
            </button>
            <t t-set-slot="content">
                <DropdownItem onSelected="() => this.duplicateSection()">
                    <i class="me-1 fa fa-fw fa-clone"/><span>Duplicate</span>
                </DropdownItem>
                <DropdownItem onSelected="() => this.deleteSection()" class="'text-danger'">
                    <i class="me-1 fa fa-fw fa-trash"/><span>Delete</span>
                </DropdownItem>
            </t>
        </Dropdown>
    </t>
</templates>
