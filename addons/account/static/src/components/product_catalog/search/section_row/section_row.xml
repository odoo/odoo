<templates>
    <t t-name="account.SectionRow">
        <li
            class="list-group-item border-0 o_section px-0"
            t-attf-class="{{this.props.section.display_type === 'line_subsection' &amp;&amp; !this.env.isSmall ? 'o_treeEntry' : ''}}"
            t-att-data-id="this.props.section.id"
            t-att-data-sequence="this.props.section.sequence"
        >

            <div
                t-attf-class="o_section_row list-group-item list-group-item-action d-flex align-items-center gap-1 border-0 cursor-pointer
                    {{this.props.section.display_type === 'line_subsection' ? 'o_subsection_row' : ''}}
                    {{this.props.selectedSection.sectionId == this.props.section.id ? 'o_selected_section' : ''}}
                "
                t-on-click="() => this.env.setSelectedSection(this.props.section.id, this.props.selectedSection.filtered)"
            >
                <button
                    class="o_toggle_fold btn border-0 rounded-end-0 px-0 bg-transparent"
                    t-attf-class="{{this.props.section.isOpen ? 'fa fa-caret-down' : 'fa fa-caret-right'}} {{this.props.section.children.length ? '' : 'opacity-0 pe-none'}}"
                    t-att-tabindex="this.props.section.children.length ? '0' : '-1'"
                />

                <input
                    t-if="this.props.state.renamingSectionId === this.props.section.id"
                    class="o_section_input"
                    type="text"
                    t-custom-model="this.props.state.newSectionName"
                    t-on-keydown="(ev) => this.env.onSectionInputKeydown(ev, null, this.props.section.id)"
                    t-on-blur="() => this.env.renameSection(this.props.section.id)"
                    t-custom-ref="InputRef"
                />

                <div
                    t-else=""
                    tabindex="0"
                    class="o_search_panel_label d-flex align-items-center w-100 overflow-hidden"
                    t-on-keydown="(ev) => this.onSectionLabelKeydown(ev)"
                    t-att-title="this.props.section.name"
                >
                    <span
                        t-attf-class="o_search_panel_label_title d-flex align-items-center flex-grow-1 {{this.props.selectedSection.sectionId == this.props.section.id ? 'fw-bold' : ''}}"
                    >
                        <span
                            class="text-truncate me-1"
                            t-att-style="'max-width: ' + (this.env.isSmall ? '200px' : '130px')"
                            t-out="this.props.section.name"
                        />
                        <span
                            class="ms-auto text-muted o_section_subtotal"
                            t-out="this.env.getFormattedSubTotal(this.props.section.subtotal)"
                        />
                        <div
                            t-if="this.props.selectedSection.sectionId == this.props.section.id"
                            class="ms-auto align-items-center o_section_toggle"
                        >
                            <span class="me-2">Filter</span>
                            <div class="form-check form-switch mb-0 small py-0">
                                <input
                                    class="form-check-input"
                                    type="checkbox"
                                    role="switch"
                                    t-att-checked="this.props.selectedSection.filtered ? true : false"
                                    t-on-click="() => this.env.setSelectedSection(
                                        this.props.selectedSection.sectionId, !this.props.selectedSection.filtered
                                    )"
                                />
                            </div>
                        </div>
                    </span>
                </div>
                <SectionDropdown section="this.props.section"/>
            </div>

            <ul
                t-if="this.props.section.isOpen and this.props.section.children.length"
                class="list-group border-0"
            >
                <t t-foreach="this.props.section.children" t-as="child" t-key="child.id">
                    <SectionRow
                        section="child"
                        state="this.props.state"
                        selectedSection="this.props.selectedSection"
                    />
                </t>
            </ul>

            <input
                t-if="this.props.state.isAddingSection === ('subsection_' + this.props.section.id) and this.props.section.display_type === 'line_section'"
                class="o_section_input ms-4 mt-1"
                style="width: 90%;"
                type="text"
                placeholder="Enter a description"
                t-custom-model="this.props.state.newSectionName"
                t-on-keydown="(ev) => this.env.onSectionInputKeydown(ev, this.props.section.id)"
                t-on-blur="() => this.env.createSection(this.props.section.id)"
                t-custom-ref="InputRef"
            />

        </li>
    </t>
</templates>
