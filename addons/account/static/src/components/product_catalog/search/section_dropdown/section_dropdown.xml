<?xml version="1.0" encoding="UTF-8"?>

<templates>
    <t t-name="account.SectionDropdown">
        <Dropdown class="ms-auto">
            <button style="min-width: 30px" class="btn p-0 border-0 bg-transparent">
                <i class="fa fa-ellipsis-v text-muted"/>
            </button>
            <t t-set-slot="content">
                <DropdownItem
                    t-if="'collapse_prices' in this.props.section"
                    onSelected="() => this.toggleFieldOfSection('collapse_prices')"
                    attrs="{ 'class': this.disablePricesButton() ? 'disabled' : '' }"
                >
                    <i class="me-1 fa fa-fw" t-att-class="this.props.section.collapse_prices ? 'fa-eye' : 'fa-eye-slash'"/>
                    <span t-if="this.props.section.collapse_prices">Show Prices</span>
                    <span t-else="">Hide Prices</span>
                </DropdownItem>
                <t t-name="composition_button">
                    <DropdownItem
                        t-if="'collapse_composition' in this.props.section"
                        onSelected="() => this.toggleFieldOfSection('collapse_composition')"
                        attrs="{ 'class': this.disableCompositionButton() ? 'disabled' : '' }"
                    >
                        <i class="me-1 fa fa-fw" t-att-class="this.props.section.collapse_composition ? 'fa-expand' : 'fa-compress'"/>
                        <span t-if="this.props.section.collapse_composition">Show Composition</span>
                        <span t-else="">Hide Composition</span>
                    </DropdownItem>
                </t>
                <DropdownItem onSelected="() => this.duplicateSection()">
                    <i class="me-1 fa fa-fw fa-clone"/><span>Duplicate</span>
                </DropdownItem>
                <DropdownItem onSelected="() => this.deleteSection()" class="'text-danger'">
                    <i class="me-1 fa fa-fw fa-trash"/><span>Delete</span>
                </DropdownItem>
            </t>
        </Dropdown>
    </t>
</templates>
