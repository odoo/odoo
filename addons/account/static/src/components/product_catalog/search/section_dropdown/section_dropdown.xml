<?xml version="1.0" encoding="UTF-8"?>

<templates>
    <t t-name="account.SectionDropdown">
        <Dropdown noClasses="true">
            <button
                t-attf-class="o_section_dropdown_button btn border-0 bg-transparent rounded-start-0 px-2 {{this.props.section.id ? '' : 'opacity-0 pe-none'}}"
                t-att-tabindex="this.props.section.id ? '0' : '-1'"
            >
                <i class="fa fa-ellipsis-v text-muted"/>
            </button>
            <t t-set-slot="content">
                <DropdownItem
                    t-if="this.props.section.display_type === 'line_section'"
                    closingMode="'closest'"
                    onSelected="() => this.env.enableSectionInput(this.props.section.id)"
                >
                    <i class="me-1 fa fa-fw fa-level-down"/><span>Add a subsection</span>
                </DropdownItem>
                <DropdownItem
                    closingMode="'closest'"
                    onSelected="() => this.env.enableRenameSectionInput(this.props.section.id)"
                >
                    <i class="me-1 fa fa-fw fa-pencil"/><span>Rename</span>
                </DropdownItem>
                <DropdownItem closingMode="'closest'" onSelected="() => this.env.duplicateSection(this.props.section)">
                    <i class="me-1 fa fa-fw fa-clone"/><span>Duplicate</span>
                </DropdownItem>
                <DropdownItem
                    class="'text-danger'"
                    closingMode="'closest'"
                    onSelected="() => this.env.deleteSection(this.props.section)"
                >
                    <i class="me-1 fa fa-fw fa-trash"/><span>Delete</span>
                </DropdownItem>
            </t>
        </Dropdown>
    </t>
</templates>
