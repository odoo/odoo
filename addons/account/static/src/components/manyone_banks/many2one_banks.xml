<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="account.Many2OneBank" t-inherit="web.Many2One">
        <xpath expr="//t[@t-if='this.props.readonly']" position="before">
            <t t-if="this.props.value.id">
                <i t-if="this.props.bankAllowOutPayment" class="me-1 oi text-success align-self-center" data-icon="security" title="Trusted"/>
                <i t-else="" class="me-1 oi text-danger align-self-center" data-icon="error" title="Untrusted"/>
            </t>
        </xpath>
    </t>
</templates>
