<odoo>
    <data>
        <record id="uom_uom_view_form" model="ir.ui.view">
            <field name="name">uom.uom.view.form.inherit.account</field>
            <field name="model">uom.uom</field>
            <field name="inherit_id" ref="uom.uom_uom_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="before">
                    <field name="fiscal_country_codes" invisible="1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
