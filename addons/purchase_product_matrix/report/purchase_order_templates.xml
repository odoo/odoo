<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="grid_purchaseorder_inherit" inherit_id="purchase.report_purchaseorder_document">
        <xpath expr="//div[@id='informations']" position="after">
            <t t-call="product_matrix.matrix">
                <t t-set="order" t-value="o"/>
            </t>
        </xpath>
        <xpath expr="//td[@id='product']" position="replace">
            <td id="product">
                <ul class="list-unstyled">
                    <li><span t-field="line.product_template_id"/></li>
                    <li t-if="line.product_template_id.display_name != line.name">
                        <span t-field="line.name"/>
                    </li>
                </ul>
            </td>
        </xpath>
    </template>
</odoo>
