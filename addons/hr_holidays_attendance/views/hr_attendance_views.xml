<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- work_entry_type_id column in the attendance list -->
    <record id="view_attendance_tree_inherit_holidays" model="ir.ui.view">
        <field name="name">hr.attendance.list.holidays</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.view_attendance_tree"/>
        <field name="arch" type="xml">
            <field name="worked_hours" position="after">
                <field name="work_entry_type_id" optional="show" string="Type"/>
            </field>
        </field>
    </record>

    <!-- work_entry_type_id on the attendance form (worked-hours group) -->
    <record id="view_attendance_form_inherit_holidays" model="ir.ui.view">
        <field name="name">hr.attendance.form.holidays</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_form"/>
        <field name="arch" type="xml">
            <field name="worked_hours" position="after">
                <field name="work_entry_type_id" string="Type" options="{'no_create': True}"/>
            </field>
        </field>
    </record>

    <!-- filters: output attendances vs. source attendances -->
    <record id="view_attendance_search_inherit_holidays" model="ir.ui.view">
        <field name="name">hr.attendance.search.holidays</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_filter"/>
        <field name="arch" type="xml">
            <filter name="auto_check" position="after">
                <separator/>
                <filter string="Overtime Entries" name="is_time_rule_output"
                        domain="[('is_time_rule_output', '=', True)]"/>
                <filter string="Source Attendances" name="source_attendances"
                        domain="[('is_time_rule_output', '=', False), ('source_attendance_id', '=', False)]"/>
            </filter>
        </field>
    </record>

</odoo>
