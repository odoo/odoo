<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Overtime attendance entries page on the attendance form -->
    <record id="view_attendance_overtime_leave_form" model="ir.ui.view">
        <field name="name">hr.attendance.overtime.leave.form</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_form"/>
        <field name="arch" type="xml">
            <sheet position="inside">
                <notebook invisible="not overtime_attendance_ids"
                    groups="hr.group_hr_manager,hr_attendance.group_hr_attendance_own">
                    <page string="Rules Outputs">
                        <field name="overtime_attendance_ids" readonly="1">
                            <list>
                                <field string="Time type" name="work_entry_type_id" readonly="1"/>
                                <field name="check_in" readonly="1"/>
                                <field name="check_out" readonly="1"/>
                                <field name="worked_hours" widget="float_time" readonly="1"/>
                            </list>
                        </field>
                    </page>
                </notebook>
            </sheet>
        </field>
    </record>

</odoo>
