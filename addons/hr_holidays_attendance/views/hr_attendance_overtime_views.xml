<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Overtime leaves page on the attendance form -->
    <record id="view_attendance_overtime_leave_form" model="ir.ui.view">
        <field name="name">hr.attendance.overtime.leave.form</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_form"/>
        <field name="arch" type="xml">
            <sheet position="inside">
                <notebook invisible="not overtime_leave_ids"
                    groups="hr.group_hr_manager,hr_attendance.group_hr_attendance_own">
                    <page string="Overtime Leaves">
                        <field name="overtime_leave_ids" readonly="1">
                            <list>
                                <field name="work_entry_type_id" readonly="1"/>
                                <field name="number_of_hours" widget="float_time" readonly="1"/>
                                <field name="state" widget="badge" readonly="1"
                                    decoration-warning="state == 'confirm'"
                                    decoration-success="state == 'validate'"
                                    decoration-danger="state == 'refuse'"/>
                            </list>
                        </field>
                    </page>
                </notebook>
            </sheet>
        </field>
    </record>

    <!-- Attendance work entry type setting -->
    <record id="res_config_settings_view_form_inherit" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.hr_holidays_attendance</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="hr_attendance.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='attendance_rules']" position="inside">
                <setting string="Attendance Work Entry Type" company_dependent="1"
                         help="Work entry type assigned to leaves generated from attendance records. Used by the time rule engine.">
                    <field name="attendance_work_entry_type_id" options="{'no_create': True}"/>
                </setting>
            </xpath>
        </field>
    </record>

</odoo>
