<?xml version='1.0' encoding='UTF-8' ?>
<odoo>
    <record id="hr_leave_accrual_level_view_form" model="ir.ui.view">
        <field name="name">hr.leave.accrual.level.form</field>
        <field name="model">hr.leave.accrual.level</field>
        <field name="inherit_id" ref="hr_holidays.hr_accrual_level_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//span[@name='yearly']" position="after">
                <span invisible="context.get('accrued_gain_time', accrued_gain_time) == 'start'">
                    based on
                    <field nolabel="1" class="ms-1" name="frequency_hourly_source" widget="radio" required="frequency == 'hourly'"/>
                </span>
            </xpath>
        </field>
    </record>
</odoo>
