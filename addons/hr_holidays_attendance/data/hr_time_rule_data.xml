<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Set the attendance work entry type as the input condition on all base rules -->
        <function model="hr.time.rule" name="write">
            <value model="hr.time.rule" eval="[
                ref('hr_holidays.hr_time_rule_employee_schedule'),
                ref('hr_holidays.hr_time_rule_l10n_sa_workdays'),
                ref('hr_holidays.hr_time_rule_l10n_jo_public_holidays'),
                ref('hr_holidays.hr_time_rule_l10n_jo_rest_days'),
                ref('hr_holidays.hr_time_rule_l10n_jo_week_days'),
                ref('hr_holidays.hr_time_rule_l10n_eg_work_days_daytime'),
                ref('hr_holidays.hr_time_rule_l10n_eg_work_days_nighttime_evening'),
                ref('hr_holidays.hr_time_rule_l10n_eg_work_days_nighttime_early'),
                ref('hr_holidays.hr_time_rule_l10n_eg_public_holidays'),
                ref('hr_holidays.hr_time_rule_l10n_eg_rest_days'),
                ref('hr_holidays.hr_time_rule_l10n_iq_day_time_1'),
                ref('hr_holidays.hr_time_rule_l10n_iq_day_time_2'),
                ref('hr_holidays.hr_time_rule_l10n_iq_night_time_1'),
                ref('hr_holidays.hr_time_rule_l10n_iq_night_time_2'),
                ref('hr_holidays.hr_time_rule_l10n_ae_day_time'),
                ref('hr_holidays.hr_time_rule_l10n_ae_night_time_1'),
                ref('hr_holidays.hr_time_rule_l10n_ae_night_time_2'),
                ref('hr_holidays.hr_time_rule_l10n_ae_off_days'),
            ]"/>
            <value eval="{'condition_work_entry_type_ids': [(4, ref('hr_work_entry.attendance_work_entry_type'))]}"/>
        </function>
    </data>
</odoo>
