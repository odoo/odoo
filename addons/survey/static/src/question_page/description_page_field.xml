<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="survey.DescriptionPageField" t-inherit="web.CharField">
        <xpath expr="//div[@class='o_field_input_buttons']" position="replace">
            <button type="button" title="Open section" class="btn btn-link o_input_box_overlay_end" t-on-click.stop="onExternalBtnClick">
                <i class="fa fa-external-link"/>
            </button>
        </xpath>
        <xpath expr="//span[@t-out='formattedValue']" position="after">
            <button class="btn btn-link o_input_box_overlay_end" t-if="props.record.data.is_page">
                <i class="fa fa-pencil"/>
            </button>
        </xpath>
    </t>

</templates>
