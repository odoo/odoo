<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.proxy.user</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="l10n_fr_pdp.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='l10n_fr_pdp_']" position="inside">
                <br/>
                <label string="Flow 10 Report Periodicity"
                        for="l10n_fr_pdp_periodicity"
                        class="col-lg-3 o_light_label"/>
                <field name="l10n_fr_pdp_periodicity"/>
            </xpath>
        </field>
    </record>
</odoo>
