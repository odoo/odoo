<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="html_editor.EmbeddedDate" t-inherit="html_editor.ReadonlyEmbeddedDate" t-inherit-mode="primary">
        <xpath expr="//span" position="attributes">
            <attribute name="t-on-click">this.onClick</attribute>
            <attribute name="t-custom-ref">embedded-date</attribute>
            <attribute name="class" add="cursor-pointer"/>
        </xpath>
    </t>
</templates>
