<templates xml:space="preserve">
    <t t-name="html_editor.ImageAlignSelector">
        <Dropdown state="this.dropdown" menuClass="'o-we-toolbar-dropdown'" menuRef="this.menuRef" focusToggleOnClosed="false">
            <button t-ref="imageAlignSelector" class="btn btn-light" t-att-title="this.props.title" name="image_align">
                <span t-attf-class="oi {{ this.state.displayIcon }}"/>
            </button>
            <t t-set-slot="content">
                <div data-prevent-closing-overlay="true">
                    <t t-foreach="this.props.items" t-as="item" t-key="item_index">
                        <DropdownItem
                            tag="'button'"
                            attrs="{ title: item.title }"
                            class="{
                                'dropdown-item_active_noarrow btn btn-light oi': true,
                                [item.icon]: true,
                                active: item.icon === this.state.displayIcon
                            }"
                            onSelected="() => this.onSelected(item)"
                            t-on-pointerdown.prevent="() => {}"
                        />
                    </t>
                </div>
            </t>
        </Dropdown>
    </t>
</templates>
