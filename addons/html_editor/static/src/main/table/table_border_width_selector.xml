<templates xml:space="preserve">
    <t t-name="html_editor.TableBorderWidthSelector">
        <Dropdown menuClass="'o-we-toolbar-dropdown'" menuRef="menuRef">
            <button class="btn btn-light" t-att-title="this.props.title" name="table_border_width">
                <t t-call="html_editor.TableBorderWidthSvg"/>
            </button>
            <t t-set-slot="content">
                <div data-prevent-closing-overlay="true" data-vertical="true">
                    <div t-foreach="this.items" t-as="item" t-key="item.value">
                        <DropdownItem
                            class="{'dropdown-item_active_noarrow btn btn-light': true, active: item.value === this.state.displayName}"
                            t-on-pointerdown.prevent="() => {}"
                            onSelected="() => this.onSelected(item)"
                        >
                            <div class="o-border-preview" t-attf-style="border-width: {{item.value}}; margin-top: {{item.margin}}; border-style: solid; width: 50px;"/>
                        </DropdownItem>
                    </div>
                </div>
            </t>
        </Dropdown>
    </t>

    <t t-name="html_editor.TableBorderWidthSvg">
        <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="var(--btn-color)">
            <path d="M120-160v-40h720v40H120Zm0-120v-80h720v80H120Zm0-160v-120h720v120H120Zm0-200v-160h720v160H120Z"/>
        </svg>
    </t>
</templates>
