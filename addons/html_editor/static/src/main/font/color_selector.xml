<templates xml:space="preserve">

<t t-name="html_editor.ColorSelector">
    <button t-custom-ref="root" class="btn btn-light" t-attf-class="o-select-color-{{this.props.type}} {{this.colorSelectorState.isOpen ? 'active' : ''}}" t-att-title="this.props.title" t-att-disabled="this.props.isDisabled">
        <t t-if="this.props.type === 'foreground'">
            <i class="fa fa-fw fa-font py-1" t-att-style="this.getSelectedColorStyle()"/>
        </t>
        <t t-elif="this.props.type === 'custom'">
            <i class="fa fa-fw py-1" t-attf-class="{{this.props.customIconClass}}" t-att-style="this.getSelectedColorStyle()"/>
        </t>
        <t t-else="">
            <i class="fa fa-fw fa-paint-brush py-1" t-att-style="this.getSelectedColorStyle()"/>
        </t>
    </button>
</t>

</templates>
