<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="html_editor.CodeToolbar">
        <div class="o_code_toolbar">
            <div data-prevent-closing-overlay="true">
                <Dropdown menuClass="'o_language_selector'">
                    <button class="btn btn-light" t-att-title="state.language.displayName" name="language">
                        <span class="px-1" t-esc="state.language.displayName"/>
                    </button>
                    <t t-set-slot="content">
                        <t t-foreach="props.languages" t-as="language" t-key="language_index">
                            <DropdownItem
                                attrs="{ name: language.displayName }"
                                onSelected="() => this.selectLanguage(language)" t-on-pointerdown.prevent="() => {}">
                                <t t-esc="language.displayName"/>
                            </DropdownItem>
                        </t>
                    </t>
                </Dropdown>
            </div>
            <CopyButton content="getContent()" copyText.translate="Copy" successText.translate="Code copied to the clipboard."/>
        </div>
    </t>
</templates>
