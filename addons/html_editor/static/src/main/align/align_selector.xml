<templates xml:space="preserve">
    <t t-name="html_editor.AlignSelector">
        <Dropdown state="dropdown" menuClass="'o-we-toolbar-dropdown'" menuRef="this.menuRef" focusToggleOnClosed="false">
            <button t-ref="alignSelector" class="btn btn-light" t-att-title="this.props.title" name="text_align">
                <span class="px-1 d-flex align-items-center">
                    <i t-att-class="`fa fa-align-${this.state.displayName}`"/>
                </span>
            </button>
            <t t-set-slot="content">
                <div data-prevent-closing-overlay="true">
                    <t t-foreach="this.items" t-as="item" t-key="item_index">
                        <DropdownItem
                            tag="'button'"
                            attrs="{ title: item.description }"
                            class="{['dropdown-item_active_noarrow btn btn-light fa fa-align-'+item.icon]: true, active: item.icon === this.state.displayName }"
                            t-on-pointerdown.prevent="() => {}"
                            onSelected="() => this.onSelected(item)"
                        />
                    </t>
                </div>
            </t>
        </Dropdown>
    </t>
</templates>
