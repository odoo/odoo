<templates xml:space="preserve">
    <t t-name="html_editor.MobileToolbar">
        <div t-custom-ref="toolbarWrapper" class="o-toolbar-above-keyboard">
            <Toolbar
                state="this.props.state"
                getSelection="this.props.getSelection"
                focusEditable="this.props.focusEditable"
                class="this.props.class"
            />
        </div>
    </t>
</templates>
