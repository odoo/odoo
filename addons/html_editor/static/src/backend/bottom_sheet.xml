<templates xml:space="preserve">
    <!-- Prevent bottom sheets from closing toolbar -->
    <t t-name="html_editor.BottomSheet" t-inherit="web.BottomSheet" t-inherit-mode="extension">
        <xpath expr="//div" position="attributes">
            <attribute name="data-prevent-closing-overlay">true</attribute>
        </xpath>
        <xpath expr="//div[hasclass('o_bottom_sheet_rail')]" position="before">
            <t t-if="this.props.withUnfocus">
                <!-- Hidden iframe to put cursor -->
                <iframe t-on-load="this.onIframeLoad"
                    style="opacity: 0"
                    srcdoc="&lt;input&gt;"
                />
            </t>
        </xpath>
    </t>

</templates>
