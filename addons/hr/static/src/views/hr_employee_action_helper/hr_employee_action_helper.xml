<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <t t-name="hr.EmployeeActionHelper" t-inherit="web.ActionHelper" t-inherit-mode="primary">
        <xpath expr="//t[@t-if='this.showDefaultHelper']" position="after">
            <t t-elif="this.showOnboardingHelper">
                <div class="d-flex h-100 w-100 flex-column align-items-center">
                    <p class="text-center fs-1 mt-auto mb-0">
                        Ready to start your experience?
                    </p>

                    <!-- "desktop" : Put "Load Sample Data" and "Create an employee" buttons in a row layout -->
                    <div class="d-none d-lg-flex flex-column align-self-center justify-content-center mb-auto mt-4">
                        <div class="d-flex justify-content-center gap-4">
                            <div class="d-flex align-self-center">
                                <a class="btn btn-primary text-nowrap text-overflow-ellipsis px-3"
                                    t-on-click="this.loadDemoData" id="loadSampleDataBtn">
                                    Load sample data
                                </a>
                            </div>
                            <div class="d-flex align-self-center">
                                <a class="btn btn-secondary text-nowrap text-overflow-ellipsis px-3"
                                    t-on-click="this.loadNewEmployeeForm">Create an employee</a>
                            </div>
                        </div>
                        <div class="my-3 py-1">
                            <hr style="width: 520px;" />
                        </div>
                        <OnboardingHelperBlocks />
                    </div>

                    <!-- "mobile" : Put "Load Sample Data" and "Create an employee" buttons in a column layout -->
                    <div class="d-flex d-lg-none flex-column pb-5 mb-auto mt-4">
                        <div class="d-flex align-self-center">
                            <a class="btn btn-primary text-nowrap text-overflow-ellipsis px-3"
                                t-on-click="this.loadDemoData" id="loadSampleDataBtn">
                                Load sample data
                            </a>
                        </div>
                        <div class="d-flex">
                            <div class="p-0 m-0 align-self-center">
                                <hr style="width: 90px;" />
                            </div>
                            <p class="fst-italic align-self-center m-0 py-0 px-3">
                                or
                            </p>
                            <div class="p-0 m-0 align-self-center">
                                <hr style="width: 90px;" />
                            </div>
                        </div>
                        <div class="d-flex align-self-center mb-auto">
                            <a class="btn btn-secondary text-nowrap text-overflow-ellipsis px-3"
                                t-on-click="this.loadNewEmployeeForm">Create an employee</a>
                        </div>
                    </div>
                </div>
            </t>
        </xpath>
    </t>
</odoo>
