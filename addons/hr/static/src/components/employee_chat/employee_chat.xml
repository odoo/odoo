<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="hr.OpenChat">
        <a t-if="this.props.record.data.user_id and this.props.record.resId"
            title="Chat"
            icon="forum"
            icon_class="oi-filled"
            t-on-click.prevent="() => this.store.openChat({ employeeId: this.props.record.resId })"
            href="#"
            class="ml8 o_employee_chat_btn"
            role="button">
            <i class="oi oi-filled align-middle fs-6" data-icon="forum"/>
        </a>
    </t>
</templates>
