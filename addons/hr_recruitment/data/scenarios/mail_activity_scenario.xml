<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="applicant_macm_enrique_activity" model="mail.activity">
            <field name="res_id" ref="hr_recruitment.applicant_macm_enrique" />
            <field name="res_model_id" ref="model_hr_applicant" />
            <field name="activity_type_id" ref="mail.mail_activity_data_email" />
            <field name="date_deadline"
                eval="DateTime.today() + relativedelta(days=1)" />
