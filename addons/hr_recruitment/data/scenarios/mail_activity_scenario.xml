            <field name="create_uid" ref="base.user_admin" />
            <field name="user_id" ref="base.user_admin" />
        </record>
        
        <record id="applicant_fsd_hannah_activity" model="mail.activity">
            <field name="res_id" ref="hr_recruitment.applicant_fsd_hannah" />
