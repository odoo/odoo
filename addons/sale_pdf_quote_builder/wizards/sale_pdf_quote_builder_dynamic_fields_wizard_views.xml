<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pdf_quote_builder_dynamic_fields_wizard" model="ir.ui.view">
        <field name="name">sale.pdf.quote.builder.dynamic.fields.wizard.view.form</field>
        <field name="model">sale.pdf.quote.builder.dynamic.fields.wizard</field>
        <field name="arch" type="xml">
            <form string="Configure Dynamic Fields">
                <sheet>
                    <field name="current_form_fields" invisible="1"/>
                    <field name="dynamic_fields_wizard_line_ids">
                        <tree editable="bottom" delete="true">
                            <field name="document_type"/>
                            <field name="form_field"/>
                            <field name="path"/>
                        </tree>
                    </field>
                </sheet>
                <footer>
                    <button name="validate_dynamic_fields_configuration" string="Validate" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

