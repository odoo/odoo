<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="salePdfQuoteBuilder.contentEditionDialog">
        <Dialog title="title">
            <span t-attf-class="card-text #{state.content ? '' : 'text-muted'}">
                <input
                    t-att-value="props.content" t-on-change="(ev) => props.content = ev.target.value" class="o_input" t-att-placeholder="props.placeholderLabel"
                />
            </span>
            <t t-set-slot="footer">
                <button class="btn btn-primary" t-on-click="onConfirm">
                    Save
                </button>
                <button class="btn btn-secondary" t-on-click="() => this.props.close()">
                    Discard
                </button>
            </t>
        </Dialog>
    </t>
</templates>
