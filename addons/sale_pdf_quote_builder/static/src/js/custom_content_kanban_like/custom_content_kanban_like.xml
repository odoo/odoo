<?xml version="1.0" encoding="UTF-8"?>

<templates xml:space="preserve">

    <t t-name="sale_pdf_quote_builder.CustomContentKanbanLike">
        <t t-if="datas.header_footer">
            <t t-foreach="datas.header_footer" t-as="formField" t-key="'hf' + formField">
                <div
                    class="card align-items-stretch flex-column mt-2"
                    t-on-click="onClickEditText('headerFooter', formField)"
                >
                    <div class="card-header justify-content-between align-items-center border-0 bg-view">
                        <h5 class="card-title text-primary"> Header and footer / <t t-out="formField"/></h5>
                    </div>
                    <div class="card-body">
                        <span class="card-text"><t t-out="formField.value or 'blablabla'"/></span>
                    </div>

<!--                    <span><t t-out="datas.header_footer[formField]"/></span>-->

                </div>
            </t>
        </t>
        <br/>
        <t t-if="datas.product_document">
            test2
        </t>
    </t>

</templates>
