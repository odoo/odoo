<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_edit_project_inherit_form_sale_project_margin" model="ir.ui.view">
        <field name="name">project.project.view.inherit.sale.project.margin</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="sale_project.view_edit_project_inherit_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_real_margin']" position="before">
                <t groups="sales_team.group_sale_salesman_all_leads">
                    <button name="action_estimated_margin"
                        type="object"
                        invisible="is_template or not allow_billable"
                        groups="project.group_project_manager"
                        class="oe_stat_button">
                        <field name="estimated_cost" invisible="1"/> <!-- Used for `estimated_cost_ratio` costs_percentpie cost_field_name -->
                        <field name="estimated_cost_ratio" widget="costs_percentpie" string="Estimated Costs" cost_field_name="estimated_cost"/>
                    </button>
                </t>
            </xpath>
        </field>
    </record>

    <record id="project_embedded_action_project_projected_margin" model="ir.embedded.actions">
        <field name="parent_res_model">project.project</field>
        <field name="sequence">135</field>
        <field name="name">Estimated Margin</field>
        <field name="groups_ids" eval="[(4, ref('project.group_project_manager'))]"/>
        <field name="parent_action_id" ref="project.act_project_project_2_project_task_all"/>
        <field name="python_method">action_estimated_margin</field>
    </record>

</odoo>
