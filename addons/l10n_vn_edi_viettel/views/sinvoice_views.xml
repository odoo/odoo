<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_l10n_vn_sinvoice_symbol_search_inherit_l10n_vn_edi_viettel" model="ir.ui.view">
        <field name="name">l10n_vn.sinvoice.symbol.search.inherit.l10n_vn_edi_viettel</field>
        <field name="model">l10n_vn.sinvoice.symbol</field>
        <field name="inherit_id" ref="l10n_vn.view_l10n_vn_sinvoice_symbol_search"/>
        <field name="arch" type="xml">
            <filter name="symbol_invoice_usage" position="before">
                <filter name="symbol_fetched" string="Fetched from SInvoice" domain="[('is_fetched', '=', True)]"/>
            </filter>
        </field>
    </record>

    <record id="view_l10n_vn_sinvoice_symbol_list_inherit_l10n_vn_edi_viettel" model="ir.ui.view">
        <field name="name">l10n_vn.sinvoice.symbol.list.inherit.l10n_vn_edi_viettel</field>
        <field name="model">l10n_vn.sinvoice.symbol</field>
        <field name="inherit_id" ref="l10n_vn.view_l10n_vn_sinvoice_symbol_list"/>
        <field name="arch" type="xml">
            <field name="name" position="before">
                <header>
                    <button name="action_fetch_symbols"
                            string="Fetch"
                            type="object"
                            class="btn-secondary"
                            display="always"/>
                </header>
            </field>
        </field>
    </record>
</odoo>
