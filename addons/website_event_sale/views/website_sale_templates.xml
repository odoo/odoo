<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="index_topbar" inherit_id="website_event.index_topbar">
        <xpath expr="//div[hasclass('o_wevent_search')]" position="before">
            <t t-call="website_sale.pricelist_list" _classes.f="d-none d-lg-inline me-2"/>
        </xpath>
    </template>

    <!-- If the sale order line concerns an event, we want the "product" link to point to the event itself and not to the product on the ecommerce -->
    <template id="cart_line_product_link_inherit_website_event_sale" inherit_id="website_sale.cart_line_product_link" name="Event Shopping Cart Line Product Link">
        <xpath expr="//a" position="attributes">
            <attribute name="t-attf-href"/>
            <attribute name="t-att-href">
                line.event_id and ('/event/%s/register' % slug(line.event_id)) or line.product_id.website_url
            </attribute>
        </xpath>
    </template>

    <!-- If the sale order line concerns an event, we want to show an additional line with the event name even on small screens -->
    <template id="cart_summary_inherit_website_event_sale" inherit_id="website_sale.cart_summary_content">
        <xpath expr="//td[@name='website_sale_cart_summary_product_name']/span" position="after">
            <span t-if="line.event_slot_id" class="text-muted" t-out="line.event_slot_id.display_name"/>
        </xpath>
    </template>

    <template id="event_confirmation" inherit_id="website_sale.confirmation">
        <div id="oe_structure_website_sale_confirmation_1" position="before">
            <t t-if="events">
                <section class="row mx-0 my-2 border rounded" t-foreach="events" t-as="event">
                    <t t-set="attendees" t-value="attendee_ids_per_event.get(event, [])"/>
                    <div class="position-relative col-5 p-0">
                        <span t-if="event.is_participating" class="o_wevent_badge badge position-absolute top-0 start-0 text-bg-success m-3 p-2 z-1">
                            <i class="fa fa-check me-2" role="img"/>Registered
                        </span>
                        <t t-call="website.record_cover"
                            _record="event"
                            use_size="True"
                            use_text_align="True"
                            additionnal_classes.f="d-block h-100 w-100 overflow-hidden ratio ratio-4x3 rounded-start">
                        </t>
                    </div>
                    <div class="col-7 d-flex flex-column align-items-start my-3">
                        <div class="d-flex align-items-center gap-1 w-100">
                            <a class="text-decoration-none" t-att-href="event.event_url or event.website_url">
                                <h4 t-field="event.name" itemprop="name" placeholder="Event Title" class="m-2 text-primary"/>
                            </a>
                        </div>
                        <h6 t-if="not event.is_multi_slots" class="mx-2 mb-0">
                            <span t-out="event.date_begin" t-options="{'widget': 'datetime', 'tz_name': event.date_tz, 'format': 'medium'}"/>
                        </h6>
                        <div t-if="attendees and not event.is_multi_slots" class="ms-2 my-3">
                            <t t-out="event.is_multi_slots"/>
                            <t t-if="attendees and not event.is_multi_slots">
                                <t t-call="website_event.registration_ticket_access" attendees="attendees"/>
                            </t>
                        </div>
                        <t t-set="event_attendees" t-value="attendee_ids_per_event.get(event, [])"/>
                        <div class="d-flex flex-column m-2 h-100">
                            <div t-if="event_attendees and event.is_multi_slots" t-foreach="event_attendees" t-as="slot" class="o_wevent_slot">
                                <div t-attf-class="d-flex flex-column justify-content-between mb-2">
                                    <div>
                                        <div class="row">
                                            <div class="col-2">
                                                <b>Start</b>
                                            </div>
                                            <div class="col-auto ps-0">
                                                <span t-out="slot.start_datetime"
                                                    t-options='{"widget": "datetime", "show_seconds": False, "tz_name": event.date_tz, "format": "medium"}'/>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-2">
                                                <b>End</b>
                                            </div>
                                            <div class="col-auto ps-0">
                                                <span t-out="slot.end_datetime"
                                                    t-options='{"widget": "datetime", "show_seconds": False, "tz_name": event.date_tz, "format": "medium"}'/>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <span t-if="website_visitor_timezone != event.date_tz" class="smaller opacity-75">(<t t-out="event.date_tz"/>)</span>
                                        </div>
                                    </div>
                                    <div t-if="event_attendees[slot]" class="mt-2 mb-3">
                                        <t t-call="website_event.registration_ticket_access" attendees="event_attendees[slot]"/>
                                    </div>
                                </div>
                                <t t-call="website_event.event_calendar_links"
                                    iCal_url="urls_per_event.get(event.id, {}).get(slot.id, {}).get('iCal_url', '')"
                                    google_url="urls_per_event.get(event.id, {}).get(slot.id, {}).get('google_url', '')"/>
                            </div>
                            <div t-if="not event.is_multi_slots" class="mt-auto">
                                <t t-call="website_event.event_calendar_links"
                                    iCal_url="urls_per_event.get(event.id, {}).get('iCal_url', '')"
                                    google_url="urls_per_event.get(event.id, {}).get('google_url', '')"/>
                            </div>
                            <t t-call="website_event.event_confirmation_end_page_hook"/>
                        </div>
                    </div>
                </section>
            </t>
        </div>
    </template>

</odoo>
