<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <!-- Template for E-invoice certificate receipt printout. Content is in Traditional Chinese to match ECPay invoice format requirements. -->
    <t t-name="l10n_tw_edi_ecpay_pos.EcpayCertificateReceipt">
        <div style="height: 171mm;" class="d-flex flex-column px-2 pt-0 pos-receipt pos-receipt-ecpay-width">
            <t t-if="order.company_logo_exist">
                <img t-att-src="companyLogo" alt="Company Logo" style="max-height: 30mm;" class="pos-receipt-logo object-fit-contain"/>
            </t>
            <t t-else="">
                <h1 class="display-6 pos-receipt-center-align" t-out="order.company.name"/>
            </t>
            <h1 class="display-6 pos-receipt-center-align">電子發票證明聯</h1>
            <h1 class="display-6 pos-receipt-center-align" t-out="order.invoice_month"/>
            <h1 class="display-6 pos-receipt-center-align" t-out="order.iis_number"/>
            <div class="d-flex justify-content-between fs-2">
                <span><t t-out="order.iis_create_date" /></span>
            </div>
            <div class="d-flex justify-content-between fs-2">
                <span>隨機碼:<t t-out="order.iis_random_number"/></span>
                <span>總計:<t t-out="order.l10n_tw_edi_invoice_amount"/></span>
            </div>
            <div class="d-flex justify-content-between fs-2">
                <span t-if="order.l10n_tw_edi_ecpay_seller_identifier != ''" >賣方: <t t-out="order.l10n_tw_edi_ecpay_seller_identifier"/></span>
            </div>
            <div t-if="order.pos_barcode" class="d-flex flex-column align-items-center mt-1">
                <img t-att-src="'/report/barcode/Code128/' + order.pos_barcode" width="490" height="75"/>
            </div>
            <div class="d-flex justify-content-center align-items-center mt-1 w-100">
                <div class="text-center w-50">
                    <img width="175" height="175" t-att-src="qrCodeLeft"/>
                </div>
                <div class="text-center w-50">
                    <img width="205" height="205" t-att-src="qrCodeRight"/>
                </div>
            </div>
        </div>
    </t>
</templates>
