<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="l10n_tw_edi_ecpay_pos.EcpayInfoPopup">
        <Dialog title.translate="Ecpay Invoicing Information">
            <div id="ecpay_info_screen" class="container">
                <div id="ecpay_tax_id_number" class="mb-4">
                    <h3 class="mb-3">ECpay E-invoice</h3>
                    <div id="ecpay_invoice_type" class="mb-3">
                        <select id="l10n_tw_edi_invoice_type" name="invoice_type" class="form-select">
                            <option id="option_general_invoice" t-attf-value="07">07: General Invoice</option>
                            <option id="option_special_invoice" t-attf-value="08">08: Special Invoice</option>
                        </select>
                    </div>
                    <div id="ecpay_invoice_print" class="mb-3">
                        <select id="print_group" name="print_group" class="form-select" t-on-change="_onChangePrintGroup">
                            <option t-attf-value="0" selected="selected">Not generate PDF invoice on Ecpay platform</option>
                            <option id="option_generate_pdf" t-attf-value="1">Generate PDF invoice on Ecpay platform</option>
                            <option id="option_donate" t-attf-value="2">Donate</option>
                        </select>
                    </div>
                    <div id="ecpay_invoice_identifier_group" t-att-class="state.showIdentifierGroup ? 'd-block' : 'd-none'">
                        <div id="ecpay_invoice_identifier">
                            <select id="identifier_group" name="identifier_group" class="form-select" t-on-change="_onChangeIdentifierGroup">
                                <option t-attf-value="0" selected="selected">Do not need Tax ID Number</option>
                                <option t-attf-value="1">Need Tax ID Number</option>
                            </select>
                        </div>
                        <div id="ecpay_invoice_customer_info" t-att-class="state.showIdentifierData ? 'd-block' : 'd-none'">
                            <div id="div-l10n_tw_edi_customer_name" class="mb-3">
                                <label for="l10n_tw_edi_customer_name" class="form-label">Customer Name</label>
                                <input id="l10n_tw_edi_customer_name" name="l10n_tw_edi_customer_name" type="text" class="form-control" disabled="1"/>
                            </div>
                            <div id="div-identifier" class="mb-3">
                                <label for="identifier" class="form-label">Tax ID Number</label>
                                <input id="identifier" maxlength="8" name="identifier" type="text" class="form-control" disabled="1"/>
                                <button type="button" id="validate_tax_id" class="btn btn-link" t-on-click="_onClickValidateTaxID">
                                    Validate Tax ID
                                </button>
                                <div id="warning-identifier" class="alert alert-danger mt-2">
                                    Please enter valid Tax ID Number (Max 8 digits)
                                </div>
                            </div>
                            <div id="div-customer_info" class="mb-3">
                                <div>
                                    <label for="l10n_tw_edi_customer_email" class="form-label">Customer Email</label>
                                    <input id="l10n_tw_edi_customer_email" name="l10n_tw_edi_customer_email" type="text" class="form-control" disabled="1"/>
                                </div>
                                <div>
                                    <label for="l10n_tw_edi_customer_phone" class="form-label">Customer Phone</label>
                                    <input id="l10n_tw_edi_customer_phone" name="l10n_tw_edi_customer_phone" type="text" class="form-control" disabled="1"/>
                                </div>
                                <div id="warning-customer-info" class="alert alert-danger mt-2">
                                    Please enter customer email or phone number
                                </div>
                            </div>
                        </div>
                    </div>
                    <div id="div-l10n_tw_edi_customer_address" t-att-class="state.showAddress ? 'd-block' : 'd-none'">
                        <label for="l10n_tw_edi_customer_address" class="form-label">Customer Address</label>
                        <input id="l10n_tw_edi_customer_address" name="l10n_tw_edi_customer_address" type="text" class="form-control" disabled="1"/>
                    </div>
                    <div id="ecpay_carrier_type_group" t-att-class="state.showCarrierType ? 'd-block' : 'd-none'">
                        <div id="carrier_type_selection">
                            <label for="l10n_tw_edi_carrier_type" class="form-label">Carrier</label>
                            <select id="l10n_tw_edi_carrier_type" name="l10n_tw_edi_carrier_type" class="form-select" t-on-change="_onChangeCarrierType">
                                <option t-attf-value="0" selected="selected"/>
                                <option t-attf-value="1">ECpay e-invoice carrier</option>
                                <option t-attf-value="2">Citizen Digital Certificate</option>
                                <option t-attf-value="3">Mobile Barcode</option>
                            </select>
                        </div>
                        <div id="ecpay_invoice_carrier_number" t-att-class="state.showCarrierNumber ? 'd-block' : 'd-none'">
                            <label for="l10n_tw_edi_carrier_number" class="form-label">Carrier Number</label>
                            <input
                                id="l10n_tw_edi_carrier_number"
                                maxlength="20"
                                name="l10n_tw_edi_carrier_number"
                                type="text"
                                t-on-input="_onInputCarrierNumber"
                                t-att-disabled="state.showReEnterCarrierNumber"
                                t-att-placeholder="state.carrierNumberPlaceholder"
                                class="form-control"
                            />
                            <button type="button" id="validate_carrier_number" class="btn btn-link" t-if="state.showValidateCarrierNumber" t-on-click="_onClickValidateCarrierNumber">
                                Validate Carrier Number
                            </button>
                            <button type="button" id="reenter_carrier_number" class="btn btn-link" t-if="state.showReEnterCarrierNumber" t-on-click="_onClickReenterCarrierNumber">
                                ReEnter Carrier Number
                            </button>
                        </div>
                    </div>
                    <div id="ecpay_invoice_love_code" class="d-none" t-att-class="state.showLoveCode ? 'd-block' : 'd-none'">
                        <label for="l10n_tw_edi_love_code" class="form-label">
                            Love Code
                            <a href="https://www.einvoice.nat.gov.tw/APCONSUMER/BTC603W/" target="_blank">
                                Love code enquire
                            </a>
                        </label>
                        <input
                            id="l10n_tw_edi_love_code"
                            maxlength="7"
                            name="l10n_tw_edi_love_code"
                            type="text"
                            class="form-control"
                            t-on-input="_onInputLoveCode"
                            t-att-disabled="state.showReEnterateLoveCode"
                            placeholder="Love code format is 3-7 digits"/>
                        <div class="d-flex gap-2 mt-2">
                            <button type="button" id="validate_love_code" class="btn btn-outline-primary btn-sm" t-if="state.showValidateLoveCode" t-on-click="_onClickValidateLoveCode">
                                Validate Love Code
                            </button>
                            <button type="button" id="reenter_love_code" class="btn btn-outline-secondary btn-sm" t-if="state.showReEnterateLoveCode" t-on-click="_onClickReenterLoveCode">
                                ReEnter Love Code
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-primary" t-on-click="confirm">Ok</button>
            </t>
        </Dialog>
    </t>
</templates>
