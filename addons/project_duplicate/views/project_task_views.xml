<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_task_form2_inherit_duplicate_detector" model="ir.ui.view">
        <field name="name">project.task.form.inherit.duplicate.detector</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_detect_duplicates" string="Detect Duplicates" type="object" class="btn-secondary" invisible="not id"/>
            </xpath>
        </field>
    </record>
</odoo>
