<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="l10n_in_port_code_form_view_inherit_l10n_in_port" model="ir.ui.view">
        <field name="name">l10n_in.port.code.form.inherit</field>
        <field name="model">l10n_in.port.code</field>
        <field name="inherit_id" ref="l10n_in.l10n_in_port_code_form_view"/>
        <field name="arch" type="xml">
            <field name="state_id" position="replace">
                <label for="street" string="Address"/>
                <div class="o_address_format">
                    <field name="street" placeholder="Street..." class="o_address_street"/>
                    <field name="street2" placeholder="Street 2..." class="o_address_street"/>
                    <field name="city" placeholder="City" class="o_address_city"/>
                    <field
                        name="state_id"
                        class="o_address_state"
                        placeholder="State"
                        options="{'no_open': True, 'no_quick_create': True}"
                        domain="[('country_id.code', '=', 'IN')]"
                    />
                    <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                    <field
                        name="country_id"
                        placeholder="Country"
                        class="o_address_country"
                        options='{"no_open": True, "no_create": True}'
                    />
                </div>
            </field>
        </field>
    </record>

</odoo>
