<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="portal_entry_discuss" model="portal.entry">
        <field name="name">Discuss</field>
        <field name="description">Access your conversations</field>
        <field name="url">/my/conversations</field>
        <field name="image" type="bytes" file="portal_discuss/static/src/img/portal-discuss.png"/>
