<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="l10n_pk_edi_iap_endpoint" model="ir.config_parameter">
        <field name="key">l10n_pk_edi.default_iap_endpoint</field>
        <field name="value">https://iap-services.odoo.com</field>
    </record>
    <record id="l10n_pk_edi_hs_code_reg" model="ir.config_parameter">
        <field name="key">l10n_pk_edi.default_hs_code_reg</field>
        <field name="value">^\d{4}\.\d{4}$</field>
    </record>
</odoo>
