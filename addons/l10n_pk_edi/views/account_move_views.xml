<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit" model="ir.ui.view">
        <field name="name">account.move.form.inherit.l10n_pk_edi</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <div role="alert" class="alert alert-danger" invisible="country_code != 'PK' or not l10n_pk_edi_status_message or l10n_pk_edi_status in (False, 'sent')">
                    <i role="img" class="fa fa-warning"/>
                    <span class="mx-1">E-Invoicing</span>
                    <field name="l10n_pk_edi_status_message"/>
                </div>
            </xpath>
            <xpath expr="//sheet/widget[@name='web_ribbon']" position="after">
                <widget name="web_ribbon" text="FBR Test" bg_color="text-bg-info" invisible="not l10n_pk_edi_testing_scenario_type" tooltip="This document is a test invoice, as FBR testing scenario type has been set."/>
            </xpath>
            <xpath expr="//div[@name='journal_div']" position="after">
                <!-- Related Fields are computed thus must be present in view -->
                <field name="l10n_pk_edi_test_environment" invisible="1"/>
                <field name="l10n_pk_edi_status" invisible="country_code != 'PK' or l10n_pk_edi_status == False"/>
                <field name="l10n_pk_edi_testing_scenario_type" invisible="country_code != 'PK' or not l10n_pk_edi_test_environment" readonly="state in ['cancel', 'posted']"/>
            </xpath>
            <xpath expr="//page[@name='other_info']" position="after">
                <page string="E-Invoicing" invisible="country_code != 'PK' or move_type != 'out_invoice'">
                    <group>
                        <group>
                            <field name="l10n_pk_edi_reference"/>
                            <field name="l10n_pk_edi_attachment_id"/>
                        </group>
                        <group>
                            <field name="l10n_pk_edi_refund_reason" invisible="debit_origin_id == False"/>
                        </group>
                    </group>
                </page>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='tax_ids']" position="after">
                <field name="l10n_pk_edi_transaction_type" optional="hide"/>
                <field name="l10n_pk_edi_sro_id" domain="[('l10n_pk_edi_transaction_type','=',l10n_pk_edi_transaction_type)]" optional="hide"/>
                <field name="l10n_pk_edi_sro_item_id" domain="[('id','in',l10n_pk_edi_filter_sro_item_ids)]" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
