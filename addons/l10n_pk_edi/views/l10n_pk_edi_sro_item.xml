<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="l10n_pk_edi_sro_item_view_list" model="ir.ui.view">
        <field name="name">l10n_pk_edi.sro.item.list</field>
        <field name="model">l10n_pk_edi.sro.item</field>
        <field name="arch" type="xml">
            <list string="Statutory Regulatory Order Items" multi_edit="1">
                <field name="name"/>
                <field name="sro_id"/>
            </list>
        </field>
    </record>

    <record id="l10n_pk_edi_sro_item_view_form" model="ir.ui.view">
        <field name="name">l10n_pk_edi.sro.item.form</field>
        <field name="model">l10n_pk_edi.sro.item</field>
        <field name="arch" type="xml">
            <form string="Statutory Regulatory Order Item">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="sro_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_l10n_pk_edi_sro_item" model="ir.actions.act_window">
        <field name="name">Statutory Regulatory Order Items</field>
        <field name="res_model">l10n_pk_edi.sro.item</field>
        <field name="view_id" ref="l10n_pk_edi_sro_item_view_list"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Statutory Regulatory Order Item
            </p>
        </field>
    </record>
</odoo>
