<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view" model="ir.ui.view">
        <field name="name">product.template.form.inherit.l10n_pk_edi</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='invoicing']//group[@name='accounting']" position="inside">
                <group string="FBR E-Invoicing">
                    <field name="l10n_pk_edi_sale_type"/>
                    <field name="l10n_pk_edi_sro_id" domain="[('l10n_pk_edi_sale_type','=',l10n_pk_edi_sale_type)]"/>
                    <field name="l10n_pk_edi_sro_item_id" domain="[('id','in',l10n_pk_edi_filter_sro_item_ids)]"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
