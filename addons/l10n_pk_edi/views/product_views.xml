<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view" model="ir.ui.view">
        <field name="name">product.template.form.inherit.l10n_pk_edi</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="E-Invoice" invisible="'PK' not in fiscal_country_codes">
                    <group>
                        <group>
                            <field name="hs_code"/>
                            <field name="l10n_pk_edi_transaction_type"/>
                            <field name="l10n_pk_edi_sro_id" domain="[('l10n_pk_edi_transaction_type','=',l10n_pk_edi_transaction_type)]"/>
                            <field name="l10n_pk_edi_sro_item_id" domain="[('id','in',l10n_pk_edi_filter_sro_item_ids)]"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
