<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="l10n_jp_schedule_4_3_deduction" model="account.report">
        <field name="name">Schedule 4-3 (Sales Deduction)</field>
        <field name="name@ja_JP">付表4-3 (売上割戻し計算)</field>
        <field name="country_id" ref="base.jp"/>
        <field name="availability_condition">country</field>
        <field name="active" eval="False"/>
        <field name="column_ids">
            <record id="l10n_jp_schedule_4_3_deduction_col_balance_a" model="account.report.column">
                <field name="name">Reduced rate (6.24%)</field>
                <field name="name@ja_JP">6.24%適用分</field>
                <field name="expression_label">balance_a</field>
            </record>
            <record id="l10n_jp_schedule_4_3_deduction_col_balance_b" model="account.report.column">
                <field name="name">Standard rate (7.8%)</field>
                <field name="name@ja_JP">7.8%適用分</field>
                <field name="expression_label">balance_b</field>
            </record>
            <record id="l10n_jp_schedule_4_3_deduction_col_balance_c" model="account.report.column">
                <field name="name">Total</field>
                <field name="name@ja_JP">合計</field>
                <field name="expression_label">balance_c</field>
            </record>
        </field>
        <field name="line_ids">
            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_1" model="account.report.line">
                <field name="name">1. Tax base amount</field>
                <field name="name@ja_JP">① 課税標準額</field>
                <field name="code">DED_S4_3_1</field>
                <field name="hierarchy_level">1</field>
                <field name="sequence">2</field>
                <field name="expression_ids">
                    <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_1_balance_a" model="account.report.expression">
                        <field name="label">balance_a</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">DED_S4_3_1_1.balance_a</field>
                        <field name="subformula">round(-3, DOWN)</field>
                    </record>
                    <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_1_balance_b" model="account.report.expression">
                        <field name="label">balance_b</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">DED_S4_3_1_1.balance_b</field>
                        <field name="subformula">round(-3, DOWN)</field>
                    </record>
                    <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_1_balance_c" model="account.report.expression">
                        <field name="label">balance_c</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">DED_S4_3_1.balance_a + DED_S4_3_1.balance_b</field>
                        <field name="subformula">round(-3, DOWN)</field>
                    </record>
                </field>
                <field name="children_ids">
                    <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_1_1" model="account.report.line">
                        <field name="name">1-1. Amount of consideration for transfer of taxable assets, etc.</field>
                        <field name="name@ja_JP">① - １ 課税資産の譲渡等の対価の額</field>
                        <field name="code">DED_S4_3_1_1</field>
                        <field name="hierarchy_level">5</field>
                        <field name="sequence">6</field>
                        <field name="expression_ids">
                            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_1_1_balance_a" model="account.report.expression">
                                <field name="label">balance_a</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">DED_S5_3_6.balance_a</field>
                                <field name="subformula">cross_report(l10n_jp.l10n_jp_schedule_5_3_deduction)</field>
                            </record>
                            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_1_1_balance_b" model="account.report.expression">
                                <field name="label">balance_b</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">DED_S5_3_6.balance_b</field>
                                <field name="subformula">cross_report(l10n_jp.l10n_jp_schedule_5_3_deduction)</field>
                            </record>
                            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_1_1_balance_c" model="account.report.expression">
                                <field name="label">balance_c</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">DED_S4_3_1_1.balance_a + DED_S4_3_1_1.balance_b</field>
                            </record>
                        </field>
                    </record>
                </field>
            </record>
            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_2" model="account.report.line">
                <field name="name">2. Consumption tax amount</field>
                <field name="name@ja_JP">② 消費税額</field>
                <field name="code">DED_S4_3_2</field>
                <field name="hierarchy_level">1</field>
                <field name="sequence">10</field>
                <field name="expression_ids">
                    <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_2_balance_a" model="account.report.expression">
                        <field name="label">balance_a</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">DED_S4_3_1.balance_a * 0.0624</field>
                    </record>
                    <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_2_balance_b" model="account.report.expression">
                        <field name="label">balance_b</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">DED_S4_3_1.balance_b * 0.078</field>
                    </record>
                    <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_2_balance_c" model="account.report.expression">
                        <field name="label">balance_c</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">DED_S4_3_2.balance_a + DED_S4_3_2.balance_b</field>
                    </record>
                </field>
            </record>
            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_3" model="account.report.line">
                <field name="name">3. Consumption tax amount related to bad debt collection</field>
                <field name="name@ja_JP">③ 貸倒回収に係る消費税額</field>
                <field name="code">DED_S4_3_3</field>
                <field name="hierarchy_level">1</field>
                <field name="sequence">14</field>
                <field name="expression_ids">
                    <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_3_balance_a" model="account.report.expression">
                        <field name="label">balance_a</field>
                        <field name="engine">external</field>
                        <field name="formula">sum</field>
                        <field name="subformula">editable;rounding=0</field>
                    </record>
                    <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_3_balance_b" model="account.report.expression">
                        <field name="label">balance_b</field>
                        <field name="engine">external</field>
                        <field name="formula">sum</field>
                        <field name="subformula">editable;rounding=0</field>
                    </record>
                    <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_3_balance_c" model="account.report.expression">
                        <field name="label">balance_c</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">DED_S4_3_3.balance_a + DED_S4_3_3.balance_b</field>
                    </record>
                </field>
            </record>
            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_dt" model="account.report.line">
                <field name="name">Deduction tax amount</field>
                <field name="name@ja_JP">控除税額</field>
                <field name="code">DED_S4_3_DT</field>
                <field name="hierarchy_level">1</field>
                <field name="sequence">18</field>
                <field name="children_ids">
                    <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_4" model="account.report.line">
                        <field name="name">4. Deductible input tax amount</field>
                        <field name="name@ja_JP">④ 控除対象仕入税額</field>
                        <field name="code">DED_S4_3_4</field>
                        <field name="hierarchy_level">5</field>
                        <field name="sequence">19</field>
                        <field name="expression_ids">
                            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_4_balance_a" model="account.report.expression">
                                <field name="label">balance_a</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">DED_S5_3_5.balance_a + DED_S5_3_37.balance_a</field>
                                <field name="subformula">cross_report(l10n_jp.l10n_jp_schedule_5_3_deduction)</field>
                            </record>
                            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_4_balance_b" model="account.report.expression">
                                <field name="label">balance_b</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">DED_S5_3_5.balance_b + DED_S5_3_37.balance_b</field>
                                <field name="subformula">cross_report(l10n_jp.l10n_jp_schedule_5_3_deduction)</field>
                            </record>
                            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_4_balance_c" model="account.report.expression">
                                <field name="label">balance_c</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">DED_S4_3_4.balance_a + DED_S4_3_4.balance_b</field>
                            </record>
                        </field>
                    </record>
                    <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_5" model="account.report.line">
                        <field name="name">5. Tax amount related to consideration for refund, etc.</field>
                        <field name="name@ja_JP">⑤ 返還等対価に係る税額</field>
                        <field name="code">DED_S4_3_5</field>
                        <field name="hierarchy_level">5</field>
                        <field name="sequence">23</field>
                    </record>
                    <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_6" model="account.report.line">
                        <field name="name">6. Tax amount related to bad debts</field>
                        <field name="name@ja_JP">⑥ 貸倒れに係る税額</field>
                        <field name="code">DED_S4_3_6</field>
                        <field name="hierarchy_level">5</field>
                        <field name="sequence">24</field>
                        <field name="expression_ids">
                            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_6_balance_a" model="account.report.expression">
                                <field name="label">balance_a</field>
                                <field name="engine">external</field>
                                <field name="formula">sum</field>
                                <field name="subformula">editable;rounding=0</field>
                            </record>
                            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_6_balance_b" model="account.report.expression">
                                <field name="label">balance_b</field>
                                <field name="engine">external</field>
                                <field name="formula">sum</field>
                                <field name="subformula">editable;rounding=0</field>
                            </record>
                            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_6_balance_c" model="account.report.expression">
                                <field name="label">balance_c</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">DED_S4_3_6.balance_a + DED_S4_3_6.balance_b</field>
                            </record>
                        </field>
                    </record>
                    <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_7" model="account.report.line">
                        <field name="name">7. Deduction tax subtotal(4+5+6)</field>
                        <field name="name@ja_JP">⑦ 控除税額小計（④＋⑤＋⑥）</field>
                        <field name="code">DED_S4_3_7</field>
                        <field name="hierarchy_level">5</field>
                        <field name="sequence">28</field>
                        <field name="expression_ids">
                            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_7_balance_a" model="account.report.expression">
                                <field name="label">balance_a</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">DED_S4_3_4.balance_a + DED_S4_3_6.balance_a</field>
                            </record>
                            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_7_balance_b" model="account.report.expression">
                                <field name="label">balance_b</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">DED_S4_3_4.balance_b + DED_S4_3_6.balance_b</field>
                            </record>
                            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_7_balance_c" model="account.report.expression">
                                <field name="label">balance_c</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">DED_S4_3_7.balance_a + DED_S4_3_7.balance_b</field>
                            </record>
                        </field>
                    </record>
                </field>
            </record>
            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_8" model="account.report.line">
                <field name="name">8. Tax refundable for insufficient deduction (7-2-3)</field>
                <field name="name@ja_JP">⑧ 控除不足還付税額（⑦−②−③）</field>
                <field name="code">DED_S4_3_8</field>
                <field name="hierarchy_level">1</field>
                <field name="sequence">32</field>
                <field name="expression_ids">
                    <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_8_balance_c" model="account.report.expression">
                        <field name="label">balance_c</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">DED_S4_3_8.sub_balance</field>
                        <field name="subformula">round(-2, DOWN)</field>
                    </record>
                    <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_8_sub_balance" model="account.report.expression">
                        <field name="label">sub_balance</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">DED_S4_3_7.balance_c - DED_S4_3_2.balance_c - DED_S4_3_3.balance_c</field>
                        <field name="subformula">if_above(JPY(0))</field>
                    </record>
                </field>
            </record>
            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_9" model="account.report.line">
                <field name="name">9. Balance (2+3-7)</field>
                <field name="name@ja_JP">⑨ 差引税額（②＋③−⑦）</field>
                <field name="code">DED_S4_3_9</field>
                <field name="hierarchy_level">1</field>
                <field name="sequence">35</field>
                <field name="expression_ids">
                    <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_9_balance_c" model="account.report.expression">
                        <field name="label">balance_c</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">DED_S4_3_9.sub_balance</field>
                        <field name="subformula">round(-2, DOWN)</field>
                    </record>
                    <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_9_sub_balance" model="account.report.expression">
                        <field name="label">sub_balance</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">DED_S4_3_2.balance_c + DED_S4_3_3.balance_c - DED_S4_3_7.balance_c</field>
                        <field name="subformula">if_above(JPY(0))</field>
                    </record>
                </field>
            </record>
            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_ltb" model="account.report.line">
                <field name="name">Consumption tax amount that is the tax base for local consumption tax</field>
                <field name="name@ja_JP">地方消費税の課税標準となる消費税額</field>
                <field name="code">DED_S4_3_LTB</field>
                <field name="hierarchy_level">1</field>
                <field name="sequence">38</field>
                <field name="children_ids">
                    <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_10" model="account.report.line">
                        <field name="name">10. Insufficient deduction refund tax amount (8)</field>
                        <field name="name@ja_JP">⑩ 控除不足還付税額（⑧）</field>
                        <field name="code">DED_S4_3_10</field>
                        <field name="hierarchy_level">3</field>
                        <field name="sequence">39</field>
                        <field name="expression_ids">
                            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_10_balance_c" model="account.report.expression">
                                <field name="label">balance_c</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">DED_S4_3_10.sub_balance</field>
                                <field name="subformula">round(-2, DOWN)</field>
                            </record>
                            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_10_sub_balance" model="account.report.expression">
                                <field name="label">sub_balance</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">DED_S4_3_8.balance_c</field>
                                <field name="subformula">if_above(JPY(0))</field>
                            </record>
                        </field>
                    </record>
                    <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_11" model="account.report.line">
                        <field name="name">11. Deduction tax amount (9)</field>
                        <field name="name@ja_JP">⑪ 差引税額（⑨）</field>
                        <field name="code">DED_S4_3_11</field>
                        <field name="hierarchy_level">3</field>
                        <field name="sequence">42</field>
                        <field name="expression_ids">
                            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_11_balance_c" model="account.report.expression">
                                <field name="label">balance_c</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">DED_S4_3_11.sub_balance</field>
                                <field name="subformula">round(-2, DOWN)</field>
                            </record>
                            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_11_sub_balance" model="account.report.expression">
                                <field name="label">sub_balance</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">DED_S4_3_9.balance_c</field>
                                <field name="subformula">if_above(JPY(0))</field>
                            </record>
                        </field>
                    </record>
                </field>
            </record>
            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_ta" model="account.report.line">
                <field name="name">Transfer amount</field>
                <field name="name@ja_JP">譲渡割額</field>
                <field name="code">DED_S4_3_TA</field>
                <field name="hierarchy_level">1</field>
                <field name="sequence">45</field>
                <field name="children_ids">
                    <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_12" model="account.report.line">
                        <field name="name">12. Amount refundable</field>
                        <field name="name@ja_JP">⑫ 還付額</field>
                        <field name="code">DED_S4_3_12</field>
                        <field name="hierarchy_level">3</field>
                        <field name="sequence">46</field>
                        <field name="expression_ids">
                            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_12_balance_c" model="account.report.expression">
                                <field name="label">balance_c</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">DED_S4_3_12.sub_balance</field>
                                <field name="subformula">round(-2, DOWN)</field>
                            </record>
                            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_12_sub_balance" model="account.report.expression">
                                <field name="label">sub_balance</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">DED_S4_3_10.balance_c * 22 / 78</field>
                                <field name="subformula">if_above(JPY(0))</field>
                            </record>
                        </field>
                    </record>
                    <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_13" model="account.report.line">
                        <field name="name">13. Amount of tax payable</field>
                        <field name="name@ja_JP">⑬ 納税額</field>
                        <field name="code">DED_S4_3_13</field>
                        <field name="hierarchy_level">3</field>
                        <field name="sequence">49</field>
                        <field name="expression_ids">
                            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_13_balance_c" model="account.report.expression">
                                <field name="label">balance_c</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">DED_S4_3_13.sub_balance</field>
                                <field name="subformula">round(-2, DOWN)</field>
                            </record>
                            <record id="l10n_jp_schedule_4_3_deduction_ded_s4_3_13_sub_balance" model="account.report.expression">
                                <field name="label">sub_balance</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">DED_S4_3_11.balance_c * 22 / 78</field>
                                <field name="subformula">if_above(JPY(0))</field>
                            </record>
                        </field>
                    </record>
                </field>
            </record>
        </field>
    </record>
</odoo>
