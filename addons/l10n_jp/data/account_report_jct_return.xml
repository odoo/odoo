<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="l10n_jp_jct_return_accumulation" model="account.report">
        <field name="name">JCT Return (Sales Accumulation)</field>
        <field name="name@ja_JP">消費税申告 (売上積上げ計算)</field>
        <field name="root_report_id" ref="account.generic_tax_report"/>
        <field name="country_id" ref="base.jp"/>
        <field name="availability_condition">country</field>
        <field name="use_sections" eval="True"/>
        <field name="section_report_ids" eval="[(6, 0, [ref('l10n_jp.l10n_jp_form_accumulation'), ref('l10n_jp.l10n_jp_schedule_1_3_accumulation'), ref('l10n_jp.l10n_jp_schedule_2_3_accumulation'), ref('l10n_jp.l10n_jp_schedule_4_3_accumulation'), ref('l10n_jp.l10n_jp_schedule_5_3_accumulation')])]"/>
        <field name="column_ids">
            <record id="l10n_jp_jct_return_accumulation_col_balance" model="account.report.column">
                <field name="name">Amount</field>
                <field name="name@ja_JP">金額</field>
                <field name="expression_label">balance</field>
            </record>
        </field>
    </record>

    <record id="l10n_jp_jct_return_deduction" model="account.report">
        <field name="name">JCT Return (Sales Deduction)</field>
        <field name="name@ja_JP">消費税申告 (売上割戻し計算)</field>
        <field name="root_report_id" ref="account.generic_tax_report"/>
        <field name="country_id" ref="base.jp"/>
        <field name="availability_condition">country</field>
        <field name="use_sections" eval="True"/>
        <field name="section_report_ids" eval="[(6, 0, [ref('l10n_jp.l10n_jp_form_deduction'), ref('l10n_jp.l10n_jp_schedule_1_3_deduction'), ref('l10n_jp.l10n_jp_schedule_2_3_deduction'), ref('l10n_jp.l10n_jp_schedule_4_3_deduction'), ref('l10n_jp.l10n_jp_schedule_5_3_deduction')])]"/>
        <field name="column_ids">
            <record id="l10n_jp_jct_return_deduction_col_balance" model="account.report.column">
                <field name="name">Amount</field>
                <field name="name@ja_JP">金額</field>
                <field name="expression_label">balance</field>
            </record>
        </field>
    </record>
</odoo>
