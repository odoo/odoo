<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="l10n_jp_schedule_1_3_accumulation" model="account.report">
        <field name="name">Schedule 1-3 (Sales Accumulation)</field>
        <field name="name@ja_JP">付表1-3 (売上積上げ計算)</field>
        <field name="country_id" ref="base.jp"/>
        <field name="availability_condition">country</field>
        <field name="column_ids">
            <record id="l10n_jp_schedule_1_3_accumulation_col_balance_a" model="account.report.column">
                <field name="name">Reduced rate (6.24%)</field>
                <field name="name@ja_JP">6.24%適用分</field>
                <field name="expression_label">balance_a</field>
            </record>
            <record id="l10n_jp_schedule_1_3_accumulation_col_balance_b" model="account.report.column">
                <field name="name">Standard rate (7.8%)</field>
                <field name="name@ja_JP">7.8%適用分</field>
                <field name="expression_label">balance_b</field>
            </record>
            <record id="l10n_jp_schedule_1_3_accumulation_col_balance_c" model="account.report.column">
                <field name="name">Total</field>
                <field name="name@ja_JP">合計</field>
                <field name="expression_label">balance_c</field>
            </record>
        </field>
        <field name="line_ids">
            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_1" model="account.report.line">
                <field name="name">1. Tax base amount</field>
                <field name="name@ja_JP">① 課税標準額</field>
                <field name="code">ACC_S1_3_1</field>
                <field name="hierarchy_level">1</field>
                <field name="sequence">2</field>
                <field name="expression_ids">
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_1_balance_a" model="account.report.expression">
                        <field name="label">balance_a</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">ACC_S1_3_1_1.balance_a</field>
                        <field name="subformula">round(-3, DOWN)</field>
                    </record>
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_1_balance_b" model="account.report.expression">
                        <field name="label">balance_b</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">ACC_S1_3_1_1.balance_b + ACC_S1_3_1_2.balance_b</field>
                        <field name="subformula">round(-3, DOWN)</field>
                    </record>
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_1_balance_c" model="account.report.expression">
                        <field name="label">balance_c</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">ACC_S1_3_1.balance_a + ACC_S1_3_1.balance_b</field>
                        <field name="subformula">round(-3, DOWN)</field>
                    </record>
                </field>
            </record>
            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_1br" model="account.report.line">
                <field name="name">Breakdown of 1</field>
                <field name="name@ja_JP">①の内訳</field>
                <field name="code">ACC_S1_3_1BR</field>
                <field name="hierarchy_level">1</field>
                <field name="sequence">6</field>
                <field name="children_ids">
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_1_1" model="account.report.line">
                        <field name="name">1-1. Amount of consideration for transfer of taxable assets, etc.</field>
                        <field name="name@ja_JP">① - １ 課税資産の譲渡等の対価の額</field>
                        <field name="code">ACC_S1_3_1_1</field>
                        <field name="hierarchy_level">5</field>
                        <field name="sequence">7</field>
                        <field name="expression_ids">
                            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_1_1_balance_a" model="account.report.expression">
                                <field name="label">balance_a</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">ACC_S2_3_1.balance_a</field>
                                <field name="subformula">cross_report(l10n_jp.l10n_jp_schedule_2_3_accumulation)</field>
                            </record>
                            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_1_1_balance_b" model="account.report.expression">
                                <field name="label">balance_b</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">ACC_S2_3_1.balance_b</field>
                                <field name="subformula">cross_report(l10n_jp.l10n_jp_schedule_2_3_accumulation)</field>
                            </record>
                            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_1_1_balance_c" model="account.report.expression">
                                <field name="label">balance_c</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">ACC_S1_3_1_1.balance_a + ACC_S1_3_1_1.balance_b</field>
                            </record>
                        </field>
                    </record>
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_1_2" model="account.report.line">
                        <field name="name">1-2. Amount of consideration paid for specified taxable purchases</field>
                        <field name="name@ja_JP">① - ２ 特定課税仕入れに係る支払対価の額</field>
                        <field name="code">ACC_S1_3_1_2</field>
                        <field name="hierarchy_level">5</field>
                        <field name="sequence">11</field>
                        <field name="expression_ids">
                            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_1_2_balance_b" model="account.report.expression">
                                <field name="label">balance_b</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">ACC_S2_3_13.balance_c</field>
                                <field name="subformula">cross_report(l10n_jp.l10n_jp_schedule_2_3_accumulation)</field>
                            </record>
                            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_1_2_balance_c" model="account.report.expression">
                                <field name="label">balance_c</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">ACC_S1_3_1_2.balance_b</field>
                            </record>
                        </field>
                    </record>
                </field>
            </record>
            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_2" model="account.report.line">
                <field name="name">2. Consumption tax amount</field>
                <field name="name@ja_JP">② 消費税額</field>
                <field name="code">ACC_S1_3_2</field>
                <field name="hierarchy_level">1</field>
                <field name="sequence">14</field>
                <field name="expression_ids">
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_2_balance_a" model="account.report.expression">
                        <field name="label">balance_a</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">ACC_S1_3_2.sub_balance_a * 0.78</field>
                        <field name="subformula">round(0, DOWN)</field>
                    </record>
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_2_balance_b" model="account.report.expression">
                        <field name="label">balance_b</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">ACC_S1_3_2.sub_balance_b * 0.78 + ACC_S1_3_2.rounded_special_purchase</field>
                        <field name="subformula">round(0, DOWN)</field>
                    </record>
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_2_rounded_special_purchase" model="account.report.expression">
                        <field name="label">rounded_special_purchase</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">ACC_S1_3_1_2.balance_b * 7.8 / 100</field>
                        <field name="subformula">round(0, DOWN)</field>
                    </record>
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_2_sub_balance_a" model="account.report.expression">
                        <field name="label">sub_balance_a</field>
                        <field name="engine">tax_tags</field>
                        <field name="formula">-S1_3_2A</field>
                    </record>
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_2_sub_balance_b" model="account.report.expression">
                        <field name="label">sub_balance_b</field>
                        <field name="engine">tax_tags</field>
                        <field name="formula">-S1_3_2B</field>
                    </record>
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_2_balance_c" model="account.report.expression">
                        <field name="label">balance_c</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">ACC_S1_3_2.balance_a + ACC_S1_3_2.balance_b</field>
                    </record>
                </field>
            </record>
            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_3" model="account.report.line">
                <field name="name">3. Tax adjustment for excess deduction</field>
                <field name="name@ja_JP">③ 控除過大調整税額</field>
                <field name="code">ACC_S1_3_3</field>
                <field name="hierarchy_level">1</field>
                <field name="sequence">21</field>
                <field name="expression_ids">
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_3_balance_a" model="account.report.expression">
                        <field name="label">balance_a</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">ACC_S2_3_27.balance_a + ACC_S2_3_28.balance_a</field>
                        <field name="subformula">cross_report(l10n_jp.l10n_jp_schedule_2_3_accumulation)</field>
                    </record>
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_3_balance_b" model="account.report.expression">
                        <field name="label">balance_b</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">ACC_S2_3_27.balance_b + ACC_S2_3_28.balance_b</field>
                        <field name="subformula">cross_report(l10n_jp.l10n_jp_schedule_2_3_accumulation)</field>
                    </record>
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_3_balance_c" model="account.report.expression">
                        <field name="label">balance_c</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">ACC_S1_3_3.balance_a + ACC_S1_3_3.balance_b</field>
                    </record>
                </field>
            </record>
            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_dt" model="account.report.line">
                <field name="name">Deduction tax amount</field>
                <field name="name@ja_JP">控除税額</field>
                <field name="code">ACC_S1_3_DT</field>
                <field name="hierarchy_level">1</field>
                <field name="sequence">25</field>
                <field name="children_ids">
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_4" model="account.report.line">
                        <field name="name">4. Amount of deductible tax on purchases</field>
                        <field name="name@ja_JP">④ 控除対象仕入税額</field>
                        <field name="code">ACC_S1_3_4</field>
                        <field name="hierarchy_level">5</field>
                        <field name="sequence">26</field>
                        <field name="expression_ids">
                            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_4_balance_a" model="account.report.expression">
                                <field name="label">balance_a</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">ACC_S2_3_26.balance_a</field>
                                <field name="subformula">cross_report(l10n_jp.l10n_jp_schedule_2_3_accumulation)</field>
                            </record>
                            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_4_balance_b" model="account.report.expression">
                                <field name="label">balance_b</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">ACC_S2_3_26.balance_b</field>
                                <field name="subformula">cross_report(l10n_jp.l10n_jp_schedule_2_3_accumulation)</field>
                            </record>
                            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_4_balance_c" model="account.report.expression">
                                <field name="label">balance_c</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">ACC_S1_3_4.balance_a + ACC_S1_3_4.balance_b</field>
                            </record>
                        </field>
                    </record>
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_5" model="account.report.line">
                        <field name="name">5. Amount of tax relating to refunds and other charges</field>
                        <field name="name@ja_JP">⑤ 返還等対価に係る税額</field>
                        <field name="code">ACC_S1_3_5</field>
                        <field name="hierarchy_level">5</field>
                        <field name="sequence">30</field>
                    </record>
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_5br" model="account.report.line">
                        <field name="name">Breakdown of 5</field>
                        <field name="name@ja_JP">⑤の内訳</field>
                        <field name="code">ACC_S1_3_5BR</field>
                        <field name="hierarchy_level">3</field>
                        <field name="sequence">31</field>
                        <field name="children_ids">
                            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_5_1" model="account.report.line">
                                <field name="name">5.1. Tax amount related to consideration for refund etc. of sales</field>
                                <field name="name@ja_JP">⑤ - １ 売上げの返還等対価に係る税額</field>
                                <field name="code">ACC_S1_3_5_1</field>
                                <field name="hierarchy_level">5</field>
                                <field name="sequence">32</field>
                            </record>
                            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_5_2" model="account.report.line">
                                <field name="name">5.2. Tax amount related to consideration for refund of specified taxable purchases</field>
                                <field name="name@ja_JP">⑤ - ２ 特定課税仕入れの返還等対価に係る税額</field>
                                <field name="code">ACC_S1_3_5_2</field>
                                <field name="hierarchy_level">5</field>
                                <field name="sequence">33</field>
                            </record>
                        </field>
                    </record>
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_6" model="account.report.line">
                        <field name="name">6. Amount of tax relating to bad debt</field>
                        <field name="name@ja_JP">⑥ 貸倒れに係る税額</field>
                        <field name="code">ACC_S1_3_6</field>
                        <field name="hierarchy_level">5</field>
                        <field name="sequence">34</field>
                        <field name="expression_ids">
                            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_6_balance_a" model="account.report.expression">
                                <field name="label">balance_a</field>
                                <field name="engine">external</field>
                                <field name="formula">sum</field>
                                <field name="subformula">editable;rounding=0</field>
                            </record>
                            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_6_balance_b" model="account.report.expression">
                                <field name="label">balance_b</field>
                                <field name="engine">external</field>
                                <field name="formula">sum</field>
                                <field name="subformula">editable;rounding=0</field>
                            </record>
                            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_6_balance_c" model="account.report.expression">
                                <field name="label">balance_c</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">ACC_S1_3_6.balance_a + ACC_S1_3_6.balance_b</field>
                            </record>
                        </field>
                    </record>
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_7" model="account.report.line">
                        <field name="name">7. Subtotal of deductible tax</field>
                        <field name="name@ja_JP">⑦ 控除税額小計</field>
                        <field name="code">ACC_S1_3_7</field>
                        <field name="hierarchy_level">5</field>
                        <field name="sequence">38</field>
                        <field name="expression_ids">
                            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_7_balance_a" model="account.report.expression">
                                <field name="label">balance_a</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">ACC_S1_3_4.balance_a + ACC_S1_3_6.balance_a</field>
                            </record>
                            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_7_balance_b" model="account.report.expression">
                                <field name="label">balance_b</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">ACC_S1_3_4.balance_b + ACC_S1_3_6.balance_b</field>
                            </record>
                            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_7_balance_c" model="account.report.expression">
                                <field name="label">balance_c</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">ACC_S1_3_7.balance_a + ACC_S1_3_7.balance_b</field>
                            </record>
                        </field>
                    </record>
                </field>
            </record>
            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_8" model="account.report.line">
                <field name="name">8. Amount of tax refundable for insufficient deduction</field>
                <field name="name@ja_JP">⑧ 控除不足還付税</field>
                <field name="code">ACC_S1_3_8</field>
                <field name="hierarchy_level">1</field>
                <field name="sequence">42</field>
                <field name="expression_ids">
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_8_balance_c" model="account.report.expression">
                        <field name="label">balance_c</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">ACC_S1_3_8.sub_balance</field>
                        <field name="subformula">round(-2, DOWN)</field>
                    </record>
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_8_sub_balance" model="account.report.expression">
                        <field name="label">sub_balance</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">ACC_S1_3_7.balance_c - ACC_S1_3_2.balance_c - ACC_S1_3_3.balance_c</field>
                        <field name="subformula">if_above(JPY(0))</field>
                    </record>
                </field>
            </record>
            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_9" model="account.report.line">
                <field name="name">9. Balance</field>
                <field name="name@ja_JP">⑨ 差引税額</field>
                <field name="code">ACC_S1_3_9</field>
                <field name="hierarchy_level">1</field>
                <field name="sequence">45</field>
                <field name="expression_ids">
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_9_balance_c" model="account.report.expression">
                        <field name="label">balance_c</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">ACC_S1_3_9.sub_balance</field>
                        <field name="subformula">round(-2, DOWN)</field>
                    </record>
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_9_sub_balance" model="account.report.expression">
                        <field name="label">sub_balance</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">ACC_S1_3_2.balance_c + ACC_S1_3_3.balance_c - ACC_S1_3_7.balance_c</field>
                        <field name="subformula">if_above(JPY(0))</field>
                    </record>
                </field>
            </record>
            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_ltb" model="account.report.line">
                <field name="name">Consumption tax amount that is the tax base for local consumption tax</field>
                <field name="name@ja_JP">地方消費税の課税標準となる消費税額</field>
                <field name="code">ACC_S1_3_LTB</field>
                <field name="hierarchy_level">1</field>
                <field name="sequence">48</field>
                <field name="children_ids">
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_10" model="account.report.line">
                        <field name="name">10. Tax refundable for insufficient deduction</field>
                        <field name="name@ja_JP">⑩ 控除不足還付税額</field>
                        <field name="code">ACC_S1_3_10</field>
                        <field name="hierarchy_level">3</field>
                        <field name="sequence">49</field>
                        <field name="expression_ids">
                            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_10_balance_c" model="account.report.expression">
                                <field name="label">balance_c</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">ACC_S1_3_10.sub_balance</field>
                                <field name="subformula">round(-2, DOWN)</field>
                            </record>
                            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_10_sub_balance" model="account.report.expression">
                                <field name="label">sub_balance</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">ACC_S1_3_8.balance_c</field>
                                <field name="subformula">if_above(JPY(0))</field>
                            </record>
                        </field>
                    </record>
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_11" model="account.report.line">
                        <field name="name">11. Balance</field>
                        <field name="name@ja_JP">⑪ 差引税額</field>
                        <field name="code">ACC_S1_3_11</field>
                        <field name="hierarchy_level">3</field>
                        <field name="sequence">52</field>
                        <field name="expression_ids">
                            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_11_balance_c" model="account.report.expression">
                                <field name="label">balance_c</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">ACC_S1_3_11.sub_balance</field>
                                <field name="subformula">round(-2, DOWN)</field>
                            </record>
                            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_11_sub_balance" model="account.report.expression">
                                <field name="label">sub_balance</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">ACC_S1_3_9.balance_c</field>
                                <field name="subformula">if_above(JPY(0))</field>
                            </record>
                        </field>
                    </record>
                </field>
            </record>
            <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_ta" model="account.report.line">
                <field name="name">Transfer amount</field>
                <field name="name@ja_JP">譲渡割額</field>
                <field name="code">ACC_S1_3_TA</field>
                <field name="hierarchy_level">1</field>
                <field name="sequence">55</field>
                <field name="children_ids">
                    <record id="l10n_jp_schedule_1_3_accumulation_acc_s1_3_12" model="account.report.line">
                        <field name="name">12. Amount refundable</field>
