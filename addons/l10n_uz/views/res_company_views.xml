<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="l10n_uz_view_company_form" model="ir.ui.view">
        <field name="name">l10n_uz.res.company.form.inherit</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_registry']" position="attributes">
                <attribute name="invisible" add="country_code == 'UZ'" separator=" or "/>
            </xpath>
            <xpath expr="//field[@name='company_registry']" position="after">
                <field name="company_registry" string="VAT Registry (VAT ID)" invisible="country_code != 'UZ'"/>
            </xpath>
        </field>
    </record>
</odoo>
