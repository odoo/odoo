<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_move_pajakio_form_view" model="ir.ui.view">
        <field name="name">account.move.pajakio.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_update_pajakio_status"
                        string="Update Pajak.io Status"
                        type="object"
                        invisible="not l10n_id_pajakio_transaction_id"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Pajak.io" invisible="not l10n_id_pajakio_transaction_id">
                    <group>
                        <field name="l10n_id_pajakio_transaction_id" readonly="1"/>
                        <field name="l10n_id_pajakio_status" readonly="1"/>
                        <field name="l10n_id_pajakio_transaction_id" readonly="1"/>
                        <field name="l10n_id_pajakio_transaction_url" readonly="1"/>
                        <field name="l10n_id_pajakio_reject_reason" readonly="1" invisible="not l10n_id_pajakio_reject_reason"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
