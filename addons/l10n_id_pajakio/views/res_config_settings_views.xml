<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.proxy.user</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='account_vendor_bills']" position="after">
                <block title="Indonesian Electronic Invoicing" id='id_edi' invisible="country_code != 'ID'">
                    <setting string="Pajak.io" company_dependent="1" help="Pajak.io Settings">
                        <div class="content-group">
                            <div class="row mt16">
                                <label string="Pajak.io Mode" for="l10n_id_pajakio_mode" />
                                <field name="l10n_id_pajakio_mode" widget="radio"/>
                            </div>
                            <div class="mt18">
                                <button name="action_pajakio_register_user" string="Register User" type="object" class="btn btn-link" invisible="not l10n_id_pajakio_show_register_user"/>
                            </div>
                            <div class="mt18">
                                <button name="action_sign_in_pajakio" string="Sign In" type="object" class="btn btn-link" invisible="not l10n_id_pajakio_show_register_user"/>
                            </div>
                            <div class="mt18">
                                <button name="action_pajakio_register_company" string="Register Company" type="object" class="btn btn-link" invisible="not l10n_id_pajakio_show_register_company"/>
                            </div>
                            <div class="mt18">
                                <!-- Show only when client id is set and pajakio not activated yet -->
                                <button name="action_activate_pajakio_service" string="Activate Pajak.io" type="object" class="btn btn-link"
                                    invisible="not l10n_id_pajakio_show_activate_service"/>
                            </div>
                            <div class="mt18">
                                <button name="action_deactivate_pajakio_service" string="Deactivate Pajak.io" type="object" class="btn btn-link" invisible="not l10n_id_pajakio_show_deactivate_service"/>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
