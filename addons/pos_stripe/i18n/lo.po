#. module: pos_stripe
#. odoo-python
#: code:addons/pos_stripe/models/pos_payment_method.py:0
msgid "Complete the Stripe onboarding for company %s."
msgstr "ສໍາເລັດການລົງທະບຽນ Stripe ສໍາລັບບໍລິສັດ %s."

#. module: pos_stripe
#. odoo-python
#: code:addons/pos_stripe/models/pos_payment_method.py:0
msgid "Do not have access to fetch token from Stripe"
msgstr "ບໍ່ມີສິດເຂົ້າເຖິງເພື່ອດຶງຂໍ້ມູນ Token ຈາກ Stripe"

#. module: pos_stripe
#: model_terms:ir.ui.view,arch_db:pos_stripe.pos_payment_method_view_form_inherit_pos_stripe
msgid ""
"Don't forget to complete Stripe connect before using this payment method."
msgstr "ຢ່າລືມສໍາເລັດການເຊື່ອມຕໍ່ Stripe ກ່ອນທີ່ຈະໃຊ້ວິທີການຊໍາລະເງິນນີ້."

#. module: pos_stripe
#. odoo-javascript
#: code:addons/pos_stripe/static/src/app/payment_stripe.js:0
msgid "Failed to discover: %s"
msgstr "ບໍ່ສາມາດຄົ້ນພົບ: %s"

#. module: pos_stripe
#. odoo-javascript
#: code:addons/pos_stripe/static/src/app/payment_stripe.js:0
msgid "Failed to load resource: net::ERR_INTERNET_DISCONNECTED."
msgstr "ບໍ່ສາມາດໂຫຼດຂໍ້ມູນໄດ້: net::ERR_INTERNET_DISCONNECTED."

#. module: pos_stripe
#. odoo-javascript
#: code:addons/pos_stripe/static/src/app/payment_stripe.js:0
msgid "No available Stripe readers."
msgstr "ບໍ່ມີເຄື່ອງອ່ານ Stripe ທີ່ພ້ອມໃຊ້ງານ."

#. module: pos_stripe
#. odoo-javascript
#: code:addons/pos_stripe/static/src/app/payment_stripe.js:0
msgid "Payment cancelled because not reader connected"
msgstr "ການຊໍາລະເງິນຖືກຍົກເລີກເນື່ອງຈາກບໍ່ໄດ້ເຊື່ອມຕໍ່ເຄື່ອງອ່ານ"

#. module: pos_stripe
#: model:ir.model,name:pos_stripe.model_pos_payment_method
msgid "Point of Sale Payment Methods"
msgstr "ວິທີການຊໍາລະເງິນຂອງລະບົບຂາຍໜ້າຮ້ານ"

#. module: pos_stripe
#. odoo-javascript
#: code:addons/pos_stripe/static/src/app/payment_stripe.js:0
msgid "Reader disconnected"
msgstr "ເຄື່ອງອ່ານຖືກຕັດການເຊື່ອມຕໍ່"

#. module: pos_stripe
#. odoo-python
#: code:addons/pos_stripe/models/pos_payment_method.py:0
msgid "Stripe"
msgstr "Stripe"

#. module: pos_stripe
#. odoo-javascript
#: code:addons/pos_stripe/static/src/app/payment_stripe.js:0
msgid "Stripe Error"
msgstr "ຂໍ້ຜິດພາດຂອງ Stripe"

#. module: pos_stripe
#: model:ir.model.fields,field_description:pos_stripe.field_pos_payment_method__stripe_serial_number
msgid "Stripe Serial Number"
msgstr "ເລກລໍາດັບ Stripe"

#. module: pos_stripe
#. odoo-python
#: code:addons/pos_stripe/models/pos_payment_method.py:0
msgid "Stripe payment provider for company %s is missing"
msgstr "ບໍ່ພົບຜູ້ໃຫ້ບໍລິການຊໍາລະເງິນ Stripe ສໍາລັບບໍລິສັດ %s"

#. module: pos_stripe
#. odoo-javascript
#: code:addons/pos_stripe/static/src/app/payment_stripe.js:0
msgid "Stripe readers %s not listed in your account"
msgstr "ເຄື່ອງອ່ານ Stripe %s ບໍ່ມີຢູ່ໃນລາຍຊື່ບັນຊີຂອງທ່ານ"

#. module: pos_stripe
#. odoo-python
#: code:addons/pos_stripe/models/pos_payment_method.py:0
msgid ""
"Terminal %(terminal)s is already used on payment method %(payment_method)s."
msgstr ""
"ເຄື່ອງເທີມິນໍ %(terminal)s ຖືກນໍາໃຊ້ແລ້ວໃນວິທີການຊໍາລະເງິນ %(payment_method)s."

#. module: pos_stripe
#: model:ir.model.fields,help:pos_stripe.field_pos_payment_method__stripe_serial_number
msgid "[Serial number of the stripe terminal], for example: WSC513105011295"
msgstr "[ເລກລໍາດັບຂອງເຄື່ອງເທີມິນໍ Stripe], ຕົວຢ່າງ: WSC513105011295"
