#. module: pos_stripe
#: model:ir.model.fields,field_description:pos_stripe.field_pos_payment_method__display_name
msgid "Display Name"
msgstr "ຊື່ສະແດງ"

#. module: pos_stripe
#. odoo-python
#: code:addons/pos_stripe/models/pos_payment_method.py:0
msgid "Do not have access to fetch token from Stripe"
msgstr "ບໍ່ມີສິດເຂົ້າເຖິງໃນການດຶງເອົາໂທເຄັນຈາກ Stripe"

#. module: pos_stripe
#. odoo-python
#: code:addons/pos_stripe/models/pos_payment_method.py:0
msgid "Do not have access to refund Stripe payment"
msgstr "ບໍ່ມີສິດເຂົ້າເຖິງໃນການຄືນເງິນຜ່ານ Stripe"

#. module: pos_stripe
#: model_terms:ir.ui.view,arch_db:pos_stripe.pos_payment_method_view_form_inherit_pos_stripe
msgid ""
"Don't forget to complete Stripe connect before using this payment method."
msgstr ""
"ຢ່າລືມຕັ້ງຄ່າການເຊື່ອມຕໍ່ Stripe ໃຫ້ສຳເລັດ ກ່ອນຈະນຳໃຊ້ວິທີການຊຳລະເງິນນີ້."

#. module: pos_stripe
#. odoo-javascript
#: code:addons/pos_stripe/static/src/app/payment_stripe.js:0
msgid "Failed to discover: %s"
msgstr "ກວດຫາບໍ່ພົບ: %s"

#. module: pos_stripe
#. odoo-javascript
#: code:addons/pos_stripe/static/src/app/payment_stripe.js:0
msgid "Failed to load resource: net::ERR_INTERNET_DISCONNECTED."
msgstr "ໂຫຼດຊັບພະຍາກອນບໍ່ສຳເລັດ: net::ERR_INTERNET_DISCONNECTED."

#. module: pos_stripe
#: model:ir.model.fields,field_description:pos_stripe.field_pos_payment_method__id
msgid "ID"
msgstr "ໄອດີ"

#. module: pos_stripe
#. odoo-javascript
#: code:addons/pos_stripe/static/src/app/payment_stripe.js:0
msgid "No available Stripe readers."
msgstr "ບໍ່ມີເຄື່ອງອ່ານ Stripe ທີ່ພ້ອມໃຊ້ງານ."

#. module: pos_stripe
#. odoo-javascript
#: code:addons/pos_stripe/static/src/app/payment_stripe.js:0
msgid "Payment cancelled because not reader connected"
msgstr "ການຊຳລະເງິນຖືກຍົກເລີກ ເນື່ອງຈາກບໍ່ມີການເຊື່ອມຕໍ່ເຄື່ອງອ່ານ"

#. module: pos_stripe
#: model:ir.model,name:pos_stripe.model_pos_payment_method
msgid "Point of Sale Payment Methods"
msgstr "ວິທີການຊຳລະເງິນຂອງຈຸດຂາຍ"

#. module: pos_stripe
#. odoo-javascript
#: code:addons/pos_stripe/static/src/app/payment_stripe.js:0
msgid "Reader disconnected"
msgstr "ເຄື່ອງອ່ານຖືກຕັດການເຊື່ອມຕໍ່"

#. module: pos_stripe
#. odoo-python
#: code:addons/pos_stripe/models/pos_payment_method.py:0
msgid "Stripe"
msgstr "Stripe"

#. module: pos_stripe
#. odoo-javascript
#: code:addons/pos_stripe/static/src/app/payment_stripe.js:0
msgid "Stripe Error"
msgstr "ຂໍ້ຜິດພາດຂອງ Stripe"

#. module: pos_stripe
#: model:ir.model.fields,field_description:pos_stripe.field_pos_payment_method__stripe_serial_number
msgid "Stripe Serial Number"
msgstr "ເລກລຳດັບເຄື່ອງ Stripe"

#. module: pos_stripe
#. odoo-python
#: code:addons/pos_stripe/models/pos_payment_method.py:0
msgid "Stripe payment provider for company %s is missing"
msgstr "ບໍ່ພົບຜູ້ໃຫ້ບໍລິການຊຳລະເງິນ Stripe ສຳລັບບໍລິສັດ %s"

#. module: pos_stripe
#. odoo-javascript
#: code:addons/pos_stripe/static/src/app/payment_stripe.js:0
msgid "Stripe readers %s not listed in your account"
msgstr "ເຄື່ອງອ່ານ Stripe %s ບໍ່ມີຢູ່ໃນບັນຊີຂອງທ່ານ"

#. module: pos_stripe
#. odoo-python
#: code:addons/pos_stripe/models/pos_payment_method.py:0
msgid ""
"Terminal %(terminal)s is already used on payment method %(payment_method)s."
msgstr ""
"ເຄື່ອງແທັກມີນໍ %(terminal)s ຖືກນຳໃຊ້ແລ້ວໃນວິທີການຊຳລະເງິນ %(payment_method)s."

#. module: pos_stripe
#. odoo-javascript
#: code:addons/pos_stripe/static/src/app/payment_stripe.js:0
msgid "You cannot refund a non-Stripe payment via Stripe"
msgstr "ທ່ານບໍ່ສາມາດຄືນເງິນທີ່ບໍ່ແມ່ນການຊຳລະຜ່ານ Stripe ຜ່ານລະບົບ Stripe ໄດ້"

#. module: pos_stripe
#: model:ir.model.fields,help:pos_stripe.field_pos_payment_method__stripe_serial_number
msgid "[Serial number of the stripe terminal], for example: WSC513105011295"
msgstr "[ເລກລຳດັບຂອງເຄື່ອງ Stripe], ຕົວຢ່າງ: WSC513105011295"
