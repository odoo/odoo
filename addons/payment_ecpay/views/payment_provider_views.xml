<?xml version='1.0' encoding='utf-8'?>
<odoo>

    <record id="payment_provider_form" model="ir.ui.view">
        <field name="name">ECPay Provider Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <group name="provider_credentials" position="inside">
                <field
                    string="Merchant ID"
                    name="ecpay_merchant_id"
                    invisible="code != 'ecpay'"
                    required="is_live"
                />
                <field
                    string="Secure Hash Secret"
                    name="ecpay_hash_key"
                    invisible="code != 'ecpay'"
                    required="is_live"
                    widget="password"
                />
                <field
                    string="Secure Hash IV"
                    name="ecpay_hash_iv"
                    invisible="code != 'ecpay'"
                    required="is_live"
                    widget="password"
                />
            </group>
        </field>
    </record>

</odoo>
