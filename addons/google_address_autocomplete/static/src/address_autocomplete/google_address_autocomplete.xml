<?xml version="1.0" encoding="UTF-8"?>

<templates>
    <t t-name="google_address_autocomplete.AddressAutoCompleteTemplate">
        <t t-if="this.props.readonly">
            <span t-out="this.value" />
        </t>
        <t t-else="">
            <AutoComplete
                value="this.value"
                sources="this.sources"
                placeholder="this.props.placeholder"
                searchOnInputClick="false"
                inputDebounceDelay="350"
                input="this.input"
            >
                <t t-set-slot="option" t-slot-scope="optionScope">
                    <strong t-out="optionScope.label"/>
                </t>
            </AutoComplete>
        </t>
    </t>
</templates>
