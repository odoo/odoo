<?xml version="1.0" encoding="UTF-8" ?>
<templates>

    <t t-name="purchase.PurchaseProductLabelSectionAutocomplete" t-inherit="web.AutoComplete">
        <xpath expr="//a[@class='dropdown-item ui-menu-item-wrapper text-truncate']" position="attributes">
            <attribute name="t-att-class">{'text-info': isPrioritized()}</attribute>
        </xpath>
    </t>

    <t t-name="purchase.PurchaseProductLabelSectionFieldAutocomplete" t-inherit="account.ProductLabelSectionAndNoteFieldAutocomplete">
        <xpath expr="//AutoComplete" position="attributes">
            <attribute name="resModel">props.resModel</attribute>
        </xpath>
    </t>

</templates>
