<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_bill_line_match_tree" model="ir.ui.view">
        <field name="name">purchase.bill.line.match.list</field>
        <field name="model">purchase.bill.line.match</field>
        <field name="arch" type="xml">
            <list string="Purchase Bill Lines"
                  decoration-info="pol_id != False"
                  decoration-muted="state == 'draft'"
                  editable="bottom" edit="1"
                  type="object">
                <header>
                    <button name="action_match_lines" type="object" string="Match" groups="account.group_account_invoice" class="btn btn-primary"/>
                    <button name="action_add_to_po" type="object" string="Add to PO" groups="purchase.group_purchase_user"/>
                </header>
                <field name="partner_id" string="Vendor" optional="hidden"/>
                <field name="reference" widget="open_match_line_widget" decoration-it="not product_id"/>
                <field name="product_id" optional="show" context="{'partner_id': False}"/>
                <field name="description" string="Description"/>
                <field name="matching_id" string="Matching" widget="matching_tag"/>
                <field name="product_uom_qty" string="Bill Qty" invisible="not aml_id"/>
                <field name="product_uom_qty_to_invoice" string="Qty to invoice" invisible="not purchase_order_id" optional="show"/>
                <field name="product_uom_qty" string="PO Qty" invisible="aml_id" optional="hide"/>
                <field name="product_uom_id" groups="uom.group_uom"/>
                <field name="product_uom_price" widget="monetary" string="Unit Price" optional="show"/>
                <field name="billed_amount_untaxed" widget="monetary_no_zero" sum="Total Billed" string="Billed"/>
                <field name="purchase_amount_untaxed" widget="monetary_no_zero" sum="Total Purchased" string="Purchased"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="purchase_bill_line_match_search" model="ir.ui.view">
        <field name="name">purchase.bill.line.match.search</field>
        <field name="model">purchase.bill.line.match</field>
        <field name="arch" type="xml">
            <search>
                <field name="description" string="Description" filter_domain="['|', ('description', 'ilike', self), ('product_id', 'ilike', self)]"/>
                <field name="partner_id" string="Vendor"/>
                <field name="line_amount_untaxed" string="Price" filter_domain="[('line_amount_untaxed', '=', self)]"/>
                <filter name="bills" string="Bills" domain="[('aml_id', '!=', False)]"/>
                <filter name="purchases" string="Purchases" domain="[('pol_id', '!=', False)]"/>
                <separator/>
                <filter name="matched" string="Matched" domain="['|', '&amp;', ('aml_id', '!=', False), ('matching_id', '!=', 0), '&amp;', ('pol_id', '!=', False), ('pol_id.invoice_lines', '!=', False)]"/>
                <filter name="unmatched" string="Unmatched" domain="['|', '&amp;', ('aml_id', '!=', False), ('matching_id', '=', 0), '&amp;', ('pol_id', '!=', False), '|', ('pol_id.invoice_lines', '=', False), ('pol_id.qty_to_invoice', '!=', 0)]"/>
                <filter name="group_by_partner" string="Vendor" context="{'group_by': 'partner_id'}"/>
                <filter name="group_by_product" string="Product" context="{'group_by': 'product_id'}"/>
                <filter name="group_by_date" string="Date" context="{'group_by': 'date'}"/>
                <filter name="group_by_matching_id" string="Matching" context="{'group_by': 'matching_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_unmatch_lines" model="ir.actions.server">
        <field name="name">Unmatch</field>
        <field name="model_id" ref="purchase.model_purchase_bill_line_match"/>
        <field name="binding_model_id" ref="purchase.model_purchase_bill_line_match"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            if records:
                res = records.action_unmatch_lines()
        </field>
    </record>
</odoo>
