<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="website_payment.SupportedPaymentMethodsOption">
        <BuilderRow label.translate="Limit">
            <BuilderNumberInput
                min="1"
                step="1"
                unit="'icons'"
                applyWithUnit="false"
                action="'supportedPaymentMethodsLimit'"
            />
        </BuilderRow>
        <BuilderRow label.translate="Height">
            <!-- The `image` field on payment methods is max 64px tall. -->
            <BuilderRange
                min="16"
                max="64"
                step="1"
                unit="'px'"
                action="'supportedPaymentMethodsHeight'"
                withNumberInput="true" />
        </BuilderRow>
        <BuilderRow label.translate="Alignment">
            <BuilderSelect dataAttributeAction="'alignment'">
                <BuilderSelectItem ltrRtlMapping="'align'" dataAttributeActionValue="'start'">
                    <div title="Align Left">
                        <i class="fa fa-align-left fa-fw" role="img" aria-hidden="true"/>
                        <span class="visually-hidden">Align Left</span>
                    </div>
                </BuilderSelectItem>
                <BuilderSelectItem dataAttributeActionValue="'center'">
                    <div title="Center">
                        <i class="fa fa-align-center fa-fw" role="img" aria-hidden="true"/>
                        <span class="visually-hidden">Center</span>
                    </div>
                </BuilderSelectItem>
                <BuilderSelectItem ltrRtlMapping="'align'" dataAttributeActionValue="'end'">
                    <div title="Align Right">
                        <i class="fa fa-align-right fa-fw" role="img" aria-hidden="true"/>
                        <span class="visually-hidden">Align Right</span>
                    </div>
                </BuilderSelectItem>
            </BuilderSelect>
        </BuilderRow>
    </t>

    <t t-inherit="website.BuilderOptions" t-inherit-mode="extension">
        <xpath expr="//t[@id='snippet_specific_options']" position="after">
            <supported_payment_methods_options
                template="website_payment.SupportedPaymentMethodsOption"
                selector=".s_supported_payment_methods"/>
        </xpath>
    </t>

</templates>
