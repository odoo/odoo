<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="website_payment.s_supported_payment_methods.icons">
        <div class="d-flex flex-wrap gap-1">
            <t t-foreach="payment_methods" t-as="pm" t-key="pm.id">
                <!-- The `image` field on the payment method has a max height of 64px, if the user
                needs taller images, then the full png is loaded for higher quality picture. -->
                <img class="img img-fluid rounded"
                     t-att-src="height &lt;= 64 ? `/web/image/payment.method/${pm.id}/image`
                                                : `/payment/static/img/${pm.code}.png`"
                     t-att-alt="pm.name"
                     t-att-title="pm.name"
                     loading="lazy"
                     t-attf-style="height: #{height}px;"
                />
            </t>
        </div>
    </t>
</templates>
