<?xml version="1.0" encoding="utf-8"?>
<!--
    Additional prison.jail records required for vacancy tracking.
    Loaded once on module install (noupdate="1").

    Includes:
    - Special Prisons for Women (5 standalone central-level facilities)
    - Women-specific sub-jails and annexures (16 records)
    - Open Air prisons / Special Sub Jails not in base hierarchy (4 records)
    - Closed sub-jails that still require vacancy records (10 records)
    - Sub Jail, Nanguneri (omitted from base hierarchy)
-->
<odoo>
<data noupdate="1">

<!-- ══════════════════════════════════════════════════════════════════════
     SPECIAL PRISONS FOR WOMEN  (standalone — treated as Central Jail tier)
══════════════════════════════════════════════════════════════════════ -->

<record id="jail_spw_chennai" model="prison.jail">
