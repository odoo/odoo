<?xml version="1.0" encoding="utf8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_pos_history" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pos.history</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='order_edit_tracking']" position='after'>
                <setting id="order_history_tracking" help="Store edited orders and orderlines in the backend">
                    <field name="is_history_tracked"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
