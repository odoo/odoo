<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-inherit="point_of_sale.PaymentScreenPaymentLines" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('paymentline_status_actions')]" position="before">
            <div t-if="state.id == 'waiting' and line.payment_method_id.payment_provider === 'cashmatic'"
                class="d-flex align-items-center justify-content-between pb-3 px-4 fs-4">
                <span>Cash dispensed</span>
                <span t-out="this.env.utils.formatCurrency(line.payment_method_id.payment_interface.amountDispensed)"/>
            </div>
        </xpath>
    </t>
</templates>
