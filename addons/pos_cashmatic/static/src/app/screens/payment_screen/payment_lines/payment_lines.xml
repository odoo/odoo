<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-inherit="point_of_sale.PaymentScreenPaymentLines" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('electronic_status') and contains(text(), 'Request sent')]" position="attributes">
            <attribute name="class">electronic_status d-flex gap-2</attribute>
        </xpath>
        <xpath expr="//div[hasclass('electronic_status') and contains(text(), 'Request sent')]" position="inside">
            <t t-if="line.payment_method_id.payment_method_type === 'cashmatic'">
                <div class="d-flex flex-column">
                    <div>
                        <strong>Cash inserted:</strong>
                        <t t-out="env.utils.formatCurrency(line.payment_method_id.payment_terminal.amountInserted)"/>
                    </div>
                    <div>
                        <strong>Cash dispensed:</strong>
                        <t t-out="env.utils.formatCurrency(line.payment_method_id.payment_terminal.amountDispensed)"/>
                    </div>
                </div>
            </t>
        </xpath>
    </t>
</templates>
