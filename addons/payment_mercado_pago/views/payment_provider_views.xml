<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="payment_provider_form" model="ir.ui.view">
        <field name="name">Mercado Pago Provider Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <header position="inside">
                <div invisible="code != 'mercado_pago'">
                    <button
                        string="Connect"
                        type="object"
                        name="action_start_onboarding"
                        invisible="mercado_pago_access_token"
                        class="btn-primary"
                    />
                    <button
                        string="Disconnect"
                        type="object"
                        name="action_reset_credentials"
                        confirm="Are you sure you want to disconnect?"
                        invisible="not mercado_pago_access_token"
                        class="btn-secondary"
                    />
                </div>
            </header>
            <group name="provider_credentials" position="inside">
                <field
                    string="Account Country"
                    name="mercado_pago_account_country_id"
                    invisible="code != 'mercado_pago'"
                    required="is_live"
                    readonly="mercado_pago_access_token and mercado_pago_account_country_id"
                    options="{'no_create': True}"
                />
                <field
                    string="Access Token"
                    name="mercado_pago_access_token"
                    invisible="code != 'mercado_pago' or not mercado_pago_access_token"
                    readonly="True"
                    widget="password"
                />
            </group>
            <group name="provider_config" position="before">
                <div
                    invisible="
                        code != 'mercado_pago'
                        or (mercado_pago_access_token and mercado_pago_public_key)
                    "
                >
                    <div
                        class="alert alert-warning mt-2"
                        role="alert"
                        invisible="not mercado_pago_access_token"
                    >
                        You must renew your connection to Mercado Pago in order to enable the new
                        Card payment method experience, which allows saving payment details for
                        recurring payments.
                    </div>
                </div>
            </group>
            <field name="available_currency_ids" position="attributes">
                <attribute
                    name="readonly"
                    separator="or"
                    add="(code == 'mercado_pago' and mercado_pago_public_key)"
                />
            </field>
        </field>
    </record>

</odoo>
