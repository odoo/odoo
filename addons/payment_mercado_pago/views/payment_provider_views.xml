<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="payment_provider_form" model="ir.ui.view">
        <field name="name">Mercado Pago Provider Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <group name="provider_credentials" position="inside">
                <group
                    name="mercado_pago_credentials"
                    invisible="code != 'mercado_pago'"
                    groups="base.group_no_one"
                >
                    <field
                        name="mercado_pago_access_token"
                        string="Access Token"
                        readonly="True"
                        password="True"
                    />
                    <button
                            string="Reset Your Mercado Pago Account"
                            type="object"
                            name="action_reset_oauth_account"
                            class="btn-secondary ms-2"
                            confirm="Are you sure you want to disconnect?"
                            invisible="not mercado_pago_access_token"
                            readonly="True"
                        />
                </group>
            </group>
            <group name="provider_credentials" position="after">
                <div invisible="code != 'mercado_pago' or mercado_pago_access_token">
                    <button
                        string="Connect"
                        type="object"
                        name="action_start_onboarding"
                        class="btn-primary"
                    />
                </div>
            </group>
        </field>
    </record>

</odoo>
