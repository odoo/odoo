#. module: payment_mercado_pago
#: model:ir.model.fields,field_description:payment_mercado_pago.field_payment_provider__mercado_pago_refresh_token
msgid "Mercado Pago Refresh Token"
msgstr "ໂທເຄັນຣີເຟຣຊ Mercado Pago"

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/models/payment_provider.py:0
msgid ""
"Mercado Pago credentials are missing. Click the \"Connect\" button to set up"
" your account."
msgstr ""
"ຂໍ້ມູນການຢືນຢັນຕົວຕົນ Mercado Pago ຫາຍໄປ. ຄລິກທີ່ປຸ່ມ \"ເຊື່ອມຕໍ່\" ເພື່ອຕັ້ງຄ່າບັນຊີຂອງທ່ານ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/models/payment_provider.py:0
msgid ""
"Mercado Pago is not available in your country; please use another payment "
"provider."
msgstr ""
"Mercado Pago ບໍ່ມີໃຫ້ບໍລິການໃນປະເທດຂອງທ່ານ; ກະລຸນາໃຊ້ຜູ້ໃຫ້ບໍລິການຊຳລະເງິນອື່ນ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/models/payment_provider.py:0
msgid "Only the currency %s is available for this account."
msgstr "ມີພຽງແຕ່ສະກຸນເງິນ %s ທີ່ສາມາດໃຊ້ໄດ້ສຳລັບບັນຊີນີ້."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/models/payment_provider.py:0
msgid "Other Payment Providers"
msgstr "ຜູ້ໃຫ້ບໍລິການຊຳລະເງິນອື່ນໆ"

#. module: payment_mercado_pago
#: model:ir.model,name:payment_mercado_pago.model_payment_provider
msgid "Payment Provider"
msgstr "ຜູ້ໃຫ້ບໍລິການຊຳລະເງິນ"

#. module: payment_mercado_pago
#: model:ir.model,name:payment_mercado_pago.model_payment_token
msgid "Payment Token"
msgstr "ໂທເຄັນການຊຳລະເງິນ"

#. module: payment_mercado_pago
#: model:ir.model,name:payment_mercado_pago.model_payment_transaction
msgid "Payment Transaction"
msgstr "ທຸລະກຳການຊຳລະເງິນ"

#. module: payment_mercado_pago
#. odoo-javascript
#: code:addons/payment_mercado_pago/static/src/interactions/payment_form.js:0
msgid "Payment processing failed"
msgstr "ການປະມວນຜົນການຊຳລະເງິນຫຼົ້ມເຫຼວ"

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid "Payment was not processed, use another card or contact issuer."
msgstr "ການຊຳລະເງິນບໍ່ໄດ້ຮັບການປະມວນຜົນ, ກະລຸນາໃຊ້ບັດອື່ນ ຫຼື ຕິດຕໍ່ຜູ້ອອກບັດ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/models/payment_transaction.py:0
msgid "Received data with invalid status: %s."
msgstr "ໄດ້ຮັບຂໍ້ມູນທີ່ມີສະຖານະບໍ່ຖືກຕ້ອງ: %s."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/models/payment_transaction.py:0
msgid "Received data with missing payment id."
msgstr "ໄດ້ຮັບຂໍ້ມູນທີ່ບໍ່ມີໄອດີການຊຳລະເງິນ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/models/payment_transaction.py:0
msgid "Received data with missing status."
msgstr "ໄດ້ຮັບຂໍ້ມູນທີ່ບໍ່ມີສະຖານະ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/models/payment_provider.py:0
msgid "Set the account country before connecting the account."
msgstr "ກຳນົດປະເທດຂອງບັນຊີກ່ອນທີ່ຈະເຊື່ອມຕໍ່ບັນຊີ."

#. module: payment_mercado_pago
#: model:ir.model.fields,help:payment_mercado_pago.field_payment_provider__mercado_pago_account_country_id
msgid ""
"The country of the Mercado Pago account. The currency will be updated to "
"match the country of the Mercado Pago account."
msgstr ""
"ປະເທດຂອງບັນຊີ Mercado Pago. ສະກຸນເງິນຈະຖືກອັບເດດໃຫ້ກົງກັບປະເທດຂອງບັນຊີ Mercado Pago."

#. module: payment_mercado_pago
#: model:ir.model.fields,help:payment_mercado_pago.field_payment_provider__code
msgid "The technical code of this payment provider."
msgstr "ລະຫັດທາງເຕັກນິກຂອງຜູ້ໃຫ້ບໍລິການຊຳລະເງິນນີ້."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid "This payment method does not process payments in installments."
msgstr "ວິທີການຊຳລະເງິນນີ້ບໍ່ຮອງຮັບການຊຳລະແບບຜ່ອນຈ່າຍ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid ""
"We are processing your payment. Don't worry, in less than 2 business days, "
"we will notify you by e-mail if your payment has been credited."
msgstr ""
"ພວກເຮົາກຳລັງປະມວນຜົນການຊຳລະເງິນຂອງທ່ານ. ບໍ່ຕ້ອງກັງວົນ, ພາຍໃນບໍ່ເກີນ 2 ວັນລັດຖະການ, ພວກເຮົາຈະແ"
"ຈ້ງໃຫ້ທ່ານຊາບຜ່ານທາງອີເມວ ຖ້າການຊຳລະເງິນຂອງທ່ານໄດ້ຮັບການຢືນຢັນ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid ""
"We are processing your payment. Don't worry, less than 2 business days we "
"will notify you by e-mail if your payment has been credited or if we need "
"more information."
msgstr ""
"ພວກເຮົາກຳລັງປະມວນຜົນການຊຳລະເງິນຂອງທ່ານ. ບໍ່ຕ້ອງກັງວົນ, ພາຍໃນບໍ່ເກີນ 2 ວັນລັດຖະການ ພວກເຮົາຈະແຈ້"
"ງໃຫ້ທ່ານຊາບຜ່ານທາງອີເມວ ຖ້າການຊຳລະເງິນຂອງທ່ານໄດ້ຮັບການຢືນຢັນ ຫຼື ຫາກພວກເຮົາຕ້ອງການຂໍ້ມູນເພີ່ມເຕີມ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid ""
"We were unable to process your payment, please check your card information."
msgstr ""
"ພວກເຮົາບໍ່ສາມາດປະມວນຜົນການຊຳລະເງິນຂອງທ່ານໄດ້, ກະລຸນາກວດເບິ່ງຂໍ້ມູນບັດຂອງທ່ານ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid "We were unable to process your payment, please use another card."
msgstr "ພວກເຮົາບໍ່ສາມາດປະມວນຜົນການຊຳລະເງິນຂອງທ່ານໄດ້, ກະລຸນາໃຊ້ບັດອື່ນ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid ""
"You have already made a payment for that value. If you need to pay again, "
"use another card or another payment method."
msgstr ""
"ທ່ານໄດ້ຊຳລະເງິນດ້ວຍມູນຄ່ານີ້ແລ້ວ. ຫາກທ່ານຕ້ອງການຊຳລະອີກຄັ້ງ, ກະລຸນາໃຊ້ບັດອື່ນ ຫຼື ວິທີການຊຳລະເງິນອື່ນ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid ""
"You have reached the limit of allowed attempts. Choose another card or other"
" means of payment."
msgstr ""
"ທ່ານໄດ້ໃຊ້ຈຳນວນຄັ້ງທີ່ອະນຸຍາດຈົນຄົບກຳນົດແລ້ວ. ກະລຸນາເລືອກບັດອື່ນ ຫຼື ວິທີການຊຳລະເງິນອື່ນ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid "You must authorize the payment with this card."
msgstr "ທ່ານຕ້ອງອະນຸມັດການຊຳລະເງິນດ້ວຍບັດນີ້."

#. module: payment_mercado_pago
#: model_terms:ir.ui.view,arch_db:payment_mercado_pago.payment_provider_form
msgid ""
"You must renew your connection to Mercado Pago in order to enable the new\n"
"                        Card payment method experience, which allows saving payment details for\n"
"                        recurring payments."
msgstr ""
"ທ່ານຕ້ອງຕໍ່ອາຍຸການເຊື່ອມຕໍ່ກັບ Mercado Pago ເພື່ອເປີດໃຊ້ງານປະສົບການການຊຳລະຜ່ານບັດແບບໃໝ່, ເຊິ່ງຊ່ວຍ"
"ໃຫ້ສາມາດບັນທຶກລາຍລະອຽດການຊຳລະເງິນສຳລັບການຊຳລະແບບຕໍ່ເນື່ອງໄດ້."

