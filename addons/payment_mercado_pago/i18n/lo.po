#. module: payment_mercado_pago
#: model_terms:ir.ui.view,arch_db:payment_mercado_pago.payment_provider_form
msgid "Access Token"
msgstr "ລະຫັດເຂົ້າເຖິງ (Token)"

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid ""
"Call your card issuer to activate your card or use another payment method. "
"The phone number is on the back of your card."
msgstr ""
"ຕິດຕໍ່ຜູ້ອອກບັດຂອງທ່ານເພື່ອເປີດໃຊ້ບັດ ຫຼື ໃຊ້ວິທີການຊຳລະເງິນອື່ນ. ເບີໂທລະສັບແມ່ນຢູ່ທາງຫຼັງບັດຂອງທ່ານ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid "Check expiration date."
msgstr "ກວດເບິ່ງວັນໝົດອາຍຸ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid "Check the card number."
msgstr "ກວດເບິ່ງໝາຍເລກບັດ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid "Check the card security code."
msgstr "ກວດເບິ່ງລະຫັດຄວາມປອດໄພຂອງບັດ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid "Check the data."
msgstr "ກວດເບິ່ງຂໍ້ມູນ."

#. module: payment_mercado_pago
#: model:ir.model.fields,field_description:payment_mercado_pago.field_payment_provider__code
msgid "Code"
msgstr "ລະຫັດ"

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/models/payment_provider.py:0
msgid "Could not establish the connection to the API."
msgstr "ບໍ່ສາມາດສ້າງການເຊື່ອມຕໍ່ກັບ API ໄດ້."

#. module: payment_mercado_pago
#: model:ir.model.fields.selection,name:payment_mercado_pago.selection__payment_provider__code__mercado_pago
msgid "Mercado Pago"
msgstr "Mercado Pago"

#. module: payment_mercado_pago
#: model:ir.model.fields,field_description:payment_mercado_pago.field_payment_provider__mercado_pago_access_token
msgid "Mercado Pago Access Token"
msgstr "ລະຫັດເຂົ້າເຖິງ (Access Token) ຂອງ Mercado Pago"

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/models/payment_transaction.py:0
msgid "No transaction found matching reference %s."
msgstr "ບໍ່ພົບທຸລະກຳທີ່ກົງກັບການອ້າງອີງ %s."

#. module: payment_mercado_pago
#: model:ir.model,name:payment_mercado_pago.model_payment_provider
msgid "Payment Provider"
msgstr "ຜູ້ໃຫ້ບໍລິການຊຳລະເງິນ"

#. module: payment_mercado_pago
#: model:ir.model,name:payment_mercado_pago.model_payment_transaction
msgid "Payment Transaction"
msgstr "ທຸລະກຳການຊຳລະເງິນ"

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid "Payment was not processed, use another card or contact issuer."
msgstr "ການຊຳລະເງິນບໍ່ໄດ້ຖືກປະມວນຜົນ, ກະລຸນາໃຊ້ບັດອື່ນ ຫຼື ຕິດຕໍ່ຜູ້ອອກບັດ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/models/payment_transaction.py:0
msgid "Received data with invalid status: %s"
msgstr "ໄດ້ຮັບຂໍ້ມູນທີ່ມີສະຖານະບໍ່ຖືກຕ້ອງ: %s"

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/models/payment_transaction.py:0
msgid "Received data with missing payment id."
msgstr "ໄດ້ຮັບຂໍ້ມູນໂດຍບໍ່ມີ ໄອດີການຊຳລະເງິນ (Payment ID)."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/models/payment_transaction.py:0
msgid "Received data with missing reference."
msgstr "ໄດ້ຮັບຂໍ້ມູນໂດຍບໍ່ມີບ່ອນອີງ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/models/payment_transaction.py:0
msgid "Received data with missing status."
msgstr "ໄດ້ຮັບຂໍ້ມູນໂດຍບໍ່ມີສະຖານະ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/models/payment_provider.py:0
msgid ""
"The communication with the API failed. Mercado Pago gave us the following "
"information: '%(error_message)s' (code %(error_code)s)"
msgstr ""
"ການຕິດຕໍ່ສື່ສານກັບ API ຫຼົ້ມເຫຼວ. Mercado Pago ໄດ້ແຈ້ງຂໍ້ມູນດັ່ງນີ້: '%(error_message)s' (ລະຫັດ %"
"(error_code)s)"

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/models/payment_provider.py:0
msgid ""
"The communication with the API failed. The response is empty. Please verify "
"your access token."
msgstr ""
"ການຕິດຕໍ່ສື່ສານກັບ API ຫຼົ້ມເຫຼວ. ບໍ່ມີການຕອບສະໜອງກັບຄືນມາ. ກະລຸນາກວດສອບລະຫັດເຂົ້າເຖິງ (Access "
"Token) ຂອງທ່ານ."

#. module: payment_mercado_pago
#: model:ir.model.fields,help:payment_mercado_pago.field_payment_provider__code
msgid "The technical code of this payment provider."
msgstr "ລະຫັດທາງເຕັກນິກຂອງຜູ້ໃຫ້ບໍລິການຊຳລະເງິນນີ້."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid "This payment method does not process payments in installments."
msgstr "ວິທີການຊຳລະເງິນນີ້ ບໍ່ຮອງຮັບການຊຳລະແບບຜ່ອນຈ່າຍ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid ""
"We are processing your payment. Don't worry, in less than 2 business days, "
"we will notify you by e-mail if your payment has been credited."
msgstr ""
"ພວກເຮົາກຳລັງປະມວນຜົນການຊຳລະເງິນຂອງທ່ານ. ບໍ່ຕ້ອງເປັນຫ່ວງ, ພາຍໃນບໍ່ເກີນ 2 ວັນທຳການ, ພວກເຮົາຈະແ"
"ຈ້ງໃຫ້ທ່ານຊາບຜ່ານທາງອີເມວ ຖ້າການຊຳລະເງິນຂອງທ່ານຖືກໂອນເຂົ້າແລ້ວ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid ""
"We are processing your payment. Don't worry, less than 2 business days we "
"will notify you by e-mail if your payment has been credited or if we need "
"more information."
msgstr ""
"ພວກເຮົາກຳລັງປະມວນຜົນການຊຳລະເງິນຂອງທ່ານ. ບໍ່ຕ້ອງເປັນຫ່ວງ, ພາຍໃນບໍ່ເກີນ 2 ວັນທຳການ ພວກເຮົາຈະແຈ້"
"ງໃຫ້ທ່ານຊາບຜ່ານທາງອີເມວ ຖ້າການຊຳລະເງິນຂອງທ່ານຖືກໂອນເຂົ້າແລ້ວ ຫຼື ຖ້າພວກເຮົາຕ້ອງການຂໍ້ມູນເພີ່ມເຕີມ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid ""
"We were unable to process your payment, please check your card information."
msgstr ""
"ພວກເຮົາບໍ່ສາມາດປະມວນຜົນການຊຳລະເງິນຂອງທ່ານໄດ້, ກະລຸນາກວດສອບຂໍ້ມູນບັດຂອງທ່ານ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid "We were unable to process your payment, please use another card."
msgstr "ພວກເຮົາບໍ່ສາມາດປະມວນຜົນການຊຳລະເງິນຂອງທ່ານໄດ້, ກະລຸນາໃຊ້ບັດອື່ນ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid ""
"You have already made a payment for that value. If you need to pay again, "
"use another card or another payment method."
msgstr ""
"ທ່ານໄດ້ຊຳລະເງິນສຳລັບຍອດນີ້ແລ້ວ. ຖ້າທ່ານຕ້ອງການຊຳລະອີກຄັ້ງ, ກະລຸນາໃຊ້ບັດອື່ນ ຫຼື ວິທີການຊຳລະເງິນອື່ນ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid ""
"You have reached the limit of allowed attempts. Choose another card or other"
" means of payment."
msgstr ""
"ທ່ານໄດ້ໃຊ້ຈຳນວນຄັ້ງທີ່ອະນຸຍາດຈົນຄົບກຳນົດແລ້ວ. ກະລຸນາເລືອກບັດອື່ນ ຫຼື ວິທີການຊຳລະເງິນອື່ນ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid "You must authorize the payment with this card."
msgstr "ທ່ານຕ້ອງໄດ້ອະນຸມັດການຊຳລະເງິນດ້ວຍບັດນີ້."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid "Your card has not enough funds."
msgstr "ຍອດເງິນໃນບັດຂອງທ່ານບໍ່ພໍ."

#. module: payment_mercado_pago
#. odoo-python
#: code:addons/payment_mercado_pago/const.py:0
msgid ""
"Your payment has been credited. In your summary you will see the charge as a"
" statement descriptor."
msgstr ""
"ການຊຳລະເງິນຂອງທ່ານຖືກໂອນເຂົ້າແລ້ວ. ທ່ານຈະເຫັນລາຍການຮຽກເກັບເງິນໃນໃບລາຍງານບັນຊີ "
"(Statement) ຂອງທ່ານ."
