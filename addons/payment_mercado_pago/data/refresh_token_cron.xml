<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record model="ir.cron" id="cron_token_refresh_mercado_pago">
        <field name="name">Payment Mercado Pago: Refresh token</field>
        <field name="model_id" ref="payment_mercado_pago.model_payment_provider" />
        <field name="state">code</field>
        <field name="code">model._cron_refresh_token()</field>
        <field name="user_id" ref="base.user_root" />
        <field name="interval_number">30</field>
        <field name="interval_type">days</field>
        <field name="active" eval="False"/>
    </record>

    <function model="payment.provider" name="_toggle_token_refresh_cron"/>

</odoo>
