<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sample_supplier_blueprint" model="populate.blueprint">
        <field name="name">Sample Supplier Data</field>
        <field name="definition_xml" type="xml">
            <model name="test_populate.supplier" count="10">
                <field name="name" length="20"/>
                <field name="email" length="25"/>
                <field name="phone" length="12"/>
                <field name="country_code"/>
                <field name="rating" start="1.0" end="5.0"/>
                <field name="is_active"/>
                <field name="established_date" start="today -20y" end="today -1y"/>
                <field name="notes" length="100"/>
            </model>
        </field>
    </record>

    <record id="sample_product_blueprint" model="populate.blueprint">
        <field name="name">Sample Product Data</field>
        <field name="definition_xml" type="xml">
            <model name="test_populate.product" count="50">
                <field name="name" length="15"/>
                <field name="price" start="5.0" end="999.99"/>
                <field name="cost" start="1.0" end="500.0"/>
                <field name="active"/>
                <field name="description" length="200"/>
                <field name="category"/>
                <field name="created_date" start="today" end="today +1y"/>
                <field name="updated_at" start="now -6m" end="now"/>
                <field name="stock_quantity" start="0" end="1000"/>
                <field name="is_featured"/>
                <field name="is_sellable" eval="True"/>
            </model>
        </field>
    </record>

    <record id="sample_static_blueprint" model="populate.blueprint">
        <field name="name">Sample Static Data</field>
        <field name="definition_xml" type="xml">
            <model name="test_populate.customer" count="5">
                <field name="name" eval="'VIP Customer'"/>
                <field name="email" length="30"/>
                <field name="age" eval="35"/>
                <field name="birth_date" start="today -30y" end="today -20y"/>
                <field name="is_vip" eval="True"/>
                <field name="preferred_category" eval="'electronics'"/>
                <field name="total_spent" eval="1000.0"/>
                <field name="registration_date"/>
                <field name="notes" eval="'Premium customer with special privileges'"/>
            </model>
        </field>
    </record>

    <record id="sample_complex_blueprint" model="populate.blueprint">
        <field name="name">Complex Multi-Model Data</field>
        <field name="definition_xml" type="xml">
            <model name="test_populate.warehouse" count="3" id="warehouses">
                <field name="name" length="20"/>
                <field name="location" length="30"/>
            </model>
            <model name="test_populate.supplier" count="5" id="active_suppliers">
                <field name="name" length="25"/>
                <field name="email" length="30"/>
                <field name="country_code" values="['US', 'CA', 'GB']"/>
                <field name="rating" start="3.0" end="5.0"/>
                <field name="is_active" eval="True"/>
                <field name="warehouse_id" ref="warehouses"/>
            </model>
            <model name="test_populate.tag" count="10" id="tags">
                <field name="name" length="12" unique="True"/>
                <field name="color" start="0" end="11"/>
            </model>
            <model name="test_populate.product" count="20" id="products">
                <field name="name" length="20"/>
                <field name="price" start="10.0" end="500.0"/>
                <field name="cost" start="1.0" end="200.0"/>
                <field name="category" values="{'electronics': 3, 'books': 1}"/>
                <field name="active" eval="True"/>
                <field name="is_sellable" eval="True"/>
                <field name="stock_quantity" start="10" end="100"/>
                <field name="supplier_id" ref="active_suppliers" null_ratio="0.1"/>
                <field name="tag_ids" ref="tags" count="3" std="1"/>
            </model>
            <model name="test_populate.customer" count="15" id="customers">
                <field name="name" length="18"/>
                <field name="email" length="25"/>
                <field name="age" start="18" end="65"/>
                <field name="birth_date" start="today -65y" end="today -18y"/>
                <field name="preferred_category"/>
                <field name="total_spent" start="0.0" end="5000.0"/>
                <field name="is_vip" values="{True: 1, False: 4}"/>
            </model>
            <model name="test_populate.order" count="30" id="orders">
                <field name="name" length="10" unique="True"/>
                <field name="customer_id" ref="customers"/>
                <field name="order_date" start="today -1y" end="today"/>
                <field name="delivery_date" start="now" end="now +3m"/>
                <field name="total_amount" start="10.0" end="2000.0"/>
                <field name="status" values="{'draft': 2, 'confirmed': 3, 'shipped': 2, 'delivered': 3}"/>
                <field name="is_urgent" values="{True: 1, False: 5}"/>
                <field name="notes" length="80" null_ratio="0.5"/>
            </model>
            <model name="test_populate.order.line" count="60">
                <field name="order_id" ref="orders"/>
                <field name="product_id" ref="products"/>
                <field name="quantity" start="1" end="20"/>
                <field name="unit_price" start="5.0" end="500.0"/>
            </model>
        </field>
    </record>

    <record id="sample_writing_blueprint" model="populate.blueprint">
        <field name="name">Writing blueprint</field>
        <field name="definition_xml" type="xml">
            <model name="test_populate.supplier" count="5" id="some_supplies">
                <field name="name" length="25"/>
                <field name="is_active" eval="True"/>
            </model>
            <model name="test_populate.supplier" type="write" ref="some_supplies">
                <field name="is_active" eval="False"/>
            </model>
        </field>
    </record>

    <record id="sample_subjobs_many_records_blueprint" model="populate.blueprint">
        <field name="name">Subjobs Blueprint</field>
        <field name="definition_xml" type="xml">
            <model name="test_populate.product" count="3000">
                <field name="name" length="10"/>
                <field name="price" start="1.0" end="100.0"/>
                <field name="active" eval="True"/>
                <field name="is_sellable" eval="True"/>
                <field name="stock_quantity" start="1" end="1000"/>
            </model>
        </field>
    </record>

    <record id="sample_distribution_blueprint" model="populate.blueprint">
        <field name="name">Distribution Showcase</field>
        <field name="definition_xml" type="xml">
            <model name="test_populate.product" count="200">
                <field name="name" length="15"/>
                <field name="price" start="5.0" end="999.99" distribution="normal(mean=80.0, std=30.0)"/>
                <field name="cost" start="1.0" end="500.0" distribution="exponential(rate=0.01)"/>
                <field name="stock_quantity" start="0" end="500" distribution="poisson(lam=50)"/>
                <field name="is_featured" values="{True: 1, False: 4}"/>
                <field name="is_sellable" eval="True"/>
                <field name="active" eval="True"/>
                <field name="category"/>
            </model>
            <model name="test_populate.customer" count="100">
                <field name="name" length="18"/>
                <field name="email" length="25"/>
                <field name="age" start="18" end="80" distribution="normal(mean=35, std=12)"/>
                <field name="birth_date" start="today -80y" end="today -18y"/>
                <field name="total_spent" start="0.0" end="10000.0" distribution="beta(alpha=1, beta=3)"/>
                <field name="preferred_category"/>
                <field name="registration_date" start="now -3y" end="now"/>
            </model>
        </field>
    </record>

    <record id="sample_virtual_fields_blueprint" model="populate.blueprint">
        <field name="name">Virtual Fields Blueprint</field>
        <field name="definition_xml" type="xml">
            <!--
                Demonstrates virtual (non-persisted) fields to correlate cost/price
                and derive stock from cost, keeping the logic in one place.
            -->
            <model name="test_populate.product" count="50">
                <field name="name" length="15"/>
                <field name="cost" start="10.0" end="300.0"/>
                <field name="v_margin" virtual="True" generator="scalar.float" start="0.1" end="0.6"/>
                <field name="price" eval="round(cost * (1 + v_margin), 2)"/>
                <field name="stock_quantity" eval="int(cost * 2)"/>
                <field name="is_sellable" eval="True"/>
                <field name="active" eval="True"/>
                <field name="category"/>
            </model>
        </field>
    </record>

    <!--
        ================================================================
        Inheritance examples
        Each child tweaks the parent without rewriting it from scratch.
        ================================================================
    -->

    <!-- Base blueprint: a modest dataset used as inheritance source -->
    <record id="sample_base_blueprint" model="populate.blueprint">
        <field name="name">Base Blueprint (parent)</field>
        <field name="definition_xml" type="xml">
            <model name="test_populate.supplier" count="5" id="base_suppliers">
                <field name="name" length="20"/>
                <field name="email" length="25"/>
                <field name="country_code"/>
                <field name="rating" start="1.0" end="5.0"/>
                <field name="is_active" eval="True"/>
            </model>
            <model name="test_populate.product" count="10">
                <field name="name" length="15"/>
                <field name="price" start="5.0" end="200.0"/>
                <field name="active" eval="True"/>
                <field name="is_sellable" eval="True"/>
                <field name="stock_quantity" start="1" end="100"/>
            </model>
        </field>
    </record>

    <!-- Child 1: bump counts and pin suppliers to US only -->
    <record id="sample_inherit_scale_blueprint" model="populate.blueprint">
        <field name="name">Inherited Blueprint – Scaled US only</field>
        <field name="inherit_id" ref="test_populate.sample_base_blueprint"/>
        <field name="definition_xml" type="xml">
            <!-- Raise supplier count and lock country to US -->
            <model name="test_populate.supplier" position="attributes">
                <attribute name="count">20</attribute>
            </model>
            <field name="country_code" position="replace">
                <field name="country_code" eval="'US'"/>
            </field>
            <!-- Raise product count -->
            <model name="test_populate.product" position="attributes">
                <attribute name="count">50</attribute>
            </model>
        </field>
    </record>

    <!-- Child 2: add new fields to existing models -->
    <record id="sample_inherit_extra_fields_blueprint" model="populate.blueprint">
        <field name="name">Inherited Blueprint - Extra fields</field>
        <field name="inherit_id" ref="test_populate.sample_base_blueprint"/>
        <field name="definition_xml" type="xml">
            <!-- Enrich suppliers with phone and notes -->
            <model name="test_populate.supplier" position="inside">
                <field name="phone" length="12"/>
                <field name="notes" length="80"/>
            </model>
            <!-- Enrich products with category and a description -->
            <model name="test_populate.product" position="inside">
                <field name="category"/>
                <field name="description" length="120"/>
            </model>
        </field>
    </record>

    <!-- Child 3: append a brand-new model block after the existing ones -->
    <record id="sample_inherit_new_model_blueprint" model="populate.blueprint">
        <field name="name">Inherited Blueprint - Added customers</field>
        <field name="inherit_id" ref="test_populate.sample_base_blueprint"/>
        <field name="definition_xml" type="xml">
            <!-- Append a customer model after the product block -->
            <model name="test_populate.product" position="after">
                <model name="test_populate.customer" count="15">
                    <field name="name" length="18"/>
                    <field name="email" length="25"/>
                    <field name="age" start="18" end="65"/>
                    <field name="preferred_category"/>
                    <field name="total_spent" start="0.0" end="3000.0"/>
                </model>
            </model>
        </field>
    </record>

    <!-- Grandchild: inherits from the "extra fields" child, then scales it up further.
         Demonstrates that chained (multi-level) inheritance works. -->
    <record id="sample_inherit_grandchild_blueprint" model="populate.blueprint">
        <field name="name">Inherited Blueprint – Grandchild (chained)</field>
        <field name="inherit_id" ref="test_populate.sample_inherit_extra_fields_blueprint"/>
        <field name="definition_xml" type="xml">
            <!-- Just scale up the product count inherited from the grandparent -->
            <model name="test_populate.product" position="attributes">
                <attribute name="count">100</attribute>
            </model>
        </field>
    </record>
</odoo>
