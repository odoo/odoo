<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_l10n_es_edi_verifactu_record_document_form" model="ir.ui.view">
            <field name="name">l10n_es_edi_verifactu.record_document.form</field>
            <field name="model">l10n_es_edi_verifactu.record_document</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group name="main_group">
                            <group name="left_column">
                                <field name="company_id" groups="base.group_multi_company"/>
                                <field name="record_type"/>
                                <field name="xml_attachment_filename" invisible="1"/>
                                <field name="xml_attachment_base64" string="XML Attachment" widget="binary" filename="xml_attachment_filename"/>
                            </group>
                            <group name="right_column">
                                <field name="document_id" string="Document" groups="base.group_no_one"/>
                                <field name="response_time"/>
                                <field name="state"/>
                            </group>
                            <group name="bottom" colspan="2">
                                <field name="record_identifier" string="Record Identifier" widget="jsonb" groups="base.group_no_one"/>
                                <field name="errors"/>
                            </group>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

    </data>
</odoo>
