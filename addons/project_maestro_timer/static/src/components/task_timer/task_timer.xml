<?xml version="1.0" encoding="utf-8"?>
<templates>

  <!-- ── Stop dialog ─────────────────────────────────────────── -->
  <t t-name="project_maestro_timer.TimerStopDialog">
    <Dialog title="'Registrar tempo'" size="'md'">
      <div class="o_timer_stop_dialog">
        <div class="mb-3 text-center">
          <span class="o_timer_elapsed_badge badge bg-danger fs-4 font-monospace px-3 py-2">
            ⏱ <t t-esc="props.elapsed"/>
          </span>
        </div>
        <div class="mb-3">
          <label class="form-label fw-bold">Descrição da atividade</label>
          <input
            type="text"
            class="form-control"
            placeholder="Ex: Reunião de alinhamento, Desenvolvimento da tela X…"
            t-model="state.description"
            t-on-keydown.enter="onConfirm"
          />
        </div>
      </div>
      <t t-set-slot="footer">
        <button class="btn btn-primary" t-on-click="onConfirm">
          ✅ Registrar tempo
        </button>
        <button class="btn btn-outline-secondary ms-2" t-on-click="onDiscard">
          🗑 Descartar
        </button>
      </t>
    </Dialog>
  </t>

  <!-- ── Timer widget ────────────────────────────────────────── -->
  <t t-name="project_maestro_timer.TaskTimerWidget">
    <div class="o_task_timer d-flex align-items-center gap-2 py-1">

      <!-- Timer running: show elapsed + stop button -->
      <t t-if="isRunning">
        <span class="o_timer_display badge bg-danger px-3 py-2 fs-6 font-monospace d-flex align-items-center gap-1">
          <i class="fa fa-circle fa-xs o_timer_blink"/>
          <t t-esc="elapsedFormatted"/>
        </span>
        <button class="btn btn-sm btn-danger d-flex align-items-center gap-1" t-on-click="onStop">
          <i class="fa fa-stop"/>
          Parar e Registrar
        </button>
      </t>

      <!-- Timer idle: show start button -->
      <t t-else="">
        <button class="btn btn-sm btn-success d-flex align-items-center gap-1" t-on-click="onStart">
          <i class="fa fa-play"/>
          Iniciar Cronômetro
        </button>
      </t>

    </div>
  </t>

</templates>
