<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="payment_provider_form" model="ir.ui.view">
        <field name="name">Bictorys Provider Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <group name="provider_credentials" position="inside">
                <group invisible="code != 'bictorys'">
                    <field
                        name="bictorys_secret_key"
                        string="Secret Key"
                        password="True"
                        required="code == 'bictorys' and state != 'disabled'"
                    />
                    <field
                        name="bictorys_webhook_secret"
                        string="Webhook Secret"
                        password="True"
                    />
                    <widget
                        name="documentation_link"
                        path="/applications/finance/payment_providers/bictorys.html"
                        label="How to configure your Bictorys account?"
                        colspan="2"
                    />
                </group>
            </group>
        </field>
    </record>

</odoo>
