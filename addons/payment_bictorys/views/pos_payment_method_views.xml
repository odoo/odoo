<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="pos_payment_method_form_bictorys" model="ir.ui.view">
        <field name="name">pos.payment.method.form.bictorys</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='use_payment_terminal']" position="after">
                <field
                    name="bictorys_terminal_identifier"
                    invisible="use_payment_terminal != 'bictorys'"
                    required="use_payment_terminal == 'bictorys'"
                />
            </xpath>
        </field>
    </record>

    <!-- POS Order list: show Bictorys order ID -->
    <record id="pos_order_list_bictorys" model="ir.ui.view">
        <field name="name">pos.order.list.bictorys</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_tree"/>
        <field name="arch" type="xml">
            <field name="state" position="after">
                <field name="bictorys_order_id" optional="hide"/>
            </field>
        </field>
    </record>

</odoo>
