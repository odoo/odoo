<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <menuitem id="hr_schedule_menu" name="HR Scheduling" sequence="100"/>

    <record id="hr_schedule_cliente_view_tree" model="ir.ui.view">
        <field name="name">hr.schedule.cliente.tree</field>
        <field name="model">hr.schedule.cliente</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="ciudad"/>
                <field name="estado_id"/>
            </list>
        </field>
    </record>

    <record id="hr_schedule_cliente_view_form" model="ir.ui.view">
        <field name="name">hr.schedule.cliente.form</field>
        <field name="model">hr.schedule.cliente</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="email"/>
                            <field name="phone"/>
                        </group>
                        <group>
                            <field name="direccion"/>
                            <field name="ciudad"/>
                            <field name="estado_id"/>
                            <field name="es_horario_variable"/>
                        </group>
                    </group>
                    <group>
                        <field name="horario_inicio" invisible="not es_horario_variable"/>
                        <field name="horario_fin" invisible="not es_horario_variable"/>
                    </group>
                    <field name="notas"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hr_schedule_cliente_action" model="ir.actions.act_window">
        <field name="name">Clients</field>
        <field name="res_model">hr.schedule.cliente</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="hr_schedule_cliente_menu" name="Clients" parent="hr_schedule_menu" action="hr_schedule_cliente_action" sequence="10"/>
</odoo>