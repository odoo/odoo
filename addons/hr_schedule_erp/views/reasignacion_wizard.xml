<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_schedule_reasignacion_wizard_view_form" model="ir.ui.view">
        <field name="name">hr.schedule.reasignacion.wizard.form</field>
        <field name="model">hr.schedule.reasignacion.wizard</field>
        <field name="arch" type="xml">
            <form string="Reasignación Rápida">
                <group>
                    <field name="servicio_id"/>
                    <field name="auxiliar_origen_id"/>
                    <field name="auxiliar_destino_id"/>
                    <field name="motivo"/>
                    <field name="detalle_motivo"/>
                </group>
                <footer>
                    <button name="action_confirmar" string="Confirmar" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="hr_schedule_reasignacion_wizard_action" model="ir.actions.act_window">
        <field name="name">Reasignación Rápida</field>
        <field name="res_model">hr.schedule.reasignacion.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>