<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_schedule_time_event_view_tree" model="ir.ui.view">
        <field name="name">hr.schedule.time.event.tree</field>
        <field name="model">hr.schedule.time.event</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="service_session_id"/>
                <field name="auxiliar_id"/>
                <field name="tipo_evento"/>
                <field name="timestamp_dispositivo"/>
                <field name="timestamp_servidor"/>
                <field name="sincronizado"/>
            </list>
        </field>
    </record>

    <record id="hr_schedule_time_event_view_form" model="ir.ui.view">
        <field name="name">hr.schedule.time.event.form</field>
        <field name="model">hr.schedule.time.event</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="tipo_evento"/>
                            <field name="service_session_id"/>
                            <field name="auxiliar_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="timestamp_dispositivo"/>
                            <field name="timestamp_servidor" readonly="1"/>
                            <field name="sincronizado"/>
                        </group>
                    </group>
                    <group>
                        <field name="ubicacion_gps"/>
                        <field name="evidencia_foto" widget="image"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hr_schedule_time_event_action" model="ir.actions.act_window">
        <field name="name">Time Events</field>
        <field name="res_model">hr.schedule.time.event</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="hr_schedule_time_tracking_menu" name="Time Tracking" parent="hr_schedule_menu" sequence="50"/>
    <menuitem id="hr_schedule_time_event_menu" name="Check-In/Out Events" parent="hr_schedule_time_tracking_menu" action="hr_schedule_time_event_action" sequence="10"/>
</odoo>