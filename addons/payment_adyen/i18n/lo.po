#. module: payment_adyen
#: model_terms:ir.ui.view,arch_db:payment_adyen.payment_provider_form
msgid ""
"<strong>Warning:</strong> To capture the amount manually, you also need to "
"set\n"
"                    the Capture Delay to manual on your Adyen account "
"settings."
msgstr ""
"<strong>ຄຳເຕືອນ:</strong> ເພື່ອຕັດເງິນດ້ວຍຕົນເອງ, ທ່ານຈຳເປັນຕ້ອງຕັ້ງຄ່າ\n"
"                    Capture Delay ເປັນ manual ໃນການຕັ້ງຄ່າບັນຊີ Adyen ຂອງທ່ານ."

#. module: payment_adyen
#. odoo-python
#: code:addons/payment_adyen/models/payment_transaction.py:0
msgid "A request was sent to void the transaction with reference %s (%s)."
msgstr "ຄຳຮ້ອງຂໍຖືກສົ່ງໄປເພື່ອຍົກເລີກທຸລະກຳດ້ວຍການອ້າງອີງ %s (%s)."

#. module: payment_adyen
#: model:ir.model.fields,field_description:payment_adyen.field_payment_provider__adyen_api_key
msgid "API Key"
msgstr "ລະຫັດ API"

#. module: payment_adyen
#: model:ir.model.fields,field_description:payment_adyen.field_payment_provider__adyen_api_url_prefix
msgid "API URL Prefix"
msgstr "ຄຳນຳໜ້າ API URL"

#. module: payment_adyen
#: model:ir.model.fields.selection,name:payment_adyen.selection__payment_provider__code__adyen
msgid "Adyen"
msgstr "Adyen"

#. module: payment_adyen
#. odoo-python
#: code:addons/payment_adyen/models/payment_transaction.py:0
msgid ""
"An error occurred during the processing of your payment. Please try again."
msgstr ""
"ເກີດຂໍ້ຜິດພາດໃນລະຫວ່າງການປະມວນຜົນການຊຳລະເງິນຂອງທ່ານ. ກະລຸນາລອງໃໝ່ອີກຄັ້ງ."

#. module: payment_adyen
#. odoo-javascript
#: code:addons/payment_adyen/static/src/js/payment_form.js:0
msgid "Cannot display the payment form"
msgstr "ບໍ່ສາມາດສະແດງແບບຟອມການຊຳລະເງິນໄດ້"

#. module: payment_adyen
#: model:ir.model.fields,field_description:payment_adyen.field_payment_provider__adyen_client_key
msgid "Client Key"
msgstr "ລະຫັດລູກຄ້າ (Client Key)"

#. module: payment_adyen
#: model:ir.model.fields,field_description:payment_adyen.field_payment_provider__code
msgid "Code"
msgstr "ລະຫັດ"

#. module: payment_adyen
#. odoo-python
#: code:addons/payment_adyen/models/payment_provider.py:0
msgid "Could not establish the connection to the API."
msgstr "ບໍ່ສາມາດເຊື່ອມຕໍ່ກັບ API ໄດ້."

#. module: payment_adyen
#: model:ir.model.fields,field_description:payment_adyen.field_payment_provider__adyen_hmac_key
msgid "HMAC Key"
msgstr "ລະຫັດ HMAC"

#. module: payment_adyen
#: model:ir.model.fields,field_description:payment_adyen.field_payment_capture_wizard__has_adyen_tx
msgid "Has Adyen Tx"
msgstr "ມີ Adyen Tx"

#. module: payment_adyen
#. odoo-javascript
#: code:addons/payment_adyen/static/src/js/payment_form.js:0
msgid "Incorrect payment details"
msgstr "ລາຍລະອຽດການຊຳລະເງິນບໍ່ຖືກຕ້ອງ"

#. module: payment_adyen
#: model_terms:ir.ui.view,arch_db:payment_adyen.payment_provider_form
msgid "Learn More"
msgstr "ຮຽນຮູ້ເພີ່ມເຕີມ"

#. module: payment_adyen
#: model:ir.model.fields,field_description:payment_adyen.field_payment_provider__adyen_merchant_account
msgid "Merchant Account"
msgstr "ບັນຊີຮ້ານຄ້າ"

#. module: payment_adyen
#. odoo-python
#: code:addons/payment_adyen/models/payment_transaction.py:0
msgid "No transaction found matching reference %s."
msgstr "ບໍ່ພົບທຸລະກຳທີ່ກົງກັບການອ້າງອີງ %s."

#. module: payment_adyen
#: model:ir.model,name:payment_adyen.model_payment_capture_wizard
msgid "Payment Capture Wizard"
msgstr "ຕົວຊ່ວຍການຕັດເງິນ"

#. module: payment_adyen
#: model:ir.model,name:payment_adyen.model_payment_provider
msgid "Payment Provider"
msgstr "ຜູ້ໃຫ້ບໍລິການຊຳລະເງິນ"

#. module: payment_adyen
#: model:ir.model,name:payment_adyen.model_payment_token
msgid "Payment Token"
msgstr "ໂທເຄັນການຊຳລະເງິນ"

#. module: payment_adyen
#: model:ir.model,name:payment_adyen.model_payment_transaction
msgid "Payment Transaction"
msgstr "ທຸລະກຳການຊຳລະເງິນ"

#. module: payment_adyen
#. odoo-javascript
#: code:addons/payment_adyen/static/src/js/payment_form.js:0
msgid "Payment processing failed"
msgstr "ການປະມວນຜົນການຊຳລະເງິນລົ້ມເຫຼວ"

#. module: payment_adyen
#. odoo-python
#: code:addons/payment_adyen/models/payment_transaction.py:0
msgid "Received data for child transaction with missing transaction values"
msgstr "ໄດ້ຮັບຂໍ້ມູນສຳລັບທຸລະກຳຍ່ອຍທີ່ຂາດຄ່າທຸລະກຳ"

#. module: payment_adyen
#. odoo-python
#: code:addons/payment_adyen/models/payment_transaction.py:0
msgid "Received data with invalid payment state: %s"
msgstr "ໄດ້ຮັບຂໍ້ມູນທີ່ມີສະຖານະການຊຳລະເງິນບໍ່ຖືກຕ້ອງ: %s"

#. module: payment_adyen
#. odoo-python
#: code:addons/payment_adyen/models/payment_transaction.py:0
msgid "Received data with missing merchant reference"
msgstr "ໄດ້ຮັບຂໍ້ມູນທີ່ຂາດການອ້າງອີງຂອງຮ້ານຄ້າ"

#. module: payment_adyen
#. odoo-python
#: code:addons/payment_adyen/models/payment_transaction.py:0
msgid "Received data with missing payment state."
msgstr "ໄດ້ຮັບຂໍ້ມູນທີ່ຂາດສະຖານະການຊຳລະເງິນ."

#. module: payment_adyen
#. odoo-python
#: code:addons/payment_adyen/controllers/main.py:0
msgid "Received tampered payment request data."
msgstr "ໄດ້ຮັບຂໍ້ມູນຄຳຮ້ອງຂໍການຊຳລະເງິນທີ່ຖືກດັດແປງ."

#. module: payment_adyen
#: model:ir.model.fields,field_description:payment_adyen.field_payment_token__adyen_shopper_reference
msgid "Shopper Reference"
msgstr "ການອ້າງອີງຜູ້ຊື້"

#. module: payment_adyen
#: model:ir.model.fields,help:payment_adyen.field_payment_provider__adyen_api_key
msgid "The API key of the webservice user"
msgstr "ລະຫັດ API ຂອງຜູ້ໃຊ້ບໍລິການເວັບ (Webservice user)"

#. module: payment_adyen
#: model:ir.model.fields,help:payment_adyen.field_payment_provider__adyen_hmac_key
msgid "The HMAC key of the webhook"
msgstr "ລະຫັດ HMAC ຂອງ webhook"

#. module: payment_adyen
#. odoo-python
#: code:addons/payment_adyen/models/payment_transaction.py:0
msgid ""
"The amount processed by Adyen for the transaction %s is different than the "
"one requested. Another transaction is created with the correct amount."
msgstr ""
"ຈຳນວນເງິນທີ່ປະມວນຜົນໂດຍ Adyen ສຳລັບທຸລະກຳ %s ແມ່ນແຕກຕ່າງຈາກຈຳນວນທີ່ຮ້ອງຂໍ. ທຸລະກຳອື່ນຖືກສ້າງຂຶ້ນ"
"ດ້ວຍຈຳນວນເງິນທີ່ຖືກຕ້ອງ."

#. module: payment_adyen
#: model:ir.model.fields,help:payment_adyen.field_payment_provider__adyen_api_url_prefix
msgid "The base URL for the API endpoints"
msgstr "URL ພື້ນຖານສຳລັບ API endpoints"

#. module: payment_adyen
#. odoo-python
#: code:addons/payment_adyen/models/payment_transaction.py:0
msgid "The capture of the transaction with reference %s failed."
msgstr "ການຕັດເງິນຂອງທຸລະກຳດ້ວຍການອ້າງອີງ %s ລົ້ມເຫຼວ."

#. module: payment_adyen
#: model_terms:ir.ui.view,arch_db:payment_adyen.payment_capture_wizard_view_form
msgid ""
"The capture or void of the transaction might take a few minutes to be\n"
"                    processed by Adyen and reflected in Odoo."
msgstr ""
"ການຕັດເງິນ ຫຼື ການຍົກເລີກທຸລະກຳອາດຈະໃຊ້ເວລາສອງສາມນາທີເພື່ອ\n"
"                    ປະມວນຜົນໂດຍ Adyen ແລະ ສະແດງຜົນໃນ Odoo."

#. module: payment_adyen
#. odoo-python
#: code:addons/payment_adyen/models/payment_transaction.py:0
msgid ""
"The capture request of %(amount)s for the transaction with reference %(ref)s "
"has been requested (%(provider_name)s)."
msgstr ""
"ຄຳຮ້ອງຂໍຕັດເງິນຈຳນວນ %(amount)ສຳລັບທຸລະກຳດ້ວຍການອ້າງອີງ %(ref) ໄດ້ຖືກສົ່ງແລ້ວ (%"
"(provider_name)s)."

#. module: payment_adyen
#: model:ir.model.fields,help:payment_adyen.field_payment_provider__adyen_client_key
msgid "The client key of the webservice user"
msgstr "ລະຫັດລູກຄ້າ (Client key) ຂອງຜູ້ໃຊ້ບໍລິການເວັບ"

#. module: payment_adyen
#: model:ir.model.fields,help:payment_adyen.field_payment_provider__adyen_merchant_account
msgid "The code of the merchant account to use with this provider"
msgstr "ລະຫັດຂອງບັນຊີຮ້ານຄ້າທີ່ຈະໃຊ້ກັບຜູ້ໃຫ້ບໍລິການນີ້"

#. module: payment_adyen
#. odoo-python
#: code:addons/payment_adyen/models/payment_provider.py:0
msgid "The communication with the API failed. Details: %s"
msgstr "ການຕິດຕໍ່ສື່ສານກັບ API ລົ້ມເຫຼວ. ລາຍລະອຽດ: %s"

#. module: payment_adyen
#: model:ir.model.fields,help:payment_adyen.field_payment_provider__code
msgid "The technical code of this payment provider."
msgstr "ລະຫັດທາງເຕັກນິກຂອງຜູ້ໃຫ້ບໍລິການຊຳລະເງິນນີ້."

#. module: payment_adyen
#. odoo-python
#: code:addons/payment_adyen/models/payment_transaction.py:0
msgid "The transaction is not linked to a token."
msgstr "ທຸລະກຳນີ້ບໍ່ໄດ້ເຊື່ອມໂຍງກັບໂທເຄັນ."

#. module: payment_adyen
#: model:ir.model.fields,help:payment_adyen.field_payment_token__adyen_shopper_reference
msgid "The unique reference of the partner owning this token"
msgstr "ການອ້າງອີງສະເພາະຂອງຄູ່ຄ້າທີ່ເປັນເຈົ້າຂອງໂທເຄັນນີ້"

#. module: payment_adyen
#. odoo-python
#: code:addons/payment_adyen/models/payment_transaction.py:0
msgid "The void of the transaction with reference %s failed."
msgstr "ການຍົກເລີກທຸລະກຳດ້ວຍການອ້າງອີງ %s ລົ້ມເຫຼວ."

#. module: payment_adyen
#. odoo-python
#: code:addons/payment_adyen/models/payment_transaction.py:0
msgid "Your payment was refused. Please try again."
msgstr "ການຊຳລະເງິນຂອງທ່ານຖືກປະຕິເສດ. ກະລຸນາລອງໃໝ່ອີກຄັ້ງ."
