<?xml version="1.0"?>
<odoo>
    <record id="card_campaign_element_view_form" model="ir.ui.view">
        <field name="name">card.campaign.element.view.form</field>
        <field name="model">card.campaign.element</field>
        <field name="arch" type="xml">
            <form string="Share Campaign Render Element">
                <sheet>
                    <div class="oe_title">
                        <h2><field name="role" readonly="1" nolabel="1" colspan="4"/></h2>
                    </div>
                    <group>
                        <group>
                            <field name="render_type" invisible="1"/>
                            <field name="res_model" invisible="1"/>
                            <field name="value_type" widget="radio" options="{'horizontal': True}"
                            readonly="not res_model or role == 'background'"/>
                        </group>
                        <group>
                            <field name="image" invisible="render_type != 'image' or value_type != 'static'" widget="image"/>
                            <field name="text" invisible="render_type != 'text' or value_type != 'static'" widget="text_emojis"/>
                            <field name="field_path" invisible="value_type != 'field'" widget="DynamicModelFieldSelectorChar" options="{'model': 'res_model'}"/>
                            <field name="text_color" widget="color" invisible="render_type != 'text'"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
