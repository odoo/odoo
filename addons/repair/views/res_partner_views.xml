<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form" model="ir.ui.view">
        <field name="name">res.partner.view.form.inherit.repair</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="%(repair.action_repair_order_tree)d" type="action" class="oe_stat_button"
                    icon="fa-wrench" groups="stock.group_stock_user" context="{'partner_id': id}">
                    <field name="repair_order_count" string="Repairs" widget="statinfo"/>
                </button>
            </div>
        </field>
    </record>
</odoo>
