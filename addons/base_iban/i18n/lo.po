msgid "Account isn't IBAN compliant."
msgstr ""

#. module: base_iban
#. openerp-web
#: code:addons/base_iban/static/src/components/iban_widget/iban_widget.xml:0
#, python-format
msgid "Account isn't a valid IBAN"
msgstr "ບັນຊີບໍ່ແມ່ນ IBAN ທີ່ຖືກຕ້ອງ"

#. module: base_iban
#: model:ir.model,name:base_iban.model_res_partner_bank
msgid "Bank Accounts"
msgstr "ບັນຊີທະນາຄານ"

#. module: base_iban
#: code:addons/base_iban/models/res_partner_bank.py:0
#, python-format
msgid "Cannot compute the BBAN because the account number is not an IBAN."
msgstr "ບໍ່ສາມາດຄິດໄລ່ BBAN ໄດ້ ເພາະວ່າເລກບັນຊີບໍ່ແມ່ນ IBAN."

#. module: base_iban
#: code:addons/base_iban/models/res_partner_bank.py:0
#, python-format
msgid "IBAN"
msgstr "IBAN"

#. module: base_iban
#: code:addons/base_iban/models/res_partner_bank.py:0
#, python-format
msgid ""
"The IBAN does not seem to be correct. You should have entered something like this %s\n"
"Where B = National bank code, S = Branch code, C = Account No, k = Check digit"
msgstr ""
"IBAN ເບິ່ງຄືວ່າບໍ່ຖືກຕ້ອງ. ທ່ານຄວນປ້ອນບາງຢ່າງຄືກັບ %s\n"
"ໂດຍທີ່ B = ລະຫັດທະນາຄານແຫ່ງຊາດ, S = ລະຫັດສາຂາ, C = ເລກບັນຊີ, k = ຕົວເລກກວດສອບ"

#. module: base_iban
#: code:addons/base_iban/models/res_partner_bank.py:0
#, python-format
msgid "The IBAN is invalid, it should begin with the country code"
msgstr "IBAN ບໍ່ຖືກຕ້ອງ, ມັນຄວນຈະເລີ່ມຕົ້ນດ້ວຍລະຫັດປະເທດ"

#. module: base_iban
#: code:addons/base_iban/models/res_partner_bank.py:0
#, python-format
msgid "There is no IBAN code."
msgstr "ບໍ່ມີລະຫັດ IBAN."

#. module: base_iban
#: code:addons/base_iban/models/res_partner_bank.py:0
#, python-format
msgid "This IBAN does not pass the validation check, please verify it."
msgstr "IBAN ນີ້ບໍ່ຜ່ານການກວດສອບຄວາມຖືກຕ້ອງ, ກະລຸນາກວດສອບຄືນໃໝ່."
