<?xml version="1.0" encoding="utf-8"?>
<templates>
    <div t-name="spreadsheet_dashboard.DashboardAction" class="o_action o_spreadsheet_dashboard_action o_field_highlight">
        <ControlPanel display="this.controlPanelDisplay">
            <t t-set-slot="control-panel-actions" t-if="!this.loader.getActiveDashboard()?.isSample">
                <t t-set="status" t-value="this.loader.getActiveDashboard() and this.loader.getActiveDashboard().status"/>
                <div class="d-flex flex-wrap w-100">
                    <DashboardSearchBar t-if="status === this.Status.Loaded and this.loader.getActiveDashboard().model.getters.getGlobalFilters().length"
                                        t-key="this.activeDashboardId"
                                        model="this.loader.getActiveDashboard().model"
                                        toggler="this.searchBarToggler"
                    />
                </div>
            </t>
            <t t-set-slot="control-panel-navigation-additional" t-if="!this.loader.getActiveDashboard()?.isSample">
                <!-- Dashboard selection -->
                <t t-if="this.env.isSmall">
                    <DashboardMobileSearchPanel
                        onDashboardSelected="(dashboardId) => this.openDashboard(dashboardId)"
                        activeDashboard="dashboard"
                        groups="this.getDashboardGroups()"/>
                </t>
                <SpreadsheetShareButton t-key="this.activeDashboardId" model="this.loader.getActiveDashboard()?.model" onSpreadsheetShared.bind="this.shareSpreadsheet" togglerClass="'btn-light'"/>
                <a
                    t-if="this.loader.getActiveDashboard()"
                    title="Toggle favorite"
                    t-on-click="this.toggleFavorite"
                    t-attf-class="o_dashboard_star align-middle lh-base fa fa-lg fa-star{{!this.loader.getActiveDashboard().data.is_favorite ? '-o' : ''}}"
                />
                <div class="ms-1 o_search_toggler" t-if="this.env.isSmall">
                    <t t-component="this.searchBarToggler.component" t-props="this.searchBarToggler.props"/>
                </div>
            </t>
        </ControlPanel>
        <t t-set="dashboard" t-value="this.loader.getActiveDashboard()"/>
        <div class="o_content o_component_with_search_panel" t-att-class="{ o_mobile_dashboard: this.env.isSmall }">
            <t t-if="!this.env.isSmall">
                <t t-if="this.state.sidebarExpanded" t-call="spreadsheet_dashboard.DashboardAction.Expanded"/>
                <t t-else="" t-call="spreadsheet_dashboard.DashboardAction.Collapsed"/>
            </t>
            <!-- Main content -->
            <h3 t-if="!dashboard" class="dashboard-loading-status">No available dashboard</h3>
            <t t-else="">
                <t t-set="status" t-value="dashboard.status"/>
                <h3 t-if="status === this.Status.Loading" class="dashboard-loading-status">Loading...</h3>
                <div t-elif="status === this.Status.Error" class="dashboard-loading-status error">
                    An error occurred while loading the dashboard
                </div>
                <t t-else="">
                    <MobileFigureContainer t-if="this.env.isSmall" spreadsheetModel="dashboard.model" t-key="dashboard.data.id"/>
                    <div t-else="" class="o_renderer" t-att-class="{'o-sample-dashboard': dashboard.isSample}">
                        <SpreadsheetComponent
                            model="dashboard.model"
                            t-key="dashboard.data.id"/>
                    </div>
                </t>
            </t>
        </div>
    </div>

    <t t-name="spreadsheet_dashboard.DashboardAction.Collapsed">
        <div class="bg-view h-100 o_search_panel_sidebar cursor-pointer d-print-none" t-on-click="this.toggleSidebar">
            <div class="d-flex">
                <button title="Open sidebar" aria-label="Open sidebar" class="btn btn-light btn-sm m-1 mb-2 p-2">
                    <i class="oi oi-lg oi-panel-right fa-flip-horizontal"/>
                </button>
                <div class="mx-auto" t-if="this.loader.getActiveDashboard()">
                    <span class="fw-bolder" t-out="this.activeDashboardGroupName"/>
                    /
                    <t t-out="this.loader.getActiveDashboard().data.name"/>
                </div>
            </div>
        </div>
    </t>

    <t t-name="spreadsheet_dashboard.DashboardAction.Expanded">
        <div class="o_spreadsheet_dashboard_search_panel o_search_panel flex-grow-0 border-end flex-shrink-0 pe-2 pb-5 ps-4 h-100 bg-view overflow-auto position-relative pt-3 d-print-none">
            <button title="Close sidebar" aria-label="Close sidebar" t-if="!this.env.isSmall and this.loader.getActiveDashboard()" class="btn btn-light btn-sm end-0 m-1 mb-2 position-absolute px-2 py-1 top-0 z-1" t-on-click="this.toggleSidebar">
                <i class="oi oi-lg oi-panel-right fa-flip-horizontal"/>
            </button>
            <div class="mt-2"/>
            <section t-foreach="this.getDashboardGroups()" t-as="group" t-key="group.id" class="o_search_panel_section o_search_panel_category mt-3">
                <header class="o_search_panel_section_header pb-2 text-uppercase o_cursor_default user-select-none">
                    <b t-out="group.name"/>
                </header>
                <ul class="list-group d-block o_search_panel_field">
                    <li t-foreach="group.dashboards" t-as="dashboard" t-key="dashboard.data.id"
                        t-on-click="() => this.openDashboard(dashboard.data.id)"
                        t-att-data-name="dashboard.data.name"
                        t-att-title="dashboard.data.name"
                        class="o_search_panel_category_value list-group-item cursor-pointer border-0 d-flex justify-content-between align-items-center px-2 py-1 my-1"
                        t-att-class="{'active': dashboard.data.id === this.loader.getActiveDashboard().data.id}">
                        <div class="o_dashboard_name">
                            <t t-out="dashboard.data.name" />
                        </div>
                        <t t-set="comp" t-value="this.dashboardButton"/>
                        <t t-if="comp">
                            <t t-component="comp" t-props="{ dashboardId: dashboard.data.id, onClick: this.editDashboard.bind(this), data: dashboard.data }"/>
                        </t>
                    </li>
                </ul>
            </section>
        </div>
    </t>
</templates>
