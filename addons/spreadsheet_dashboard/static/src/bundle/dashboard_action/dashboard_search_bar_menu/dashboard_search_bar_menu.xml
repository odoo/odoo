<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="spreadsheet_dashboard.DashboardSearchBarMenu">
        <div class="d-flex">
            <DashboardFilterList
                filtersAndValues="this.state.filtersAndValues"
                searchableParentRelations="this.searchableParentRelations"
                onFilterChange.bind="this.onFilterChange"
                model="this.props.model"/>
        </div>
        <div class="o-filter-values-footer d-flex mt-3 pt-3 border-top gap-1">
            <button class="btn btn-primary" t-on-click="this.onConfirm">Filter</button>
            <button class="btn btn-secondary" t-on-click="this.onDiscard">Discard</button>
        </div>
    </t>

</templates>
