<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="hr_presence.PresenceCogMenu">
        <Dropdown>
            <button t-attf-class="{{ is_actionmenu ? 'btn btn-secondary' : '' }}">
                <i class="fa fa-clock-o me-1"/>
                Presence Control
            </button>
            <t t-set-slot="content">
                <t t-set="currentGroup" t-value="null"/>
                <t t-foreach="this.PresenceActionItems" t-as="item" t-key="item.key">
                    <t t-if="currentGroup !== null and currentGroup !== item.groupNumber">
                        <div role="separator" class="dropdown-divider"/>
                    </t>
                    <DropdownItem class="'o_menu_item'" onSelected="() => this.onItemSelected(item)">
                        <t t-out="item.description"/>
                    </DropdownItem>
                    <t t-set="currentGroup" t-value="item.groupNumber"/>
                </t>
            </t>
        </Dropdown>
    </t>

</templates>
