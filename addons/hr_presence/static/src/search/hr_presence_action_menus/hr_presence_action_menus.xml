<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="hr_presence.actionmenu" t-inherit="hr.actionmenu" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o_cp_action_menus')]" position="before">
            <t t-if="this.PresenceActionItems.length" class="d-inline-block">
                <t t-call="hr_presence.PresenceCogMenu" is_actionmenu="true"/>
            </t>
        </xpath>
    </t>
</templates>
