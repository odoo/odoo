<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="hr_presence.actionmenu" t-inherit="web.ActionMenus" t-inherit-mode="primary">
        <xpath expr="//div[@t-if='this.props.items.print?.length']" position="before">
            <t t-if="this.PresenceActionItems.length" class="d-inline-block">
                <t t-call="hr_presence.menu" is_actionmenu="'True'"/>
            </t>
        </xpath>
    </t>
</templates>
