<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="account_view_invoice_tree_inherit_l10n_sa" model="ir.ui.view">
            <field name="name">account.view.invoice.tree.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_invoice_tree"/>
            <field name="arch" type="xml">
                <field name="invoice_date_due" position="after">
                    <field name="country_code" invisible="1"/>
                    <field name="l10n_sa_confirmation_datetime" string="Issue Date" attrs="{'invisible': [('country_code', '!=', 'SA'), ('move_type', 'not in', ['out_invoice', 'out_refund', 'in_refund'])]}" optional="hide"/>
                </field>
            </field>
        </record>
    </data>
</odoo>
