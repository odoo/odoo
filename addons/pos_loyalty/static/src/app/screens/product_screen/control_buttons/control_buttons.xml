<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_loyalty.ControlButtons" t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
        <xpath
            expr="//t[@t-if='this.props.showRemainingButtons']/div/t[@name='o_pricelist_button']"
            position="before">
            <t t-if="this.pos.models['loyalty.program'].some((p) => p.program_type == 'ewallet')">
                <t t-set="_orderTotal" t-value="this.pos.getOrder().priceIncl" />
                <t t-set="_eWalletPrograms" t-value="this._getEWalletPrograms()" />
                <t t-set="_eWalletRewards" t-value="this._getEWalletRewards(this.pos.getOrder())" />
                
                <t t-set="btnText">
                    <t t-if="_orderTotal lt 0 and _eWalletPrograms.length">eWallet Refund</t>
                    <t t-elif="_eWalletRewards.length">eWallet Pay</t>
                    <t t-else="">eWallet</t>
                </t>
                <t t-call="point_of_sale.controlButton"
                    iconClasses="'fa fa-credit-card '"
                    btnText="btnText"
                    btnClasses="'btn-secondary ' + ((_orderTotal lt 0 and _eWalletPrograms.length gte 1) or _eWalletRewards.length gte 1 ? ' highlight text-action': ' disabled')"
                    onClick="this.onClickWallet"/>
            </t>
            <t t-if="this.pos.models['loyalty.program'].some((p) => ['coupons', 'promotion', 'gift_card', 'promo_code', 'next_order_coupons'].includes(p.program_type))" t-call="point_of_sale.controlButton"
                iconClasses="'fa fa-percent'"
                btnText.translate="Enter Code"
                btnClasses="'btn-secondary '"
                onClick="() => this.clickPromoCode()">
            </t>
            <t t-if="this.pos.models['loyalty.program'].length and this.pos.cashier._role !== 'restrictive'" t-call="point_of_sale.controlButton"
                iconClasses="'fa fa-star'"
                btnText.translate="Reward"
                btnClasses="'btn-secondary ' + (this.state.nbrRewards ? ' highlight' : 'disabled')"
                disabled="!this.state.nbrRewards"
                onClick="() => this.clickRewards()">
            </t>
        </xpath>
        <xpath expr="//t[@t-if='this.props.showRemainingButtons']/div/t[@name='o_pricelist_button']" position="before">
             <t t-if="this.pos.models['loyalty.program'].some((p) => ['coupons', 'promotion'].includes(p.program_type)) and this.pos.cashier._role !== 'restrictive'" t-call="point_of_sale.controlButton"
                 iconClasses="'fa fa-star'"
                 btnText.translate="Reset Programs"
                 btnClasses="'btn-secondary '"
                 disabled="!this.pos.getOrder().isProgramsResettable()"
                 onClick="() => this.pos.resetPrograms()">
            </t>
        </xpath>
        <xpath expr="//button[hasclass('more-btn')]" position="attributes">
            <attribute name="t-attf-class">{{ this.state.nbrRewards ? 'active text-action' : '' }}</attribute>
        </xpath>
    </t>
</templates>
