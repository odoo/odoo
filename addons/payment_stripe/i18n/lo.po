msgstr "ໂທເຄັນການຊຳລະເງິນ"

#. module: payment_stripe
#: model:ir.model,name:payment_stripe.model_payment_transaction
msgid "Payment Transaction"
msgstr "ທຸລະກຳການຊຳລະເງິນ"

#. module: payment_stripe
#. odoo-javascript
#: code:addons/payment_stripe/static/src/interactions/payment_form.js:0
msgid "Payment processing failed"
msgstr "ການປະມວນຜົນການຊຳລະເງິນຫຼົ້ມເຫຼວ"

#. module: payment_stripe
#. odoo-python
#: code:addons/payment_stripe/models/payment_provider.py:0
msgid "Please use live credentials to enable Apple Pay."
msgstr ""
"ກະລຸນາໃຊ້ຂໍ້ມູນການເຂົ້າລະບົບຕົວຈິງ (live credentials) ເພື່ອເປີດໃຊ້ Apple Pay."

#. module: payment_stripe
#: model:ir.model.fields,field_description:payment_stripe.field_payment_provider__stripe_publishable_key
msgid "Publishable Key"
msgstr "Publishable Key"

#. module: payment_stripe
#. odoo-python
#: code:addons/payment_stripe/models/payment_transaction.py:0
msgid "Received data with invalid intent status: %s."
msgstr "ໄດ້ຮັບຂໍ້ມູນທີ່ມີສະຖານະ intent ບໍ່ຖືກຕ້ອງ: %s."

#. module: payment_stripe
#. odoo-python
#: code:addons/payment_stripe/models/payment_transaction.py:0
msgid "Received data with missing intent status."
msgstr "ໄດ້ຮັບຂໍ້ມູນທີ່ບໍ່ມີສະຖານະ intent."

#. module: payment_stripe
#: model:ir.model.fields,field_description:payment_stripe.field_payment_provider__stripe_secret_key
msgid "Secret Key"
msgstr "Secret Key"

#. module: payment_stripe
#: model:ir.model.fields.selection,name:payment_stripe.selection__payment_provider__code__stripe
msgid "Stripe"
msgstr "Stripe"

#. module: payment_stripe
#. odoo-python
#: code:addons/payment_stripe/models/payment_provider.py:0
msgid ""
"Stripe Connect is not available in your country, please use another payment "
"provider."
msgstr ""
"Stripe Connect ບໍ່ທັນຮອງຮັບໃນປະເທດຂອງທ່ານ, ກະລຸນາໃຊ້ຜູ້ໃຫ້ບໍລິການຊຳລະເງິນອື່ນ."

#. module: payment_stripe
#: model:ir.model.fields,field_description:payment_stripe.field_payment_token__stripe_mandate
msgid "Stripe Mandate"
msgstr "Stripe Mandate"

#. module: payment_stripe
#: model:ir.model.fields,field_description:payment_stripe.field_payment_token__stripe_payment_method
msgid "Stripe Payment Method ID"
msgstr "ID ວິທີການຊຳລະເງິນຂອງ Stripe"

#. module: payment_stripe
#. odoo-python
#: code:addons/payment_stripe/models/payment_transaction.py:0
msgid "The customer left the payment page."
msgstr "ລູກຄ້າໄດ້ອອກຈາກໜ້າການຊຳລະເງິນ."

#. module: payment_stripe
#: model:ir.model.fields,help:payment_stripe.field_payment_provider__stripe_publishable_key
msgid "The key solely used to identify the account with Stripe"
msgstr "ຄີທີ່ໃຊ້ສະເພາະເພື່ອລະບຸຕົວຕົນບັນຊີກັບ Stripe"

#. module: payment_stripe
#. odoo-python
#: code:addons/payment_stripe/models/payment_transaction.py:0
msgid ""
"The refund did not go through. Please log into your Stripe Dashboard to get "
"more information on that matter, and address any accounting discrepancies."
msgstr ""
"ການຄືນເງິນບໍ່ສຳເລັດ. ກະລຸນາເຂົ້າສູ່ລະບົບ Stripe Dashboard ຂອງທ່ານເພື່ອເບິ່ງຂໍ້ມູນເພີ່ມເຕີມກ່ຽວກັບບັນຫາ"
"ນີ້ ແລະ ກວດສອບຄວາມຜິດພາດທາງບັນຊີ."

#. module: payment_stripe
#: model:ir.model.fields,help:payment_stripe.field_payment_provider__code
msgid "The technical code of this payment provider."
msgstr "ລະຫັດທາງເຕັກນິກຂອງຜູ້ໃຫ້ບໍລິການຊຳລະເງິນນີ້."

#. module: payment_stripe
#. odoo-python
#: code:addons/payment_stripe/models/payment_token.py:0
msgid "Unable to convert payment token to new API."
msgstr "ບໍ່ສາມາດປ່ຽນໂທເຄັນການຊຳລະເງິນເປັນ API ໃໝ່ໄດ້."

#. module: payment_stripe
#: model:ir.model.fields,field_description:payment_stripe.field_payment_provider__stripe_webhook_secret
msgid "Webhook Signing Secret"
msgstr "Webhook Signing Secret"

#. module: payment_stripe
#. odoo-python
#: code:addons/payment_stripe/models/payment_provider.py:0
msgid "You Stripe Webhook was successfully set up!"
msgstr "ຕັ້ງຄ່າ Stripe Webhook ຂອງທ່ານສຳເລັດແລ້ວ!"

#. module: payment_stripe
#. odoo-python
#: code:addons/payment_stripe/models/payment_provider.py:0
msgid ""
"You cannot create a Stripe Webhook if your Stripe Secret Key is not set."
msgstr ""
"ທ່ານບໍ່ສາມາດສ້າງ Stripe Webhook ໄດ້ ຖ້າຫາກຍັງບໍ່ທັນຕັ້ງຄ່າ Stripe Secret Key."

#. module: payment_stripe
#. odoo-python
#: code:addons/payment_stripe/models/payment_provider.py:0
msgid ""
"You cannot set the provider state to Enabled until your onboarding to Stripe"
" is completed."
msgstr ""
"ທ່ານບໍ່ສາມາດຕັ້ງສະຖານະຜູ້ໃຫ້ບໍລິການເປັນ ເປີດໃຊ້ງານ (Enabled) ໄດ້ ຈົນກວ່າການລົງທະບຽນເຂົ້າໃຊ້ "
"Stripe (onboarding) ຈະສຳເລັດ."

#. module: payment_stripe
#. odoo-python
#: code:addons/payment_stripe/models/payment_provider.py:0
msgid ""
"You cannot set the provider to Test Mode while it is linked with your Stripe"
" account."
msgstr ""
"ທ່ານບໍ່ສາມາດຕັ້ງຜູ້ໃຫ້ບໍລິການເປັນ ໂໝດທົດລອງ (Test Mode) ໄດ້ ໃນຂະນະທີ່ມັນຍັງເຊື່ອມຕໍ່ກັບບັນຊີ Stripe ຂ"
"ອງທ່ານ."

#. module: payment_stripe
#. odoo-python
#: code:addons/payment_stripe/models/payment_provider.py:0
msgid "Your Stripe Webhook is already set up."
msgstr "Stripe Webhook ຂອງທ່ານຖືກຕັ້ງຄ່າຮຽບຮ້ອຍແລ້ວ."

#. module: payment_stripe
#. odoo-javascript
#: code:addons/payment_stripe/static/src/interactions/express_checkout.js:0
msgid "Your order"
msgstr "ລາຍການສັ່ງຊື້ຂອງທ່ານ"

#. module: payment_stripe
#. odoo-python
#: code:addons/payment_stripe/models/payment_provider.py:0
msgid "Your web domain was successfully verified."
msgstr "ຢືນຢັນໂດເມນເວັບໄຊຂອງທ່ານສຳເລັດແລ້ວ."
