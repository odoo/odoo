<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="mail.ActivityAssignPopover">
        <div class="o-mail-ActivityAssignPopover">
            <h6 t-if="this.hasHeader" class="p-2 fw-bolder bg-200 border-bottom">Assign</h6>
            <div class="py-2 px-3" style="min-width: 16rem;">
                <div class="d-flex align-items-center">
                    <i class="fa fa-user me-2" role="img" aria-label="User"/>
                    <img t-if="this.userId()"
                         t-att-src="this.getAvatarUrl(this.userId())"
                         class="o_avatar rounded me-2"
                         style="width: 1.5rem; height: 1.5rem; object-fit: cover;" 
                         alt="Avatar"
                    />
                    <Many2XAutocomplete
                        resModel="'res.users'"
                        value="this.userName()"
                        getDomain.bind="this.getDomain"
                        update.bind="this.onSelect"
                        activeActions="{}"
                        placeholder="this.responsibleLabel"
                        fieldString="this.responsibleLabel"
                    >
                        <t t-set-slot="option" t-slot-scope="scope">
                            <div class="d-flex align-items-center">
                                <img t-if="scope.data?.record?.id"
                                    t-att-src="this.getAvatarUrl(scope.data.record.id)"
                                        class="o_avatar rounded me-2"
                                        style="width: 1.5rem; height: 1.5rem; object-fit: cover;" 
                                        alt="Avatar"/>
                                <span t-out="scope.label"/>
                            </div>
                        </t>
                    </Many2XAutocomplete>
                </div>
                <div class="mt-2">
                    <button type="button" class="btn btn-sm btn-primary" aria-label="Assign" t-on-click="this.onClickAssign" t-att-disabled="this.disableAssignButton()">
                        Assign
                    </button>
                    <button type="button" class="btn btn-sm btn-secondary mx-2" t-on-click="this.close">
                        Discard
                    </button>
                </div>
            </div>
        </div>
    </t>
</templates>
