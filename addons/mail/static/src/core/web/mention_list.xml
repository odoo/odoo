<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="mail.MentionList">
        <div class="o-mail-MentionList search d-flex">
            <input type="text" class="form-control border-0 flex-grow-1 rounded-end-0" t-custom-ref="autofocus" t-att-placeholder="this.placeholder" t-custom-model="this.state.searchTerm" t-on-keydown="this.onKeydown"/>
            <i class="oi oi-search p-2 fs-5 rounded-end" title="Search..." role="img" aria-label="Search..."/>
        </div>
        <NavigableList class="'o-mail-MentionList-suggestionList'" t-props="this.navigableListProps"/>
    </t>
</templates>
