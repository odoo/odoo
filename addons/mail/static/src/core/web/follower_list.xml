<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="mail.FollowerList">

        <DropdownItem class="'o-mail-Follower d-flex justify-content-between p-0'">
            <t t-if="props.thread.selfFollower">
                <a class="o-mail-Follower-details d-flex align-items-center flex-grow-1 px-3 o-min-width-0 text-danger" href="#" role="menuitem" t-on-click="onClickUnfollow">
                    Unfollow
                </a>
                <button class="o-mail-Follower-action btn btn-icon rounded-0" title="Edit subscription" aria-label="Edit subscription" t-on-click="(ev) => this.onClickEdit(ev)">
                    <i class="fa fa-pencil"/>
                </button>
            </t>
            <a t-else="" class="o-mail-Follower-details d-flex align-items-center flex-grow-1 px-3 o-min-width-0 text-success" href="#" role="menuitem" t-on-click="onClickFollow">
                Follow
            </a>
        </DropdownItem>
        <div role="separator" class="dropdown-divider"/>

        <t t-if="props.thread.hasWriteAccess">
            <DropdownItem onSelected="() => this.onClickAddFollowers()" attrs="{ href: '#' }">
                Add Followers
            </DropdownItem>
            <div t-if="props.thread.followers.length > 0" role="separator" class="dropdown-divider"/>
        </t>
        <t t-if="props.thread.selfFollower">
            <Follower follower="props.thread.selfFollower" onFollowerChanged="props.onFollowerChanged" close="props.dropdown.close"/>
            <div t-if="props.thread.followers.length > 0" role="separator" class="dropdown-divider"/>
        </t>
        <t t-if="props.thread.followers.length > 0">
            <t t-foreach="props.thread.followers" t-as="follower" t-key="follower.id">
                <Follower follower="follower" onFollowerChanged="props.onFollowerChanged" close="props.dropdown.close"/>
            </t>
            <span t-if="!props.thread.followersFullyLoaded" class="btn btn-link" t-on-click="props.thread.loadMoreFollowers" t-ref="load-more">Load more</span>
        </t>
        <div t-elif="!props.thread.hasWriteAccess" class="dropdown-item disabled">
            No Followers
        </div>
    </t>

</templates>
