<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="mail.Thread.startMessage" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o-mail-Thread-avatar')]" position="attributes">
            <attribute name="t-att-class">{
                'mt-2': !this.env.inChatWindow,
                'cursor-pointer': this.startMessageAvatarPartner,
                'o-mail-Thread-avatarChatWindow mt-1': this.env.inChatWindow,
            }</attribute>
            <attribute name="t-on-click">this.onClickStartMessageAvatar</attribute>
        </xpath>
    </t>
</templates>
