<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="mail.ChatWindow.headerContent" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o-mail-ChatWindow-threadAvatar')]" position="attributes">
            <attribute name="t-att-class">{
                'py-1': !this.threadActions.actions.length gt 3,
                'py-2': this.threadActions.actions.length lte 3,
                'ps-2': !this.hasActionsMenu,
                'cursor-pointer': this.correspondentPartner,
            }</attribute>
            <attribute name="t-on-click">this.onClickThreadAvatar</attribute>
        </xpath>
    </t>
</templates>
