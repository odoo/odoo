<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="mail.DiscussContent" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o-mail-DiscussContent-threadAvatar')]" position="attributes">
            <attribute name="t-att-class">{ 'cursor-pointer': this.correspondentPartner }</attribute>
            <attribute name="t-on-click">this.onClickThreadAvatar</attribute>
        </xpath>
        <xpath expr="//*[@t-custom-ref='main']" position="inside">
            <t t-if="!this.ui.isSmall" t-call="mail.Discuss.loading"/>
        </xpath>
        <xpath expr="//*[@name='thread']" position="inside">
            <t t-if="!this.ui.isSmall" t-call="mail.Discuss.loading"/>
        </xpath>
    </t>
</templates>
