<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="mail.ActivityListPopoverItem">
        <div class="o-mail-ActivityListPopoverItem d-flex flex-column border-bottom py-2">
            <div class="overflow-auto d-flex align-items-baseline ms-3 me-1">
                <span class="o-mail-ActivityListPopoverItem-name flex-grow-1 flex-basis-0 text-truncate">
                    <t t-if="this.activity().summary">
                        <b class="text-900 me-2 text-truncate" t-out="this.activity().summary"/>
                    </t>
                    <t t-if="!this.activity().summary and this.activity().activity_type_id">
                        <b class="text-900 me-2 text-truncate" t-out="this.activity().activity_type_id[1]"/>
                    </t>
                </span>
                <button t-if="this.hasAssignButton" class="o-mail-ActivityListPopoverItem-assignbtn btn btn-sm btn-success btn-link" title="Assign" aria-label="Assign" t-on-click="this.onClickAssignButton">
                    <i class="fa fa-user" role="img" aria-label="Assign"/>
                </button>
                <t t-if="this.activity().can_write">
                    <FileUploader t-if="this.hasFileUploader" onUploaded.bind="this.onFileUploaded">
                        <t t-set-slot="toggler">
                            <button class="btn btn-sm btn-success btn-link" title="Upload file" aria-label="Upload File">
                                <i class="fa fa-upload"/>
                            </button>
                        </t>
                    </FileUploader>
                    <button t-if="this.hasMarkDoneButton" class="o-mail-ActivityListPopoverItem-markAsDone btn btn-sm btn-success btn-link" title="Mark as done" aria-label="Mark as done" t-on-click="this.toggleFn(this.hasMarkDoneView)">
                        <i class="fa fa-check"/>
                    </button>
                </t>
                <button t-if="this.hasEditButton" class="o-mail-ActivityListPopoverItem-editbtn btn btn-sm btn-success btn-link" title="Edit" aria-label="Edit" t-on-click="this.onClickEditActivityButton">
                    <i class="fa fa-pencil"/>
                </button>
            </div>
            <div class="o-mail-ActivityListPopoverItem-user d-flex align-items-center flex-wrap mx-3">
                <img class="me-2 rounded object-fit-cover" t-if="this.activity().user_id?.partner_id" t-att-src="this.activity().user_id.partner_id.avatarUrl" style="max-width: 1.5rem; max-height: 1.5rem;"/>
                <div t-elif="this.activity().role_id" class="me-2 rounded bg-200 text-600 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 1.5rem; height: 1.5rem;">
                    <i class="fa fa-users" role="img" title="Role" aria-label="Role" style="font-size: 12px;"/>
                </div>
                <div class="mt-1">
                    <small t-if="this.activity().user_id" class="text-truncate">
                        <t t-out="this.activity().user_id.name"/>
                        <span t-if="this.activity().state !== 'today'" class="mx-1">-</span>
                    </small>
                    <small t-elif="this.activity().role_id" class="text-truncate text-muted">
                        @<t t-out="this.activity().role_id.name"/>
                        <span t-if="this.activity().state !== 'today'" class="mx-1">-</span>
                    </small>
                    <small t-if="['overdue', 'planned'].includes(this.activity().state)" class="fw-bold" t-att-title="this.activity().dateDeadlineFormatted" t-out="this.delayLabel"/>
                    <small t-if="this.activity().state === 'done'" class="fw-bold" t-att-title="this.dateDoneFormatted" t-out="this.activity().dateDoneFormatted"/>
                </div>
            </div>
            <div t-if="this.activity().attachment_ids?.length" class="mx-5">
                <t t-foreach="this.activity().attachment_ids" t-as="attachment" t-key="attachment.id">
                    <a t-attf-href="/web/content/#{attachment.id}?download=true"
                       t-on-click.stop="" t-out="attachment.name"
                       class="d-inline-block text-truncate" style="max-width: 120px;"/>
                    <br t-if="!attachment_last"/>
                </t>
            </div>
            <ActivityMarkAsDone t-if="this.hasMarkDoneView()" activity="this.activity" close="this.closeMarkDoneView" onClickDoneAndScheduleNext="this.onClickDoneAndScheduleNext" onActivityChanged="this.onActivityChanged"/>
            <div t-if="this.activity().mail_template_ids.length > 0" class="mx-3 mt-2">
                <ActivityMailTemplate activity="this.activity" onClickButtons="this.onClickEditActivityButtonProp" onActivityChanged="this.onActivityChanged"/>
            </div>
        </div>
    </t>
</templates>
