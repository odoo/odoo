<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="mail.MessageActionMenuMobile">
         <BottomSheet close="() => this.props.close?.()">
                <div class="list-group mb-3">
                    <t t-foreach="messageActions.actions.slice(quickActionCount)" t-as="action" t-key="action.id">
                        <button class="list-group-item list-group-item-action d-flex align-items-baseline" t-on-click="() => this.onClickAction(action)">
                            <i class="fa-lg fa-fw me-2" t-att-class="action.icon"/>
                            <span t-esc="action.title"/>
                            <i t-if="action.mobileCloseAfterClick" class="oi oi-chevron-right ms-auto"/>
                        </button>
                    </t>
                </div>
        </BottomSheet>
    </t>
</templates>
