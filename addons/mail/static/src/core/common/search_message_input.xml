<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="mail.SearchMessageInput">
        <div class="o-mail-SearchMessageInput d-flex py-2">
            <div class="input-group">
                <div class="o_searchview form-control d-flex align-items-center bg-view p-0" role="search" aria-autocomplete="list">
                    <div class="o_searchview_input_container d-flex align-items-center flex-grow-1 flex-wrap gap-1 h-100">
                        <div class="input-group-text bg-transparent border-0 pe-0">
                            <i class="oi oi-search opacity-25"/>
                        </div>
                        <input type="text" class="o_searchview_input form-control flex-grow-1 w-auto border-0 rounded-start ps-2 bg-view" accesskey="Q" t-att-placeholder="this.inputPlaceholder" t-custom-model="this.state.searchTerm" t-on-input="this.onInputSearch" t-custom-ref="autofocus" role="searchbox"/>
                        <i class="fa fa-fw fa-times-circle me-2 opacity-50 opacity-100-hover cursor-pointer" t-att-class="{ 'invisible': !this.state.searchTerm }" role="button" aria-label="Clear Search" title="Clear Search" t-on-click="() => this.clear()"/>
                    </div>
                </div>
            </div>
            <Dropdown t-if="this.env.inChatter">
                <button class="btn btn-outline-secondary ms-2" aria-label="Filter Messages" title="Filter Messages">
                    <i class="fa fa-filter" role="img"/>
                </button>
                <t t-set-slot="content">
                    <t t-foreach="this.searchFilters" t-as="searchFilter" t-key="searchFilter.label">
                        <DropdownItem onSelected="() => this.onChangeSearchFilter(searchFilter)">
                            <input type="radio" class="form-check-input ms-0 me-2" t-att-checked="searchFilter.is_notification === this.props.messageSearch.is_notification" value="searchFilter.label"/>
                            <t t-out="searchFilter.name"/>
                        </DropdownItem>
                    </t>
                </t>
            </Dropdown>
            <button t-if="this.env.inChatter" class="btn btn-outline-secondary ms-2" t-on-click="() => this.onClickClose()" aria-label="Close button">
                <i class="o_searchview_icon oi oi-close cursor-pointer" role="img" aria-label="Close search" title="Close"/>
            </button>
        </div>
    </t>
</templates>
