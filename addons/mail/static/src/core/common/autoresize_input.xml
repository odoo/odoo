<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

<t t-name="mail.AutoresizeInput">
    <input
        class="o-mail-AutoresizeInput px-1 border-1 text-truncate rounded"
        t-attf-class="{{ this.props.className }}"
        t-att-class="{'o-focused': this.isFocused()}"
        t-att-placeholder="this.props.placeholder"
        t-att-disabled="!this.props.enabled"
        t-att-title="this.value()"
        t-model="this.value"
        t-on-keydown="this.onKeydownInput"
        t-on-focus="() => this.isFocused.set(true)"
        t-on-blur="this.onBlurInput"
        t-custom-ref="input"
        type="text"
    />
</t>

</templates>
