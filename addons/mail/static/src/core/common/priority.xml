<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="mail.Priority">
        <div t-if="this.priority gt 0" class="d-inline" t-att-aria-label="this.label" t-att-title="this.label">
            <span t-foreach="Array(this.priority)" t-as="star" t-key="star_index" class="fa o-mail-priority-star fa-star"/>
        </div>
    </t>
</templates>
