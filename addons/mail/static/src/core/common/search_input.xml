<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="mail.SearchInput">
        <div class="o-mail-SearchInput position-relative flex-grow-1" t-att-class="props.classNames" role="search">
            <label
                t-att-id="`${this.uniqueId}-icon`"
                t-att-for="`${this.uniqueId}-input`"
                class="position-absolute top-50 px-2 translate-middle-y smaller opacity-50"
                role="status"
            >
                <t t-if="this.spinner.visible">
                    <i class="fa fa-spin fa-circle-o-notch" title="Loading..." aria-hidden="true"/>
                    <p class="visually-hidden">Search is loading...</p>
                </t>
                <i t-else="" class="oi oi-search" aria-hidden="true"/>
            </label>
            <input
                t-att-id="`${this.uniqueId}-input`"
                t-ref="inputRef"
                type="text"
                class="form-control bg-view ps-4"
                t-att-class="{ 'pe-4': props.onClear }"
                t-att-placeholder="props.placeholder"
                t-att-aria-label="props.placeholder"
                t-att-aria-describedby="`${this.uniqueId}-icon`"
                t-custom-model="this.props.search.searchTerm"
                t-att-accesskey="props.accesskey"
                autocomplete="off"
                t-on-keydown="(ev) => props.onKeydown?.(ev)"
            />
            <button
                t-if="this.props.onClear and this.props.search.searchTerm"
                type="button"
                class="btn btn-link text-reset p-0 border-0 shadow-none position-absolute top-0 bottom-0 end-0 me-2 d-flex align-items-center opacity-50 opacity-100-hover"
                t-on-click="props.onClear"
                aria-label="Clear"
                title="Clear"
            >
                <i class="fa fa-times-circle" aria-hidden="true"/>
            </button>
        </div>
    </t>

</templates>
