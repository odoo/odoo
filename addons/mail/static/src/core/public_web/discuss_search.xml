<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
<t t-name="mail.DiscussSearch">
    <div class="o-mail-DiscussSearch d-flex gap-1" t-attf-class="{{ this.props.class }}" t-att-class="{
        'o-gap-1_5': this.store.discuss.isSidebarCompact,
        'align-items-center': this.store.discuss.isSidebarCompact and !this.ui.isSmall,
        'align-items-stretch': !(this.store.discuss.isSidebarCompact and !this.ui.isSmall),
    }" t-custom-ref="root">
        <t t-if="this.store.self_user?.share === false">
            <Dropdown t-if="this.store.discuss.isSidebarCompact and !this.ui.isSmall" state="this.meetingFloating" position="'right-start'" menuClass="'o-mail-DiscussSidebar-floatingMenu px-2 mx-2 my-0 min-w-0 ' + this.store.discussDropdownMenuClass(this)" manual="true">
                <t t-call="mail.DiscussSearch.newMeeting"/>
                <t t-set-slot="content">
                    <div t-custom-ref="meeting-floating">
                        <span class="text-muted user-select-none" t-out="this.newMeetingText"/>
                    </div>
                </t>
            </Dropdown>
            <t t-else="" t-call="mail.DiscussSearch.newMeeting"/>
        </t>
        <Dropdown t-if="this.store.discuss.isSidebarCompact and !this.ui.isSmall" state="this.searchFloating" position="'right-start'" menuClass="'o-mail-DiscussSidebar-floatingMenu mx-2 my-0 min-w-0 ' + this.store.discussDropdownMenuClass(this)" manual="true">
            <t t-call="mail.DiscussSearch.inputContainer"/>
            <t t-set-slot="content">
                <div class="px-2" t-custom-ref="search-floating">
                    <span class="text-muted user-select-none">Search conversations</span>
                </div>
            </t>
        </Dropdown>
        <t t-else="" t-call="mail.DiscussSearch.inputContainer"/>
    </div>
</t>

<t t-name="mail.DiscussSearch.inputContainer">
    <div class="o-mail-DiscussSearch-inputContainer border border-secondary position-relative d-flex align-items-center justify-content-center gap-1 flex-grow-1 flex-basis-0 min-w-0 rounded-2" t-on-click="this.onClickSearchConversations">
        <div class="d-flex w-100 align-items-center justify-content-center gap-1" t-att-class="{ 'p-2': this.store.discuss.isSidebarCompact and !this.ui.isSmall }">
            <i class="oi oi-search opacity-50"/>
            <input t-if="this.ui.isSmall or !this.store.discuss.isSidebarCompact" class="form-control rounded-2 border-0 bg-inherit px-0 w-auto text-center" t-att-class="{ 'lh-1': !this.ui.isSmall }" disabled="true" placeholder="Search" size="8" tabindex="0"/>
        </div>
        <div class="o-mail-DiscussSearch-inputClickable position-absolute z-1 opacity-0 cursor-pointer w-100 h-100"/>
    </div>
</t>

<t t-name="mail.DiscussSearch.newMeeting">
    <button class="o-mail-DiscussSearch-newMeeting btn btn-primary d-flex align-items-center justify-content-center gap-1 flex-grow-1 flex-basis-0 min-w-0 rounded-2" t-att-title="this.newMeetingText" t-on-click="this.onClickNewMeeting" data-hotkey="m" t-custom-ref="meeting-btn" t-att-class="{
        'p-2': this.store.discuss.isSidebarCompact and !this.ui.isSmall,
        'px-1 py-1': !this.store.discuss.isSidebarCompact or this.ui.isSmall,
    }">
        <svg xmlns="http://www.w3.org/2000/svg" width="17" height="13" fill="none" aria-hidden="true">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M11 0a2 2 0 0 1 2 2v4l4-4v9l-4-3v3a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h9ZM6 6H3v1h3v3h1V7h3V6H7V3H6v3Z" fill="currentColor"/>
        </svg>
        <span t-if="!this.store.discuss.isSidebarCompact or this.ui.isSmall" class="text-truncate">Meeting</span>
    </button>
</t>

</templates>
