<templates>
    <t t-name="mail.NodePositionManager">
        <t t-foreach="this.nodeIds" t-as="nodeId" t-key="nodeId_index">
            <node-position t-att-data-id="nodeId"/>
        </t>
    </t>
    <t t-name="mail.ElementLayout">
        <t t-tag="this.model.tag" t-att="this.model.renderAttributes()">
            <t t-call="mail.NodePositionManager"
                t-call-context="this.nodePositionManager.renderContext({ renderPositionedNodes: this.renderPositionedNodes })"/>
        </t>
    </t>
</templates>
