<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

<t t-name="mail.WelcomePage">
    <div class="o-mail-WelcomePage container-xl d-flex align-items-center justify-content-center py-3" style="min-height: 100dvh;">
        <div t-if="this.showCallPreview" class="row align-items-center w-100">
            <div class="col-12 col-lg-8 order-2 order-lg-1">
                <t t-call="mail.WelcomePage.callPreview"/>
            </div>
            <div class="col-12 col-lg-4 order-1 order-lg-2">
                <t t-call="mail.WelcomePage.core"/>
            </div>
        </div>
        <div t-else="" class="row justify-content-center w-100">
            <div class="col-md-8 col-lg-5">
                <t t-call="mail.WelcomePage.core"/>
            </div>
        </div>
    </div>
</t>

<t t-name="mail.WelcomePage.callPreview">
    <div class="w-100 py-2">
        <CallPreview activateCamera="this.state.activateCamera" activateMicrophone="this.state.activateMicrophone" onSettingsChanged="(settings) => this.onCallSettingsChanged(settings)" hasSettingsAtBottom="true"/>
    </div>
</t>

<t t-name="mail.WelcomePage.core">
    <div t-att-class="this.ui.isSmall ? 'd-flex flex-column gap-1' : ''">
        <section class="card shadow-sm border-0 rounded-2 overflow-hidden">
            <div class="card-body p-2">
                <div class="d-flex flex-column gap-2">
                    <t t-call="mail.WelcomePage.inviteHeader"/>
                    <div class="bg-secondary-subtle rounded-2 p-2 d-flex flex-column gap-3">
                        <t t-call="mail.WelcomePage.invitedBy"/>
                        <t t-call="mail.WelcomePage.meetingDetails"/>
                        <t t-call="mail.WelcomePage.joiningAs"/>
                    </div>
                    <t t-call="mail.WelcomePage.joinSection"/>
                </div>
            </div>
        </section>
    </div>
</t>

<t t-name="mail.WelcomePage.invitedBy">
    <div class="d-flex align-items-center gap-2 w-100 text-start">
        <img class="rounded-3" t-att-src="this.channel.create_uid.avatarUrl" alt="User Avatar" width="32" height="32"/>
        <div class="d-flex flex-column overflow-hidden">
            <span class="o-fw-600 text-uppercase text-muted smaller opacity-75">Invited by</span>
            <div class="d-flex gap-1">
                <span class="o-fw-600 text-truncate" t-att-title="this.channel.create_uid.name" t-out="this.channel.create_uid.name"/>
                <span t-if="this.store.companyName" class="text-truncate text-muted" t-att-title="this.store.companyName" t-out="this.store.companyName"/>
            </div>
        </div>
    </div>
</t>

<t t-name="mail.WelcomePage.inviteHeader">
    <div class="d-flex flex-column align-items-center text-center pt-2 rounded-2">
        <div class="bg-primary text-white rounded-2 d-flex p-2">
            <i class="oi oi-users fs-4"/>
        </div>
        <div class="fs-3 o-fw-600 mb-1">
            <t t-if="this.showCallPreview">You've been invited to a meeting!</t>
            <t t-else="">You've been invited to a chat!</t>
        </div>
    </div>
</t>

<t t-name="mail.WelcomePage.joiningAs">
    <div t-if="this.store.self_user" class="d-flex align-items-center gap-2">
        <img t-attf-src="/web/image/res.users/{{this.store.self_user.id}}/avatar_128/64x64" class="rounded-3" alt="User avatar" width="32" height="32"/>
        <div class="d-flex flex-column overflow-hidden">
            <span class="text-uppercase text-muted o-fw-600 smaller opacity-75">Joining as</span>
            <span class="o-fw-600 text-truncate" t-att-title="this.store.self_user?.name || this.state.userName.trim() || 'Guest'" t-out="this.store.self_user?.name || this.state.userName.trim() || 'Guest'"/>
        </div>
    </div>
</t>

<t t-name="mail.WelcomePage.joinSection">
    <div t-if="this.store.self_guest and !this.store.self_user">
        <label class="d-flex justify-content-between align-items-center mb-1">
            <span class="o-fw-600">Enter your name</span>
            <small class="text-muted" t-att-class="{'text-danger': this.state.userName.length > 60}">
                <t t-out="this.state.userName.length"/>/60
            </small>
        </label>
        <input class="form-control form-control-lg rounded" type="text" name="guest_name" placeholder="E.g: John Doe" t-custom-model="this.state.userName" t-on-keydown="this.onKeydownInput"/>
    </div>
    <button class="btn btn-primary btn-lg w-100 my-2" title="Join Channel" t-att-disabled="!this.canJoin" t-on-click="this.joinChannel">
        <t t-if="this.showCallPreview">Join Call</t>
        <t t-else="">Join Conversation</t>
        <i class="oi oi-arrow-right ms-2"/>
    </button>
</t>

<t t-name="mail.WelcomePage.meetingDetails">
    <div t-if="this.channel.description or this.channel.member_count > 0" class="w-100 text-start">
        <div class="d-flex align-items-center gap-2">
            <div class="o-mail-WelcomePage-MeetingIcon d-flex justify-content-center">
                <i class="fa fs-2" t-att-class="this.showCallPreview ? 'fa-calendar' : 'fa-comments'"/>
            </div>
            <span class="fw-medium fs-5 text-truncate min-w-0 flex-grow-1" t-att-title="this.channel.displayName" t-out="this.channel.displayName"/>
            <AvatarStack personas="this.channel.channel_member_ids.map(m => m.persona).filter(p => p?.name)" total="this.channel.member_count"/>
        </div>
        <div t-if="this.channel.description" class="o-mail-WelcomePage-description mt-1">
            <div t-if="!this.state.isDescriptionUnfolded" class="d-flex align-items-center gap-1 overflow-hidden">
                <span t-ref="this.description" class="text-truncate text-muted flex-grow-1" t-out="this.channel.description"/>
                <span t-if="this.shouldShowMoreDescription" t-on-click="this.unfoldDescription" class="text-primary fw-medium cursor-pointer">more</span>
            </div>
            <div t-else="" t-ref="this.description" class="o-mail-WelcomePage-IsDescriptionUnfolded text-muted text-break overflow-auto o-scrollbar-thin">
                <span t-out="this.channel.description"/>
            </div>
        </div>
    </div>
</t>

</templates>
