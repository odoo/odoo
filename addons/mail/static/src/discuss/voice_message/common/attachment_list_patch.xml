<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="mail.AttachmentList" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o-mail-AttachmentCard')]" position="after">
            <div
                t-if="attachment.voice"
                class="position-absolute top-0 start-0 p-1 o-text-white"
            >
                <Dropdown menuClass="'d-flex flex-column py-0'" position="'bottom-start'">
                    <button class="btn btn-sm btn-light rounded px-1 py-0" tabindex="0" role="menuitem" aria-label="Playback speed" title="Playback speed">
                        <span class="fw-semibold"><t t-out="this.getPlaybackRate(attachment)"/>x</span>
                    </button>
                    <t t-set-slot="content">
                        <DropdownItem
                            t-foreach="[0.5, 0.75, 1, 1.25, 1.5, 2]"
                            t-as="rate"
                            t-key="rate"
                            class="'px-2 py-1 d-flex align-items-center justify-content-between rounded-0'"
                            onSelected="() => this.setPlaybackRate(attachment, rate)"
                        >
                            <span class="me-2"><t t-out="rate"/>x</span>
                            <i t-if="this.getPlaybackRate(attachment) === rate" class="fa fa-check"/>
                        </DropdownItem>
                    </t>
                </Dropdown>
            </div>
        </xpath>
        <xpath expr="//div[hasclass('o-mail-AttachmentCard-info')]" position="replace">
            <t t-if="attachment.voice">
                <VoicePlayer attachment="attachment"/>
            </t>
            <t t-else="">$0</t>
        </xpath>
        <xpath expr="(//div[@t-if='!this.isMobileOS'])" position="attributes">
            <attribute name="t-if">!this.isMobileOS and !attachment.voice</attribute>
        </xpath>
    </t>
</templates>
