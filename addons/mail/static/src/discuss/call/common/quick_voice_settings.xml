<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="discuss.QuickVoiceSettings">
        <div class="o-discuss-QuickVoiceSettings d-flex flex-column">
            <DeviceSelect label.translate="Microphone" kind="'audioinput'"/>
            <t t-if="!this.isMobile()">
                <hr class="mx-2 my-1 o-discuss-separator"/>
                <button class="btn border-transparent d-flex align-items-center px-2 py-1" t-on-click="() => this.store.settings.usePushToTalk = !this.store.settings.usePushToTalk">
                    <label class="d-flex align-items-center flex-wrap mw-100 cursor-pointer gap-2">
                        <span class="text-truncate text-wrap">Push-to-Talk</span>
                        <span t-if="this.store.settings.pushToTalkKey" class="o-fs-small opacity-50" t-out="this.pttKeyDisplayText"/>
                    </label>
                    <div class="flex-grow-1"/>
                    <div class="form-check form-switch">
                        <input class="form-check-input mx-0" type="checkbox" role="switch" t-att-checked="this.store.settings.usePushToTalk ? 'checked' : ''"/>
                    </div>
                </button>
            </t>
            <hr class="mx-2 my-1 o-discuss-separator"/>
            <DeviceSelect label.translate="Speakers" kind="'audiooutput'"/>
            <t t-if="this.store.rtc.selfSession">
                <hr class="mx-2 my-1 o-discuss-separator"/>
                <button class="btn border-transparent d-flex align-items-center px-2 py-1" t-on-click="() => this.store.rtc.toggleDeafen()">
                    <span class="text-truncate text-wrap">Deafen</span>
                    <div class="flex-grow-1"/>
                    <div class="form-check form-switch">
                        <input class="form-check-input mx-0" type="checkbox" role="switch" t-att-checked="this.store.rtc.selfSession?.is_deaf ? 'checked' : ''"/>
                    </div>
                </button>
            </t>
            <t t-if="!this.env.pipWindow">
                <hr class="mx-2 my-1 o-discuss-separator"/>
                <button class="btn border-transparent d-flex align-items-center px-2 py-1" t-on-click="this.onClickVoiceSettings">
                    <span>Advanced Settings</span>
                    <div class="flex-grow-1"/>
                    <i class="fa fa-fw fa-gear o-fs-small opacity-75"/>
                </button>
            </t>
        </div>
    </t>

</templates>
