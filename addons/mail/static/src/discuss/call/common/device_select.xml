<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="discuss.CallDeviceSelect">
        <Dropdown
            menuClass="this.props.menuClass"
            disabled="!this.isPermissionGranted(this.props.kind)"
            openOnMouseEnter="false"
        >
            <button
                t-if="this.isPermissionGranted(this.props.kind)"
                t-attf-class="o-mail-DeviceSelect-button btn btn-secondary o-dropdown-caret {{ this.env.inDialog ? 'w-50' : 'w-100' }}"
                t-att-data-kind="this.props.kind"
             >
                <i t-if="this.props.icon" t-att-class="this.props.icon"/>
                <span
                    class="pe-2 text-start text-truncate"
                    t-attf-class="{{ this.props.icon ? 'ps-2' : '' }}"
                    t-out="this.selectLabel || this.BROWSER_DEFAULT"/>
            </button>
            <button
                t-else=""
                t-attf-class="o-mail-DeviceSelect-button btn btn-secondary d-flex align-items-center {{ this.env.inDialog ? 'w-50' : 'w-100' }}"
                t-att-data-kind="this.props.kind"
                t-on-pointerdown.prevent="() => this.showPermissionDialog(this.props.kind)"
                t-on-keydown.prevent="() => this.showPermissionDialog(this.props.kind)"
            >
                <i t-if="this.props.icon" t-att-class="this.props.icon"/>
                <span
                    class="text-truncate flex-grow-1"
                    t-attf-class="{{ this.props.icon ? 'ps-2' : '' }}"
                    t-out="this.PERMISSION_NEEDED"/>
            </button>
            <t t-set-slot="content">
                <DropdownItem t-if="!this.isBrowserChrome or this.props.kind === 'videoinput'" class="{ 'active': this.isSelected() }" onSelected="this.onSelectAudioDevice.bind(this)" closingMode="'closest'">
                    <t t-out="this.BROWSER_DEFAULT"/>
                </DropdownItem>
                <t t-foreach="this.state.userDevices" t-as="device" t-key="device_index">
                    <DropdownItem t-if="device.kind === this.props.kind" class="{ 'active': this.isSelected(device.deviceId) }" onSelected="this.onSelectAudioDevice.bind(this, device)" closingMode="'closest'">
                        <t t-out="device.label || 'device ' + device_index"/>
                    </DropdownItem>
                </t>
            </t>
        </Dropdown>
    </t>

</templates>
