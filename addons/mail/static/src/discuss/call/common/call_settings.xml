<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="discuss.CallSettings">
        <ActionPanel t-if="this.props.withActionPanel" close="this.props.close" title.translate="Voice &amp; Video Settings" icon="'fa fa-gear'">
            <t t-call="discuss.CallSettings.content" />
        </ActionPanel>
        <t t-else="" t-call="discuss.CallSettings.content" />
    </t>

    <t t-name="discuss.CallSettings.content">
        <div class="o-discuss-CallSettings d-flex flex-column">
            <Tabs direction="'h'" initialTabId="'voice'">
                <t t-set-slot="headers">
                    <TabHeader id="'voice'" title.translate="Voice &amp; Audio">
                        <div class="py-1 px-2"><i class="fa fa-microphone me-2"/>Voice &amp; Audio</div>
                    </TabHeader>
                    <TabHeader id="'video'" title.translate="Video">
                        <div class="py-1 px-2"><i class="fa fa-video-camera me-2"/>Video</div>
                    </TabHeader>
                    <TabHeader t-if="this.env.debug" id="'technical'" title.translate="Technical">
                        <div class="py-1 px-2"><i class="fa fa-cogs me-2"/>Technical</div>
                    </TabHeader>
                </t>
                <t t-set-slot="panels">
                    <TabPanel id="'voice'">
                        <div class="d-flex flex-column my-2 p-1">
                            <div class="d-flex gap-2" t-att-class="this.props.isCompact or this.isMobileOS ? 'flex-column' : 'flex-row'">
                                <div class="d-flex flex-column flex-grow-1 gap-1 overflow-hidden" t-att-class="this.props.isCompact or this.isMobileOS ? 'w-100' : 'w-50'" aria-label="Microphone">
                                    <span class="flex-shrink-0 fw-bold text-muted small text-uppercase">
                                        <i class="fa fa-microphone text-muted ms-1 me-2"/>Microphone
                                    </span>
                                    <DeviceSelect kind="'audioinput'"/>
                                </div>
                                <div class="d-flex flex-column flex-grow-1 gap-1 overflow-hidden" t-att-class="this.props.isCompact or this.isMobileOS ? 'w-100' : 'w-50'" aria-label="Speakers">
                                    <span class="flex-shrink-0 fw-bold text-muted small text-uppercase">
                                        <i class="fa fa-volume-up text-muted ms-1 me-2"/>Speakers
                                    </span>
                                    <DeviceSelect kind="'audiooutput'"/>
                                </div>
                            </div>
                            <hr class="my-3 border-secondary opacity-75"/>
                            <div class="d-flex flex-column gap-2">
                                <span t-if="this.store.settings.usePushToTalk and !this.isMobileOS and !this.pttExtService.isEnabled" class="small text-muted fst-italic alert alert-warning px-3 py-2 m-0" t-out="this.pttExtService.downloadText"/>
                                <div class="d-flex flex-column border rounded">
                                    <t t-call="discuss.CallSettings.textToggler">
                                        <t t-set="text">Enable Push-to-talk</t>
                                        <t t-set="value" t-value="this.store.settings.usePushToTalk"/>
                                        <t t-set="onchange" t-value="this.onChangePushToTalk"/>
                                    </t>
                                    <hr class="my-0 border-secondary opacity-75"/>
                                    <div class="o-pb-2_5 pt-1 o-px-2_5">
                                        <t t-if="!this.store.settings.usePushToTalk">
                                            <div class="d-flex flex-column gap-2">
                                                <span class="text-muted o-ps-0_5 pt-2"><i class="fa fa-info-circle me-2"/>Adjust the slider to set the voice detection sensitivity.</span>
                                                <div class="d-flex gap-2" t-att-class="this.props.isCompact or this.isMobileOS ? 'flex-column' : 'flex-row'">
                                                    <button class="btn px-3 flex-shrink-0" t-att-class="this.microphoneVolume.isActive ? 'btn-danger' : 'btn-secondary'" t-on-click="this.microphoneVolume.toggle" t-att-disabled="!this.microphoneVolume.isReady">
                                                        <i class="fa me-2" t-att-class="this.microphoneVolume.isActive ? 'fa-stop' : 'fa-microphone'"/>
                                                        <t t-out="this.microphoneVolume.isActive ? this.stopText : this.testText"/>
                                                    </button>
                                                    <div class="d-flex align-items-center flex-grow-1 gap-2 border rounded px-2 py-1">
                                                        <input class="o-Discuss-CallSettings-thresholdInput form-range" t-attf-style="--volume: {{this.microphoneVolume.value * 100}}%;" type="range" min="0.001" max="1" step="0.001" t-model="this.store.settings.voiceActivationThreshold" title="Voice detection sensitivity"/>
                                                        <small class="fw-bold"><t t-out="Math.round(this.store.settings.voiceActivationThreshold * 100)"/>%</small>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                        <t t-else="">
                                            <div class="d-flex flex-column gap-2">
                                                <span class="text-muted o-ps-0_5 pt-2">
                                                    <i class="fa fa-info-circle me-2"/>
                                                    <t t-if="this.isMobileOS">Delay after releasing push-to-talk</t>
                                                    <t t-elif="this.store.settings.isRegisteringKey">Press any key to register it as your shortcut.</t>
                                                    <t t-else="">Click the button below to register a new shortcut.</t>
                                                </span>
                                                <div class="d-flex gap-2" t-att-class="this.props.isCompact or this.isMobileOS ? 'flex-column' : 'flex-row'">
                                                    <button t-if="!this.isMobileOS" class="btn px-4 flex-shrink-0" t-att-class="this.store.settings.isRegisteringKey ? 'btn-danger' : 'btn-secondary'" t-on-click="this.onClickRegisterKeyButton" aria-label="Register new shortcut">
                                                        <i class="fa me-2" t-att-class="this.store.settings.isRegisteringKey ? 'fa-times' : 'fa-keyboard-o'"/>
                                                        <t t-out="this.store.settings.pushToTalkKeyText"/>
                                                    </button>
                                                    <div class="d-flex align-items-center flex-grow-1 gap-2 border rounded px-2 py-1">
                                                        <small class="text-muted text-nowrap">Delay:</small>
                                                        <input class="o-discuss-CallSettings-delayInput form-range" type="range" min="0" max="2000" step="1" t-att-value="this.store.settings.voiceActiveDuration" t-on-input="this.onChangeDelay" title="Delay after releasing push-to-talk"/>
                                                        <small class="o-discuss-CallSettings-voiceActiveDuration fw-bold"><t t-out="this.store.settings.voiceActiveDuration"/>ms</small>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </TabPanel>
                    <TabPanel id="'video'">
                        <div class="d-flex flex-column my-2 p-1">
                            <div class="d-flex flex-column flex-grow-1 gap-1" aria-label="Camera">
                                <span class="flex-shrink-0 fw-bold text-muted small text-uppercase">
                                    <i class="fa fa-video-camera text-muted ms-1 me-2"/>Camera
                                </span>
                                <DeviceSelect kind="'videoinput'"/>
                            </div>
                            <hr class="my-3 border-secondary opacity-75"/>
                            <div class="d-flex flex-column border rounded">
                                <t t-if="this.store.settings.hasCanvasFilterSupport">
                                    <t t-call="discuss.CallSettings.textToggler">
                                        <t t-set="text">Blur video background</t>
                                        <t t-set="description">Apply a privacy blur to your surroundings.</t>
                                        <t t-set="value" t-value="this.store.settings.useBlur"/>
                                        <t t-set="onchange" t-value="this.onChangeBlur"/>
                                    </t>
                                </t>
                                <t t-if="this.store.settings.useBlur">
                                    <div class="d-flex gap-3 o-py-2_5 px-3" t-att-class="this.props.isCompact or this.isMobileOS ? 'flex-column' : 'flex-row'">
                                        <div class="d-flex flex-column flex-grow-1 gap-1" title="Background blur intensity" aria-label="Background blur intensity">
                                            <span class="flex-shrink-0 d-flex justify-content-between fw-bold text-muted small text-uppercase">
                                                <span>Intensity</span>
                                                <span class="o-discuss-DiscussCallSettings-width-text-percentage"><t t-out="Math.floor(this.store.settings.backgroundBlurAmount * 5)"/>%</span>
                                            </span>
                                            <input class="form-range" type="range" min="0" max="20" step="1" t-att-value="this.store.settings.backgroundBlurAmount" t-on-change="this.onChangeBackgroundBlurAmount"/>
                                        </div>
                                        <div class="d-flex flex-column flex-grow-1 gap-1" title="Edge blur intensity" aria-label="Edge blur intensity">
                                            <span class="flex-shrink-0 d-flex justify-content-between fw-bold text-muted small text-uppercase">
                                                <span>Edge Softness</span>
                                                <span class="o-discuss-DiscussCallSettings-width-text-percentage"><t t-out="Math.floor(this.store.settings.edgeBlurAmount * 5)"/>%</span>
                                            </span>
                                            <input class="form-range" type="range" min="0" max="20" step="1" t-att-value="this.store.settings.edgeBlurAmount" t-on-change="this.onChangeEdgeBlurAmount"/>
                                        </div>
                                    </div>
                                </t>
                                <hr class="border-secondary opacity-75 m-0"/>
                                <t t-call="discuss.CallSettings.textToggler">
                                    <t t-set="text">Show video participants only</t>
                                    <t t-set="description">Hide participants who have turned off their camera.</t>
                                    <t t-set="value" t-value="this.store.settings.showOnlyVideo"/>
                                    <t t-set="onchange" t-value="this.onChangeShowOnlyVideo"/>
                                </t>
                                <hr class="border-secondary opacity-75 m-0"/>
                                <t t-call="discuss.CallSettings.textToggler">
                                    <t t-set="text">Auto-focus speaker</t>
                                    <t t-set="description">Automatically enlarge the person currently speaking.</t>
                                    <t t-set="value" t-value="this.store.settings.useCallAutoFocus"/>
                                    <t t-set="onchange" t-value="this.onChangeCallAutoFocus"/>
                                </t>
                            </div>
                        </div>
                    </TabPanel>
                    <TabPanel id="'technical'">
                        <div class="d-flex flex-column my-2 p-1">
                            <div class="d-flex flex-column border rounded">
                                <t t-call="discuss.CallSettings.textToggler">
                                    <t t-set="text">Log RTC events</t>
                                    <t t-set="description">Save detailed RTC connection logs for troubleshooting.</t>
                                    <t t-set="value" t-value="this.store.settings.logRtc"/>
                                    <t t-set="onchange" t-value="this.onChangeLogRtc"/>
                                </t>
                                <button class="btn btn-secondary rounded-top-0" t-on-click="this.onClickDownloadLogs"><i class="fa fa-download me-2"/><span>Download Logs</span></button>
                            </div>
                        </div>
                    </TabPanel>
                </t>
            </Tabs>
        </div>
    </t>
    <t t-name="discuss.CallSettings.textToggler">
        <label class="o-discuss-CallSettings-item d-flex align-items-center justify-content-between o-py-2_5 px-3 gap-1 cursor-pointer" t-att-aria-label="text">
            <div class="d-flex flex-column user-select-none">
                <span class="fw-bold" t-out="text"/>
                <small class="text-muted fst-italic" t-out="description"/>
            </div>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" role="switch" t-on-change="onchange" t-att-checked="value" t-att-title="text" t-att-aria-label="text"/>
            </div>
        </label>
    </t>
</templates>
