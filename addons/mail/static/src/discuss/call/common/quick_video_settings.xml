<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="discuss.QuickVideoSettings">
        <div class="o-discuss-QuickVideoSettings d-flex flex-column">
            <DeviceSelect label.translate="Camera" kind="'videoinput'"/>
            <t t-if="!this.isBrowserSafari()">
                <hr class="mx-2 my-1 o-discuss-separator"/>
                <div class="btn border-transparent d-flex align-items-center px-2 py-1" t-on-click="() => this.store.settings.useBlur = !this.store.settings.useBlur">
                    <span class="text-truncate text-wrap">Blur Background</span>
                    <div class="flex-grow-1"/>
                    <div class="form-check form-switch ms-2">
                        <input class="form-check-input mx-0" type="checkbox" role="switch" t-att-checked="this.store.settings?.useBlur ? 'checked' : ''"/>
                    </div>
                </div>
            </t>
            <t t-if="!this.env.pipWindow">
                <hr class="mx-2 my-1 o-discuss-separator"/>
                <button class="btn border-transparent d-flex align-items-center px-2 py-1" t-on-click="this.onClickVideoSettings">
                    <span>Advanced Settings</span>
                    <div class="flex-grow-1"/>
                    <i class="fa fa-fw fa-gear o-fs-small opacity-75"/>
                </button>
            </t>
        </div>
    </t>

</templates>
