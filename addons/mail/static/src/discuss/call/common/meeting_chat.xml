<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="mail.MeetingChat">
        <ActionPanel t-if="this.channel" title.translate="In call messages" resizable="true" minWidth="300" initialWidth="400" icon="'fa fa-comments'" contentRef="this.panelContentRef">
            <t t-set-slot="header-extra">
                <button t-if="this.env.pinMenu and this.channel?.pinnedMessages?.length > 0" title="Pinned Messages" class="btn opacity-75 opacity-100-hover p-1 me-3 position-relative" t-on-click="() => this.env.pinMenu.open()">
                    <i class="fa fa-thumb-tack"/>
                    <span class="o-mail-MeetingChat-pinCounter badge rounded-circle position-absolute" t-out="this.channel.pinnedMessages.length"/>
                </button>
            </t>
            <Thread thread="this.channel.thread" jumpPresent="this.state.jumpPresent"/>
            <t t-call="mail.ChatWindow.memberTyping"/>
            <Composer
                composer="this.channel.composer"
                autofocus="!this.isMobileOS"
                onDiscardCallback="() => (this.channel.composer.replyToMessage = undefined)"
                onPostCallback.bind="() => this.state.jumpPresent++"
                dropzoneRef="this.panelContentRef"
           />
        </ActionPanel>
    </t>
</templates>
