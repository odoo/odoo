<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="discuss.CallContextMenu">
        <div class="o-discuss-CallContextMenu d-flex flex-column gap-1 p-2 rounded">
            <t t-if="!this.isSelf">
                <button class="btn o-discuss-CallContextMenu-item d-flex align-items-center gap-2 w-100 px-2 py-1 border-0 rounded text-reset text-start cursor-pointer" t-on-click="this.togglePin">
                    <i class="fa fa-fw fa-thumb-tack opacity-75"/><t t-if="this.isPinned">Unpin</t><t t-else="">Pin</t>
                </button>
                <div class="o-discuss-CallContextMenu-row d-flex align-items-center gap-2 w-100 px-2 py-1">
                    <button class="btn o-discuss-CallContextMenu-muteToggle border-0 p-0 lh-1 cursor-pointer text-reset" t-on-click="this.toggleLocallyMute" t-att-title="this.muteLabel" t-att-aria-label="this.muteLabel">
                        <i class="fa fa-fw" t-att-class="(this.isLocallyMuted or this.state.rangeVolume === 0) ? 'fa-volume-off' : 'fa-volume-up'"/>
                    </button>
                    <div class="position-relative flex-grow-1">
                        <input type="range" min="0.0" max="1" step="0.01" class="form-range h-auto" t-att-value="this.volume" t-model.proxy="this.state.rangeVolume" t-on-change="this.onChangeVolume"/>
                        <output t-out="`${Math.round(this.state.rangeVolume * 200)}%`" class="o-mail-CallContextMenu-volumeTooltip fw-bold rounded" t-attf-style="--progress:{{this.state.rangeVolume * 100}}%;"/>
                    </div>
                </div>
                <button t-if="this.canModerate" class="btn o-discuss-CallContextMenu-item o-danger d-flex align-items-center gap-2 w-100 px-2 py-1 border-0 rounded text-danger text-start cursor-pointer" t-on-click="this.onClickRemoveFromCall">
                    <i class="fa fa-fw fa-times-circle"/>Remove from call
                </button>
            </t>
            <t t-if="this.env.debug and !this.isSelf and this.rtc.connectionType === this.rtcConnectionTypes.P2P">
                <hr class="w-100 border-top"/>
                <div><span class="fw-bolder">RTC Session ID: </span><t t-out="this.props.rtcSession.id"/></div>
                <div><span class="fw-bolder">Connection type: </span><t t-out="this.rtc.connectionType"/></div>
                <div><span class="fw-bolder">To peer: </span><t t-out="this.outboundConnectionTypeText"/></div>
                <div><span class="fw-bolder">From peer: </span><t t-out="this.inboundConnectionTypeText"/></div>
                <div><span class="fw-bolder">Connection: </span><t t-out="this.state.peerStats.connectionState"/></div>
                <div><span class="fw-bolder">ICE connection: </span><t t-out="this.state.peerStats.iceConnectionState"/></div>
                <div><span class="fw-bolder">ICE: </span><t t-out="this.state.peerStats.iceState"/></div>
                <div><span class="fw-bolder">DTLS: </span><t t-out="this.state.peerStats.dtlsState"/></div>
                <div><span class="fw-bolder">Data channel: </span><t t-out="this.state.peerStats.dataChannelState"/></div>
                <div t-if="this.props.rtcSession.audioError"><span class="fw-bolder">Audio player: </span><t t-out="this.props.rtcSession.audioError"/></div>
                <div t-if="this.props.rtcSession.videoError"><span class="fw-bolder">Video player: </span><t t-out="this.props.rtcSession.videoError"/></div>
                <hr class="w-100 border-top"/>
                <div><span class="fw-bolder">ICE gathering: </span><t t-out="this.state.peerStats.iceGatheringState"/></div>
                <div><span class="fw-bolder">Packets sent: </span><t t-out="this.state.peerStats.packetsSent"/></div>
                <div><span class="fw-bolder">Packets received: </span><t t-out="this.state.peerStats.packetsReceived"/></div>
                <div><span class="fw-bolder">Log step: </span><t t-out="this.props.rtcSession.logStep"/></div>
            </t>
            <t t-elif="this.env.debug and this.isSelf and this.rtc.connectionType === this.rtcConnectionTypes.SERVER">
                <div><span class="fw-bolder">Connection type: </span><t t-out="this.rtc.connectionType"/></div>
                <div><span class="fw-bolder">RTC Session ID: </span><t t-out="this.props.rtcSession.id"/></div>
                <hr class="w-100 border-top"/>
                <div><span class="fw-bolder">Upload: </span><t t-out="this.outboundConnectionTypeText"/></div>
                <div><span class="fw-bolder">up ICE: </span><t t-out="this.state.uploadStats.iceState"/></div>
                <div><span class="fw-bolder">up DTLS: </span><t t-out="this.state.uploadStats.dtlsState"/></div>
                <div><span class="fw-bolder">Packets sent: </span><t t-out="this.state.uploadStats.packetsSent"/></div>
                <div><span class="fw-bolder">available bitrate: </span><t t-out="this.state.uploadStats.availableOutgoingBitrate"/></div>
                <hr class="w-100 border-top"/>
                <div><span class="fw-bolder">Download: </span><t t-out="this.inboundConnectionTypeText"/></div>
                <div><span class="fw-bolder">down ICE: </span><t t-out="this.state.downloadStats.iceState"/></div>
                <div><span class="fw-bolder">down DTLS: </span><t t-out="this.state.downloadStats.dtlsState"/></div>
                <div><span class="fw-bolder">Packets received: </span><t t-out="this.state.downloadStats.packetsReceived"/></div>
                <t t-if="this.state.producerStats.audio">
                    <hr class="w-100 border-top"/>
                    <div><span class="fw-bolder">microphone</span></div>
                    <div><span class="fw-bolder">codec: </span><t t-out="this.state.producerStats.audio.codec"/></div>
                    <div><span class="fw-bolder">clock rate: </span><t t-out="this.state.producerStats.audio.clockRate"/></div>
                </t>
                <t t-if="this.state.producerStats.camera and this.props.rtcSession.is_camera_on">
                    <hr class="w-100 border-top"/>
                    <div><span class="fw-bolder">camera</span></div>
                    <div><span class="fw-bolder">codec: </span><t t-out="this.state.producerStats.camera.codec"/></div>
                    <div><span class="fw-bolder">clock rate: </span><t t-out="this.state.producerStats.camera.clockRate"/></div>
                </t>
                <t t-if="this.state.producerStats.screen and this.props.rtcSession.is_screen_sharing_on">
                    <hr class="w-100 border-top"/>
                    <div><span class="fw-bolder">screen</span></div>
                    <div><span class="fw-bolder">codec: </span><t t-out="this.state.producerStats.screen.codec"/></div>
                    <div><span class="fw-bolder">clock rate: </span><t t-out="this.state.producerStats.screen.clockRate"/></div>
                </t>
            </t>
        </div>
    </t>
</templates>
