<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="mail.CallDebriefMediaControls">
        <div class="o-CallDebrief-media-controls d-flex align-items-center p-2 border-top">
            <div class="o_feedback_indicator">
                <span t-if="this.props.feedback" t-key="this.props.feedback.id" class="o_animate_fade" t-out="this.props.feedback.text"/>
            </div>

            <div class="o_media_controls_spacer"/>

            <div class="d-flex align-items-center">
                <button t-on-click="() => this.props.onSeek(-5)" class="btn btn-secondary btn-sm o-CallDebrief-btn rounded-pill me-1" title="Skip backward (j, ←)">
                    <small>-5s</small>
                </button>
                <button t-on-click="this.props.onTogglePlay" class="btn btn-primary btn-sm o-CallDebrief-btn rounded-pill me-1" style="width: 32px;" title="Play/Pause (k, space)">
                    <i t-att-class="this.props.isPlaying ? 'fa fa-pause' : 'fa fa-play'"/>
                </button>
                <button t-on-click="() => this.props.onSeek(5)" class="btn btn-secondary btn-sm o-CallDebrief-btn rounded-pill me-2" title="Skip forward (l, →)">
                    <small>+5s</small>
                </button>
                <div class="position-relative d-flex align-items-center" t-on-mouseenter="this.showVolumeSlider" t-on-mouseleave="this.hideVolumeSlider">
                    <button t-on-click="this.props.onToggleMute" class="btn btn-secondary btn-sm o-CallDebrief-btn rounded-pill o_volume_button" title="Mute (m)">
                        <i t-att-class="this.volumeIconClass"/>
                    </button>
                    <div t-if="this.isVolumeSliderVisible()" class="position-absolute o_volume_slider_container">
                        <input type="range"
                            class="form-range"
                            min="0"
                            max="1"
                            step="0.05"
                            t-att-value="this.props.volume"
                            t-on-input="(ev) => this.props.onSetVolume(ev)"
                        />
                    </div>
                </div>
            </div>

            <div class="o_media_controls_spacer d-flex justify-content-end align-items-center">
                <div class="o-CallDebrief-settings-inline d-flex align-items-center bg-secondary rounded-pill px-3 py-1 me-2">
                    <div class="o_speed_selector_group d-flex align-items-center me-2" title="Playback Speed (&lt;, &gt;)">
                        <label for="playbackRateSelect" class="form-label small mb-0 me-1">Speed</label>
                        <select id="playbackRateSelect" class="form-select form-select-sm" t-on-change="(ev) => this.props.onSetPlaybackRate(ev)">
                            <t t-foreach="this.props.playbackRates" t-as="rate" t-key="rate">
                                <option t-att-value="rate" t-att-selected="this.props.playbackRate === rate ? 'selected' : null">
                                    <t t-out="rate"/>x
                                </option>
                            </t>
                        </select>
                    </div>
                    <div t-if="this.props.media" class="o-CallDebrief-download-separator">
                        <a t-att-href="this.props.media.mediaUrl + '?download=1'" download="download" class="btn btn-link btn-sm p-0 text-dark" title="Download">
                            <i class="fa fa-download"/>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
