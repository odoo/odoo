<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="mail.CallDebriefTimeline">
        <div class="o-CallDebriefTimeline-container z-1">
            <div class="o-CallDebriefTimeline position-relative d-flex align-items-center flex-grow-1" t-ref="this.timeline" t-on-pointerdown="this.onDragStart" t-on-pointermove="this.onHoverMove" t-on-pointerleave="this.onLeaveMove">
                <div class="o-CallDebriefTimeline-track position-relative d-flex gap-1 align-items-center w-100 rounded z-0" t-att-class="{'rounded-pill pb-2 bg-300': this.props.mediaSegments.length === 0}">
                    <t t-if="this.props.mediaSegments">
                        <t t-foreach="this.props.mediaSegments" t-as="segment" t-key="segment.id">
                            <div class="o-CallDebriefTimeline-media-segment position-absolute rounded-1 bg-200 overflow-hidden"
                                 t-att-style="this._stylePositionMediaSegment(segment)">
                                <div class="o-CallDebriefTimeline-media-progress position-absolute left-0 top-0 h-100 bg-primary" t-att-style="this._stylePositionMediaProgress(segment)"/>
                            </div>
                        </t>
                    </t>
                </div>

                <!-- Playhead (rendered on top of everything) -->
                <div
                    t-if="this.props.currentTime !== undefined"
                    class="o-CallDebriefTimeline-playhead position-absolute top-50 translate-middle rounded-pill overflow-hidden"
                    t-att-style="this._stylePositionPlayhead()"
                >
                </div>
                <div class="o-CallDebriefTimeline-timestamp o-tooltip tooltip-inner position-absolute top-100 translate-middle d-none d-md-block mt-2 pe-none" t-ref="this.timestamp" t-att-style="this._stylePositionTimestamp()" t-out="this.formatDuration(this.displayedTimestamp)"/>
            </div>
        </div>
    </t>
</templates>
