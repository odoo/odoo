<?xml version="1.0" encoding="UTF-8"?>
<templates>

    <t t-name="mail.Many2OneAvatarUserField">
        <Many2One t-props="m2oProps">
            <t t-set-slot="start">
                <t t-if="value !== false">
                    <Avatar cssClass="'o_m2o_avatar'" resModel="relation" resId="value[0]" noSpacing="true"/>
                </t>
            </t>
            <t t-set-slot="items" t-slot-scope="itemsScope">
                <span class="o_avatar_many2x_autocomplete o_avatar d-flex align-items-center">
                    <img class="rounded me-1" t-attf-src="/web/image/{{relation}}/{{itemsScope.record.id}}/avatar_128"/>
                    <t t-esc="itemsScope.record.display_name"/>
                </span>
            </t>
        </Many2One>
    </t>

</templates>
