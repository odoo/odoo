<templates xml:space="preserve">
    <span t-name="mail.MailActivityListRescheduleDropdown">
        <Dropdown>
            <button class="btn btn-link p-0 text-dark" type="button">
                <i class="oi oi-filled o_button_icon" data-icon="calendar_today"/> <span class="o_dropdown_title">Reschedule</span>
            </button>

            <t t-set-slot="content">
                <DropdownItem onSelected="(ev) => this.rescheduleActivity(ev, this.targetDays.today.actionName)">
                    <div class="d-flex justify-content-between">
                        <span>
                            <i class="oi me-1" data-icon="early_on"/> Today
                        </span>
                        <span t-out="this.targetDays.today.displayDay" class="ms-2 text-muted"/>
                    </div>
                </DropdownItem>
                <DropdownItem onSelected="(ev) => this.rescheduleActivity(ev, this.targetDays.tomorrow.actionName)">
                    <div class="d-flex justify-content-between">
                        <span>
                            <i class="oi me-1" data-icon="event_upcoming"/> Tomorrow
                        </span>
                        <span t-out="this.targetDays.tomorrow.displayDay" class="ms-2 text-muted"/>
                    </div>
                </DropdownItem>
                <DropdownItem onSelected="(ev) => this.rescheduleActivity(ev, this.targetDays.nextWeek.actionName)">
                    <div class="d-flex justify-content-between">
                        <span>
                            <i class="oi me-1" data-icon="calendar_clock"/> Next Week
                        </span>
                        <span t-out="this.targetDays.nextWeek.displayDay" class="ms-2 text-muted"/>
                    </div>
                </DropdownItem>
            </t>
        </Dropdown>
    </span>
</templates>
