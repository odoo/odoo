<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_partner_account_vat_vies_form" model="ir.ui.view">
            <field name="model">res.partner</field>
            <field name="name">view.partner.account.vat.vies.form</field>
            <field name="priority">15</field>
            <field name="inherit_id" ref="base.view_partner_form" />
            <field name="arch" type="xml">
                <div id="vat_div" position="inside">
                    <span class="text-nowrap ps-2">
                        <label for="vies_valid" invisible="not perform_vies_validation"/>
                        <field name="vies_valid" invisible="not perform_vies_validation" class="oe_inline"/>
                    </span>
                </div>
            </field>
        </record>
    </data>
</odoo>
