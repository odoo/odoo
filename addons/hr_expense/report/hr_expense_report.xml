<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_expense">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page o_content_pdf">
                        <t t-if="o_index == 0">
                            <h2>Expenses Report</h2>
                            <div class="row o_header mb-3">
                                <div class="col-6">
                                    <div class="row">
                                        <div class="col-3 fw-bold">Employee:</div>
                                        <div class="col-9 text-muted">
                                            <span t-field="o.employee_id.name"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="row" t-if="o.manager_id.name">
                                        <div class="col-3 fw-bold">Manager:</div>
                                        <div class="col-9 text-muted">
                                            <span t-field="o.manager_id"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <table class="o_has_total_table table table-borderless">
                                <thead>
                                    <tr>
                                        <th class="text-start">Date</th>
                                        <th class="text-start">Name</th>
                                        <th class="text-end">Unit Price</th>
                                        <th class="text-end">Qty</th>
                                        <th class="text-end">Taxes</th>
                                        <th class="text-end">Total</th>
                                        <th class="text-start">Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="docs" t-as="line">
                                        <td><span t-field="line.date"/></td>
                                        <td><span t-field="line.name"/></td>
                                        <td class="text-end"><span t-field="line.price_unit"/></td>
                                        <td class="text-end"><span t-field="line.quantity"/></td>
                                        <td class="text-end">
                                            <t t-set="taxes" t-value="', '.join(tax.tax_label for tax in line.tax_ids if tax.tax_label)"/>
                                            <span t-out="taxes"/>
                                        </td>
                                        <td class="text-end fw-bold">
                                            <span t-field="line.total_amount"
                                                t-options='{"widget": "monetary", "display_currency": line.company_currency_id}'/>
                                        </td>
                                        <td><span t-field="line.state"/></td>
                                    </tr>
                                </tbody>
                            </table>
                            <div class="row justify-content-end o_total mt-n3">
                                <div class="col-4">
                                    <table class="table table-borderless">
                                        <tbody>
                                            <tr>
                                                <td>Untaxed Amount</td>
                                                <td class="text-end">
                                                    <t t-set="total_untaxed" t-value="sum(d.untaxed_amount for d in docs)"/>
                                                    <span t-esc="'%.2f' % total_untaxed"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td>Taxes</td>
                                                <td class="text-end">
                                                    <t t-set="total_tax" t-value="sum(d.tax_amount for d in docs)"/>
                                                    <span t-esc="'%.2f' % total_tax"/>
                                                </td>
                                            </tr>
                                            <tr class="fw-bold">
                                                <td>Total</td>
                                                <td class="text-end">
                                                    <t t-set="total" t-value="sum(d.total_amount for d in docs)"/>
                                                    <span t-esc="'%.2f' % total"/>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <template id="report_expense_summary">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page o_content_pdf">
                    <div class="oe_structure"></div>
                    <h2>Expenses Report</h2>
                    <div class="row o_header">
                        <div class="col-6">
                            <div class="row">
                                <div class="col-3 fw-bold"><span>Employee:</span></div>
                                <div class="col-9 text-muted">
                                    <span t-field="docs[0].employee_id.name"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="row" t-if="docs[0].manager_id.name">
                                <div class="col-3 fw-bold"><span>Manager:</span></div>
                                <div class="col-9 text-muted">
                                    <span t-field="docs[0].manager_id"/>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-3 fw-bold"><span>Paid by:</span></div>
                                <div class="col-9 text-muted">
                                    <span t-field="docs[0].payment_mode"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="oe_structure"></div>
                    <table class="o_has_total_table table table-borderless">
                        <thead>
                            <tr>
                                <th class="text-start">Date</th>
                                <th class="text-start">Name</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-end">Quantity</th>
                                <th class="text-end">Taxes</th>
                                <t t-set="foreign_currencies" t-value="any(o.currency_id != o.company_currency_id for o in docs)"/>
                                <th t-if="foreign_currencies" class="text-end">Subtotal in currency</th>
                                <th class="text-end">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="docs" t-as="line">
                                <td class="text-start">
                                    <span t-field="line.date"/>
                                </td>
                                <td t-att-class="'text-start' + (' o_overflow' if len(line.name) > 30 else '')">
                                    <span t-field="line.name"/>
                                </td>
                                <td class="text-end">
                                    <span t-field="line.price_unit"/>
                                </td>
                                <td class="text-end">
                                    <span t-field="line.quantity"/>
                                </td>
                                <td class="text-end">
                                    <t t-set="taxes" t-value="', '.join(tax.tax_label for tax in line.tax_ids if tax.tax_label)"/>
                                    <span t-out="taxes"/>
                                </td>
                                <td t-if="foreign_currencies" class="text-end">
                                    <span t-field="line.total_amount_currency"
                                        t-options='{"widget": "monetary", "display_currency": line.currency_id}'/>
                                </td>
                                <td class="text-end">
                                    <span t-field="line.total_amount"
                                        t-options='{"widget": "monetary", "display_currency": line.company_currency_id}'/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                    <div class="oe_structure"></div>
                    <div class="row justify-content-end o_total mt-n3">
                        <div class="col-4">
                            <table class="table table-borderless">
                                <tbody>
                                    <tr>
                                        <td>Untaxed Amount</td>
                                        <td class="text-end">
                                            <t t-set="total_untaxed" t-value="sum(docs.mapped('untaxed_amount'))"/>
                                            <span t-out="total_untaxed"
                                                t-options='{"widget": "monetary", "display_currency": docs[0].company_currency_id}'/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Taxes</td>
                                        <td class="text-end">
                                            <t t-set="total_tax" t-value="sum(docs.mapped('tax_amount'))"/>
                                            <span t-out="total_tax"
                                                t-options='{"widget": "monetary", "display_currency": docs[0].company_currency_id}'/>
                                        </td>
                                    </tr>
                                    <tr class="fw-bold">
                                        <td>Total</td>
                                        <td class="text-end">
                                            <t t-set="total_amt" t-value="sum(docs.mapped('total_amount'))"/>
                                            <span t-out="total_amt"
                                                t-options='{"widget": "monetary", "display_currency": docs[0].company_currency_id}'/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>

    <template id="report_expense_img">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="oe_structure"></div>
                    <div t-if="attachment and attachment.mimetype != 'application/pdf'">
                        <h3> <span t-out="attachment.res_name">Attachment Name</span> </h3>
                        <img t-att-src="attachment.image_src" class="o_attachment_pdf"/>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="action_report_hr_expense" model="ir.actions.report">
        <field name="name">Expenses Report</field>
        <field name="model">hr.expense</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hr_expense.report_expense</field>
        <field name="report_file">hr_expense.report_expense</field>
        <field name="print_report_name">'Expense - %s - %s' % (object.employee_id.name, (object.name).replace('/', ''))</field>
        <field name="binding_model_id" ref="model_hr_expense"/>
        <field name="binding_type">report</field>
    </record>

    <record id="action_report_expense_img" model="ir.actions.report">
        <field name="name">Expense Report Image</field>
        <field name="model">hr.expense</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hr_expense.report_expense_img</field>
        <field name="report_file">hr_expense.report_expense_img</field>
    </record>

    <record id="action_report_hr_expense_summary" model="ir.actions.report">
        <field name="name">Expense Summary</field>
        <field name="model">hr.expense</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hr_expense.report_expense_summary</field>
        <field name="report_file">hr_expense.report_expense_summary</field>
    </record>

</odoo>
