" %s"
msgstr ""
"ທ່ານບໍ່ສາມາດປະຕິເສດ:\n"
" %s"

#. module: hr_expense
#. odoo-python
#: code:addons/hr_expense/models/hr_expense.py:0
msgid "You cannot report expenses for different employees in the same report."
msgstr "ທ່ານບໍ່ສາມາດລາຍງານຄ່າໃຊ້ຈ່າຍຂອງພະນັກງານຫຼາຍຄົນໃນບົດລາຍງານດຽວກັນໄດ້."

#. module: hr_expense
#. odoo-python
#: code:addons/hr_expense/models/hr_expense.py:0
msgid "You cannot report the expenses without amount!"
msgstr "ທ່ານບໍ່ສາມາດລາຍງານຄ່າໃຊ້ຈ່າຍໂດຍບໍ່ມີຈຳນວນເງິນໄດ້!"

#. module: hr_expense
#. odoo-python
#: code:addons/hr_expense/models/hr_expense.py:0
msgid "You cannot report twice the same line!"
msgstr "ທ່ານບໍ່ສາມາດລາຍງານລາຍການດຽວກັນສອງຄັ້ງໄດ້!"

#. module: hr_expense
#. odoo-python
#: code:addons/hr_expense/models/hr_expense.py:0
msgid "You have no expense to report"
msgstr "ທ່ານບໍ່ມີຄ່າໃຊ້ຈ່າຍທີ່ຈະລາຍງານ"

#. module: hr_expense
#. odoo-python
#: code:addons/hr_expense/models/hr_expense.py:0
msgid "You need to have at least one category that can be expensed in your database to proceed!"
msgstr ""
"ທ່ານຈຳເປັນຕ້ອງມີຢ່າງໜ້ອຍໜຶ່ງໝວດໝູ່ທີ່ສາມາດເບີກຄ່າໃຊ້ຈ່າຍໄດ້ໃນຖານຂໍ້ມູນຂອງທ່ານເພື່ອດຳເນີນການຕໍ່!"

#. module: hr_expense
#: model_terms:ir.ui.view,arch_db:hr_expense.hr_expense_template_refuse_reason
