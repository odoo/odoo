#. module: hr_expense
#. odoo-python
#: code:addons/hr_expense/models/hr_expense.py:0
#, python-format
msgid "You cannot report expenses for different employees in the same report."
msgstr "ທ່ານບໍ່ສາມາດລາຍງານຄ່າໃຊ້ຈ່າຍຂອງພະນັກງານຫຼາຍຄົນໃນບົດລາຍງານດຽວກັນ."

#. module: hr_expense
#. odoo-python
#: code:addons/hr_expense/models/hr_expense.py:0
#, python-format
msgid "You cannot report the expenses without amount!"
msgstr "ທ່ານບໍ່ສາມາດລາຍງານຄ່າໃຊ້ຈ່າຍທີ່ບໍ່ມີຈຳນວນເງິນ!"

#. module: hr_expense
#. odoo-python
#: code:addons/hr_expense/models/hr_expense.py:0
#, python-format
