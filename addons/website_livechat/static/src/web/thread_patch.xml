<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="website_livechat.Thread" t-inherit="mail.Thread" t-inherit-mode="extension">
        <xpath expr="//*[hasclass('o-mail-Thread')]" position="before">
            <t t-set="visitor" t-value="props.thread.livechat_visitor_id"/>
            <div t-if="!env.inChatWindow and (visitor?.website_id or visitor?.history)" class="o-website_livechat-VisitorBanner py-4 px-4 d-flex gap-2 border-bottom">
                <span t-if="visitor.website_id">
                    <i class="me-1 fa fa-globe" aria-label="Website"/>
                    <span t-out="visitor.website_id.name"/>
                </span>
                <span t-if="visitor.history" t-att-title="visitor.history" class="d-flex align-items-center flex-grow-1 w-0 text-truncate">
                    <i class="me-1 fa fa-history" aria-label="History"/>
                    <span t-out="visitor.history" class="d-block text-truncate overflow-hidden"/>
                </span>
            </div>
        </xpath>
    </t>
</templates>
