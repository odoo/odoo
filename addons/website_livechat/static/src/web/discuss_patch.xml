<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="mail.Discuss" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o-mail-Discuss-threadAvatar')]" position="before">
            <div title="Avatar" t-if="thread.correspondent" class="me-2 d-flex justify-content-center">
                <img class="rounded o-website_livechat-Visitor-avatar o_object_fit_cover" t-att-src="thread.correspondent.persona.avatarUrl" alt="Avatar"/>
            </div>
        </xpath>
        <xpath expr="//t[@t-if='thread.allowDescription and (thread.is_editable or (!thread.is_editable and thread.description))']" position="after">
                <span title="Language" t-if="thread.visitor?.lang_name">
                    <i class="me-1 fa fa-comment-o" aria-label="Language"/>
                    <t t-out="thread.visitor?.lang_name"/>
                </span>
        </xpath>
    </t>
</templates>
