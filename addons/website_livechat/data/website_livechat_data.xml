<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            Note that the default website may change and the fields listed below
            will not automatically move to the new default website. Add fields to
            _get_settings_to_copy_onto_new_default_website() to copy them when
            the default website changes.
         -->
        <record id="base.default_website" model="website" forcecreate="False">
            <field name="channel_id" ref="im_livechat.im_livechat_channel_data"></field>
        </record>
    </data>
</odoo>
