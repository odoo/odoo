<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Job profiles (the possible outcomes) -->
        <record id="profile_developer" model="job.match.profile">
            <field name="name">Developer</field>
            <field name="sequence">1</field>
            <field name="posting_url">https://www.odoo.com/jobs/developer</field>
            <field name="description" type="html">
                <p>You love building things and solving problems with code.</p>
            </field>
        </record>

        <record id="profile_consultant" model="job.match.profile">
            <field name="name">Functional Consultant</field>
            <field name="sequence">2</field>
            <field name="posting_url">https://www.odoo.com/jobs/consultant</field>
            <field name="description" type="html">
                <p>You enjoy understanding clients and configuring solutions that fit them.</p>
            </field>
        </record>

        <record id="profile_bizdev" model="job.match.profile">
            <field name="name">Business Developer</field>
            <field name="sequence">3</field>
            <field name="posting_url">https://www.odoo.com/jobs/business-developer</field>
            <field name="description" type="html">
                <p>You thrive on meeting people, networking and closing deals.</p>
            </field>
        </record>

        <!-- The job-matching survey -->
        <record id="survey_job_match_demo" model="survey.survey">
            <field name="title">Which Odoo job fits you?</field>
            <field name="is_job_match" eval="True"/>
            <field name="access_mode">public</field>
            <field name="users_login_required" eval="False"/>
            <field name="questions_layout">page_per_question</field>
            <field name="description" type="html">
                <p>Answer a few quick questions and discover which Odoo role suits you best!</p>
            </field>
            <field name="description_done" type="html">
                <p>Thanks for playing! Here is your match.</p>
            </field>
        </record>

        <!-- Q1 -->
        <record id="q1" model="survey.question">
            <field name="survey_id" ref="survey_job_match_demo"/>
            <field name="title">What do you enjoy most?</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">1</field>
        </record>
        <record id="q1_a" model="survey.question.answer">
            <field name="question_id" ref="q1"/>
            <field name="value">Solving logic puzzles and building things</field>
            <field name="sequence">1</field>
        </record>
        <record id="q1_b" model="survey.question.answer">
            <field name="question_id" ref="q1"/>
            <field name="value">Helping people and explaining solutions</field>
            <field name="sequence">2</field>
        </record>
        <record id="q1_c" model="survey.question.answer">
            <field name="question_id" ref="q1"/>
            <field name="value">Meeting people and closing deals</field>
            <field name="sequence">3</field>
        </record>

        <!-- Q2 -->
        <record id="q2" model="survey.question">
            <field name="survey_id" ref="survey_job_match_demo"/>
            <field name="title">Pick a task you'd love</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">2</field>
        </record>
        <record id="q2_a" model="survey.question.answer">
            <field name="question_id" ref="q2"/>
            <field name="value">Writing code</field>
            <field name="sequence">1</field>
        </record>
        <record id="q2_b" model="survey.question.answer">
            <field name="question_id" ref="q2"/>
            <field name="value">Configuring software for a client</field>
            <field name="sequence">2</field>
        </record>
        <record id="q2_c" model="survey.question.answer">
            <field name="question_id" ref="q2"/>
            <field name="value">Pitching to a new customer</field>
            <field name="sequence">3</field>
        </record>

        <!-- Q3 -->
        <record id="q3" model="survey.question">
            <field name="survey_id" ref="survey_job_match_demo"/>
            <field name="title">How do you prefer to work?</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">3</field>
        </record>
        <record id="q3_a" model="survey.question.answer">
            <field name="question_id" ref="q3"/>
            <field name="value">Deep focus, alone or in a small team</field>
            <field name="sequence">1</field>
        </record>
        <record id="q3_b" model="survey.question.answer">
            <field name="question_id" ref="q3"/>
            <field name="value">Lots of client interaction</field>
            <field name="sequence">2</field>
        </record>
        <record id="q3_c" model="survey.question.answer">
            <field name="question_id" ref="q3"/>
            <field name="value">Out in the field, networking</field>
            <field name="sequence">3</field>
        </record>

        <!-- Q4: hard requirement (language knockout) -->
        <record id="q4" model="survey.question">
            <field name="survey_id" ref="survey_job_match_demo"/>
            <field name="title">Which languages can you work in?</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">4</field>
        </record>
        <record id="q4_a" model="survey.question.answer">
            <field name="question_id" ref="q4"/>
            <field name="value">Dutch and English</field>
            <field name="sequence">1</field>
        </record>
        <record id="q4_b" model="survey.question.answer">
            <field name="question_id" ref="q4"/>
            <field name="value">English only (no Dutch)</field>
            <field name="sequence">2</field>
        </record>

        <!-- Weights: each answer grants points to one or more profiles -->
        <!-- Q4: "English only" disqualifies the Business Developer role (requires Dutch) -->
        <record id="w_q4_b_biz_ko" model="job.match.answer.weight">
            <field name="answer_id" ref="q4_b"/><field name="profile_id" ref="profile_bizdev"/><field name="is_eliminating" eval="True"/><field name="points">0</field>
        </record>
        <!-- Q1 -->
        <record id="w_q1_a_dev" model="job.match.answer.weight">
            <field name="answer_id" ref="q1_a"/><field name="profile_id" ref="profile_developer"/><field name="points">3</field>
        </record>
        <record id="w_q1_a_cons" model="job.match.answer.weight">
            <field name="answer_id" ref="q1_a"/><field name="profile_id" ref="profile_consultant"/><field name="points">1</field>
        </record>
        <record id="w_q1_b_cons" model="job.match.answer.weight">
            <field name="answer_id" ref="q1_b"/><field name="profile_id" ref="profile_consultant"/><field name="points">3</field>
        </record>
        <record id="w_q1_b_biz" model="job.match.answer.weight">
            <field name="answer_id" ref="q1_b"/><field name="profile_id" ref="profile_bizdev"/><field name="points">1</field>
        </record>
        <record id="w_q1_c_biz" model="job.match.answer.weight">
            <field name="answer_id" ref="q1_c"/><field name="profile_id" ref="profile_bizdev"/><field name="points">3</field>
        </record>

        <!-- Q2 -->
        <record id="w_q2_a_dev" model="job.match.answer.weight">
            <field name="answer_id" ref="q2_a"/><field name="profile_id" ref="profile_developer"/><field name="points">3</field>
        </record>
        <record id="w_q2_b_cons" model="job.match.answer.weight">
            <field name="answer_id" ref="q2_b"/><field name="profile_id" ref="profile_consultant"/><field name="points">3</field>
        </record>
        <record id="w_q2_c_biz" model="job.match.answer.weight">
            <field name="answer_id" ref="q2_c"/><field name="profile_id" ref="profile_bizdev"/><field name="points">3</field>
        </record>

        <!-- Q3 -->
        <record id="w_q3_a_dev" model="job.match.answer.weight">
            <field name="answer_id" ref="q3_a"/><field name="profile_id" ref="profile_developer"/><field name="points">2</field>
        </record>
        <record id="w_q3_a_cons" model="job.match.answer.weight">
            <field name="answer_id" ref="q3_a"/><field name="profile_id" ref="profile_consultant"/><field name="points">1</field>
        </record>
        <record id="w_q3_b_cons" model="job.match.answer.weight">
            <field name="answer_id" ref="q3_b"/><field name="profile_id" ref="profile_consultant"/><field name="points">2</field>
        </record>
        <record id="w_q3_b_biz" model="job.match.answer.weight">
            <field name="answer_id" ref="q3_b"/><field name="profile_id" ref="profile_bizdev"/><field name="points">2</field>
        </record>
        <record id="w_q3_c_biz" model="job.match.answer.weight">
            <field name="answer_id" ref="q3_c"/><field name="profile_id" ref="profile_bizdev"/><field name="points">3</field>
        </record>

    </data>
</odoo>
