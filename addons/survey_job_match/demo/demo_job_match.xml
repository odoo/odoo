            <field name="survey_id" ref="survey_job_match_demo"/>
            <field name="title">What are you looking for?</field>
            <field name="question_type">simple_choice</field>
            <field name="sequence">1</field>
        </record>
        <record id="q1_a" model="survey.question.answer">
            <field name="question_id" ref="q1"/>
            <field name="value">A job at Odoo</field>
            <field name="sequence">1</field>
        </record>
        <record id="q1_b" model="survey.question.answer">
            <field name="question_id" ref="q1"/>
            <field name="value">An internship at Odoo</field>
            <field name="sequence">2</field>
        </record>
        <record id="q1_c" model="survey.question.answer">
            <field name="question_id" ref="q1"/>
            <field name="value">A student job</field>
            <field name="sequence">3</field>
            <field name="job_match_result_message" type="html">
                <p>Although we don't typically offer paid student jobs, we would still be happy to hear from you. You are welcome to email your specific situation to <a href="mailto:berecruitment@odoo.com">berecruitment@odoo.com</a> so we can see what might be possible.</p>
                <p>Alternatively, we encourage you to apply for one of our internships, which often include a nice reward and the potential for a full-time job offer for the best candidates afterwards.</p>
            </field>
        </record>

        <!-- Q1 eliminations: "A job at Odoo" rules out the internships -->
        <record id="e_q1_a_horeca" model="job.match.answer.weight">
            <field name="answer_id" ref="q1_a"/><field name="profile_id" ref="profile_bizdev_horeca"/><field name="is_eliminating" eval="True"/><field name="points">0</field>
        </record>
        <record id="e_q1_a_dint" model="job.match.answer.weight">
            <field name="answer_id" ref="q1_a"/><field name="profile_id" ref="profile_dev_intern"/><field name="is_eliminating" eval="True"/><field name="points">0</field>
        </record>
        <record id="e_q1_a_bint" model="job.match.answer.weight">
            <field name="answer_id" ref="q1_a"/><field name="profile_id" ref="profile_bizdev_intern"/><field name="is_eliminating" eval="True"/><field name="points">0</field>
        </record>
