<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="survey_survey_view_form_job_match" model="ir.ui.view">
        <field name="name">survey.survey.view.form.job.match</field>
        <field name="model">survey.survey</field>
        <field name="inherit_id" ref="survey.survey_survey_view_form"/>
        <field name="arch" type="xml">
            <!-- Stat button to configure the answer/profile weights -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="%(action_job_match_weights)d"
                    type="action"
                    class="oe_stat_button"
                    icon="fa-magic"
                    invisible="not is_job_match">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Match</span>
                        <span class="o_stat_text">Weights</span>
                    </div>
                </button>
            </xpath>

            <!-- Flag to turn the survey into a job-matching game -->
            <xpath expr="//field[@name='scoring_type'][@widget='radio']" position="before">
                <field name="is_job_match"/>
            </xpath>
        </field>
    </record>

</odoo>
