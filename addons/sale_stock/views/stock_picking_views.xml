<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="sale_stock_help_message_template" inherit_id="stock.help_message_template">
        <xpath expr="//p[@name='top_help_message']/t[@name='delivery_message']" position="replace">
            <t t-if="picking_type_code == 'outgoing'">
                No delivery yet! Automate them with sales orders.
            </t>
        </xpath>
        <xpath expr="//p[@name='bottom_help_message']/t[@name='delivery_message']" position="replace">
            <t t-if="picking_type_code == 'outgoing'">
                Reduce back orders with reservations, locations management, smart
                replenishment propositions, shipping connectors, barcode scanner, etc.
            </t>
        </xpath>
        <xpath expr="//p[@name='bottom_help_message']" position="after">
            <a t-if="picking_type_code == 'outgoing'" class="btn btn-secondary" name="sale.action_orders" type="action">Sales Orders</a>
        </xpath>
    </template>
    <record model="ir.ui.view" id="view_picking_form">
    <field name="name">sale.stock.view.picking.form</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"></field>
        <field name="arch" type="xml">
            <field name="origin" position="after">
                <field
                    name="return_reason_id"
                    invisible="not (
                        allow_spontaneous_returns
                        and return_id
                        and picking_type_code == 'incoming'
                    )"
                />
            </field>
            <xpath expr="//field[@name='move_type']" position="before">
                <field name="sale_id"/>
            </xpath>
            <xpath expr="//button[@name='action_return']" position="attributes">
                <attribute name="invisible">not show_return or not (state == 'done' or sale_id)</attribute>
            </xpath>
        </field>
    </record>

    <!-- Stock Picking Return -->
    <!-- Views -->
    <record id="stock_picking_return_report_graph" model="ir.ui.view">
         <field name="name">stock.picking.return.report.graph</field>
         <field name="model">stock.picking</field>
         <field name="arch" type="xml">
             <graph sample="1">
                 <field name="scheduled_date" interval="week" type="col"/>
                 <field name="return_reason_id" type="row"/>
             </graph>
         </field>
    </record>

    <record id="stock_picking_return_report_pivot" model="ir.ui.view">
         <field name="name">stock.picking.return.report.pivot</field>
         <field name="model">stock.picking</field>
         <field name="arch" type="xml">
             <pivot sample="1">
                 <field name="scheduled_date" interval="week" type="col"/>
                 <field name="return_reason_id" type="row"/>
             </pivot>
         </field>
    </record>

    <!-- Actions -->
    <record id="action_stock_picking_return_report" model="ir.actions.act_window">
        <field name="name">Returns</field>
        <field name="res_model">stock.picking</field>
        <field name="domain">
            [('picking_type_id.code', '=', 'incoming'), ('return_id', '!=', False)]
        </field>
        <field name="context">{'search_default_group_by_return_reason': 1}</field>
        <field name="view_mode">graph,pivot,list,form</field>
    </record>

    <record id="action_stock_picking_return_report_graph" model="ir.actions.act_window.view">
        <field name="sequence" eval="5"/>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="stock_picking_return_report_graph"/>
        <field name="act_window_id" ref="action_stock_picking_return_report"/>
    </record>

    <record id="action_stock_picking_return_report_pivot" model="ir.actions.act_window.view">
        <field name="sequence" eval="10"/>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="stock_picking_return_report_pivot"/>
        <field name="act_window_id" ref="action_stock_picking_return_report"/>
    </record>

    <!-- Menus -->
    <menuitem
        name="Returns"
        id="menu_stock_picking_return_report"
        action="sale_stock.action_stock_picking_return_report"
        parent="stock.menu_warehouse_report"
        sequence="350"
    />

</odoo>
