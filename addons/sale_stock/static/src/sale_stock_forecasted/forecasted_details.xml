<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="sale_stock.ForecastedDetails" t-inherit="stock.ForecastedDetails" t-inherit-mode="extension">
        <xpath expr="//tr[@name='draft_picking_out']" position="after">
            <tr t-if="props.docs.product[line.product.id].draft_sale_qty.out" name="draft_so_out" t-attf-class="#{props.docs.product[line.product.id].draft_sale_orders_matched and 'table-info'} #{multipleProducts and 'collapse show' or ''} collapseGroup_#{line.product.id}">
                <td>Quotations</td>
                <td class="text-end">
                    <t t-out="_formatFloat(-props.docs.product[line.product.id].draft_sale_qty.out)"/> <t t-out="line.uom_id.display_name"/>
                </td>
                <td>
                    <t t-foreach="props.docs.product[line.product.id].draft_sale_orders" t-as="sale_order" t-key="sale_order_index">
                        <t t-if="sale_order_index > 0"> | </t>
                        <a t-attf-href="#" t-out="sale_order.name"
                            class="fw-bold"
                            t-on-click.prevent="() => this.props.openView('sale.order', 'form', sale_order.id)"/>
                    </t>
                </td>
            </tr>
        </xpath>
        <xpath expr="//td[@name='usedby_cell']" position="inside">
            <span t-if="line.move_out and line.move_out.picking_id and line.move_out.picking_id.sale_id">
                | <span t-out="line.move_out.picking_id.sale_id.partner_id.display_name"/>
            </span>
        </xpath>
    </t>
</templates>
