<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_invoice_document" inherit_id="account.report_invoice_document" primary="True">
        <t name="invoice_title" position="replace">
            <t name="invoice_title" t-if="o.company_id.l10n_au_is_gst_registered">Tax Invoice</t>
            <t t-else="">$0</t>
        </t>
        <t name="draft_invoice_title" position="replace">
            <t name="draft_invoice_title" t-if="o.company_id.l10n_au_is_gst_registered">Draft Tax Invoice</t>
            <t t-else="">$0</t>
        </t>
        <t name="cancelled_invoice_title" position="replace">
            <t name="cancelled_invoice_title" t-if="o.company_id.l10n_au_is_gst_registered">Cancelled Tax Invoice</t>
            <t t-else="">$0</t>
        </t>
        <t name="credit_note_title" position="replace">
            <t name="credit_note_title" t-if="o.company_id.l10n_au_is_gst_registered">Tax Credit Note</t>
            <t t-else="">$0</t>
        </t>
        <t name="draft_credit_note_title" position="replace">
            <t name="draft_credit_note_title" t-if="o.company_id.l10n_au_is_gst_registered">Draft Tax Credit Note</t>
            <t t-else="">$0</t>
        </t>
        <t name="cancelled_credit_note_title" position="replace">
            <t name="cancelled_credit_note_title" t-if="o.company_id.l10n_au_is_gst_registered">Cancelled Tax Credit Note</t>
            <t t-else="">$0</t>
        </t>
        <t name="vendor_credit_note_title" position="replace">
            <t name="vendor_credit_note_title" t-if="o.company_id.l10n_au_is_gst_registered">Tax Vendor Credit Note</t>
            <t t-else="">$0</t>
        </t>
        <t name="vendor_bill_title" position="replace">
            <t name="vendor_bill_title" t-if="o.company_id.l10n_au_is_gst_registered">Tax Vendor Bill</t>
            <t t-else="">$0</t>
        </t>
        <t name="proforma_invoice_title" position="replace">
            <t name="proforma_invoice_title" t-if="o.company_id.l10n_au_is_gst_registered">Proforma Tax Invoice</t>
            <t t-else="">$0</t>
        </t>
        <t name="draft_proforma_invoice_title" position="replace">
            <t name="draft_proforma_invoice_title" t-if="o.company_id.l10n_au_is_gst_registered">Draft Proforma Tax Invoice</t>
            <t t-else="">$0</t>
        </t>
        <t name="cancelled_proforma_invoice_title" position="replace">
            <t name="cancelled_proforma_invoice_title" t-if="o.company_id.l10n_au_is_gst_registered">Cancelled Proforma Tax Invoice</t>
            <t t-else="">$0</t>
        </t>
        <t name="proforma_credit_note_title" position="replace">
            <t name="proforma_credit_note_title" t-if="o.company_id.l10n_au_is_gst_registered">Proforma Tax Credit Note</t>
            <t t-else="">$0</t>
        </t>
        <t name="draft_proforma_credit_note_title" position="replace">
            <t name="draft_proforma_credit_note_title" t-if="o.company_id.l10n_au_is_gst_registered">Draft Proforma Tax Credit Note</t>
            <t t-else="">$0</t>
        </t>
        <t name="cancelled_proforma_credit_note_title" position="replace">
            <t name="cancelled_proforma_credit_note_title" t-if="o.company_id.l10n_au_is_gst_registered">Cancelled Proforma Tax Credit Note</t>
            <t t-else="">$0</t>
        </t>
        <t name="proforma_vendor_credit_note_title" position="replace">
            <t name="proforma_vendor_credit_note_title" t-if="o.company_id.l10n_au_is_gst_registered">Proforma Tax Vendor Credit Note</t>
            <t t-else="">$0</t>
        </t>
        <t name="proforma_vendor_bill_title" position="replace">
            <t name="proforma_vendor_bill_title" t-if="o.company_id.l10n_au_is_gst_registered">Proforma Tax Vendor Bill</t>
            <t t-else="">$0</t>
        </t>
        <xpath expr="//t[@t-if='o.partner_bank_id']//span[@t-field='o.partner_bank_id']" position="after">
            <t t-if="o.partner_bank_id.country_id.code == 'AU' and o.partner_bank_id.clearing_number">
                - <span class="fw-bold" t-out="o.partner_bank_id.clearing_number"/>
            </t>
        </xpath>
    </template>

    <!-- Workaround for Studio reports, see odoo/odoo#60660 -->
    <template id="report_invoice" inherit_id="account.report_invoice">
        <xpath expr='//t[@t-call="account.report_invoice_document"]' position="after">
            <t t-elif="o._get_name_invoice_report() == 'l10n_au.report_invoice_document'"
               t-call="l10n_au.report_invoice_document"
               t-lang="lang"/>
        </xpath>
    </template>
</odoo>
