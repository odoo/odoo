<?xml version="1.0"?>

<odoo>
    <record id="estate_property_offer_list_view" model="ir.ui.view">
        <field name="name">estate.property.offer.list_view</field>
        <field name="model">estate.property.offer</field>
        <field name="arch" type="xml">
            <list string="Estate Property Offer List View">
                <field name="price" />
                <field name="partner_id" />
                <field name="status" />
            </list>
        </field>
    </record>

    <!-- without this form view, the default form with property_id will be used
    it will also show to property, in which user can select another property
    which is technically wrong -->
    <record id="estate_property_offer_form_view" model="ir.ui.view">
        <field name="name">estate.property.offer.form_view</field>
        <field name="model">estate.property.offer</field>
        <field name="arch" type="xml">
            <form string="Estate Property Offer">
                <sheet>
                    <group>
                        <field name="price" />
                        <field name="partner_id" />
                        <field name="status" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>