<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="wb_teacher_list_view" model="ir.ui.view">
        <field name="name">wb.teacher.list.view</field>
        <field name="model">wb.teacher</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="yos"/>
                <field name="subject"/>
                <field name="isActive"/>
            </list>
        </field>
    </record>

    <record id="wb_teacher_form_view" model="ir.ui.view">
        <field name="name">wb.teacher.form.view</field>
        <field name="model">wb.teacher</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="name"/>
                    <field name="yos"/>
                    <field name="subject"/>
                    <field name="age"/>
                    <field name="salary"/>
                    <field name="address"/>
                    <field name="isActive"/>
                </group>
            </form>
        </field>
    </record>

    <record id="wb_teacher_action" model="ir.actions.act_window">
        <field name="name">Teacher</field>
        <field name="res_model">wb.teacher</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>