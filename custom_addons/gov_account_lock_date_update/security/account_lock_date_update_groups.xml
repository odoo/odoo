<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="privilege_account_lock_date_update" model="res.groups.privilege">
            <field name="name">Lock Date Update</field>
        </record>

        <record id="group_account_lock_date_manager" model="res.groups">
            <field name="name">Lock Date Manager</field>
            <field name="privilege_id" ref="gov_account_lock_date_update.privilege_account_lock_date_update"/>
            <field name="implied_ids" eval="[(4, ref('account.group_account_manager'))]"/>
        </record>

        <record id="rule_account_lock_date_log_company" model="ir.rule">
            <field name="name">Lock Date Log multi-company</field>
            <field name="model_id" ref="gov_account_lock_date_update.model_account_lock_date_log"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('account.group_account_user'))]"/>
        </record>
    </data>
</odoo>



