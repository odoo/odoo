<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_lock_date_log_view_list" model="ir.ui.view">
        <field name="name">account.lock.date.log.list</field>
        <field name="model">account.lock.date.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="date_applied"/>
                <field name="company_id"/>
                <field name="user_id"/>
                <field name="lock_date_old"/>
                <field name="lock_date_new"/>
            </list>
        </field>
    </record>

    <record id="account_lock_date_log_view_form" model="ir.ui.view">
        <field name="name">account.lock.date.log.form</field>
        <field name="model">account.lock.date.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="date_applied" readonly="1"/>
                        <field name="company_id" readonly="1"/>
                        <field name="user_id" readonly="1"/>
                        <field name="lock_date_old" readonly="1"/>
                        <field name="lock_date_new" readonly="1"/>
                        <field name="note" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="account_lock_date_log_action" model="ir.actions.act_window">
        <field name="name">Lock Date Change Log</field>
        <field name="res_model">account.lock.date.log</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="account_lock_date_log_menu"
        name="Lock Date Logs"
        parent="account.menu_finance_configuration"
        action="account_lock_date_log_action"
        sequence="75"
        groups="gov_account_lock_date_update.group_account_lock_date_manager"
    />
</odoo>


