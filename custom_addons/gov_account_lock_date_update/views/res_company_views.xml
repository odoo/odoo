<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_company_view_form_inherit_lock_date" model="ir.ui.view">
        <field name="name">res.company.form.inherit.lock.date.update</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Accounting Lock Dates">
                    <field name="fiscalyear_lock_date" readonly="1"/>
                    <button
                        name="action_open_lock_date_wizard"
                        string="Update Lock Date"
                        type="object"
                        class="btn-primary"
                        groups="gov_account_lock_date_update.group_account_lock_date_manager"
                    />
                </group>
            </xpath>
        </field>
    </record>
</odoo>


