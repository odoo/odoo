<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_br_account" model="ir.ui.view">
        <field name="name">account.move.form.br.account</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Fiscal BR">
                    <group>
                        <field name="regime_tributario"/>
                        <field name="natureza_operacao"/>
                        <field name="finalidade_emissao"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>

