<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_br_account" model="ir.ui.view">
        <field name="name">res.company.form.br.account</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group" position="inside">
                <group string="Fiscal BR">
                    <field name="regime_tributario"/>
                    <field name="period_lock_date"/>
                    <field name="certificado_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>

