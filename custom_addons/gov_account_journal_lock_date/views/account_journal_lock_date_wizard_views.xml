<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_journal_lock_date_wizard_view_form" model="ir.ui.view">
        <field name="name">account.journal.lock.date.wizard.form</field>
        <field name="model">account.journal.lock.date.wizard</field>
        <field name="arch" type="xml">
            <form string="Update Journal Lock Date">
                <group>
                    <field name="journal_id"/>
                    <field name="journal_lock_date"/>
                    <field name="lock_date_note"/>
                </group>
                <footer>
                    <button name="action_apply" type="object" string="Apply" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="account_journal_lock_date_wizard_action" model="ir.actions.act_window">
        <field name="name">Update Journal Lock Date</field>
        <field name="res_model">account.journal.lock.date.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="account_journal_lock_date_wizard_view_form"/>
        <field name="target">new</field>
    </record>
</odoo>

