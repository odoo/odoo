<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Keep the primary finance app/menu aligned with Enterprise naming -->
    <record id="account.menu_finance" model="ir.ui.menu">
        <field name="name">Accounting</field>
        <field name="web_icon">account,static/description/icon.png</field>
    </record>

    <!-- Align Settings app label from Invoicing to Accounting -->
    <record id="view_res_config_settings_accountant_branding" model="ir.ui.view">
        <field name="name">res.config.settings.accountant.branding</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='account']" position="attributes">
                <attribute name="data-string">Accounting</attribute>
                <attribute name="string">Accounting</attribute>
            </xpath>
        </field>
    </record>
</odoo>
