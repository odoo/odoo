<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gov_auditoria_diligencia_wizard_form" model="ir.ui.view">
        <field name="name">gov.auditoria.diligencia.wizard.form</field>
        <field name="model">gov.auditoria.diligencia.wizard</field>
        <field name="arch" type="xml">
            <form string="Registrar Diligencia">
                <group>
                    <field name="ciclo_id" readonly="1"/>
                    <field name="data_evento"/>
                    <field name="descricao"/>
                    <field name="criar_prazo"/>
                    <field name="prazo_dias" invisible="not criar_prazo"/>
                    <field name="documento_ids" widget="many2many_binary"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Registrar" type="object" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_gov_auditoria_acordao_wizard_form" model="ir.ui.view">
        <field name="name">gov.auditoria.acordao.wizard.form</field>
        <field name="model">gov.auditoria.acordao.wizard</field>
        <field name="arch" type="xml">
            <form string="Registrar Acordao">
                <group>
                    <field name="ciclo_id" readonly="1"/>
                    <field name="tipo_decisao"/>
                    <field name="numero_acordao"/>
                    <field name="data_acordao"/>
                    <field name="data_publicacao"/>
                    <field name="prazo_recurso_dias"/>
                    <field name="valor_condenacao"/>
                    <field name="ementa"/>
                    <field name="attachment_ids" widget="many2many_binary"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Registrar" type="object" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_gov_auditoria_apontamento_resposta_wizard_form" model="ir.ui.view">
        <field name="name">gov.auditoria.apontamento.resposta.wizard.form</field>
        <field name="model">gov.auditoria.apontamento.resposta.wizard</field>
        <field name="arch" type="xml">
            <form string="Registrar Resposta">
                <group>
                    <field name="ciclo_id" readonly="1"/>
                    <field name="apontamento_id"/>
                    <field name="data_resposta"/>
                    <field name="protocolo_externo"/>
                    <field name="marcar_prazo_cumprido"/>
                    <field name="resposta"/>
                    <field name="attachment_ids" widget="many2many_binary"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Registrar" type="object" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_gov_auditoria_protocolo_wizard_form" model="ir.ui.view">
        <field name="name">gov.auditoria.protocolo.wizard.form</field>
        <field name="model">gov.auditoria.protocolo.wizard</field>
        <field name="arch" type="xml">
            <form string="Registrar Protocolo de Envio">
                <group>
                    <field name="ciclo_id" readonly="1"/>
                    <field name="protocolo_externo"/>
                    <field name="data_envio"/>
                    <field name="documento_ids" widget="many2many_tags"/>
                    <field name="recibo_attachment_id"/>
                    <field name="observacao"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Protocolar" type="object" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
