<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="privilege_gov_auditoria" model="res.groups.privilege">
        <field name="name">GOV Auditoria</field>
        <field name="sequence">95</field>
    </record>

    <record id="group_auditoria_user" model="res.groups">
        <field name="name">GOV Auditoria / Usuario</field>
        <field name="privilege_id" ref="gov_auditoria.privilege_gov_auditoria"/>
        <field name="implied_ids" eval="[(4, ref('gov_base.group_gov_operador'))]"/>
    </record>

    <record id="group_auditoria_manager" model="res.groups">
        <field name="name">GOV Auditoria / Gestor</field>
        <field name="privilege_id" ref="gov_auditoria.privilege_gov_auditoria"/>
        <field name="implied_ids" eval="[(4, ref('gov_auditoria.group_auditoria_user'))]"/>
    </record>

    <record id="group_auditoria_admin" model="res.groups">
        <field name="name">GOV Auditoria / Administrador</field>
        <field name="privilege_id" ref="gov_auditoria.privilege_gov_auditoria"/>
        <field name="implied_ids" eval="[(4, ref('gov_auditoria.group_auditoria_manager'))]"/>
    </record>

    <record id="group_auditoria_auditor" model="res.groups">
        <field name="name">GOV Auditoria / Auditor Externo</field>
        <field name="privilege_id" ref="gov_auditoria.privilege_gov_auditoria"/>
    </record>
</odoo>
