<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<t t-name="gov_processos.GovDocumentBuilder">
  <div class="gov-builder-root">

    <!-- TOPBAR -->
    <div class="gov-builder-topbar">
      <div class="gov-builder-topbar-left">
        <button class="gov-btn gov-btn-ghost" t-on-click="onBack" title="Voltar ao documento">
          <i class="fa fa-arrow-left"/> <t t-esc="backLabel"/>
        </button>
        <span class="gov-builder-docname" t-if="state.doc">
          <i class="fa fa-file-text-o"/> <t t-esc="state.doc.name"/>
        </span>
      </div>
      <div class="gov-builder-topbar-center">
        <span class="gov-builder-title">✦ Construtor Visual de Documento</span>
        <div class="gov-builder-mode-switch">
          <button class="gov-btn"
                  t-att-class="state.editMode === 'visual' ? 'gov-btn-primary' : 'gov-btn-secondary'"
                  t-on-click="() => this.setEditMode('visual')">
            <i class="fa fa-th-large"/> Visual
          </button>
          <button class="gov-btn"
                  t-att-class="state.editMode === 'typst' ? 'gov-btn-primary' : 'gov-btn-secondary'"
                  t-on-click="() => this.setEditMode('typst')">
            <i class="fa fa-code"/> Typst
          </button>
        </div>
      </div>
      <div class="gov-builder-topbar-right">
        <span class="gov-builder-badge" t-esc="builderBadge"/>
        <button class="gov-btn gov-btn-secondary" t-on-click="onGeneratePdf"
                t-att-disabled="state.saving or isLocked">
          <i class="fa fa-file-pdf-o"/> Gerar PDF
        </button>
        <button class="gov-btn gov-btn-primary" t-on-click="onSave"
                t-att-disabled="state.saving or isLocked">
          <i t-att-class="state.saving ? 'fa fa-spinner fa-spin' : 'fa fa-save'"/>
          <t t-if="state.saving">Salvando...</t>
          <t t-else="">Salvar Documento</t>
        </button>
      </div>
    </div>

    <!-- LOADING -->
    <div t-if="state.loading" class="gov-builder-loading">
      <i class="fa fa-spinner fa-spin fa-2x"/>
      <p>Carregando documento...</p>
    </div>

    <!-- MAIN LAYOUT -->
    <div t-elif="state.editMode === 'visual'" class="gov-builder-layout">

      <!-- SIDEBAR: catálogo de blocos -->
      <div class="gov-builder-sidebar">
        <div class="gov-sidebar-header">
          <span class="gov-sidebar-title">
            <i class="fa fa-th-large"/> Biblioteca de Blocos
          </span>
          <input
            class="gov-sidebar-search"
            type="text"
            placeholder="Buscar bloco..."
            t-model="state.searchQuery"
          />
        </div>
        <div class="gov-sidebar-blocks">
          <t t-foreach="filteredCatalog" t-as="blockDef" t-key="blockDef.type">
            <div
              class="gov-catalog-block"
              draggable="true"
              t-on-dragstart="(ev) => this.onCatalogDragStart(ev, blockDef)"
              t-on-click="() => this.addBlock(blockDef.type)"
              t-att-title="blockDef.description"
            >
              <span class="gov-catalog-block-label">
                <t t-esc="blockDef.label"/>
              </span>
              <span class="gov-catalog-block-desc">
                <t t-esc="blockDef.description"/>
              </span>
              <span class="gov-catalog-block-hint">
                <i class="fa fa-arrows-alt"/> arraste ou clique
              </span>
            </div>
          </t>
        </div>
      </div>

      <!-- PRANCHETA / CANVAS -->
      <div class="gov-builder-canvas-wrap">
        <div class="gov-builder-context-strip" t-if="state.recordContext.process_number or state.recordContext.doc_name">
          <div class="gov-builder-context-main">
            <span class="gov-builder-context-kicker">Registro Vinculado</span>
            <strong>
              <t t-esc="state.recordContext.doc_type_label or state.doc?.name or 'Documento'"/>
            </strong>
            <span class="gov-builder-context-text">
              Processo <t t-esc="state.recordContext.process_number or '—'"/> ·
              <t t-esc="state.recordContext.process_subject or 'Sem assunto'"/>
            </span>
          </div>
          <div class="gov-builder-context-side">
            <span class="gov-builder-badge" t-if="state.builderTemplate?.name">
              <t t-esc="state.builderTemplate.name"/>
            </span>
            <span class="gov-builder-badge">
              <t t-esc="state.recordContext.company_name or 'UG não informada'"/>
            </span>
          </div>
        </div>

        <!-- Drop zone: início da lista -->
        <div
          class="gov-drop-zone"
          t-att-class="state.dragOverIndex === 0 ? 'gov-drop-zone--active' : ''"
          t-on-dragover="(ev) => this.onCanvasDragOver(ev, 0)"
          t-on-dragleave="onCanvasDragLeave"
          t-on-drop="(ev) => this.onCanvasDrop(ev, 0)"
        />

        <!-- Blocos na prancheta -->
        <t t-foreach="state.blocks" t-as="block" t-key="block.id">

          <!-- Bloco -->
          <div
            class="gov-canvas-block"
            t-att-class="state.activeBlockId === block.id ? 'gov-canvas-block--active' : ''"
            draggable="true"
            t-on-dragstart="(ev) => this.onBlockDragStart(ev, block_index)"
          >
            <!-- Cabeçalho do bloco -->
            <div class="gov-block-header">
              <span class="gov-block-handle" title="Arrastar para reordenar">
                <i class="fa fa-grip-vertical"/>
              </span>
              <span class="gov-block-type-label">
                <t t-esc="block.label"/>
              </span>
              <div class="gov-block-actions">
                <button class="gov-block-btn" title="Mover para cima"
                        t-on-click="() => this.moveUp(block_index)"
                        t-att-disabled="block_index === 0">
                  <i class="fa fa-chevron-up"/>
                </button>
                <button class="gov-block-btn" title="Mover para baixo"
                        t-on-click="() => this.moveDown(block_index)"
                        t-att-disabled="block_index === state.blocks.length - 1">
                  <i class="fa fa-chevron-down"/>
                </button>
                <button class="gov-block-btn gov-block-btn--edit" title="Editar conteúdo"
                        t-if="block.editable"
                        t-on-click="() => this.toggleEdit(block.id)">
                  <i t-att-class="state.activeBlockId === block.id ? 'fa fa-check' : 'fa fa-pencil'"/>
                </button>
                <button class="gov-block-btn gov-block-btn--danger" title="Remover bloco"
                        t-on-click="() => this.removeBlock(block.id)">
                  <i class="fa fa-trash"/>
                </button>
              </div>
            </div>

            <!-- Preview do bloco -->
            <div class="gov-block-preview" t-if="state.activeBlockId !== block.id">
              <GovBlockPreview block="block" bindings="state.recordContext"/>
            </div>

            <!-- Editor inline quando ativo -->
            <div class="gov-block-editor" t-if="state.activeBlockId === block.id">
              <GovBlockEditor block="block"
                              bindings="state.recordContext"
                              slashState="state.slashMenu"
                              slashCommands="state.slashMenu.commands"
                              onUpdate="(field, val) => this.updateBlockContent(block.id, field, val)"
                              onRichTextInput="(blockId, field, ev) => this.onRichTextInput(blockId, field, ev)"
                              onRichTextKeydown="(blockId, ev) => this.onRichTextKeydown(blockId, ev)"
                              onSlashCommandSelect="(blockId, command) => this.onSlashCommandSelect(blockId, command)"/>
            </div>
          </div>

          <!-- Drop zone entre blocos -->
          <div
            class="gov-drop-zone"
            t-att-class="state.dragOverIndex === block_index + 1 ? 'gov-drop-zone--active' : ''"
            t-on-dragover="(ev) => this.onCanvasDragOver(ev, block_index + 1)"
            t-on-dragleave="onCanvasDragLeave"
            t-on-drop="(ev) => this.onCanvasDrop(ev, block_index + 1)"
          />

        </t>

        <!-- Estado vazio -->
        <div class="gov-canvas-empty" t-if="state.blocks.length === 0">
          <img class="gov-canvas-empty-art"
               src="/gov_processos/static/src/img/gov_builder_empty_state.svg"
               alt="Ilustração do construtor visual"/>
          <i class="fa fa-hand-pointer-o fa-3x gov-canvas-empty-icon"/>
          <p>Arraste blocos da biblioteca ou clique neles para adicionar</p>
          <p class="gov-canvas-empty-hint">Cada bloco representa uma seção do documento</p>
        </div>
      </div>
    </div>

    <div t-else="" class="gov-builder-editor-wrap">
      <div class="gov-typst-workbench">
        <div class="gov-typst-panel">
          <div class="gov-typst-panel-head">
            <div>
              <div class="gov-typst-panel-title">Codigo Typst Completo</div>
              <div class="gov-typst-panel-hint">
                O conteúdo salvo aqui atualiza diretamente o <code>typst_source</code> do documento.
              </div>
              <div class="gov-typst-panel-shortcuts">
                Use o painel lateral para validar, depurar com IA, corrigir ou completar no cursor.
              </div>
            </div>
            <div class="gov-typst-panel-side">
              <img class="gov-typst-panel-art"
                   src="/gov_processos/static/src/img/gov_builder_typst_panel.svg"
                   alt="Ilustração do editor Typst"/>
              <div class="gov-typst-panel-actions">
                <span class="gov-builder-badge">Fonte principal do PDF</span>
                <button class="gov-btn gov-btn-secondary" t-on-click="scrollTypstToTop">
                  <i class="fa fa-arrow-up"/> Topo
                </button>
                <button class="gov-btn gov-btn-secondary" t-on-click="scrollTypstToBottom">
                  <i class="fa fa-arrow-down"/> Fim
                </button>
              </div>
            </div>
          </div>
          <textarea
            class="gov-typst-textarea"
            spellcheck="false"
            t-ref="typstEditor"
            t-att-readonly="isLocked"
            t-att-value="state.typstSource"
            t-on-input="onTypstInput"
            t-on-paste="onTypstPaste"
            placeholder="Cole ou edite o documento Typst completo aqui."
          />
        </div>

        <div class="gov-typst-assistant-card">
          <div class="gov-typst-assistant-head">
            <div>
              <div class="gov-typst-panel-title">Assistente Typst</div>
              <div class="gov-typst-panel-hint">
                Validação local e apoio do Ollama do ai_gov para debug, correção e autocomplete.
              </div>
            </div>
            <img class="gov-typst-assistant-art"
                 src="/gov_processos/static/src/img/gov_builder_typst_ai.svg"
                 alt="Ilustração do assistente Typst"/>
          </div>

          <div class="gov-typst-toolbar">
            <span class="gov-builder-badge" t-if="state.assistantInfo" t-esc="assistantBadge"/>
            <button class="gov-btn gov-btn-secondary"
                    t-on-click="onQuickEscapeCurrency"
                    t-att-disabled="isLocked or !hasCurrencyRisk">
              <i class="fa fa-money"/> Escapar R$
            </button>
            <button class="gov-btn gov-btn-secondary"
                    t-on-click="onValidateTypst"
                    t-att-disabled="state.validatingTypst">
              <i t-att-class="state.validatingTypst ? 'fa fa-spinner fa-spin' : 'fa fa-stethoscope'"/>
              <t t-if="state.validatingTypst">Validando...</t>
              <t t-else="">Validar</t>
            </button>
          </div>

          <div class="gov-typst-assistant-section">
            <label class="gov-typst-assistant-label">Pedido para a IA</label>
            <textarea
              class="gov-typst-assistant-prompt"
              t-att-value="state.assistantPrompt"
              t-on-input="onAssistantPromptInput"
              placeholder="Ex.: explique o erro da tabela da seção 8; complete a checklist; corrija apenas o bloco selecionado."
            />
            <div class="gov-typst-assistant-footnote">
              O autocomplete usa a posição atual do cursor ou a seleção ativa do editor.
            </div>
          </div>

          <div class="gov-typst-toolbar gov-typst-toolbar--stacked">
            <button class="gov-btn gov-btn-secondary"
                    t-on-click="() => this.onRunTypstAssistant('debug')"
                    t-att-disabled="state.assistantBusy">
              <i t-att-class="state.assistantBusy and state.assistantMode === 'debug' ? 'fa fa-spinner fa-spin' : 'fa fa-bug'"/>
              Diagnosticar IA
            </button>
            <button class="gov-btn gov-btn-secondary"
                    t-on-click="() => this.onRunTypstAssistant('fix')"
                    t-att-disabled="state.assistantBusy or isLocked">
              <i t-att-class="state.assistantBusy and state.assistantMode === 'fix' ? 'fa fa-spinner fa-spin' : 'fa fa-magic'"/>
              Corrigir com IA
            </button>
            <button class="gov-btn gov-btn-primary"
                    t-on-click="() => this.onRunTypstAssistant('autocomplete')"
                    t-att-disabled="state.assistantBusy or isLocked">
              <i t-att-class="state.assistantBusy and state.assistantMode === 'autocomplete' ? 'fa fa-spinner fa-spin' : 'fa fa-plus-circle'"/>
              Autocompletar IA
            </button>
          </div>

          <div class="gov-typst-status-card">
            <div class="gov-typst-status-head">
              <span class="gov-typst-status-title">Saúde do documento</span>
              <span t-att-class="typstStatusClass" t-esc="typstStatusLabel"/>
            </div>
            <div class="gov-typst-status-message">
              <t t-esc="state.typstValidation?.compile_message or 'Ainda não houve uma validação recente do código.'"/>
            </div>
            <div class="gov-typst-status-meta" t-esc="typstStatsLabel"/>
          </div>

          <div class="gov-typst-status-card">
            <div class="gov-typst-status-head">
              <span class="gov-typst-status-title">Diagnósticos</span>
              <span class="gov-builder-badge" t-esc="String(typstDiagnostics.length)"/>
            </div>
            <div t-if="typstDiagnostics.length" class="gov-typst-diagnostic-list">
              <t t-foreach="typstDiagnostics" t-as="diagnostic" t-key="(diagnostic.code || 'diag') + '_' + diagnostic_index">
                <div class="gov-typst-diagnostic-item"
                     t-att-class="'gov-typst-diagnostic-item--' + (diagnostic.severity || 'info')">
                  <div class="gov-typst-diagnostic-head">
                    <span class="gov-typst-diagnostic-source">
                      <t t-esc="diagnostic.source or 'local'"/>
                    </span>
                    <span class="gov-typst-diagnostic-location"
                          t-if="diagnostic.line">
                      <t t-esc="'L' + diagnostic.line + (diagnostic.column ? ':' + diagnostic.column : '')"/>
                    </span>
                  </div>
                  <div class="gov-typst-diagnostic-message" t-esc="diagnostic.message"/>
                  <div class="gov-typst-diagnostic-hint" t-if="diagnostic.hint" t-esc="diagnostic.hint"/>
                  <pre class="gov-typst-diagnostic-excerpt" t-if="diagnostic.excerpt" t-esc="diagnostic.excerpt"/>
                </div>
              </t>
            </div>
            <div t-else="" class="gov-typst-empty-note">
              Sem diagnósticos no momento. Valide o código ou peça ajuda à IA.
            </div>
          </div>

          <div class="gov-typst-status-card" t-if="state.assistantResult or state.assistantBusy">
            <div class="gov-typst-status-head">
              <span class="gov-typst-status-title">Resposta da IA</span>
              <span class="gov-builder-badge"
                    t-if="state.assistantProvider or state.assistantModel"
                    t-esc="(state.assistantProvider || 'ollama') + (state.assistantModel ? ' · ' + state.assistantModel : '')"/>
            </div>
            <div class="gov-typst-status-meta" t-if="state.assistantDurationMs">
              <t t-esc="String(state.assistantDurationMs) + ' ms'"/>
            </div>
            <pre class="gov-typst-ai-result" t-if="state.assistantResult" t-esc="state.assistantResult"/>
            <div t-else="" class="gov-typst-empty-note">
              Aguardando resposta do assistente...
            </div>
            <div class="gov-typst-toolbar gov-typst-toolbar--stacked">
              <button class="gov-btn gov-btn-primary"
                      t-if="assistantCanApply"
                      t-on-click="applyAssistantSuggestion">
                <i class="fa fa-check"/> <t t-esc="assistantApplyLabel"/>
              </button>
              <button class="gov-btn gov-btn-secondary"
                      t-if="state.assistantResult"
                      t-on-click="clearAssistantResult">
                <i class="fa fa-eraser"/> Limpar painel
              </button>
            </div>
            <div class="gov-typst-inline-validation" t-if="state.assistantValidation">
              <span class="gov-typst-inline-validation-title">Pré-validação da sugestão</span>
              <span t-att-class="state.assistantValidation.compile_ok ? 'gov-typst-inline-validation-badge gov-typst-inline-validation-badge--success' : 'gov-typst-inline-validation-badge gov-typst-inline-validation-badge--warning'">
                <t t-esc="state.assistantValidation.compile_ok ? 'Compila' : 'Revise antes de aplicar'"/>
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</t>

<!-- Sub-componente: Preview do bloco -->
<t t-name="gov_processos.GovBlockPreview">
  <div class="gov-preview-inner">
    <t t-if="props.block.type === 'titulo'">
      <strong t-esc="resolvedContent.titulo or '(sem título)'"/>
      <span t-if="resolvedContent.subtitulo" class="gov-preview-sub">
        — <t t-esc="resolvedContent.subtitulo"/>
      </span>
    </t>
    <t t-elif="props.block.type === 'cabecalho_processo'">
      <div class="gov-preview-table">
        <t t-foreach="headerRows" t-as="row" t-key="row.label">
          <div class="gov-preview-table-row">
            <span class="gov-preview-table-label" t-esc="row.label"/>
            <span class="gov-preview-table-value" t-esc="row.value"/>
          </div>
        </t>
      </div>
    </t>
    <t t-elif="props.block.type === 'texto_livre' or props.block.type === 'objeto'
               or props.block.type === 'justificativa' or props.block.type === 'base_legal'
               or props.block.type === 'encaminhamento'">
      <div t-out="resolvedContent.html or '(vazio)'"/>
    </t>
    <t t-elif="props.block.type === 'quadro_resumo'">
      <div class="gov-preview-table">
        <t t-foreach="summaryRows" t-as="row" t-key="row.label + '_' + row.value">
          <div class="gov-preview-table-row">
            <span class="gov-preview-table-label" t-esc="row.label"/>
            <span class="gov-preview-table-value" t-esc="row.value or '—'"/>
          </div>
        </t>
      </div>
    </t>
    <t t-elif="props.block.type === 'pontos_chave'">
      <pre class="gov-preview-pre" t-esc="resolvedContent.texto or '(vazio)'"/>
    </t>
    <t t-elif="props.block.type === 'assinatura'">
      <span>✍️ <t t-esc="resolvedContent.nome or '(nome)'"/> —
        <t t-esc="resolvedContent.cargo or '(cargo)'"/>
      </span>
    </t>
    <t t-else="">
      <span class="gov-preview-auto">
        ✓ Bloco preenchido automaticamente com dados do processo
      </span>
    </t>
  </div>
</t>

<!-- Sub-componente: Editor inline do bloco -->
<t t-name="gov_processos.GovBlockEditor">
  <div class="gov-editor-inner">

    <!-- Titulo -->
    <t t-if="props.block.type === 'titulo'">
      <div class="gov-field">
        <label>Título</label>
        <input type="text" class="gov-input"
               t-att-value="resolvedContent.titulo"
               t-on-input="(ev) => props.onUpdate('titulo', ev.target.value)"/>
      </div>
      <div class="gov-field">
        <label>Subtítulo</label>
        <input type="text" class="gov-input"
               t-att-value="resolvedContent.subtitulo"
               t-on-input="(ev) => props.onUpdate('subtitulo', ev.target.value)"/>
      </div>
    </t>

    <t t-elif="props.block.type === 'cabecalho_processo'">
      <div class="gov-field gov-field--full">
        <label>Dados vinculados ao processo</label>
        <div class="gov-bound-card">
          <div class="gov-bound-card-hint">
            Este bloco é alimentado automaticamente pelo registro atual do Odoo.
          </div>
          <div class="gov-preview-table">
            <t t-foreach="resolvedContent.rows" t-as="row" t-key="row.label">
              <div class="gov-preview-table-row">
                <span class="gov-preview-table-label" t-esc="row.label"/>
                <span class="gov-preview-table-value" t-esc="row.value"/>
              </div>
            </t>
          </div>
        </div>
      </div>
    </t>

    <!-- Campos HTML: usa o widget de texto nativo do Odoo -->
    <t t-elif="props.block.type === 'texto_livre' or props.block.type === 'objeto'
               or props.block.type === 'justificativa' or props.block.type === 'base_legal'
               or props.block.type === 'encaminhamento'">
      <div class="gov-field gov-field--full">
        <label>Conteúdo (suporta /comandos, títulos, listas...)</label>
        <div
          class="gov-html-editor"
          contenteditable="true"
          t-ref="htmlEditor"
          t-on-input="(ev) => props.onRichTextInput(props.block.id, 'html', ev)"
          t-on-keydown="(ev) => props.onRichTextKeydown(props.block.id, ev)"
          t-out="resolvedContent.html"
        />
        <span class="gov-field-hint">
          <t t-if="props.block.type === 'texto_livre'">
            Use <code>/base-legal</code> para abrir a base dos slash commands.
          </t>
          <t t-else="">
            O conteúdo aceita títulos, listas, tabelas e HTML básico.
          </t>
        </span>
        <div class="gov-slash-menu" t-if="isSlashMenuOpen">
          <button class="gov-slash-item"
                  t-foreach="props.slashCommands"
                  t-as="command"
                  t-key="command.name"
                  t-on-mousedown.prevent="() => {}"
                  t-on-click="() => props.onSlashCommandSelect(props.block.id, command)">
            <span class="gov-slash-item-label" t-esc="command.label"/>
            <span class="gov-slash-item-desc" t-esc="command.description"/>
          </button>
        </div>
      </div>
    </t>

    <!-- Quadro resumo: linhas no formato "Rótulo: valor" -->
    <t t-elif="props.block.type === 'quadro_resumo'">
      <div class="gov-field gov-field--full">
        <label>Linhas (formato: Rótulo: valor)</label>
          <div class="gov-bound-card">
            <div class="gov-bound-card-hint">
              Deixe em branco para usar automaticamente os dados do processo atual.
            </div>
            <div class="gov-preview-table">
            <t t-foreach="summaryLines" t-as="line" t-key="line">
              <div class="gov-preview-table-row">
                <span class="gov-preview-table-value" t-esc="line"/>
              </div>
            </t>
            </div>
        </div>
        <textarea class="gov-textarea" rows="6"
                  t-att-value="resolvedContent.linhas"
                  t-on-input="(ev) => props.onUpdate('linhas', ev.target.value)"/>
        <span class="gov-field-hint">Exemplo: Valor estimado: R$ 50.000,00. Se apagar tudo, o binding volta.</span>
      </div>
    </t>

    <!-- Pontos-chave: um por linha -->
    <t t-elif="props.block.type === 'pontos_chave'">
      <div class="gov-field gov-field--full">
        <label>Pontos (um por linha)</label>
        <textarea class="gov-textarea" rows="6"
                  t-att-value="resolvedContent.texto"
                  t-on-input="(ev) => props.onUpdate('texto', ev.target.value)"/>
      </div>
    </t>

    <!-- Assinatura -->
    <t t-elif="props.block.type === 'assinatura'">
      <div class="gov-field">
        <label>Nome do Assinante</label>
