<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gov_document_type_list" model="ir.ui.view">
        <field name="name">gov.document.type.list</field>
        <field name="model">gov.document.type</field>
        <field name="arch" type="xml">
            <list string="Tipos Documentais">
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_gov_document_type_form" model="ir.ui.view">
        <field name="name">gov.document.type.form</field>
        <field name="model">gov.document.type</field>
        <field name="arch" type="xml">
            <form string="Tipo Documental">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="versioning_policy"/>
                            <field name="typst_package_ref"/>
                        </group>
                        <group>
                            <field name="active"/>
                            <field name="process_model"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                    <group string="Templates">
                        <field name="template_ids" context="{'default_document_type_id': id}">
                            <list editable="bottom">
                                <field name="name"/>
                                <field name="code"/>
                                <field name="version"/>
                                <field name="active"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gov_document_type" model="ir.actions.act_window">
        <field name="name">Tipos Documentais</field>
        <field name="res_model">gov.document.type</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
