<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="gov_document_builder.EmptyDropZone">
        <div class="gdb-drop-zone-empty">
            <div class="gdb-dz-icon">⬡</div>
            <p>Nenhum bloco adicionado</p>
            <span>Clique nos itens da biblioteca ou arraste-os aqui</span>
        </div>
    </t>

    <t t-name="gov_document_builder.DocumentCanvas">
        <section
            class="gdb-document-canvas"
            t-on-click="clearSelection"
            t-on-dragover="onCanvasDragOver"
            t-on-drop="onCanvasDrop"
        >
            <t t-if="!this.store.state.nodes.length">
                <EmptyDropZone />
            </t>
            <div t-else="" class="gdb-doc-nodes">
                <t t-foreach="this.store.state.nodes" t-as="node" t-key="node.id">
                    <div
                        class="gdb-canvas-item"
                        draggable="true"
                        t-att-class="{
                            'gdb-drag-over-before': this.store.state.dragState.overNodeId === node.id &amp;&amp; this.store.state.dragState.placement === 'before',
                            'gdb-drag-over-after': this.store.state.dragState.overNodeId === node.id &amp;&amp; this.store.state.dragState.placement === 'after',
                        }"
                        t-on-dragstart="(ev) => this.onDragStart(ev, node.id)"
                        t-on-dragover="(ev) => this.onDragOver(ev, node.id)"
                        t-on-drop="(ev) => this.onDrop(ev, node.id)"
                    >
                        <DocumentNode
                            index="node_index"
                            isSelected="this.store.state.selectedNodeId === node.id"
                            node="node"
                            onDelete="() => this.deleteNode(node.id)"
                            onMove="(direction) => this.moveNode(node.id, direction)"
                            onSelect="() => this.selectNode(node.id)"
                        />
                    </div>
                </t>
            </div>
        </section>
    </t>
</templates>
