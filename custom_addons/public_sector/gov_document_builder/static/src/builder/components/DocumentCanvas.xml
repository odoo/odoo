<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="gov_document_builder.EmptyDropZone">
        <div class="card border-2 border-dashed h-100">
            <div class="card-body d-flex flex-column align-items-center justify-content-center text-center gap-2 py-5">
                <span class="fs-2">+</span>
                <h3 class="h6 mb-0">Canvas vazio</h3>
                <p class="text-muted mb-0">Selecione um bloco na biblioteca lateral para iniciar o documento.</p>
            </div>
        </div>
    </t>

    <t t-name="gov_document_builder.DocumentCanvas">
        <section
            class="gdb-canvas d-flex flex-column gap-3 h-100"
            t-on-click="clearSelection"
            t-on-dragover="onCanvasDragOver"
            t-on-drop="onCanvasDrop"
        >
            <t t-if="!this.store.state.nodes.length">
                <EmptyDropZone />
            </t>
            <div t-else="" class="d-flex flex-column gap-3">
                <t t-foreach="this.store.state.nodes" t-as="node" t-key="node.id">
                    <div
                        class="gdb-canvas-item"
                        draggable="true"
                        t-att-class="{
                            'drag-over-before': this.store.state.dragState.overNodeId === node.id &amp;&amp; this.store.state.dragState.placement === 'before',
                            'drag-over-after': this.store.state.dragState.overNodeId === node.id &amp;&amp; this.store.state.dragState.placement === 'after',
                        }"
                        t-on-dragstart="(ev) => this.onDragStart(ev, node.id)"
                        t-on-dragover="(ev) => this.onDragOver(ev, node.id)"
                        t-on-drop="(ev) => this.onDrop(ev, node.id)"
                    >
                        <DocumentNode
                            index="node_index"
                            isSelected="this.store.state.selectedNodeId === node.id"
                            node="node"
                            onDelete="() => this.deleteNode(node.id)"
                            onMove="(direction) => this.moveNode(node.id, direction)"
                            onSelect="() => this.selectNode(node.id)"
                        />
                    </div>
                </t>
            </div>
        </section>
    </t>
</templates>
