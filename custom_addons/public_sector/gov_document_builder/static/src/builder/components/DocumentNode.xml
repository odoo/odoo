<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="gov_document_builder.DocumentNode">
        <div
            t-attf-class="doc-node {{ props.isSelected ? 'selected' : '' }}"
            t-on-click.stop="selectNode"
        >
            <div t-if="props.node.locked" class="node-locked-badge"/>
            <div class="node-controls">
                <button type="button" class="nc-btn move-up" t-on-click.stop="moveUp">
                    ↑
                </button>
                <button type="button" class="nc-btn move-dn" t-on-click.stop="moveDown">
                    ↓
                </button>
                <button
                    t-if="!props.node.locked"
                    type="button"
                    class="nc-btn"
                    t-on-click.stop="deleteNode"
                >
                    ×
                </button>
            </div>
            <div class="gdb-node-meta">
                <span class="gdb-node-index">#<t t-esc="props.index + 1" /></span>
                <span class="gdb-node-type"><t t-esc="this.blockTypeLabel" /></span>
            </div>
            <div t-if="props.node.type === 'heading1'" class="n-heading-1">
                <h1><t t-esc="this.headingText || 'Título Principal'" /></h1>
            </div>
            <div t-elif="props.node.type === 'heading2'" class="n-heading-2">
                <h2><t t-esc="this.headingText || 'Seção'" /></h2>
            </div>
            <div t-elif="props.node.type === 'heading'" class="n-heading-2">
                <h2><t t-esc="this.headingText || 'Título'" /></h2>
            </div>
            <div t-elif="props.node.type === 'process_header'" class="n-process-field gdb-stack">
                <t t-foreach="this.processRows" t-as="row" t-key="row.label">
                    <div class="pf-row">
                        <div class="pf-label"><t t-esc="row.label" /></div>
                        <div class="pf-value">
                            <t t-esc="row.value" />
                            <span class="pf-binding"><t t-esc="row.binding" /></span>
                        </div>
                    </div>
                </t>
            </div>
            <div t-elif="props.node.type === 'process_field'" class="n-process-field">
                <div class="pf-row">
                    <div class="pf-label"><t t-esc="this.nodeLabel" /></div>
                    <div class="pf-value">
                        <em class="gdb-placeholder-inline">valor resolvido em runtime</em>
                        <span class="pf-binding"><t t-esc="this.bindingLabel" /></span>
                    </div>
                </div>
            </div>
            <div t-elif="props.node.type === 'rich_text' || props.node.type === 'richtext'" class="n-richtext">
                <p t-if="(props.node.props || {}).content" class="rt-content">
                    <t t-esc="this.nodeContent" />
                </p>
                <p t-else="" class="rt-placeholder">
                    Clique para editar o conteúdo deste parágrafo. Suporte a blocos semânticos e
                    binding declarativo.
                </p>
            </div>
            <div t-elif="props.node.type === 'legal_basis'" class="n-legal-basis">
                <div class="lb-box">
                    <div class="lb-title">Base Legal</div>
                    <div class="lb-text">
                        Lei 14.133/2021, com destaque para a fase preparatória e a formalização da
                        necessidade administrativa.
                    </div>
                </div>
            </div>
            <div t-elif="props.node.type === 'signature'" class="n-signature">
                <div class="sig-grid">
                    <t t-foreach="this.signatureBlocks" t-as="signatory" t-key="signatory.name">
                        <div class="sig-block">
                            <div class="sig-name"><t t-esc="signatory.name" /></div>
                            <div class="sig-role"><t t-esc="signatory.role" /></div>
                        </div>
                    </t>
                </div>
            </div>
            <div t-elif="props.node.type === 'table' || props.node.type === 'quadro_resumo'" class="n-table">
                <table class="doc-table">
                    <thead>
                        <tr>
                            <th>Campo</th>
                            <th>Valor</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="this.summaryRows" t-as="row" t-key="row[0]">
                            <tr>
                                <td><t t-esc="row[0]" /></td>
                                <td><t t-esc="row[1]" /></td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
            <div t-elif="props.node.type === 'divider'" class="n-divider">
                <div class="divider-line"/>
            </div>
            <div t-elif="props.node.type === 'bullet_list'" class="n-richtext">
                <ul class="gdb-bullet-list">
                    <t t-if="this.bulletItems.length">
                        <t t-foreach="this.bulletItems" t-as="item" t-key="item">
                            <li class="rt-content"><t t-esc="item" /></li>
                        </t>
                    </t>
                    <t t-else="">
                        <li class="rt-content">Lista de conclusões e pontos-chave do documento.</li>
                        <li class="rt-content">Base para pareceres, despacho e encaminhamento.</li>
                        <li class="rt-content">Pode ser derivada do contexto do processo.</li>
                    </t>
                </ul>
            </div>
            <div t-elif="props.node.type === 'metadata'" class="n-process-field">
                <div class="pf-row">
                    <div class="pf-label">Local e Data</div>
                    <div class="pf-value">
                        <t t-esc="this.metadataText" />
                        <span class="pf-binding">institution.city + document.date</span>
                    </div>
                </div>
            </div>
            <div t-elif="props.node.type === 'conditional'" class="gdb-conditional-block">
                <div class="gdb-conditional-title">Bloco Condicional</div>
                <p class="rt-placeholder">
                    Visível conforme regra de contexto definida no template.
                </p>
            </div>
            <div t-else="" class="n-richtext">
                <p class="rt-placeholder">[<t t-esc="props.node.type" />]</p>
            </div>
        </div>
    </t>
</templates>
