<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="gov_document_builder.PropertiesPanel">
        <aside class="gdb-right-panel">
            <div class="gdb-rp-header">
                <h3>Propriedades</h3>
            </div>

            <div t-if="!this.selectedNode" class="gdb-rp-scroll gdb-rp-empty">
                <div>
                    <div class="gdb-rp-empty-icon">✎</div>
                    <p>Nenhum bloco selecionado</p>
                    <span>Clique em um bloco no canvas para editar suas propriedades</span>
                </div>
            </div>

            <div t-else="" class="gdb-rp-scroll">
                <div class="node-type-badge">
                    <span class="gdb-node-type-icon">◧</span>
                    <span>
                        <t t-esc="this.blockName" />
                    </span>
                </div>

                <div t-if="this.selectedNode.locked" class="gdb-locked-note">
                    Bloco obrigatório — estrutura travada
                </div>

                <div class="prop-section">
                    <span class="prop-label">Identificador</span>
                    <div class="gdb-prop-chip">
                        <code><t t-esc="this.selectedNode.id" /></code>
                    </div>
                </div>

                <div
                    t-if="this.selectedNode.type === 'heading' || this.selectedNode.type === 'heading1' || this.selectedNode.type === 'heading2'"
                    class="prop-section"
                >
                    <label class="prop-label">Texto do Título</label>
                    <input
                        type="text"
                        class="prop-input"
                        t-att-value="this.nodeText"
                        t-on-input="updateText"
                    />
                </div>

                <div t-if="this.selectedNode.type === 'process_field'" class="prop-section">
                    <label class="prop-label">Rótulo</label>
                    <input
                        type="text"
                        class="prop-input"
                        t-att-value="this.nodeLabel"
                        t-on-input="updateLabel"
                    />
                </div>

                <div
                    t-if="this.selectedNode.type === 'rich_text' || this.selectedNode.type === 'richtext' || this.selectedNode.type === 'legal_basis'"
                    class="prop-section"
                >
                    <label class="prop-label">Conteúdo</label>
                    <textarea
                        class="prop-input gdb-prop-textarea"
                        rows="8"
                        t-att-value="this.nodeContent"
                        t-on-input="updateContent"
                    />
                </div>

                <div t-if="this.selectedNode.type === 'bullet_list'" class="prop-section">
                    <label class="prop-label">Itens da Lista</label>
                    <textarea
                        class="prop-input gdb-prop-textarea"
                        rows="8"
                        placeholder="Um item por linha"
                        t-att-value="this.bulletItemsText"
                        t-on-input="updateBulletItems"
                    />
                </div>

                <div t-if="this.supportsBinding" class="prop-section">
                    <label class="prop-label">Vinculação (Binding)</label>
                    <div class="binding-chip">
                        <div class="binding-dot"/>
                        <span class="binding-path"><t t-esc="this.bindingDisplayPath" /></span>
                        <span t-if="this.hasBinding" class="binding-badge">ATIVO</span>
                    </div>

                    <div class="gdb-binding-editor">
                        <div class="toggle-row">
                            <span class="toggle-label">Usar binding declarativo</span>
                            <div t-attf-class="toggle-switch {{ this.hasBinding ? '' : 'off' }}">
                                <input
                                    class="gdb-toggle-input"
                                    type="checkbox"
                                    id="gdbBindingToggle"
                                    t-att-checked="this.hasBinding ? true : undefined"
                                    t-on-change="toggleBinding"
                                />
                            </div>
                        </div>

                        <div t-if="this.hasBinding" class="gdb-binding-fields">
                            <label class="prop-label">Fonte</label>
                            <input
                                type="text"
                                class="prop-input"
                                placeholder="process"
                                t-att-value="this.bindingSource"
                                t-on-input="(ev) => this.updateBindingField('source', ev)"
                            />

                            <label class="prop-label">Caminho</label>
                            <input
                                type="text"
                                class="prop-input"
                                placeholder="objeto"
                                t-att-value="this.bindingPath"
                                t-on-input="(ev) => this.updateBindingField('path', ev)"
                            />

                            <label class="prop-label">Fallback</label>
                            <input
                                type="text"
                                class="prop-input"
                                t-att-value="this.bindingFallback"
                                t-on-input="(ev) => this.updateBindingField('fallback', ev)"
                            />

                            <label class="prop-label">Transformador</label>
                            <input
                                type="text"
                                class="prop-input"
                                placeholder="strip, upper, lower..."
                                t-att-value="this.bindingTransform"
                                t-on-input="(ev) => this.updateBindingField('transform', ev)"
                            />
                        </div>
                    </div>
                </div>

                <div class="prop-section">
                    <span class="prop-label">Configurações</span>
                    <div class="toggle-row">
                        <span class="toggle-label">Estrutura travada</span>
                        <span class="gdb-setting-chip"><t t-esc="this.selectedNode.locked ? 'Sim' : 'Não'" /></span>
                    </div>
                    <div class="toggle-row">
                        <span class="toggle-label">Sequência</span>
                        <span class="gdb-setting-chip"><t t-esc="this.selectedNode.sequence" /></span>
                    </div>
                </div>
            </div>

            <div class="gdb-rp-actions">
                <button type="button" class="gdb-rp-action-btn muted" t-on-click="duplicateNode">
                    Duplicar bloco
                </button>
                <button
                    type="button"
                    class="gdb-rp-action-btn danger"
                    t-att-disabled="this.selectedNode.locked ? true : undefined"
                    t-on-click="deleteNode"
                >
                    Remover bloco
                </button>
            </div>
        </aside>
    </t>
</templates>
