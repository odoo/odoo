<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="gov_document_builder.DocumentBuilderRoot">
        <div class="gdb-root">
            <header class="gdb-toolbar">
                <button type="button" class="gdb-toolbar-back" t-on-click="closeBuilder">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="15 18 9 12 15 6"/>
                    </svg>
                    Voltar
                </button>
                <div class="gdb-toolbar-divider"/>
                <div class="gdb-toolbar-title">
                    <span class="gdb-doc-name">
                        <t t-esc="this.store.state.documentName || 'Documento administrativo'" />
                    </span>
                    <span class="gdb-doc-meta">
                        <t t-esc="this.processMeta" />
                    </span>
                </div>

                <div class="gdb-mode-toggle" role="group" aria-label="Modo de edição">
                    <button
                        type="button"
                        t-attf-class="gdb-mode-btn {{ this.store.state.mode === 'visual' ? 'active' : '' }}"
                        t-on-click="() => this.setMode('visual')"
                    >
                        Visual
                    </button>
                    <button
                        type="button"
                        t-attf-class="gdb-mode-btn {{ this.store.state.mode === 'typst' ? 'active' : '' }}"
                        t-on-click="() => this.setMode('typst')"
                    >
                        Typst
                    </button>
                </div>

                <div class="gdb-toolbar-actions">
                    <span class="gdb-block-count">
                        <t t-esc="this.blockCountLabel" />
                    </span>
                    <span t-if="this.store.state.dirty" class="gdb-dirty-badge">
                        Alterações pendentes
                    </span>
                    <button type="button" class="gdb-btn gdb-btn-ghost" disabled="disabled">
                        Gerar PDF
                    </button>
                    <button type="button" class="gdb-btn gdb-btn-ghost" t-on-click="exportTypst">
                        Exportar .typ
                    </button>
                    <button
                        type="button"
                        class="gdb-btn gdb-btn-primary"
                        t-att-disabled="this.store.state.saving ? true : undefined"
                        t-on-click="saveLayout"
                    >
                        <t t-if="this.store.state.saving">Salvando...</t>
                        <t t-else="">Salvar</t>
                    </button>
                </div>
            </header>

            <div class="gdb-main-area">
                <BlockPalette />

                <section class="gdb-center-stage">
                    <div t-if="this.store.state.mode === 'visual'" class="gdb-canvas-area">
                        <div class="gdb-process-band">
                            <div class="gdb-process-badge">
                                <t t-esc="this.processBadge" />
                            </div>
                            <div class="gdb-process-info">
                                <div class="gdb-process-title">
                                    <t t-esc="this.processTitle" />
                                </div>
                                <div class="gdb-process-sub">
                                    <t t-esc="this.processSubtitle" />
                                </div>
                            </div>
                            <div t-attf-class="gdb-process-status {{ this.statusClass }}">
                                <div class="gdb-status-dot"/>
                                <span><t t-esc="this.stateLabel" /></span>
                            </div>
                        </div>

                        <div class="gdb-document-paper">
                            <DocumentCanvas />
                        </div>
                    </div>

                    <div t-else="" class="gdb-typst-panel active">
                        <div class="gdb-typst-readonly-badge">
                            Somente leitura — edição via modo visual
                        </div>
                        <div class="gdb-typst-code">
                            <t t-out="this.highlightedTypstSource" />
                        </div>
                    </div>
                </section>

                <PropertiesPanel />
            </div>

            <footer class="gdb-status-bar">
                <div class="gdb-sb-item">
                    <div class="gdb-sb-dot"/>
                    <t t-esc="this.processConnectionLabel" />
                </div>
                <div class="gdb-sb-sep">·</div>
                <div class="gdb-sb-item"><t t-esc="this.institutionContext.name || 'Instituição'" /></div>
                <div class="gdb-sb-sep">·</div>
                <div class="gdb-sb-item"><t t-esc="this.documentTypeLabel" /></div>
                <div class="gdb-sb-sep">·</div>
                <div class="gdb-sb-item"><t t-esc="this.blockCountLabel" /></div>
                <div class="gdb-sb-spacer"/>
                <div class="gdb-sb-version">gov_document_builder v1.0 · Kodoo/GRP</div>
            </footer>
        </div>
    </t>
</templates>
