<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="gov_document_builder.BlockPalette">
        <aside class="gdb-palette">
            <div class="gdb-palette-header">
                <h3>Biblioteca de Blocos</h3>
                <div class="gdb-search-box">
                    <svg class="gdb-search-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8"/>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                    <input
                        type="search"
                        placeholder="Buscar bloco..."
                        t-att-value="this.localState.query"
                        t-on-input="updateQuery"
                    />
                </div>
            </div>
            <div class="gdb-palette-scroll">
                <t t-if="this.groupedBlocks.length">
                    <t t-foreach="this.groupedBlocks" t-as="group" t-key="group.name">
                        <section>
                            <span class="gdb-cat-label"><t t-esc="group.name" /></span>
                            <div>
                                <t t-foreach="group.blocks" t-as="block" t-key="block.id">
                                    <button
                                        type="button"
                                        class="gdb-block-item"
                                        t-on-click="() => this.insertBlock(block.code)"
                                    >
                                        <div class="gdb-block-icon">
                                            <i
                                                t-if="block.icon &amp;&amp; block.icon.startsWith('fa-')"
                                                t-att-class="'fa ' + block.icon"
                                                aria-hidden="true"
                                            />
                                            <span t-else="">
                                                <t t-esc="block.icon || '[]'" />
                                            </span>
                                        </div>
                                        <div class="gdb-block-item-text">
                                            <div class="gdb-block-item-line">
                                                <span class="gdb-block-item-name"><t t-esc="block.name" /></span>
                                                <span t-if="block.is_locked_by_default" class="gdb-fixed-badge">
                                                    Fixo
                                                </span>
                                            </div>
                                            <span class="gdb-block-item-desc">
                                                <t t-esc="block.description || 'Sem descrição.'" />
                                            </span>
                                            <span t-if="block.supports_binding" class="gdb-block-drag-hint">
                                                Binding declarativo disponível
                                            </span>
                                            <span t-if="!block.supports_binding" class="gdb-block-drag-hint">
                                                Bloco estrutural
                                            </span>
                                        </div>
                                    </button>
                                </t>
                            </div>
                        </section>
                    </t>
                </t>
                <div t-else="" class="gdb-palette-empty">
                    Nenhum bloco encontrado para o filtro atual.
                </div>
            </div>
        </aside>
    </t>
</templates>
