<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gov_ai_ml_memory_vector_list" model="ir.ui.view">
        <field name="name">gov.ai.ml.memory.vector.list</field>
        <field name="model">gov.ai.ml.memory.vector</field>
        <field name="arch" type="xml">
            <list string="Vetores de Memoria">
                <field name="memory_id"/>
                <field name="company_id"/>
                <field name="embedding_provider"/>
                <field name="embedding_model"/>
                <field name="embedding_dim"/>
                <field name="text_hash"/>
                <field name="updated_at"/>
            </list>
        </field>
    </record>

    <record id="view_gov_ai_ml_memory_vector_form" model="ir.ui.view">
        <field name="name">gov.ai.ml.memory.vector.form</field>
        <field name="model">gov.ai.ml.memory.vector</field>
        <field name="arch" type="xml">
            <form string="Vetor de Memoria">
                <sheet>
                    <group>
                        <field name="memory_id" readonly="1"/>
                        <field name="company_id" readonly="1"/>
                        <field name="embedding_provider" readonly="1"/>
                        <field name="embedding_model" readonly="1"/>
                        <field name="embedding_dim" readonly="1"/>
                        <field name="updated_at" readonly="1"/>
                    </group>
                    <group>
                        <field name="text_hash" readonly="1"/>
                    </group>
                    <group string="Embedding (JSON)">
                        <field name="embedding_json" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gov_ai_ml_memory_vector" model="ir.actions.act_window">
        <field name="name">Vetores de Memoria</field>
        <field name="res_model">gov.ai.ml.memory.vector</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
