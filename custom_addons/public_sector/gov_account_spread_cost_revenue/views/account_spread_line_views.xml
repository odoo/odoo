<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_spread_line_view_list" model="ir.ui.view">
        <field name="name">account.spread.line.list</field>
        <field name="model">account.spread.line</field>
        <field name="arch" type="xml">
            <list>
                <field name="spread_id"/>
                <field name="date"/>
                <field name="amount"/>
                <field name="state"/>
                <field name="move_id"/>
                <button name="action_post" type="object" string="Post" invisible="move_id"/>
                <button name="action_unpost" type="object" string="Unpost" groups="gov_account_spread_cost_revenue.group_account_spread_manager" invisible="not move_id"/>
            </list>
        </field>
    </record>

    <record id="account_spread_invoice_wizard_view_form" model="ir.ui.view">
        <field name="name">account.spread.invoice.wizard.form</field>
        <field name="model">account.spread.invoice.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Spread">
                <group>
                    <field name="move_line_id"/>
                    <field name="company_id"/>
                    <field name="estimated_amount"/>
                    <field name="account_id"/>
                    <field name="journal_id"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                    <field name="period_type"/>
                </group>
                <footer>
                    <button name="action_create_spread" type="object" class="btn-primary" string="Create"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="account_spread_invoice_wizard_action" model="ir.actions.act_window">
        <field name="name">Create Spread</field>
        <field name="res_model">account.spread.invoice.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>

