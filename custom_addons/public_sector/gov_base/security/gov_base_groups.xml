<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_grp" model="ir.module.category">
        <field name="name">AGI Gov</field>
        <field name="sequence">90</field>
    </record>

    <record id="privilege_grp" model="res.groups.privilege">
        <field name="name">AGI Gov</field>
        <field name="sequence">90</field>
    </record>

    <record id="group_gov_operador" model="res.groups">
        <field name="name">AGI Gov / Operador</field>
        <field name="privilege_id" ref="gov_base.privilege_grp"/>
    </record>

    <record id="group_gov_gestor" model="res.groups">
        <field name="name">AGI Gov / Gestor</field>
        <field name="privilege_id" ref="gov_base.privilege_grp"/>
        <field name="implied_ids" eval="[(4, ref('gov_base.group_gov_operador'))]"/>
    </record>

    <record id="group_gov_admin" model="res.groups">
        <field name="name">AGI Gov / Administrador</field>
        <field name="privilege_id" ref="gov_base.privilege_grp"/>
        <field name="implied_ids" eval="[(4, ref('gov_base.group_gov_gestor'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>

</odoo>
