<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_journal_lock_date_view_form_inherit" model="ir.ui.view">
        <field name="name">account.journal.form.inherit.lock.date</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_open_lock_date_wizard"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-lock"
                    string="Lock Date"
                    groups="gov_account_journal_lock_date.group_account_journal_lock_manager"
                />
            </xpath>
            <xpath expr="//page[@name='advanced_settings']//field[@name='restrict_mode_hash_table']" position="after">
                <field name="journal_lock_date"/>
                <field name="lock_date_note"/>
            </xpath>
        </field>
    </record>
</odoo>

