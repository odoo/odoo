<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data>

    <!-- List view with Send & Cancel buttons -->
    <record id="view_excel_export_task_list" model="ir.ui.view">
      <field name="name">excel.export.task.list</field>
      <field name="model">excel.export.task</field>
      <field name="arch" type="xml">
        <list string="Excel Export Tasks">
          <field name="name"/>
          <field name="model_id"/>
          <field name="file_id"/>
          <field name="sheet_name"/>
          <field name="state"/>
          <!-- action buttons -->
          <button name="action_send"
              string="▶ Export"
              type="object"
              class="btn-primary"
            />

        </list>
      </field>
    </record>

    <!-- Form view (no changes needed here) -->
    <record id="view_excel_export_task_form" model="ir.ui.view">
        <field name="name">excel.export.task.form</field>
        <field name="model">excel.export.task</field>
        <field name="arch" type="xml">
            <form string="Excel Export Task">
                <sheet>
                    <group>
                        <field name="name" placeholder="Export Task Name"/>
                        <field name="state" widget="statusbar" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Export Setup">
                            <group>
                                <field name="model_id"
                                       options="{'no_create': True}"
                                       placeholder="Select a model to export"
                                       help="Choose the Odoo model whose records you want to export."/>
                                <field name="file_id"
                                       placeholder="Workbook File ID"
                                       help="Paste the GUID from your OneDrive Excel file URL."/>
                                <field name="sheet_name"
                                       placeholder="Sheet1"
                                       help="Name of the worksheet in your Excel file."/>
                            </group>
                        </page>
                        <page string="Fields to Export">
                            <group>
                                <field name="fields_to_export"
                                       string="Fields to Export"
                                       widget="many2many_checkboxes"
                                       domain="[('model_id','=',model_id),('store','=',True),('ttype','not in',['one2many','many2many'])]"
                                       help="Select fields to export to Excel. Only storable fields (not one2many/many2many) are available."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


    <!-- Window action -->
    <record id="action_excel_export_task" model="ir.actions.act_window">
      <field name="name">Excel Export Tasks</field>
      <field name="res_model">excel.export.task</field>
      <field name="view_mode">list,form</field>
      <field name="view_ids" eval="[
        (5, 0, 0),
        (0, 0, {'view_mode':'list','view_id':ref('view_excel_export_task_list')}),
        (0, 0, {'view_mode':'form','view_id':ref('view_excel_export_task_form')})
      ]"/>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Create your first Excel Export Task
        </p>
      </field>
    </record>

    <!-- Menu items -->
   <!-- Main app icon (shows in the nine dots menu) -->
    <menuitem
        id="menu_excel_exports_root"
        name="Excel Online Connector"
        action="action_excel_export_task"
        sequence="100"
        web_icon="excel_connector,static/description/icon.png"
    />

    <!-- Submenu for Export Tasks (shows in left sidebar when app is open) -->
    <menuitem
        id="menu_excel_export_tasks"
        name="Export Tasks"
        parent="menu_excel_exports_root"
        action="action_excel_export_task"
        sequence="10"/>


  </data>
</odoo>
