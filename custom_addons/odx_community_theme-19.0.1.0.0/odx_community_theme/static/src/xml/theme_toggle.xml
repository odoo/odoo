<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="odx_community_theme.ThemeToggle">
        <button
            class="odx-theme-toggle o_nav_entry"
            t-on-click="toggle"
            t-att-title="isDark ? 'Switch to light mode' : 'Switch to dark mode'"
            t-att-aria-label="isDark ? 'Switch to light mode' : 'Switch to dark mode'"
            type="button"
        >
            <!-- Sun icon (shown in dark mode → click to go light) -->
            <svg t-if="isDark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="odx-theme-icon">
                <circle cx="12" cy="12" r="4"/>
                <path d="M12 2v2"/>
                <path d="M12 20v2"/>
                <path d="m4.93 4.93 1.41 1.41"/>
                <path d="m17.66 17.66 1.41 1.41"/>
                <path d="M2 12h2"/>
                <path d="M20 12h2"/>
                <path d="m6.34 17.66-1.41 1.41"/>
                <path d="m19.07 4.93-1.41 1.41"/>
            </svg>
            <!-- Moon icon (shown in light mode → click to go dark) -->
            <svg t-if="!isDark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="odx-theme-icon">
                <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
            </svg>
        </button>
    </t>

</templates>
