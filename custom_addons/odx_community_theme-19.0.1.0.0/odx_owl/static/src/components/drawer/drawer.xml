<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="odx_owl.Drawer">
        <Dialog
            open="isOpen"
            onOpenChange="handleOpenChange"
            closeOnEscape="props.closeOnEscape"
            closeOnOverlay="props.closeOnOverlay"
            onEscapeKeyDown="props.onEscapeKeyDown"
            onInteractOutside="props.onInteractOutside"
            onPointerDownOutside="props.onPointerDownOutside"
        >
            <t t-if="props.slots and props.slots.trigger" t-set-slot="trigger">
                <t t-slot="trigger"/>
            </t>
            <t t-if="props.slots and props.slots.content" t-set-slot="content">
                <t t-slot="content"/>
            </t>
            <t t-else="" t-set-slot="content">
                <DrawerOverlay/>
                <DrawerContent
                    dir="directionName"
                    direction="resolvedDirection"
                    size="props.size"
                    className="panelClassName"
                    showClose="props.showClose"
                    showHandle="props.showHandle"
                >
                    <t t-if="hasHeader">
                        <t t-if="props.slots and props.slots.header">
                            <t t-slot="header"/>
                        </t>
                        <DrawerHeader t-else="">
                            <DrawerTitle t-if="props.title" text="props.title"/>
                            <DrawerDescription t-if="props.description" text="props.description"/>
                        </DrawerHeader>
                    </t>

                    <div class="odx-dialog__body">
                        <t t-slot="default"/>
                    </div>

                    <t t-if="props.slots and props.slots.footer">
                        <t t-slot="footer"/>
                    </t>
                </DrawerContent>
            </t>
        </Dialog>
    </t>

    <t t-name="odx_owl.DrawerOverlay">
        <DialogOverlay className="classes"/>
    </t>

    <t t-name="odx_owl.DrawerContent">
        <DialogContent className="classes" dir="directionName" tag="props.tag">
            <div t-if="props.showHandle" class="odx-drawer__handle" aria-hidden="true"/>
            <t t-slot="default"/>
            <DialogClose t-if="props.showClose" className="'odx-drawer__close'"/>
        </DialogContent>
    </t>

    <t t-name="odx_owl.DrawerClose">
        <DialogClose
            className="classes"
            ariaLabel="props.ariaLabel"
            onClick="props.onClick"
            type="props.type"
        >
            <t t-slot="default"/>
        </DialogClose>
    </t>

    <t t-name="odx_owl.DrawerTrigger">
        <t t-tag="props.tag" t-att-class="classes">
            <t t-slot="default">
                <t t-esc="props.text"/>
            </t>
        </t>
    </t>

    <t t-name="odx_owl.DrawerHeader">
        <DialogHeader className="classes">
            <t t-slot="default"/>
        </DialogHeader>
    </t>

    <t t-name="odx_owl.DrawerFooter">
        <DialogFooter className="classes">
            <t t-slot="default"/>
        </DialogFooter>
    </t>

    <t t-name="odx_owl.DrawerTitle">
        <DialogTitle className="classes" tag="props.tag" text="props.text">
            <t t-slot="default">
                <t t-esc="props.text"/>
            </t>
        </DialogTitle>
    </t>

    <t t-name="odx_owl.DrawerDescription">
        <DialogDescription className="classes" tag="props.tag" text="props.text">
            <t t-slot="default">
                <t t-esc="props.text"/>
            </t>
        </DialogDescription>
    </t>
</templates>
