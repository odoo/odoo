<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="privilege_account_spread" model="res.groups.privilege">
        <field name="name">Spread Cost and Revenue</field>
    </record>

    <record id="group_account_spread_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="gov_account_spread_cost_revenue.privilege_account_spread"/>
    </record>

    <record id="group_account_spread_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="gov_account_spread_cost_revenue.privilege_account_spread"/>
        <field name="implied_ids" eval="[(4, ref('gov_account_spread_cost_revenue.group_account_spread_user'))]"/>
    </record>

    <record id="account_spread_rule_company" model="ir.rule">
        <field name="name">Account Spread company scope</field>
        <field name="model_id" ref="model_account_spread"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('gov_account_spread_cost_revenue.group_account_spread_user')), (4, ref('gov_account_spread_cost_revenue.group_account_spread_manager'))]"/>
    </record>
</odoo>


