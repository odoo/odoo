<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_spread_view_list" model="ir.ui.view">
        <field name="name">account.spread.list</field>
        <field name="model">account.spread</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="spread_type"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="estimated_amount"/>
                <field name="unspread_amount"/>
                <field name="state"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="account_spread_view_form" model="ir.ui.view">
        <field name="name">account.spread.form</field>
        <field name="model">account.spread</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_post_all_lines" type="object" string="Post Due Lines" invisible="state == 'draft'"/>
                    <button name="action_draft" type="object" string="Reset To Draft" groups="gov_account_spread_cost_revenue.group_account_spread_manager" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,posted,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="spread_type"/>
                            <field name="move_line_id"/>
                            <field name="move_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="account_id"/>
                            <field name="journal_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="period_type"/>
                        </group>
                        <group>
                            <field name="estimated_amount"/>
                            <field name="unspread_amount" readonly="1"/>
                            <field name="spread_progress" widget="progressbar"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Spread Lines">
                            <field name="spread_line_ids" readonly="1">
                                <list>
                                    <field name="date"/>
                                    <field name="amount"/>
                                    <field name="state"/>
                                    <field name="move_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="account_spread_view_search" model="ir.ui.view">
        <field name="name">account.spread.search</field>
        <field name="model">account.spread</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="state"/>
                <field name="spread_type"/>
                <filter name="filter_confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter name="filter_done" string="Done" domain="[('state', '=', 'done')]"/>
                <group>
                    <filter name="group_company" string="Company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="account_spread_action" model="ir.actions.act_window">
        <field name="name">Spread Schedules</field>
        <field name="res_model">account.spread</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="account_spread_view_search"/>
    </record>
</odoo>

