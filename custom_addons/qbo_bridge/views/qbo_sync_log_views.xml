<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List (primary view — logs are read-only) -->
    <record id="view_qbo_sync_log_list" model="ir.ui.view">
        <field name="name">qbo.sync.log.list</field>
        <field name="model">qbo.sync.log</field>
        <field name="arch" type="xml">
            <list create="false" delete="false" editable="false"
                  decoration-danger="status == 'error'"
                  decoration-warning="status == 'conflict'"
                  decoration-muted="status == 'skipped'"
                  decoration-success="status == 'success'">
                <field name="sync_date"/>
                <field name="company_id"/>
                <field name="realm_id"/>
                <field name="entity_type"/>
                <field name="direction"/>
                <field name="status"/>
                <field name="qbo_id"/>
                <field name="odoo_record_ref"/>
                <field name="duration_ms" string="ms"/>
                <field name="message" optional="show"/>
            </list>
        </field>
    </record>

    <!-- Search -->
    <record id="view_qbo_sync_log_search" model="ir.ui.view">
        <field name="name">qbo.sync.log.search</field>
        <field name="model">qbo.sync.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="qbo_id"/>
                <field name="company_id"/>
                <filter string="Errors" name="errors"
                        domain="[('status','=','error')]"/>
                <filter string="Conflicts" name="conflicts"
                        domain="[('status','=','conflict')]"/>
                <filter string="Today" name="today"
                        domain="[('sync_date','&gt;=', (context_today()).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group by">
                    <filter string="Entity type" name="group_entity"
                            context="{'group_by':'entity_type'}"/>
                    <filter string="Direction" name="group_direction"
                            context="{'group_by':'direction'}"/>
                    <filter string="Status" name="group_status"
                            context="{'group_by':'status'}"/>
                    <filter string="Company" name="group_company"
                            context="{'group_by':'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_qbo_sync_log" model="ir.actions.act_window">
        <field name="name">Sync Log</field>
        <field name="res_model">qbo.sync.log</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
