<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form -->
    <record id="view_qbo_company_mapping_form" model="ir.ui.view">
        <field name="name">qbo.company.mapping.form</field>
        <field name="model">qbo.company.mapping</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_sync_now"
                            string="Sync now"
                            type="object"
                            class="btn-primary"
                            confirm="This will immediately run a full two-way sync. Continue?"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                                name="action_view_conflicts" icon="fa-exclamation-triangle"
                                invisible="conflict_count == 0">
                            <field name="conflict_count" widget="statinfo" string="Conflicts"/>
                        </button>
                        <button class="oe_stat_button" type="object"
                                name="action_view_logs" icon="fa-list">
                            <field name="log_count" widget="statinfo" string="Logs"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="display_name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Mapping">
                            <field name="company_id"/>
                            <field name="realm_id"/>
                            <field name="sync_enabled"/>
                            <field name="sync_interval_minutes"/>
                        </group>
                        <group string="Last synced">
                            <field name="last_sync_date" readonly="1"/>
                            <field name="last_sync_accounts" readonly="1"/>
                            <field name="last_sync_partners" readonly="1"/>
                            <field name="last_sync_invoices" readonly="1"/>
                            <field name="last_sync_payments" readonly="1"/>
                            <field name="last_sync_journal_entries" readonly="1"/>
                            <field name="last_sync_products" readonly="1"/>
                        </group>
                    </group>
                    <group string="Entities to sync">
                        <group>
                            <field name="sync_accounts"/>
                            <field name="sync_partners"/>
                            <field name="sync_invoices"/>
                        </group>
                        <group>
                            <field name="sync_payments"/>
                            <field name="sync_journal_entries"/>
                            <field name="sync_products"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List -->
    <record id="view_qbo_company_mapping_list" model="ir.ui.view">
        <field name="name">qbo.company.mapping.list</field>
        <field name="model">qbo.company.mapping</field>
        <field name="arch" type="xml">
            <list>
                <field name="company_id"/>
                <field name="realm_id"/>
                <field name="sync_enabled" widget="toggle_button"/>
                <field name="last_sync_date"/>
                <field name="conflict_count"
                       decoration-danger="conflict_count &gt; 0"
                       decoration-muted="conflict_count == 0"/>
                <button name="action_sync_now" type="object"
                        string="Sync now" icon="fa-refresh"
                        confirm="Run sync now?"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_qbo_company_mapping" model="ir.actions.act_window">
        <field name="name">Company Mappings</field>
        <field name="res_model">qbo.company.mapping</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
