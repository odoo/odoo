<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- list-->
    <record id="app_action_view_tree" model="ir.ui.view">
        <field name="name">app.ir.actions.actions.list</field>
        <field name="model">ir.actions.actions</field>
        <field name="inherit_id" ref="base.action_view_tree"/>
        <field name="arch" type="xml">
            <field name="type" position="after">
                <field name="path" optional="hide"/>
                <field name="binding_model_id" optional="show"/>
            </field>
        </field>
    </record>
    <!-- form-->
    <record id="app_action_view_form" model="ir.ui.view">
        <field name="name">app.ir.actions.actions.form</field>
        <field name="model">ir.actions.actions</field>
        <field name="inherit_id" ref="base.action_view"/>
        <field name="arch" type="xml">
            <field name="type" position="after">
                <field name="path"/>
                <field name="binding_model_id"/>
                <field name="xml_id"/>
            </field>
        </field>
    </record>
    <!-- search-->
    <record id="app_action_view_search" model="ir.ui.view">
        <field name="name">app.ir.actions.actions.search</field>
        <field name="model">ir.actions.actions</field>
        <field name="inherit_id" ref="base.action_view_search"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="binding_model_id"/>
            </field>
        </field>
    </record>
</odoo>
