<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_gov_empenho_company_operador" model="ir.rule">
        <field name="name">NE: acesso por UG (operador)</field>
        <field name="model_id" ref="gov_empenho.model_gov_empenho"/>
        <field name="domain_force">[('ug_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('gov_base.group_gov_operador'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_gov_empenho_company_gestor" model="ir.rule">
        <field name="name">NE: acesso por UG (gestor)</field>
        <field name="model_id" ref="gov_empenho.model_gov_empenho"/>
        <field name="domain_force">[('ug_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('gov_base.group_gov_gestor'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>
</odoo>
