<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_account_form_inherit_gov_base" model="ir.ui.view">
        <field name="name">account.account.form.inherit.gov.base</field>
        <field name="model">account.account</field>
        <field name="inherit_id" ref="account.view_account_form"/>
