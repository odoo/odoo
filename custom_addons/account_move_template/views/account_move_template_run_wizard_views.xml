<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_move_template_run_wizard_view_form" model="ir.ui.view">
        <field name="name">account.move.template.run.wizard.form</field>
        <field name="model">account.move.template.run.wizard</field>
        <field name="arch" type="xml">
            <form string="Run Template">
                <group>
                    <field name="template_id"/>
                    <field name="company_id"/>
                    <field name="date"/>
                    <field name="ref"/>
                    <field name="amount"/>
                </group>
                <group string="Preview">
                    <field name="preview_line_ids" nolabel="1">
                        <list>
                            <field name="sequence"/>
                            <field name="name"/>
                            <field name="account_id"/>
                            <field name="partner_id"/>
                            <field name="move_type"/>
                            <field name="amount"/>
                        </list>
                    </field>
                </group>
                <footer>
                    <button name="action_create_move" type="object" string="Create And Post" class="btn-primary"/>
                    <button name="action_create_move_draft" type="object" string="Create Draft" class="btn-secondary"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="account_move_template_run_wizard_action" model="ir.actions.act_window">
        <field name="name">Run Template</field>
        <field name="res_model">account.move.template.run.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
