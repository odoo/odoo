<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_saleorder_document_compact" inherit_id="sale.report_saleorder_document">
        
        <xpath expr="//div[@class='page']" position="attributes">
            <attribute name="style">font-size: 10px !important; line-height: 1.1 !important;</attribute>
        </xpath>

        <xpath expr="//table[hasclass('table')]" position="attributes">
            <attribute name="class">table table-sm o_main_table table-borderless</attribute>
        </xpath>

        <xpath expr="//table[hasclass('table')]//thead//tr" position="attributes">
            <attribute name="style">line-height: 1; background-color: #f2f2f2;</attribute>
        </xpath>

        <xpath expr="//table[hasclass('table')]//tbody//tr" position="attributes">
            <attribute name="style">line-height: 1;</attribute>
        </xpath>

        <xpath expr="//div[@name='so_total_summary']" position="attributes">
            <attribute name="style">margin-top: 5px !important;</attribute>
        </xpath>

    </template>
</odoo>