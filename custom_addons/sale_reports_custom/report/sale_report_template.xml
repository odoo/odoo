<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_saleorder_compact_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="font-size: 10px; line-height: 1.1;">

                        <h5 class="text-center">
                            <t t-if="is_proforma">Pro-Forma Invoice #</t>
                            <t t-elif="doc.state in ['draft', 'sent']">Cotización #</t>
                            <t t-else="">Orden #</t>
                            <span t-field="doc.name"/>
                        </h5>
                        <div class="row mt-2 mb-2">
                            <div class="col-6">
                                <strong>Cliente:</strong>
                                <span t-field="doc.partner_id.name"/>
                                <br/>
                                <strong>RIF/ID:</strong>
                                <span t-field="doc.partner_id.vat"/>
                            </div>
                            <div class="col-6 text-end">
                                <strong>Fecha:</strong>
                                <span t-field="doc.date_order" t-options='{"widget": "date"}'/>
                                <br/>
                                <strong>Vendedor:</strong>
                                <span t-field="doc.user_id.name"/>
                            </div>
                        </div>

                        <table class="table table-sm" style="border: 1px solid black;">
                            <thead>
                                <tr style="background-color: #eee;">
                                    <th>Descripción</th>
                                    <th class="text-end">Cant.</th>
                                    <th class="text-end">Precio</th>
                                    <th class="text-end">Monto</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.order_line" t-as="line">
                                    <tr>
                                        <td>
                                            <span t-field="line.name"/>
                                        </td>
                                        <td class="text-end">
                                            <span t-field="line.product_uom_qty"/>
                                        </td>
                                        <td class="text-end">
                                            <span t-field="line.price_unit"/>
                                        </td>
                                        <td class="text-end">
                                            <span t-field="line.price_subtotal"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <div class="row justify-content-end">
                            <div class="col-4">
                                <table class="table table-sm">
                                    <!-- Subtotal, Taxes, Total -->
                                    <t t-call="sale.document_tax_totals">
                                        <t t-set="tax_totals" t-value="doc.tax_totals"/>
                                        <t t-set="currency" t-value="doc.currency_id"/>
                                    </t>
                                </table>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>