<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_employee_view_form_check_in_only" model="ir.ui.view">
        <field name="name">hr.employee.form.check.in.only</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='hr_settings']" position="inside">
                <separator string="Attendance Tracking"/>
                <group>
                    <field name="x_check_in_only" widget="boolean_toggle"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
