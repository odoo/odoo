<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend hr.leave form to add attendance issue fields -->
    <record id="hr_leave_view_form_inherit_attendance_issue" model="ir.ui.view">
        <field name="name">hr.leave.form.inherit.attendance.issue</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="before">
                <field name="x_attendance_ids" widget="many2many_tags"
                       options="{'no_create': True, 'no_edit': True}"
                       readonly="state in ['cancel', 'refuse', 'validate', 'validate1']"/>
                <field name="x_total_late_minutes" readonly="1" invisible="x_total_late_minutes == 0"/>
                <field name="x_total_early_leave_minutes" readonly="1" invisible="x_total_early_leave_minutes == 0"/>
                <field name="x_total_absent_days" readonly="1" invisible="1"/>

                <!-- Attendance issue breakdown lines -->
                <field name="x_attendance_line_ids"
                       invisible="not request_unit_hours or x_attendance_count == 0"
                       readonly="state in ['cancel', 'refuse', 'validate', 'validate1']"
                       nolabel="1" colspan="2">
                    <list editable="bottom" create="false" delete="false"
                          decoration-info="accepted_minutes &lt; duration_minutes"
                          decoration-success="accepted_minutes == duration_minutes">
                        <field name="attendance_id" readonly="1" force_save="1" column_invisible="True"/>
                        <field name="date" readonly="1" force_save="1"/>
                        <field name="issue_type" readonly="1" force_save="1"/>
                        <field name="hour_from" widget="float_time" readonly="1" force_save="1"/>
                        <field name="hour_to" widget="float_time" readonly="1" force_save="1"/>
                        <field name="duration_minutes" readonly="1" string="Minutes"/>
                        <field name="accepted_minutes" string="✔ Accepted" force_save="1"
                               class="fw-bold text-primary"/>
                    </list>
                </field>
            </xpath>

            <!-- Hide the standard Hours label and fields -->
            <xpath expr="//label[@for='request_hour_from']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//div[field[@name='request_hour_from']]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <!-- Extend hr.attendance list to show coverage status -->
    <record id="hr_attendance_view_list_inherit_coverage" model="ir.ui.view">
        <field name="name">hr.attendance.list.inherit.coverage</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.view_attendance_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="x_is_covered" string="Covered"
                       widget="boolean_toggle" readonly="1"
                       optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Extend hr.attendance form to show related leaves -->
    <record id="hr_attendance_view_form_inherit_leaves" model="ir.ui.view">
        <field name="name">hr.attendance.form.inherit.leaves</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Related Time Off"
                       invisible="not x_leave_ids">
                    <field name="x_leave_ids" widget="one2many_list"
                           readonly="1"/>
                    <field name="x_is_covered" readonly="1"
                           widget="boolean_toggle"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
