<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="hr_holidays.LeaveStatsComponent" t-inherit="hr_holidays.LeaveStatsComponent" t-inherit-mode="extension">

        <!-- ── Employee summary: replace each leave row ── -->
        <xpath expr="//div[@t-foreach='state.leaves']" position="replace">
            <div t-foreach="state.leaves" t-as="leave" t-key="leave.id" class="mb-2">
                <!-- Main row -->
                <div class="d-flex gap-1">
                    <span class="col-3 fw-bold" t-out="leave.holiday_status_id.display_name"/>
                    <div t-if="leave.leave_type_request_unit == 'hour'" class="d-flex gap-2 col-6 flex-wrap">
                        <span t-out="leave.date_from"/>
                        <t t-if="leave.date_from !== leave.date_to">
                            <i class="fa fa-long-arrow-right my-1" aria-label="Arrow icon" title="Arrow"/>
                            <span t-out="leave.date_to"/>
                        </t>
                        <t t-else="">
                            <span t-out="leave.hour_from" class="fst-italic"/>
                            <i class="fa fa-long-arrow-right my-1" aria-label="Arrow icon" title="Arrow"/>
                            <span t-out="leave.hour_to" class="fst-italic"/>
                        </t>
                    </div>
                    <div t-else="" class="col-6 d-flex gap-2 flex-wrap">
                        <span t-out="leave.date_from"/>
                        <i class="fa fa-long-arrow-right my-1" aria-label="Arrow icon" title="Arrow"/>
                        <span t-out="leave.date_to"/>
                    </div>
                    <div class="col-3 flex-wrap">
                    (
                        <span t-if="leave.leave_type_request_unit == 'hour'"><t t-out="leave.number_of_hours"/> hours</span>
                        <span t-else=""><t t-out="leave.number_of_days"/> days</span>
                    )
                    </div>
                </div>
                <!-- Attendance breakdown sub-rows -->
                <t t-if="leave.attendance_breakdown and leave.attendance_breakdown.length > 1">
                    <div t-foreach="leave.attendance_breakdown" t-as="att" t-key="att_index"
                         class="d-flex gap-1 ms-4 ps-2 text-muted" style="font-size: 0.85em;">
                        <span class="col-3"><t t-out="att_index + 1"/>-</span>
                        <span class="col-6">
                            <t t-out="att.date"/>
                            <t t-if="att.is_absent"><i class="ms-1 fa fa-calendar-times-o" title="Absent"/></t>
                        </span>
                        <span class="col-3"><t t-out="att.hours_display"/> hours</span>
                    </div>
                </t>
            </div>
        </xpath>

        <!-- ── Department summary: replace each leave row ── -->
        <xpath expr="//div[@t-foreach='state.departmentLeaves']" position="replace">
            <div t-foreach="state.departmentLeaves" t-as="leave" t-key="leave.id" class="d-flex flex-column mb-2">
                <div class="d-flex my-1 gap-1">
                    <div class="col-3 d-flex">
                        <KanbanMany2OneAvatarEmployeeField
                            record="{'data' : {'employee_id': leave.employee_id}, 'fields': this.props.record.fields}"
                            name="'employee_id'" relation="'hr.employee.public'"
                        />
                        <span t-out="leave.employee_id.display_name" class="mx-1 fw-bold"/>
                    </div>
                    <div t-if="leave.leave_type_request_unit == 'hour'" class="d-flex gap-2 col-6 flex-wrap">
                        <span t-out="leave.date_from"/>
                        <t t-if="leave.date_from !== leave.date_to">
                            <i class="fa fa-long-arrow-right my-1" aria-label="Arrow icon" title="Arrow"/>
                            <span t-out="leave.date_to"/>
                        </t>
                        <t t-else="">
                            <span t-out="leave.hour_from" class="fst-italic"/>
                            <i class="fa fa-long-arrow-right my-1" aria-label="Arrow icon" title="Arrow"/>
                            <span t-out="leave.hour_to" class="fst-italic"/>
                        </t>
                    </div>
                    <div t-else="" class="col-6 d-flex gap-2 flex-wrap">
                        <span t-out="leave.date_from"/>
                        <i class="fa fa-long-arrow-right my-1" aria-label="Arrow icon" title="Arrow"/>
                        <span t-out="leave.date_to"/>
                    </div>
                    <div class="col-3 flex-wrap">
                    (
                        <span t-if="leave.leave_type_request_unit == 'hour'"><t t-out="leave.number_of_hours"/> hours</span>
                        <span t-else=""><t t-out="leave.number_of_days"/> days</span>
                    )
                    </div>
                </div>
                <!-- Attendance breakdown sub-rows -->
                <t t-if="leave.attendance_breakdown and leave.attendance_breakdown.length > 1">
                    <div t-foreach="leave.attendance_breakdown" t-as="att" t-key="att_index"
                         class="d-flex gap-1 ms-4 ps-2 text-muted" style="font-size: 0.85em;">
                        <span class="col-3"><t t-out="att_index + 1"/>-</span>
                        <span class="col-6">
                            <t t-out="att.date"/>
                            <t t-if="att.is_absent"><i class="ms-1 fa fa-calendar-times-o" title="Absent"/></t>
                        </span>
                        <span class="col-3"><t t-out="att.hours_display"/> hours</span>
                    </div>
                </t>
            </div>
        </xpath>

    </t>

</templates>







