<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_ksw_payroll" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.ksw.payroll</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="om_hr_payroll.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='om_hr_payroll_account']" position="after">
                <h2>Social Insurance (GOSI)</h2>
                <div class="row mt16 o_settings_container" id="ksw_gosi_settings">
                    <div class="col-lg-6 col-12 o_setting_box">
                        <div class="o_setting_right_pane">
                            <label for="ksw_gosi_rate"/>
                            <div class="text-muted">
                                Percentage deducted from (Basic + HRA) for Saudi employees.
                            </div>
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="ksw_gosi_rate" class="o_light_label"/>
                                    <span class="ms-1">%</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

</odoo>

