<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Extend hr.leave FORM: vacation payslip link                  -->
    <!-- (field lives in KSW_payroll because it references hr.payslip -->
    <!--  which comes from om_hr_payroll)                              -->
    <!-- ============================================================ -->
    <record id="hr_leave_view_form_inherit_payroll_vacation" model="ir.ui.view">
        <field name="name">hr.leave.form.inherit.payroll.vacation</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="KSW_annual_leave.hr_leave_view_form_inherit_annual_return"/>
        <field name="arch" type="xml">
            <!-- Insert vacation payslip section before the first approver field -->
            <xpath expr="//field[@name='x_dm_approved_by']/.." position="before">
                <group string="Vacation Payslips"
                       invisible="not x_vacation_payslip_id"
                       col="2">
                    <field name="x_vacation_payslip_ids" nolabel="1"
                           widget="many2many_tags"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>

