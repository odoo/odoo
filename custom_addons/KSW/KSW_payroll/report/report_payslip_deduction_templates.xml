<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--  PAYSLIP REPORT — Combined single report:                    -->
    <!--  Worked Days + Other Inputs + Salary Computation +           -->
    <!--  Attendance Deduction Breakdown                              -->
    <!--  Completely replaces the stock om_hr_payroll report_payslip  -->
    <!-- ============================================================ -->
    <template id="report_payslip_override"
              inherit_id="om_hr_payroll.report_payslip">

        <!-- Gut the original page and replace it entirely -->
        <xpath expr="//div[hasclass('page')]" position="replace">
            <div class="page">

                <!-- ── Header ── -->
                <h2>Payslip</h2>
                <p t-out="o.name"/>

                <!-- ── Employee info ── -->
                <table class="table table-sm table-bordered mb-3">
                    <tr>
                        <td style="width:20%"><strong>Employee</strong></td>
                        <td style="width:30%" t-out="o.employee_id.name"/>
                        <td style="width:20%"><strong>Designation</strong></td>
                        <td style="width:30%" t-out="o.employee_id.job_id.name or ''"/>
                    </tr>
                    <tr>
                        <td><strong>Department</strong></td>
                        <td t-out="o.employee_id.department_id.name or ''"/>
                        <td><strong>ID No.</strong></td>
                        <td t-out="o.employee_id.ssnid or o.employee_id.identification_id or ''"/>
                    </tr>
                    <tr>
                        <td><strong>Reference</strong></td>
                        <td t-out="o.number or ''"/>
                        <td><strong>Bank Account</strong></td>
                        <td>
                            <t t-if="o.employee_id.bank_account_ids">
                                <span t-out="o.employee_id.bank_account_ids[0].acc_number"/>
                            </t>
                        </td>
                    </tr>
                    <tr>
                        <td><strong>Period</strong></td>
                        <td>
                            <span t-field="o.date_from"/> –
                            <span t-field="o.date_to"/>
                        </td>
                        <td><strong>Company</strong></td>
                        <td t-out="o.company_id.name"/>
                    </tr>
                </table>

                <!-- ══════════════════════════════════════════════════ -->
                <!--  Section 1: Worked Days                          -->
                <!-- ══════════════════════════════════════════════════ -->
                <t t-if="o.worked_days_line_ids">
                    <h4>Worked Days</h4>
                    <table class="table table-sm table-bordered">
                        <thead class="table-light">
                            <tr>
                                <th>Description</th>
                                <th>Code</th>
                                <th class="text-end">Days</th>
                                <th class="text-end">Hours</th>
                                <th class="text-end">Deduction</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="wd_total_days" t-value="0"/>
                            <t t-set="wd_total_hours" t-value="0"/>
                            <t t-set="wd_total_ded" t-value="0"/>
                            <tr t-foreach="o.worked_days_line_ids" t-as="wd"
                                t-attf-class="#{'table-danger fw-bold' if wd.code == 'ATT_DED' else 'table-warning' if wd.code in ('ATT_ABS','ATT_LATE','ATT_EARLY') else ''}">
                                <td t-out="wd.name"/>
                                <td t-out="wd.code"/>
                                <td class="text-end" t-out="'%.0f' % wd.number_of_days"/>
                                <td class="text-end" t-out="'%.0f' % wd.number_of_hours"/>
                                <td class="text-end" t-out="'%.0f' % wd.amount if wd.amount else ''"/>
                                <t t-set="wd_total_days" t-value="wd_total_days + wd.number_of_days"/>
                                <t t-set="wd_total_hours" t-value="wd_total_hours + wd.number_of_hours"/>
                                <t t-set="wd_total_ded" t-value="wd_total_ded + (wd.amount or 0)"/>
                            </tr>
                        </tbody>
                        <tfoot class="fw-bold table-light">
                            <tr>
                                <td colspan="2">Total</td>
                                <td class="text-end" t-out="'%.0f' % wd_total_days"/>
                                <td class="text-end" t-out="'%.0f' % wd_total_hours"/>
                                <td class="text-end" t-out="'%.0f' % wd_total_ded if wd_total_ded else ''"/>
                            </tr>
                        </tfoot>
                    </table>
                </t>

                <!-- ══════════════════════════════════════════════════ -->
                <!--  Section 2: Other Inputs                         -->
                <!-- ══════════════════════════════════════════════════ -->
                <t t-if="o.input_line_ids">
                    <h4>Other Inputs</h4>
                    <table class="table table-sm table-bordered">
                        <thead class="table-light">
                            <tr>
                                <th>Description</th>
                                <th>Code</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="o.input_line_ids" t-as="inp">
                                <td t-out="inp.name"/>
                                <td t-out="inp.code"/>
                                <td class="text-end" t-out="'%.0f' % inp.amount"/>
                            </tr>
                        </tbody>
                    </table>
                </t>

                <!-- ══════════════════════════════════════════════════ -->
                <!--  Section 3: Attendance Deduction Breakdown       -->
                <!-- ══════════════════════════════════════════════════ -->
                <t t-set="deduction_rows" t-value="o.get_deduction_breakdown()"/>
                <t t-if="deduction_rows">
                    <h4>Attendance Deduction Breakdown</h4>
                    <table class="table table-sm table-bordered">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th>Day</th>
                                <th class="text-end">Late (min)</th>
                                <th class="text-end">Early (min)</th>
                                <th class="text-center">Absent</th>
                                <th class="text-end">Deduction</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="total_ded" t-value="0"/>
                            <tr t-foreach="deduction_rows" t-as="row"
                                t-attf-class="#{'table-danger' if row['is_absent'] else 'table-warning'}">
                                <td t-out="row['date']"/>
                                <td t-out="row['day']"/>
                                <td class="text-end" t-out="'%.0f' % row['late_min']"/>
                                <td class="text-end" t-out="'%.0f' % row['early_min']"/>
                                <td class="text-center" t-out="'Yes' if row['is_absent'] else ''"/>
                                <td class="text-end" t-out="'%.2f' % row['deduction']"/>
                                <t t-set="total_ded"
                                   t-value="total_ded + row['deduction']"/>
                            </tr>
                        </tbody>
                        <tfoot class="fw-bold table-light">
                            <tr>
                                <td colspan="5">Total Deductions</td>
                                <td class="text-end" t-out="'%.0f' % total_ded"/>
                            </tr>
                        </tfoot>
                    </table>
                </t>

                <!-- ══════════════════════════════════════════════════ -->
                <!--  Section 4: Salary Computation (all visible)     -->
                <!-- ══════════════════════════════════════════════════ -->
                <t t-set="basic_total" t-value="sum(l.total for l in o.line_ids if l.code == 'BASIC')"/>
                <t t-set="attded_total" t-value="sum(l.total for l in o.line_ids if l.code == 'ATTDED')"/>
                <h4>Salary Computation</h4>
                <table class="table table-sm table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>Description</th>
                            <th>Code</th>
                            <th class="text-end">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="o.line_ids.filtered(lambda l: l.appears_on_payslip).sorted('sequence')"
                            t-as="line">
                            <tr t-attf-class="#{'table-success fw-bold' if line.code == 'NET' else 'table-danger' if line.total &lt; 0 else 'fw-bold' if line.code in ('BASIC','GROSS') else 'text-muted' if line.total == 0 else ''}">
                                <td t-out="line.name"/>
                                <td t-out="line.code"/>
                                <td class="text-end" t-out="'%.0f' % line.total"/>
                            </tr>
                            <tr t-if="line.code == 'BASIC'" class="table-info">
                                <td>Net Basic Salary (Basic - ATTDED)</td>
                                <td></td>
                                <td class="text-end" t-out="'%.0f' % (basic_total + attded_total)"/>
                            </tr>
                        </t>
                    </tbody>
                </table>

                <p class="text-end mt-4">
                    <strong>Authorized Signature</strong>
                </p>
            </div>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!--  Hide the second report from the Print menu — everything is  -->
    <!--  now in the main payslip report above.                       -->
    <!-- ============================================================ -->
    <record id="om_hr_payroll.payslip_details_report" model="ir.actions.report">
        <field name="binding_model_id" eval="False"/>
    </record>

</odoo>

