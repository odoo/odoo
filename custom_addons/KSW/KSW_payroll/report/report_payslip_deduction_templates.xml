<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Inherit the payslip report to add attendance deduction detail -->
    <!-- ============================================================ -->
    <template id="report_payslip_inherit_deduction"
              inherit_id="om_hr_payroll.report_payslip">
        <xpath expr="//table[hasclass('table-sm')][last()]" position="after">
            <t t-set="deduction_records"
               t-value="request.env['hr.attendance'].sudo().search([
                   ('employee_id', '=', o.employee_id.id),
                   ('check_in', '&gt;=', str(o.date_from) + ' 00:00:00'),
                   ('check_in', '&lt;=', str(o.date_to) + ' 23:59:59'),
                   ('x_deduction_amount', '&gt;', 0),
               ], order='check_in asc')"/>
            <t t-if="deduction_records">
                <h4 class="mt-3">Attendance Deductions</h4>
                <table class="table table-sm table-bordered">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Day</th>
                            <th>Late (min)</th>
                            <th>Early (min)</th>
                            <th>Absent</th>
                            <th class="text-end">Deduction</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-set="total_deduction" t-value="0"/>
                        <tr t-foreach="deduction_records" t-as="att">
                            <td t-out="att.check_in.strftime('%Y-%m-%d')"/>
                            <td t-out="att.x_day_of_week"/>
                            <td t-out="'%.0f' % (att.x_net_late_minutes or 0)"/>
                            <td t-out="'%.0f' % (att.x_net_early_leave_minutes or 0)"/>
                            <td t-out="'Yes' if att.x_net_is_absent else ''"/>
                            <td class="text-end">
                                <span t-out="att.x_deduction_amount"
                                      t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                            </td>
                            <t t-set="total_deduction"
                               t-value="total_deduction + att.x_deduction_amount"/>
                        </tr>
                    </tbody>
                    <tfoot>
                        <tr class="fw-bold">
                            <td colspan="5">Total Deductions</td>
                            <td class="text-end">
                                <span t-out="total_deduction"
                                      t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </t>
        </xpath>
    </template>

</odoo>

