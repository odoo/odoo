<odoo>
    <!-- Adding temp flag in working schedule -->
    <record id="adding_temp_flag_to_resource_calendar_form" model="ir.ui.view">
        <field name="name">resource.calendar.view.form.inherit.temp_flag</field>
        <field name="model">resource.calendar</field>
        <field name="inherit_id" ref="resource.resource_calendar_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tz']" position="after">
                <field name="is_temp_schedule"/>
            </xpath>
        </field>
    </record>

