<odoo>
     <record id="adding_working_schedule_to_employee_form" model="ir.ui.view">
        <field name="name">hr.employee.view.form.inherit.resource.calendar</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <!-- Add our schedule fields after the Schedule separator -->
            <xpath expr="//separator[@name='schedule']" position="after">
                <field name="main_calendar_id"/>
                <field name="temp_calendar_id"/>
            </xpath>
            <!-- Hide the standard Working Hours field in the Payroll page -->
            <xpath expr="//group[@name='contract']/field[@name='resource_calendar_id']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>
