<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <record id="type_loan" model="ksw.deduction.type">
            <field name="name">Personal Loan</field>
            <field name="code">LOAN</field>
            <field name="category">borrowed</field>
            <field name="is_loan" eval="True"/>
            <field name="default_installments">10</field>
            <field name="description">Personal loan granted to the employee (requires full approval chain).</field>
            <field name="sequence">10</field>
        </record>

        <record id="type_advance" model="ksw.deduction.type">
            <field name="name">Salary Advance</field>
            <field name="code">ADV</field>
            <field name="category">borrowed</field>
            <field name="is_loan" eval="False"/>
            <field name="default_installments">1</field>
            <field name="description">Short-term salary advance, deducted in one installment.</field>
            <field name="sequence">20</field>
        </record>

        <record id="type_gov_penalty" model="ksw.deduction.type">
            <field name="name">Government Penalty</field>
            <field name="code">GOVPEN</field>
            <field name="category">company_paid</field>
            <field name="is_loan" eval="False"/>
            <field name="default_installments">1</field>
            <field name="description">Government fine paid by the company on behalf of the employee.</field>
            <field name="sequence">30</field>
        </record>

        <record id="type_internal_penalty" model="ksw.deduction.type">
            <field name="name">Internal Penalty</field>
            <field name="code">INTPEN</field>
            <field name="category">company_paid</field>
            <field name="is_loan" eval="False"/>
            <field name="default_installments">1</field>
            <field name="description">Internal company penalty applied to the employee.</field>
            <field name="sequence">40</field>
        </record>

    </data>
</odoo>

