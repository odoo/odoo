<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="hr_employee_view_form_inherit_ksw_deduction" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.ksw.deduction</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" type="object"
                        name="action_view_deductions" icon="fa-money"
                        groups="hr.group_hr_user">
                    <field name="x_deduction_count" widget="statinfo"
                           string="Deductions"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>

