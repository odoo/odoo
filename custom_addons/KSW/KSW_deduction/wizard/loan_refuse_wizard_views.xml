<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Loan Refusal Wizard                                           -->
    <!-- ============================================================ -->
    <record id="ksw_loan_refuse_wizard_form" model="ir.ui.view">
        <field name="name">ksw.loan.refuse.wizard.form</field>
        <field name="model">ksw.loan.refuse.wizard</field>
        <field name="arch" type="xml">
            <form string="Refuse Loan Request">
                <sheet>
                    <div class="alert alert-danger d-flex align-items-start"
                         role="alert">
                        <i class="fa fa-ban fa-lg me-2 mt-1"
                           title="Refuse" role="img" aria-label="Refuse"/>
                        <div>
                            <strong>You are about to refuse this loan request.</strong>
                            <div class="mt-1">
                                The reason you provide below
                                <b>will be shown to the employee</b>
                                and recorded permanently in the approval
                                history. Please be clear and respectful.
                            </div>
                        </div>
                    </div>

                    <div class="card mb-3">
                        <div class="card-header bg-light">
                            <strong>Request under review</strong>
                        </div>
                        <div class="card-body">
                            <group>
                                <group>
                                    <field name="deduction_id" readonly="1"/>
                                    <field name="employee_id" readonly="1"/>
                                    <field name="step" readonly="1"/>
                                </group>
                                <group>
                                    <field name="amount" readonly="1"/>
                                    <field name="installments" readonly="1"/>
                                    <field name="currency_id" invisible="1"/>
                                </group>
                            </group>
                        </div>
                    </div>

                    <separator string="Reason for refusal"/>
                    <field name="reason" required="1" nolabel="1"
                           placeholder="Explain clearly why this loan request is being refused. The employee will see this reason."/>
                </sheet>
                <footer>
                    <button name="action_confirm" type="object"
                            string="Confirm Refusal"
                            class="btn-danger"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>

