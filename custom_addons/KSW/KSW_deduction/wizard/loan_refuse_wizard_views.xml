<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Loan Refusal Wizard                                           -->
    <!-- ============================================================ -->
    <record id="ksw_loan_refuse_wizard_form" model="ir.ui.view">
        <field name="name">ksw.loan.refuse.wizard.form</field>
        <field name="model">ksw.loan.refuse.wizard</field>
        <field name="arch" type="xml">
            <form string="Refuse Loan Request">
                <sheet>
                    <div class="alert alert-warning" role="status">
                        <strong>⛔ Refuse Loan Request</strong><br/>
                        You are about to refuse this loan request. The
                        reason you provide below will be recorded and
                        shown to the employee.
                    </div>
                    <group>
                        <group>
                            <field name="deduction_id" readonly="1"/>
                            <field name="employee_id" readonly="1"/>
                            <field name="step" readonly="1"/>
                        </group>
                        <group>
                            <field name="amount" readonly="1"/>
                            <field name="installments" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="reason" required="1" nolabel="1"
                               placeholder="Explain clearly why this loan request is being refused. The employee will see this reason."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" type="object"
                            string="Confirm Refusal"
                            class="btn-danger"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>

