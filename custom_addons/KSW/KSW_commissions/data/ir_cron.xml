<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <!--
            Monthly cron — runs on the 1st of each month.
            Creates a draft sheet for every employee assigned to an active
            commission template that doesn't yet have one for the current
            period. NO auto-confirm — closing the sheet stays a manual
            supervisor action.

            ``numbercall`` is removed (Odoo 19 — see AGENTS.md gotcha).
        -->
        <record id="ir_cron_create_monthly_sheets" model="ir.cron">
            <field name="name">KSW Commissions: monthly sheet creation</field>
            <field name="model_id" ref="model_ksw_commission_sheet"/>
            <field name="state">code</field>
            <field name="code">model._cron_ensure_monthly_sheets()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>

