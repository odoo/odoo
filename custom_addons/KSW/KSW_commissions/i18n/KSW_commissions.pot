#. module: KSW_commissions
#: model_terms:ir.ui.view,arch_db:KSW_commissions.view_ksw_deduction_form_inherit_awaiting_commission
msgid ""
"The loan total stays balanced (50 + 150 = 200) so\n"
"                    the schedule is unaffected; payroll skips the\n"
"                    parked row, and the commission sheet flips it to\n"
"                    <i>Paid</i> when finalised."
msgstr ""

#. module: KSW_commissions
#: model_terms:ir.ui.view,arch_db:KSW_commissions.view_ksw_deduction_form_inherit_awaiting_commission
msgid ""
"The matching commission sheet automatically\n"
"                            picks the 150 up in its <i>Loans (auto)</i>\n"
"                            field and settles it on Finalise."
msgstr ""

#. module: KSW_commissions
#: model:ir.model.fields,help:KSW_commissions.field_ksw_deduction_line__x_awaiting_commission
msgid ""
"Tick on a PENDING installment line to mean: do not deduct this slice from "
"payroll — recoup it from the employee's monthly commission sheet instead. "
"The matching commission sheet automatically picks it up in its \"Loans "
"(auto)\" total. Cleared automatically when the line is paid via a commission"
" sheet."
msgstr ""

