<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Commission Batch — Form -->
    <record id="view_ksw_commission_batch_form" model="ir.ui.view">
        <field name="name">ksw.commission.batch.form</field>
        <field name="model">ksw.commission.batch</field>
        <field name="arch" type="xml">
            <form string="Commission Batch">
                <field name="state" invisible="1"/>
                <header>
                    <button name="action_close" string="Close Batch" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_reset_to_draft" string="Reopen"
                            type="object" class="btn-secondary"
                            groups="KSW_commissions.group_commission_officer"
                            invisible="state == 'draft'"/>
                    <button name="action_open_export_wizard"
                            string="Export Bank File" type="object"
                            class="btn-secondary"
                            groups="KSW_commissions.group_commission_accountant"
                            invisible="state != 'closed'"/>
                    <statusbar statusfield="state" statusbar_visible="draft,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="period"/>
                            <field name="x_salary_bank_account_id"
                                   options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="sheet_count" readonly="1"/>
                            <field name="total_payable" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <field name="sheet_ids" widget="many2many_list">
                        <list>
                            <field name="name"/>
                            <field name="employee_id"/>
                            <field name="department_id"/>
                            <field name="period"/>
                            <field name="lines_subtotal"/>
                            <field name="driver_commission_amount"/>
                            <field name="x_loans_amount_locked"/>
                            <field name="total_payable" sum="Total Payable"/>
                            <field name="state"/>
                        </list>
                    </field>
                    <field name="note" placeholder="Internal notes…"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Commission Batch — List -->
    <record id="view_ksw_commission_batch_list" model="ir.ui.view">
        <field name="name">ksw.commission.batch.list</field>
        <field name="model">ksw.commission.batch</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'closed'"
                  decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="period"/>
                <field name="sheet_count"/>
                <field name="total_payable" sum="Total"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Commission Batch — Search -->
    <record id="view_ksw_commission_batch_search" model="ir.ui.view">
        <field name="name">ksw.commission.batch.search</field>
        <field name="model">ksw.commission.batch</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="period"/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="closed" string="Closed" domain="[('state','=','closed')]"/>
                <group>
                    <filter string="Period" name="grp_period" domain="[]"
                            context="{'group_by': 'period'}"/>
                    <filter string="State" name="grp_state" domain="[]"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_ksw_commission_batch" model="ir.actions.act_window">
        <field name="name">Commission Batches</field>
        <field name="res_model">ksw.commission.batch</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_ksw_commission_batch_search"/>
    </record>

</odoo>

