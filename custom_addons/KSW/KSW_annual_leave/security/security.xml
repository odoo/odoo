    <!-- ============================================================ -->
    <!-- Record Rules — hr.leave.allocation (read cascade)             -->
    <!-- ============================================================ -->
    <!--
        Odoo's stock allocation rules let `base.group_user` read only
        own + `leave_manager_id` allocations. When a Supervisor (or
        Create-Supervisor) user picks a subordinate in the leave
        creation form, the leave-type filter `has_valid_allocation`
        must read that subordinate's allocation — but the stock rule
        excludes parent_id descendants, so annual-vacation types
        silently disappear from the dropdown.

        These KSW rules grant **read-only** access to allocations of
        subordinates (parent_id descendants, recursive) for users in
        any KSW Supervisor or Officer Create/View tier. Write/create/
        unlink on allocations remain admin-only — KSW leaves the
        allocation lifecycle to the existing infrastructure.
    -->
    <record id="hr_leave_allocation_rule_view_supervisor" model="ir.rule">
        <field name="name">KSW Allocation: view supervisor (immediate subordinates)</field>
        <field name="model_id" ref="hr_holidays.model_hr_leave_allocation"/>
        <field name="groups" eval="[
            (4, ref('group_leave_view_supervisor')),
            (4, ref('group_leave_create_supervisor')),
        ]"/>
        <field name="domain_force">[('employee_id.parent_id.user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="hr_leave_allocation_rule_view_supervisor_cascading" model="ir.rule">
        <field name="name">KSW Allocation: view supervisor cascading (subordinates, recursive)</field>
        <field name="model_id" ref="hr_holidays.model_hr_leave_allocation"/>
        <field name="groups" eval="[
            (4, ref('group_leave_view_supervisor_cascading')),
            (4, ref('group_leave_create_supervisor_cascading')),
        ]"/>
        <field name="domain_force">[('employee_id', 'child_of', user.employee_ids.ids)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="hr_leave_allocation_rule_view_officer" model="ir.rule">
        <field name="name">KSW Allocation: view officer (all)</field>
        <field name="model_id" ref="hr_holidays.model_hr_leave_allocation"/>
        <field name="groups" eval="[
            (4, ref('group_leave_view_officer')),
            (4, ref('group_leave_create_officer')),
