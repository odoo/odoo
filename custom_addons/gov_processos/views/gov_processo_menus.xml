<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_gov_processo_all" model="ir.actions.act_window">
        <field name="name">Todos os Processos</field>
        <field name="res_model">gov.processo</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="gov_processos.view_gov_processo_search"/>
        <field name="context">{'search_default_my_ug': 1, 'default_ug_id': allowed_company_ids and allowed_company_ids[0]}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                <i class="fa fa-folder-open"/> Cadastre seu primeiro processo administrativo.
            </p>
        </field>
    </record>

    <record id="action_gov_processo_my" model="ir.actions.act_window">
        <field name="name">Meus Processos</field>
        <field name="res_model">gov.processo</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="gov_processos.view_gov_processo_search"/>
        <field name="domain">[('responsible_id', '=', uid)]</field>
        <field name="context">{'search_default_my_ug': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                <i class="fa fa-folder-open"/> Você ainda não possui processos sob sua responsabilidade.
            </p>
        </field>
    </record>

