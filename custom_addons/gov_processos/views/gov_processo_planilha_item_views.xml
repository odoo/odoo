<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gov_processo_planilha_item_list" model="ir.ui.view">
        <field name="name">gov.processo.planilha.item.list</field>
        <field name="model">gov.processo.planilha.item</field>
        <field name="arch" type="xml">
            <list string="Itens Estruturados XLSX" create="true" delete="true">
                <field name="sequence" widget="handle"/>
                <field name="lot_code"/>
                <field name="item_number"/>
                <field name="class_abc"/>
                <field name="lot_description" optional="show"/>
                <field name="description"/>
                <field name="unit"/>
                <field name="monthly_quantity"/>
                <field name="annual_quantity"/>
                <field name="unit_price"/>
                <field name="annual_total" optional="show"/>
                <field
                    name="status"
                    widget="badge"
                    decoration-success="status == 'aberta'"
                    decoration-warning="status == 'pendente'"
                    decoration-danger="status == 'fechada'"
                />
            </list>
        </field>
    </record>

    <record id="view_gov_processo_planilha_item_form" model="ir.ui.view">
        <field name="name">gov.processo.planilha.item.form</field>
        <field name="model">gov.processo.planilha.item</field>
        <field name="arch" type="xml">
            <form string="Item Estruturado XLSX">
                <sheet>
                    <div class="alert alert-warning mb-3" role="alert" invisible="can_edit">
                        Este item so pode ser alterado enquanto a fase correspondente estiver aberta.
                    </div>
                    <group>
                        <group string="Identificacao">
                            <field name="processo_id" readonly="1"/>
                            <field name="fase"/>
                            <field
                                name="status"
                                widget="badge"
                                decoration-success="status == 'aberta'"
                                decoration-warning="status == 'pendente'"
                                decoration-danger="status == 'fechada'"
                            />
                            <field name="class_abc"/>
                            <field name="lot_code"/>
                            <field name="item_number"/>
                            <field name="lot_description"/>
                        </group>
                        <group string="Quantidades e Valores">
                            <field name="description"/>
                            <field name="unit"/>
                            <field name="monthly_quantity"/>
                            <field name="annual_quantity"/>
                            <field name="unit_price"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="monthly_total" readonly="1"/>
                            <field name="annual_total" readonly="1"/>
                        </group>
                    </group>
                    <group string="Especificacao Tecnica">
                        <field
                            name="specification"
                            nolabel="1"
                            placeholder="Descreva a especificacao minima do item..."
                            readonly="not can_edit"
                        />
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
