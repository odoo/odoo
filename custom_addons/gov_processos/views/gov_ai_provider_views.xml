<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gov_ai_provider_config_list" model="ir.ui.view">
        <field name="name">gov.ai.provider.config.list</field>
        <field name="model">gov.ai.provider.config</field>
        <field name="arch" type="xml">
            <list string="Provedores de Modelo">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="company_id"/>
                <field name="provider"/>
                <field name="model_name"/>
                <field name="is_default" widget="boolean_toggle"/>
                <field name="memory_top_k"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_gov_ai_provider_config_form" model="ir.ui.view">
        <field name="name">gov.ai.provider.config.form</field>
        <field name="model">gov.ai.provider.config</field>
        <field name="arch" type="xml">
            <form string="Configuração de Provedor">
                <sheet>
                    <group>
                        <group string="Identificação">
                            <field name="name"/>
                            <field name="company_id"/>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="is_default"/>
                        </group>
                        <group string="Conexão">
                            <field name="provider"/>
                            <field name="model_name"/>
                            <field name="endpoint_url"/>
                            <field name="api_key" password="True"/>
                        </group>
                    </group>
                    <group string="Parâmetros">
                        <field name="temperature"/>
                        <field name="max_tokens"/>
                        <field name="timeout_seconds"/>
                        <field name="memory_top_k"/>
                    </group>
                    <group string="Observações">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gov_ai_provider_config" model="ir.actions.act_window">
        <field name="name">Provedores de Modelo</field>
        <field name="res_model">gov.ai.provider.config</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
