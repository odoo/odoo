<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gov_siafi_wizard_form" model="ir.ui.view">
        <field name="name">gov.siafi.wizard.form</field>
        <field name="model">gov.siafi.wizard</field>
        <field name="arch" type="xml">
            <form string="Exportacao SIAFI - Execucao Orcamentaria">
                <sheet>
                    <group string="Filtros de Exportacao">
                        <group>
                            <field name="ug_id" options="{'no_create': True}"/>
                            <field name="exercicio"/>
                        </group>
                        <group>
                            <field name="data_ini"/>
                            <field name="data_fim"/>
                        </group>
                    </group>

                    <group string="Documentos a Incluir">
                        <group>
                            <field name="incluir_ne" widget="boolean_toggle"/>
                            <field name="state_ne" invisible="not incluir_ne"/>
                        </group>
                        <group>
                            <field name="incluir_nl" widget="boolean_toggle"/>
                            <field name="incluir_op" widget="boolean_toggle"/>
                            <field name="state_op" invisible="not incluir_op"/>
                        </group>
                    </group>

                    <group string="Resumo do Periodo">
                        <field
                            name="preview_resumo"
                            nolabel="1"
                            colspan="2"
                            readonly="1"
                            widget="text"
                            style="font-family: monospace; font-size: 0.9em; white-space: pre; min-height: 80px;"
                        />
                    </group>

                    <group string="Arquivo Gerado" invisible="not gerado">
                        <field
                            name="arquivo_txt"
                            widget="binary"
                            filename="arquivo_nome"
                            readonly="1"
                        />
                        <field name="arquivo_nome" invisible="1"/>
                        <field
                            name="hash_sha256"
                            readonly="1"
                            string="SHA-256"
                            style="font-family: monospace; font-size: 0.85em;"
                        />
                    </group>
                </sheet>
                <footer>
                    <button
                        name="action_exportar"
                        string="Exportar SIAFI"
                        type="object"
                        class="btn-primary"
                    />
                    <button string="Fechar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_gov_siafi_wizard" model="ir.actions.act_window">
        <field name="name">Exportar SIAFI</field>
        <field name="res_model">gov.siafi.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
