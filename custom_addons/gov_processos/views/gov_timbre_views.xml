<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gov_timbre_list" model="ir.ui.view">
        <field name="name">gov.timbre.list</field>
        <field name="model">gov.timbre</field>
        <field name="arch" type="xml">
            <list string="Timbres Institucionais">
                <field name="name"/>
                <field name="ug_id"/>
                <field name="is_default" widget="boolean"/>
                <field name="cabecalho_img" widget="image" options="{'size': [40, 40]}"/>
                <field name="cabecalho_altura" string="Alt. Cab. (cm)"/>
                <field name="active" widget="boolean" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_gov_timbre_form" model="ir.ui.view">
        <field name="name">gov.timbre.form</field>
        <field name="model">gov.timbre</field>
        <field name="arch" type="xml">
            <form string="Timbre Institucional">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        <b>Instrucoes de upload:</b><br/>
                        Cabecalho: PNG ou JPG, largura ate 800px, altura recomendada ate 200px, max 500KB.<br/>
                        Rodape: PNG ou JPG, largura ate 800px, altura recomendada ate 100px, max 300KB.<br/>
                        O LaTeX reserva a altura configurada e escala a imagem proporcionalmente.
                    </div>

                    <group string="Identificacao">
                        <field name="name"/>
                        <field name="ug_id" options="{'no_create': True}"/>
                        <field name="is_default" widget="boolean_toggle" string="Timbre padrao para esta UG"/>
                        <field name="active" widget="boolean_toggle"/>
                    </group>

                    <notebook>
                        <page string="Cabecalho">
                            <group>
                                <field
                                    name="cabecalho_img"
                                    widget="image"
                                    options="{'size': [600, 150]}"
                                    string="Imagem do Cabecalho"
                                />
                                <field name="cabecalho_img_fname"/>
                                <field
                                    name="cabecalho_altura"
                                    string="Altura reservada no PDF (cm)"
                                    help="Padrao: 3.0 cm"
                                />
                            </group>
                        </page>

                        <page string="Rodape">
                            <group>
                                <field
                                    name="rodape_img"
                                    widget="image"
                                    options="{'size': [600, 80]}"
                                    string="Imagem do Rodape"
                                />
                                <field name="rodape_img_fname"/>
                                <field
                                    name="rodape_altura"
                                    string="Altura reservada no PDF (cm)"
                                    help="Padrao: 1.5 cm"
                                />
                            </group>
                        </page>

                        <page
                            string="Fallback Textual"
                            help="Usado quando nao ha imagem configurada"
                        >
                            <group>
                                <field name="orgao_nome" placeholder="Nome do orgao para fallback"/>
                                <field name="secretaria_nome"/>
                                <field name="cnpj"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gov_timbre" model="ir.actions.act_window">
        <field name="name">Timbres</field>
        <field name="res_model">gov.timbre</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
