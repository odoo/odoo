<odoo>
    <record id="seq_clinic_visit_token" model="ir.sequence">
        <field name="name">Clinic Visit Token</field>
        <field name="code">clinic.visit.token</field>
        <field name="prefix"></field>
        <field name="padding">3</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_hospital_queue_token" model="ir.sequence">
        <field name="name">Hospital Queue Token</field>
        <field name="code">hospital.queue</field>
        <field name="prefix">T</field>
        <field name="padding">3</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
