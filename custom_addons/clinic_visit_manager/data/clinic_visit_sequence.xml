<odoo>
    <record id="seq_clinic_visit_token" model="ir.sequence">
        <field name="name">Clinic Visit Token</field>
        <field name="code">clinic.visit.token</field>
        <field name="prefix">CVT/%(y)s%(month)s%(day)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
