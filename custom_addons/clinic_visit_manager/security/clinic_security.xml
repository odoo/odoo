<odoo>
    <record id="module_category_clinic_visit_manager" model="ir.module.category">
        <field name="name">Clinic</field>
        <field name="description">Clinic Visit Manager access roles</field>
        <field name="sequence">30</field>
    </record>

    <record id="res_groups_privilege_clinic_visit_manager" model="res.groups.privilege">
        <field name="name">Clinic</field>
        <field name="sequence">30</field>
        <field name="category_id" ref="module_category_clinic_visit_manager"/>
    </record>

    <record id="group_clinic_receptionist" model="res.groups">
        <field name="name">Receptionist</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_clinic_visit_manager"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('account.group_account_invoice'))]"/>
        <field name="comment">Can register patients, create visits, send visits to the queue, and cancel active visits.</field>
    </record>

    <record id="group_clinic_doctor" model="res.groups">
        <field name="name">Doctor</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_clinic_visit_manager"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Can read patient cards, update visits, start consultations, and mark visits done.</field>
    </record>

    <record id="group_clinic_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="sequence">30</field>
        <field name="privilege_id" ref="res_groups_privilege_clinic_visit_manager"/>
        <field name="implied_ids"
               eval="[(4, ref('group_clinic_receptionist')), (4, ref('group_clinic_doctor'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        <field name="comment">Has full access to clinic visits, patients, dashboard, and cleanup actions.</field>
    </record>
</odoo>
