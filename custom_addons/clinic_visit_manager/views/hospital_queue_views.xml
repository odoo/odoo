<odoo>
    <record id="view_hospital_queue_list" model="ir.ui.view">
        <field name="name">hospital.queue.list</field>
        <field name="model">hospital.queue</field>
        <field name="arch" type="xml">
            <list string="Hospital Queue" default_order="queue_number asc">
                <field name="queue_number"/>
                <field name="token"/>
                <field name="patient_name"/>
                <field name="doctor_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_hospital_queue_form" model="ir.ui.view">
        <field name="name">hospital.queue.form</field>
        <field name="model">hospital.queue</field>
        <field name="arch" type="xml">
            <form string="Hospital Queue Token">
                <header>
                    <button name="action_complete"
                            type="object"
                            string="Complete"
                            class="btn-primary"
                            groups="clinic_visit_manager.group_clinic_doctor,clinic_visit_manager.group_clinic_manager"
                            invisible="state == 'done'"/>
                    <button name="action_skip"
                            type="object"
                            string="Skip"
                            groups="clinic_visit_manager.group_clinic_doctor,clinic_visit_manager.group_clinic_manager"
                            invisible="state not in ('waiting', 'serving')"/>
                    <button name="action_recall"
                            type="object"
                            string="Recall"
                            class="btn-secondary"
                            groups="clinic_visit_manager.group_clinic_doctor,clinic_visit_manager.group_clinic_manager"
                            invisible="state not in ('skipped', 'serving')"/>
                    <field name="state" widget="statusbar" statusbar_visible="waiting,serving,done,skipped"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="token"/>
                            <field name="queue_number"/>
                            <field name="patient_name"/>
                        </group>
                        <group>
                            <field name="doctor_id"/>
                            <field name="state"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hospital_queue_search" model="ir.ui.view">
        <field name="name">hospital.queue.search</field>
        <field name="model">hospital.queue</field>
        <field name="arch" type="xml">
            <search string="Hospital Queue">
                <field name="token"/>
                <field name="patient_name"/>
                <field name="doctor_id"/>
                <filter name="active_queue"
                        string="Active Queue"
                        domain="[('state', 'in', ('waiting', 'serving', 'skipped'))]"/>
                <filter name="waiting" string="Waiting" domain="[('state', '=', 'waiting')]"/>
                <filter name="serving" string="Serving" domain="[('state', '=', 'serving')]"/>
                <separator/>
                <filter name="group_by_doctor" string="Doctor" context="{'group_by': 'doctor_id'}"/>
                <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="action_hospital_queue" model="ir.actions.act_window">
        <field name="name">Hospital Queue Tokens</field>
        <field name="res_model">hospital.queue</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hospital_queue_search"/>
        <field name="context">{'search_default_active_queue': 1}</field>
    </record>

    <record id="action_hospital_queue_dashboard" model="ir.actions.client">
        <field name="name">Hospital Queue</field>
        <field name="tag">clinic_visit_manager.hospital_queue_dashboard</field>
    </record>

    <record id="action_hospital_queue_tv" model="ir.actions.client">
        <field name="name">Queue TV Display</field>
        <field name="tag">clinic_visit_manager.hospital_queue_tv</field>
    </record>

    <menuitem id="menu_clinic_root"
              name="Clinic"
              action="action_hospital_queue_dashboard"
              groups="base.group_user"/>

    <record id="menu_clinic_root" model="ir.ui.menu">
        <field name="action" ref="action_hospital_queue_dashboard"/>
    </record>

    <menuitem id="menu_hospital_queue_dashboard"
              name="Hospital Queue"
              parent="menu_clinic_root"
              action="action_hospital_queue_dashboard"
              sequence="2"
              groups="base.group_no_one"/>

    <record id="menu_hospital_queue_dashboard" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <menuitem id="menu_hospital_queue_records"
              name="Queue Tokens"
              parent="menu_clinic_root"
              action="action_hospital_queue"
              sequence="3"
              groups="base.group_no_one"/>

    <record id="menu_hospital_queue_records" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <menuitem id="menu_hospital_queue_tv"
              name="Queue TV Display"
              parent="menu_clinic_root"
              action="action_hospital_queue_tv"
              sequence="4"
              groups="base.group_no_one"/>

    <record id="menu_hospital_queue_tv" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>
</odoo>
