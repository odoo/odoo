<odoo>

    <record id="view_clinic_visit_list" model="ir.ui.view">
        <field name="name">clinic.visit.list</field>
        <field name="model">clinic.visit</field>
        <field name="arch" type="xml">
            <list string="Clinic Visits">
                <field name="token_number"/>
                <field name="name"/>
                <field name="patient_name"/>
                <field name="patient_id"/>
                <field name="doctor_name"/>
                <field name="visit_date"/>
                <field name="queued_at" optional="hide"/>
                <field name="queue_wait_minutes"/>
                <field name="temperature_celsius" optional="hide"/>
                <field name="pulse_rate" optional="hide"/>
                <field name="oxygen_saturation" optional="hide"/>
                <field name="fee"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_clinic_visit_form" model="ir.ui.view">
        <field name="name">clinic.visit.form</field>
        <field name="model">clinic.visit</field>
        <field name="arch" type="xml">
            <form string="Clinic Visit">
                <header>
                    <button name="action_confirm"
                            type="object"
                            string="Send to Queue"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_start_consultation"
                            type="object"
                            string="Start Consultation"
                            class="btn-primary"
                            invisible="state != 'waiting'"/>

                    <button name="action_done"
                            type="object"
                            string="Mark Done"
                            class="btn-success"
                            invisible="state not in ('waiting', 'in_consultation')"/>

                    <button name="action_cancel"
                            type="object"
                            string="Cancel"
                            invisible="state in ('done', 'cancelled')"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,waiting,in_consultation,done"/>
                </header>

                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="token_number"/>
                            <field name="patient_name"/>
                            <field name="patient_id"/>
                            <field name="doctor_name"/>
                            <field name="visit_date"/>
                            <field name="queued_at"/>
                            <field name="consultation_started_at"/>
                            <field name="completed_at"/>
                        </group>

                        <group>
                            <field name="fee"/>
                            <field name="state"/>
                            <field name="queue_wait_minutes"/>
                            <field name="consultation_minutes"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Symptoms">
                            <field name="symptoms"/>
                        </page>

                        <page string="Vitals">
                            <group>
                                <group string="Body Measurements">
                                    <field name="temperature_celsius"/>
                                    <field name="weight_kg"/>
                                    <field name="height_cm"/>
                                    <field name="bmi"/>
                                </group>

                                <group string="Clinical Signs">
                                    <field name="blood_pressure_systolic"/>
                                    <field name="blood_pressure_diastolic"/>
                                    <field name="pulse_rate"/>
                                    <field name="respiratory_rate"/>
                                    <field name="oxygen_saturation"/>
                                </group>
                            </group>
                        </page>

                        <page string="Doctor Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_clinic_visit_search" model="ir.ui.view">
        <field name="name">clinic.visit.search</field>
        <field name="model">clinic.visit</field>
        <field name="arch" type="xml">
            <search string="Clinic Visits">
                <field name="token_number"/>
                <field name="patient_name"/>
                <field name="patient_id"/>
                <field name="doctor_name"/>
                <filter name="active_queue"
                        string="Active Queue"
                        domain="[('state', 'in', ('waiting', 'in_consultation'))]"/>
                <filter name="today"
                        string="Today"
                        domain="[('visit_date', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00')), ('visit_date', '&lt;=', context_today().strftime('%Y-%m-%d 23:59:59'))]"/>
                <separator/>
                <filter name="group_by_state"
                        string="Status"
                        context="{'group_by': 'state'}"/>
                <filter name="group_by_doctor"
                        string="Doctor"
                        context="{'group_by': 'doctor_name'}"/>
            </search>
        </field>
    </record>

    <record id="action_clinic_visit" model="ir.actions.act_window">
        <field name="name">Clinic Visits</field>
        <field name="res_model">clinic.visit</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_clinic_visit_search"/>
    </record>

    <menuitem id="menu_clinic_root"
              name="Clinic"/>

    <menuitem id="menu_clinic_visit"
              name="Visits"
              parent="menu_clinic_root"
              action="action_clinic_visit"/>

</odoo>
