<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_gov_compras_catalog_item_code" model="ir.sequence">
        <field name="name">Código Interno Item Catálogo</field>
        <field name="code">gov.compras.catalog.item.code</field>
        <field name="prefix">ITM/%(year)s/</field>
        <field name="padding">6</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_gov_compras_item_track" model="ir.sequence">
        <field name="name">ID Rastreio Item Compras</field>
        <field name="code">gov.compras.item.track</field>
        <field name="prefix">CMP/%(year)s/</field>
        <field name="padding">6</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
