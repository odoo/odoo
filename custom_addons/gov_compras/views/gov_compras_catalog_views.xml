<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gov_compras_catalog_item_list" model="ir.ui.view">
        <field name="name">gov.compras.catalog.item.list</field>
        <field name="model">gov.compras.catalog.item</field>
        <field name="arch" type="xml">
            <list string="Catálogo de Itens">
                <field name="code"/>
                <field name="name"/>
                <field name="ug_id"/>
                <field name="categoria" optional="show"/>
                <field name="unidade_medida" optional="show"/>
                <field name="natureza_despesa" optional="show"/>
                <field name="ativo_previsao"/>
                <field name="active" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_gov_compras_catalog_item_form" model="ir.ui.view">
        <field name="name">gov.compras.catalog.item.form</field>
        <field name="model">gov.compras.catalog.item</field>
        <field name="arch" type="xml">
            <form string="Item de Catálogo">
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="ug_id"/>
                            <field name="categoria"/>
                        </group>
                        <group>
                            <field name="unidade_medida"/>
                            <field name="natureza_despesa"/>
                            <field name="ativo_previsao"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Descrição Técnica">
                        <field name="descricao" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_gov_compras_catalog_item_search" model="ir.ui.view">
        <field name="name">gov.compras.catalog.item.search</field>
        <field name="model">gov.compras.catalog.item</field>
        <field name="arch" type="xml">
            <search string="Catálogo de Itens">
                <field name="code"/>
                <field name="name"/>
                <field name="ug_id"/>
                <field name="categoria"/>
                <filter string="Ativos Previsão" name="f_previsao" domain="[('ativo_previsao', '=', True)]"/>
                <filter name="g_ug" string="UG" context="{'group_by': 'ug_id'}"/>
                <filter name="g_categoria" string="Categoria" context="{'group_by': 'categoria'}"/>
            </search>
        </field>
    </record>

    <record id="action_gov_compras_catalog_item" model="ir.actions.act_window">
        <field name="name">Catálogo de Itens</field>
        <field name="res_model">gov.compras.catalog.item</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_gov_compras_catalog_item_search"/>
    </record>
</odoo>

