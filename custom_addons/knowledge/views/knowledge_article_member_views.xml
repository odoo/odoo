<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="knowledge_article_member_view_list" model="ir.ui.view">
        <field name="name">knowledge.article.member.list</field>
        <field name="model">knowledge.article.member</field>
        <field name="arch" type="xml">
            <list>
                <field name="article_id"/>
                <field name="partner_id"/>
                <field name="permission"/>
            </list>
        </field>
    </record>

    <record id="knowledge_article_member_view_form" model="ir.ui.view">
        <field name="name">knowledge.article.member.form</field>
        <field name="model">knowledge.article.member</field>
        <field name="arch" type="xml">
            <form string="Article Member">
                <sheet>
                    <group>
                        <field name="article_id"/>
                        <field name="partner_id"/>
                        <field name="permission"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="knowledge_article_member_action" model="ir.actions.act_window">
        <field name="name">Article Members</field>
        <field name="res_model">knowledge.article.member</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="knowledge_article_member_view_list"/>
    </record>
</odoo>
