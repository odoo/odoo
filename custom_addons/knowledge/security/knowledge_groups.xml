<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="privilege_knowledge" model="res.groups.privilege">
        <field name="name">Knowledge</field>
    </record>

    <record id="group_knowledge_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="knowledge.privilege_knowledge"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_knowledge_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="knowledge.privilege_knowledge"/>
        <field name="implied_ids" eval="[(4, ref('knowledge.group_knowledge_user'))]"/>
    </record>
</odoo>


