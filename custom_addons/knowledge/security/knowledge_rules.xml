<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="knowledge_article_rule_workspace_user" model="ir.rule">
        <field name="name">Knowledge Article Workspace</field>
        <field name="model_id" ref="model_knowledge_article"/>
        <field name="groups" eval="[(4, ref('knowledge.group_knowledge_user'))]"/>
        <field name="domain_force">[('category', '=', 'workspace')]</field>
    </record>

    <record id="knowledge_article_rule_private_user" model="ir.rule">
        <field name="name">Knowledge Article Private</field>
        <field name="model_id" ref="model_knowledge_article"/>
        <field name="groups" eval="[(4, ref('knowledge.group_knowledge_user'))]"/>
        <field name="domain_force">
            [('category', '=', 'private'), '|', ('owner_partner_id', '=', user.partner_id.id), '&amp;', ('member_ids.partner_id', '=', user.partner_id.id), ('member_ids.permission', 'in', ['read', 'write'])]
        </field>
    </record>

    <record id="knowledge_article_rule_shared_user" model="ir.rule">
        <field name="name">Knowledge Article Shared</field>
        <field name="model_id" ref="model_knowledge_article"/>
        <field name="groups" eval="[(4, ref('knowledge.group_knowledge_user'))]"/>
        <field name="domain_force">
            [('category', '=', 'shared'), ('member_ids.partner_id', '=', user.partner_id.id), ('member_ids.permission', 'in', ['read', 'write'])]
        </field>
    </record>

    <record id="knowledge_article_rule_manager_all" model="ir.rule">
        <field name="name">Knowledge Article Manager Full Access</field>
        <field name="model_id" ref="model_knowledge_article"/>
        <field name="groups" eval="[(4, ref('knowledge.group_knowledge_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>
