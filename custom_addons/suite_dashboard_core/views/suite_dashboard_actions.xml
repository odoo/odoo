<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_suite_dashboard_hub" model="ir.actions.client">
        <field name="name">Dashboard Hub</field>
        <field name="tag">suite_dashboard_hub</field>
    </record>

    <record id="action_suite_dashboard_workspace" model="ir.actions.act_window">
        <field name="name">Workspaces</field>
        <field name="res_model">suite.dashboard.workspace</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_suite_dashboard_template" model="ir.actions.act_window">
        <field name="name">Templates</field>
        <field name="res_model">suite.dashboard.template</field>
