        <field name="name">AI Providers</field>
        <field name="res_model">suite.dashboard.ai.provider</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_suite_dashboard_ai_run" model="ir.actions.act_window">
        <field name="name">AI Runs</field>
        <field name="res_model">suite.dashboard.ai.run</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
