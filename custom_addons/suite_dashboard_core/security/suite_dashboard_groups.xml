<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_suite_dashboard" model="ir.module.category">
        <field name="name">Suite Dashboard</field>
        <field name="sequence">91</field>
    </record>

    <record id="suite_dashboard_privilege_main" model="res.groups.privilege">
        <field name="name">Suite Dashboard</field>
        <field name="category_id" ref="suite_dashboard_core.module_category_suite_dashboard"/>
    </record>

    <record id="group_suite_dashboard_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="suite_dashboard_core.suite_dashboard_privilege_main"/>
        <field name="implied_ids" eval="[Command.link(ref('base.group_user'))]"/>
    </record>

    <record id="group_suite_dashboard_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="suite_dashboard_core.suite_dashboard_privilege_main"/>
        <field name="implied_ids" eval="[Command.link(ref('suite_dashboard_core.group_suite_dashboard_user'))]"/>
    </record>

    <record id="group_suite_dashboard_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="privilege_id" ref="suite_dashboard_core.suite_dashboard_privilege_main"/>
        <field name="implied_ids" eval="[Command.link(ref('suite_dashboard_core.group_suite_dashboard_manager'))]"/>
        <field name="user_ids" eval="[Command.link(ref('base.user_admin'))]"/>
    </record>
</odoo>
