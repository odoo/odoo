<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_br_base" model="ir.ui.view">
        <field name="name">res.partner.form.br.base</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Dados BR">
                    <group>
                        <group>
                            <field name="tipo_pessoa"/>
                            <field name="cnpj_cpf"/>
                            <field name="ie"/>
                            <field name="im"/>
                        </group>
                        <group>
                            <field name="municipio_id"/>
                            <field name="state_id"/>
                            <field name="zip"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>

