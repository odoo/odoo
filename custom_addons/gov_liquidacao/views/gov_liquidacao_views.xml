<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gov_liquidacao_list" model="ir.ui.view">
        <field name="name">gov.liquidacao.list</field>
        <field name="model">gov.liquidacao</field>
        <field name="arch" type="xml">
            <list
                string="Notas de Liquidação"
                decoration-danger="state == 'cancelado'"
                decoration-success="state == 'liquidado'"
                decoration-warning="state == 'atestado'"
            >
                <field name="name"/>
                <field name="ug_id"/>
                <field name="exercicio"/>
                <field name="empenho_id"/>
                <field name="credor_id"/>
                <field name="valor_liquidado" widget="monetary"/>
                <field name="data_liquidacao"/>
                <field name="nf_numero" optional="show"/>
                <field name="atestante_id" optional="show"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_gov_liquidacao_form" model="ir.ui.view">
        <field name="name">gov.liquidacao.form</field>
        <field name="model">gov.liquidacao</field>
        <field name="arch" type="xml">
            <form string="Nota de Liquidação">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="rascunho,atestado,liquidado,cancelado"/>
                    <button
                        name="action_abrir_wizard_ateste"
                        string="Atestar Recebimento"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'rascunho'"
                    />
                    <button
                        name="action_liquidar"
                        string="Confirmar Liquidação"
                        type="object"
                        class="btn-success"
                        invisible="state != 'atestado'"
                    />
                    <button
                        name="action_gerar_nl_pdf"
                        string="Gerar PDF"
                        type="object"
                        class="btn-secondary"
                        invisible="state not in ('atestado','liquidado')"
                    />
                    <button
                        name="action_cancelar"
                        string="Cancelar"
                        type="object"
                        class="btn-danger"
                        invisible="state not in ('rascunho','atestado')"
                        groups="gov_base.group_gov_admin"
                    />
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button
                            class="oe_stat_button"
                            name="action_open_pagamentos"
                            type="object"
                            icon="fa-credit-card"
                        >
                            <field name="pagamento_count" widget="statinfo" string="Pagamentos"/>
                        </button>
                    </div>

                    <group>
                        <group string="Identificação">
                            <field name="name" readonly="1"/>
                            <field name="ug_id"/>
                            <field name="exercicio"/>
                            <field name="data_liquidacao"/>
                            <field name="data_vencimento"/>
                        </group>
                        <group string="Empenho de Origem">
                            <field
                                name="empenho_id"
                                options="{'no_create': True}"
                                readonly="state != 'rascunho'"
                            />
                            <field name="empenho_name" readonly="1"/>
                            <field name="credor_id" readonly="1"/>
                            <field name="natureza_despesa" readonly="1"/>
                        </group>
                    </group>

                    <group string="Valores">
                        <group>
                            <field name="valor_empenho_liquido" readonly="1" widget="monetary"/>
                            <field name="valor_ja_liquidado" readonly="1" widget="monetary"/>
                            <field name="valor_disponivel" readonly="1" widget="monetary"/>
                        </group>
                        <group>
                            <field name="valor_liquidado" widget="monetary" readonly="state != 'rascunho'"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>

                    <group string="Nota Fiscal / Fatura">
                        <group>
                            <field name="nf_numero"/>
                            <field name="nf_data"/>
                        </group>
                        <group>
                            <field name="nf_valor" widget="monetary"/>
                            <field name="nf_chave_nfe"/>
                        </group>
                    </group>

                    <group string="Objeto da Liquidação">
                        <field
                            name="objeto_liquidacao"
                            nolabel="1"
                            colspan="2"
                            readonly="state != 'rascunho'"
                            placeholder="Descreva o objeto: serviço prestado, material entregue, etapa concluída..."
                        />
                    </group>

                    <group string="Ateste">
                        <field
                            name="atestante_id"
                            options="{'no_create': True}"
                            readonly="state not in ('rascunho',)"
                        />
                        <field name="data_ateste" readonly="1"/>
                        <field name="observacao_ateste" readonly="state not in ('rascunho','atestado')"/>
                    </group>

                    <group string="Lançamento Contábil" invisible="not move_nl_id">
                        <field name="move_nl_id" readonly="1" options="{'no_open': False}"/>
                    </group>

                    <notebook>
                        <page string="Eventos de Desembolso">
                            <group>
                                <field
                                    name="valor_liquidado"
                                    readonly="1"
                                    widget="monetary"
                                    string="Valor da NL"
                                />
                                <field
                                    name="valor_eventos"
                                    readonly="1"
                                    widget="monetary"
                                    string="Soma Eventos"
                                />
                                <field
                                    name="eventos_conferidos"
                                    widget="boolean"
                                    readonly="1"
                                    string="Conferido"
                                />
                            </group>
                            <div
                                class="alert alert-warning"
                                role="alert"
                                invisible="eventos_conferidos or not evento_ids"
                            >
                                A soma dos eventos
                                (<field name="valor_eventos" widget="monetary" nolabel="1" readonly="1"/>)
                                nao confere com o valor liquidado
                                (<field name="valor_liquidado" widget="monetary" nolabel="1" readonly="1"/>).
                                Ajuste antes de confirmar a liquidacao.
                            </div>
                            <field
                                name="evento_ids"
                                readonly="state in ('liquidado','cancelado')"
                                context="{'default_liquidacao_id': id}"
                            >
                                <list editable="bottom">
                                    <field name="tipo_id" options="{'no_create': False}"/>
                                    <field name="account_id" options="{'no_create': True}"/>
                                    <field name="destinatario_id"/>
                                    <field name="valor" widget="monetary"/>
                                    <field name="state" widget="badge" readonly="1"/>
                                    <field name="pd_name" readonly="1"/>
                                    <field name="observacao" optional="show"/>
                                </list>
                            </field>
                        </page>
                        <page string="PDF / Download" invisible="not pdf_nl_file">
                            <group string="Nota de Liquidação — PDF Oficial">
                                <field
                                    name="pdf_nl_file"
                                    widget="binary"
                                    filename="pdf_nl_filename"
                                    readonly="1"
                                />
                                <field name="pdf_nl_filename" invisible="1"/>
                                <field
                                    name="hash_sha256"
                                    readonly="1"
                                    string="SHA-256"
                                    style="font-family: monospace; font-size: 0.85em;"
                                />
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_gov_liquidacao_search" model="ir.ui.view">
        <field name="name">gov.liquidacao.search</field>
        <field name="model">gov.liquidacao</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Número NL"/>
                <field name="empenho_id" string="NE"/>
                <field name="credor_id" string="Credor"/>
                <filter string="Rascunhos" name="f_rascunho" domain="[('state','=','rascunho')]"/>
                <filter string="Atestados" name="f_atestado" domain="[('state','=','atestado')]"/>
                <filter string="Liquidados" name="f_liquidado" domain="[('state','=','liquidado')]"/>
                <filter string="Cancelados" name="f_cancelado" domain="[('state','=','cancelado')]"/>
                <separator/>
                <filter name="g_estado" string="Estado" context="{'group_by':'state'}"/>
                <filter name="g_ug" string="UG" context="{'group_by':'ug_id'}"/>
                <filter name="g_credor" string="Credor" context="{'group_by':'credor_id'}"/>
                <filter name="g_empenho" string="NE" context="{'group_by':'empenho_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_gov_liquidacao" model="ir.actions.act_window">
        <field name="name">Notas de Liquidação</field>
        <field name="res_model">gov.liquidacao</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
