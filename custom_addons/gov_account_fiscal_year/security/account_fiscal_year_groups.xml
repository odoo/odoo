<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="privilege_account_fiscal_year" model="res.groups.privilege">
            <field name="name">Fiscal Year Management</field>
        </record>

        <record id="group_account_fiscal_year_manager" model="res.groups">
            <field name="name">Fiscal Year Manager</field>
            <field name="privilege_id" ref="gov_account_fiscal_year.privilege_account_fiscal_year"/>
            <field name="implied_ids" eval="[(4, ref('account.group_account_manager'))]"/>
        </record>

        <record id="rule_account_fiscal_year_company" model="ir.rule">
            <field name="name">Fiscal Year multi-company</field>
            <field name="model_id" ref="gov_account_fiscal_year.model_account_fiscal_year"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('gov_account_fiscal_year.group_account_fiscal_year_manager'))]"/>
        </record>
    </data>
</odoo>



