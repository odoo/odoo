<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="privilege_sale_subscription" model="res.groups.privilege">
            <field name="name">Subscriptions</field>
        </record>

        <record id="group_sale_subscription_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="sale_subscription.privilege_sale_subscription"/>
            <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        </record>

        <record id="group_sale_subscription_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="sale_subscription.privilege_sale_subscription"/>
            <field name="implied_ids" eval="[(4, ref('sale_subscription.group_sale_subscription_user')), (4, ref('sales_team.group_sale_manager'))]"/>
        </record>

        <record id="rule_sale_subscription_company" model="ir.rule">
            <field name="name">Sale Subscription multi-company</field>
            <field name="model_id" ref="sale_subscription.model_sale_subscription"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('sale_subscription.group_sale_subscription_user'))]"/>
        </record>

        <record id="rule_sale_subscription_line_company" model="ir.rule">
            <field name="name">Sale Subscription Line multi-company</field>
            <field name="model_id" ref="sale_subscription.model_sale_subscription_line"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('sale_subscription.group_sale_subscription_user'))]"/>
        </record>

        <record id="rule_sale_subscription_template_company" model="ir.rule">
            <field name="name">Sale Subscription Template multi-company</field>
            <field name="model_id" ref="sale_subscription.model_sale_subscription_template"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('sale_subscription.group_sale_subscription_user'))]"/>
        </record>

        <record id="rule_sale_subscription_stage_company" model="ir.rule">
            <field name="name">Sale Subscription Stage multi-company</field>
            <field name="model_id" ref="sale_subscription.model_sale_subscription_stage"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('sale_subscription.group_sale_subscription_user'))]"/>
        </record>

        <record id="rule_sale_subscription_close_reason_company" model="ir.rule">
            <field name="name">Sale Subscription Close Reason multi-company</field>
            <field name="model_id" ref="sale_subscription.model_sale_subscription_close_reason"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('sale_subscription.group_sale_subscription_user'))]"/>
        </record>

        <record id="rule_sale_subscription_tag_company" model="ir.rule">
            <field name="name">Sale Subscription Tag multi-company</field>
            <field name="model_id" ref="sale_subscription.model_sale_subscription_tag"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('sale_subscription.group_sale_subscription_user'))]"/>
        </record>
    </data>
</odoo>


