<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_partner_view_form_sale_subscription" model="ir.ui.view">
        <field name="name">res.partner.form.sale.subscription</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_view_subscription_ids"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-refresh"
                    groups="sale_subscription.group_sale_subscription_user"
                >
                    <field name="subscription_count" widget="statinfo" string="Subscriptions"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>

