<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_subscription_stage_view_list" model="ir.ui.view">
        <field name="name">sale.subscription.stage.list</field>
        <field name="model">sale.subscription.stage</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="category"/>
                <field name="fold"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="sale_subscription_stage_view_form" model="ir.ui.view">
        <field name="name">sale.subscription.stage.form</field>
        <field name="model">sale.subscription.stage</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="category"/>
                        </group>
                        <group>
                            <field name="company_id"/>
                            <field name="fold"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="sale_subscription_stage_action" model="ir.actions.act_window">
        <field name="name">Subscription Stages</field>
        <field name="res_model">sale.subscription.stage</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

