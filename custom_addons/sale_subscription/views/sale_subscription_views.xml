<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_subscription_view_list" model="ir.ui.view">
        <field name="name">sale.subscription.list</field>
        <field name="model">sale.subscription</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="stage_id"/>
                <field name="recurring_next_date"/>
                <field name="to_renew"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="amount_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="user_id"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="sale_subscription_view_form" model="ir.ui.view">
        <field name="name">sale.subscription.form</field>
        <field name="model">sale.subscription</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_draft" string="Set Draft" type="object"/>
                    <button name="action_start_subscription" string="Start" type="object" class="oe_highlight"/>
                    <button name="action_set_to_renew" string="Mark To Renew" type="object"/>
                    <button name="action_subscription_close" string="Close" type="object"/>
                    <button name="action_subscription_cancel" string="Cancel" type="object"/>
                    <button name="create_invoice" string="Create Invoice" type="object" class="btn-primary"/>
                    <field name="stage_id" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button
                            name="action_view_invoice_ids"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-file-text-o"
                        >
                            <field name="invoice_count" widget="statinfo" string="Invoices"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code" readonly="1"/>
                            <field name="partner_id"/>
                            <field name="user_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date"/>
                            <field name="recurring_next_date"/>
                            <field name="recurring_rule_type"/>
                            <field name="recurring_interval"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="template_id"/>
                            <field name="pricelist_id"/>
                            <field name="journal_id"/>
                            <field name="payment_token_id"/>
                        </group>
                        <group>
                            <field name="analytic_account_id"/>
                            <field name="tag_ids" widget="many2many_tags"/>
                            <field name="to_renew"/>
                            <field name="close_reason_id"/>
                            <field name="health"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="price_unit"/>
                                    <field name="discount"/>
                                    <field name="tax_ids" widget="many2many_tags"/>
                                    <field name="currency_id" column_invisible="True"/>
                                    <field name="price_subtotal" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="price_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="currency_id" invisible="1"/>
                                <field name="recurring_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="amount_tax" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="amount_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="mrr" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </group>
                        </page>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="sale_subscription_view_kanban" model="ir.ui.view">
        <field name="name">sale.subscription.kanban</field>
        <field name="model">sale.subscription</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id">
                <field name="stage_id"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="currency_id"/>
                <field name="amount_total"/>
                <field name="to_renew"/>
                <field name="health"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_primary_bottom">
                                <strong><field name="name"/></strong>
                            </div>
                            <div class="text-muted">
                                <field name="partner_id"/>
                            </div>
                            <div>
                                <field name="amount_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </div>
                            <div>
                                <field name="health"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="sale_subscription_view_search" model="ir.ui.view">
        <field name="name">sale.subscription.search</field>
        <field name="model">sale.subscription</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="partner_id"/>
                <field name="stage_id"/>
                <field name="user_id"/>
                <field name="to_renew"/>
                <field name="recurring_next_date"/>
                <filter name="filter_to_renew" string="To Renew" domain="[('to_renew', '=', True)]"/>
                <group>
                    <filter name="group_by_stage" string="Stage" context="{'group_by': 'stage_id'}"/>
                    <filter name="group_by_partner" string="Customer" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_by_user" string="Salesperson" context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="sale_subscription_close_reason_view_list" model="ir.ui.view">
        <field name="name">sale.subscription.close.reason.list</field>
        <field name="model">sale.subscription.close.reason</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="description"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="sale_subscription_action" model="ir.actions.act_window">
        <field name="name">Subscriptions</field>
        <field name="res_model">sale.subscription</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="sale_subscription_view_search"/>
    </record>

    <record id="sale_subscription_close_reason_action" model="ir.actions.act_window">
        <field name="name">Close Reasons</field>
        <field name="res_model">sale.subscription.close.reason</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="product_template_action_subscription" model="ir.actions.act_window">
        <field name="name">Subscribable Products</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('subscribable', '=', True)]</field>
        <field name="context">{'default_subscribable': True}</field>
    </record>
</odoo>
