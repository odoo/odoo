<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Actual view: add biometric user ID field -->
    <record id="adding_biometric_user_employee_form" model="ir.ui.view">
        <field name="name">hr.employee.view.form.inherit.biometric.user</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='identification_group']"
                   position="inside">
                <field name="biometric_user_id"/>
            </xpath>
        </field>
    </record>
</odoo>
