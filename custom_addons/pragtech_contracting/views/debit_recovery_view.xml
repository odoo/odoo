<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="debit_view_tree" model="ir.ui.view">
            <field name="name">debit.view.tree</field>
            <field name="model">debit.recovery</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="project_id"/>
                    <field name="sub_project"/>
                    <field name="workorder_id"/>
                    <field name="contractor_id"/>
                </tree>
            </field>
        </record>

        <record id="debit_form_view" model="ir.ui.view">
            <field name="name">Debit Recovery</field>
            <field name="model">debit.recovery</field>
            <field name="arch" type="xml">
                <form string="Debit">
                    <header>
                        <button name="change_state" type="object" string="Change Stage" class="oe_highlight" invisible="flag"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>

                            <group colspan="4" col="4">
                                <field name="project_id" readonly="flag"/>
                                <field name="sub_project" domain="[('project_id','=',project_id)]" readonly="flag"/>
                                <field name="project_wbs" domain="[('project_id','=',project_id),('sub_project','=',sub_project)]" readonly="flag"/>
                                <field name="company_id" readonly="flag"/>
                            </group>

                            <group colspan="4" col="4">
                                <field name="workorder_id" readonly="flag" domain="['|','|',('project_id','=',project_id),('sub_project','=',sub_project),('project_wbs','=',project_wbs)]"/>
                                <field name="contractor_id" readonly="flag" domain="[('contractor','=',True)]"/>
                                <field name="stage_id"/>
                                <field name="flag" invisible="1"/>
                            </group>

                            <div align="right">
                                <button name="compute_debit" type="object" class="fa fa-search" string="Search" invisible="flag"/>
                            </div>

                            <field name="debit_line_ids">
                                <tree editable="bottom" create="false" delete="false">
                                    <field name="is_use"/>
                                    <field name="debit_id" readonly="1"/>
                                    <field name="project_id" readonly="1"/>
                                    <field name="sub_project" domain="[('project_id','=',project_id)]" readonly="1"/>
                                    <field name="workorder_id" readonly="1"/>
                                    <field name="debit_note_amount" readonly="1"/>
                                    <field name="recovered_till_date" readonly="1"/>
                                    <field name="balance_amount"/>
                                    <field name="total_recovery" readonly="1"/>
                                    <field name="payment_mode"/>
                                    <field name="condition" invisible="1"/>
                                    <field name="bank_name" invisible="payment_mode == 'cash'"/>
                                    <field name="payment_refrence" readonly="1"/>
                                    <field name="transaction_date" readonly="1"/>
                                </tree>
                            </field>

                            <notebook>
                                <page string="Audit Trail">
                                    <group colspan="4" col="4">
                                        <group>
                                            <div>
                                                <field name="mesge_ids" nolabel="1">
                                                    <tree create="false">
                                                        <field name="date"/>
                                                        <field name="author_id"/>
                                                        <field name="to_stage"/>
                                                        <field name="remark"/>
                                                        <field name="res_id" invisible="1"/>
                                                        <field name="model" invisible="1"/>
                                                        <field name="is_use" invisible="1"/>
                                                    </tree>
                                                </field>
                                            </div>
                                        </group>
                                        <group>
                                            <div>
                                            </div>
                                        </group>
                                    </group>
                                </page>
                            </notebook>

                        </div>

                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_debit" model="ir.actions.act_window">
            <field name="name">Debit</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">debit.recovery</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to create a Debit Recovery.
                </p>
            </field>
        </record>

    </data>
</odoo>

