<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sign_request_view_list" model="ir.ui.view">
        <field name="name">sign.request.list</field>
        <field name="model">sign.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="reference"/>
                <field name="name"/>
                <field name="template_id"/>
                <field name="state"/>
                <field name="progress"/>
                <field name="validity_date"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="sign_request_view_form" model="ir.ui.view">
        <field name="name">sign.request.form</field>
        <field name="model">sign.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_draft" string="Set Draft" type="object"/>
                    <button name="action_open_send_wizard" string="Send" type="object" class="oe_highlight"/>
                    <button name="action_signed" string="Mark Signed" type="object"/>
                    <button name="action_refuse" string="Refuse" type="object"/>
                    <button name="action_cancel" string="Cancel" type="object"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="reference" readonly="1"/>
                            <field name="template_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="validity_date"/>
                            <field name="reminder"/>
                            <field name="last_reminder" readonly="1"/>
                            <field name="completion_date" readonly="1"/>
                        </group>
                    </group>

                    <group>
                        <group>
                            <field name="progress" readonly="1"/>
                            <field name="nb_closed" readonly="1"/>
                            <field name="nb_total" readonly="1"/>
                        </group>
                        <group>
                            <field name="favorited_ids" widget="many2many_tags"/>
                            <field name="color"/>
                            <field name="active"/>
                        </group>
                    </group>

                    <group>
                        <field name="message" placeholder="Message sent to signers"/>
                    </group>

                    <notebook>
                        <page string="Signers">
                            <field name="request_item_ids">
                                <list editable="bottom">
                                    <field name="partner_id"/>
                                    <field name="signer_name"/>
                                    <field name="signer_email"/>
                                    <field name="state"/>
                                    <field name="signing_date"/>
                                </list>
                            </field>
                        </page>

                        <page string="Completed Document">
                            <group>
                                <field name="completed_document" filename="completed_document_name"/>
                            </group>
                        </page>

                        <page string="Logs">
                            <field name="log_ids" readonly="1">
                                <list>
                                    <field name="log_date"/>
                                    <field name="event"/>
                                    <field name="user_id"/>
                                    <field name="sign_request_item_id"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="sign_request_view_kanban" model="ir.ui.view">
        <field name="name">sign.request.kanban</field>
        <field name="model">sign.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="name"/>
                <field name="reference"/>
                <field name="state"/>
                <field name="progress"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_card oe_kanban_global_click">
                            <strong><field name="name"/></strong>
                            <div class="text-muted">
                                <field name="reference"/>
                            </div>
                            <div>
                                <field name="progress"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="sign_request_view_search" model="ir.ui.view">
        <field name="name">sign.request.search</field>
        <field name="model">sign.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="reference"/>
                <field name="template_id"/>
                <field name="state"/>
                <field name="validity_date"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <filter name="filter_sent" string="Sent" domain="[('state', '=', 'sent')]"/>
                <filter name="filter_signed" string="Signed" domain="[('state', '=', 'signed')]"/>
                <filter name="filter_refused" string="Refused" domain="[('state', '=', 'refused')]"/>
                <group>
                    <filter name="group_by_state" string="State" context="{'group_by': 'state'}"/>
                    <filter name="group_by_template" string="Template" context="{'group_by': 'template_id'}"/>
                    <filter name="group_by_company" string="Company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <record id="sign_request_action" model="ir.actions.act_window">
        <field name="name">Requests</field>
        <field name="res_model">sign.request</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="sign_request_view_search"/>
    </record>
</odoo>
