<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="rule_sign_request_company" model="ir.rule">
            <field name="name">Sign Request multi-company</field>
            <field name="model_id" ref="sign.model_sign_request"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('sign.group_sign_employee'))]"/>
        </record>

        <record id="rule_sign_request_item_company" model="ir.rule">
            <field name="name">Sign Request Item multi-company</field>
            <field name="model_id" ref="sign.model_sign_request_item"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('sign.group_sign_employee'))]"/>
        </record>

        <record id="rule_sign_log_company" model="ir.rule">
            <field name="name">Sign Log multi-company</field>
            <field name="model_id" ref="sign.model_sign_log"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('sign.group_sign_employee'))]"/>
        </record>

        <record id="rule_sign_request_item_public_token" model="ir.rule">
            <field name="name">Sign Request Item public token access</field>
            <field name="model_id" ref="sign.model_sign_request_item"/>
            <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_public')), (4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>
