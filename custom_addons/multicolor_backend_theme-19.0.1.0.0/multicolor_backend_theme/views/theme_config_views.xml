<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_theme_config_tree" model="ir.ui.view">
        <field name="name">theme.config.tree</field>
        <field name="model">theme.config</field>
        <field name="arch" type="xml">
            <list string="Multicolor Backend Themes">
                <field name="name"/>
                <field name="is_theme_active"/>
                <field name="theme_main_color" widget="color"/>
                <field name="theme_font_color" widget="color"/>
                <field name="view_font_color" widget="color"/>
            </list>
        </field>
    </record>

    <record id="view_theme_config_form" model="ir.ui.view">
        <field name="name">theme.config.form</field>
        <field name="model">theme.config</field>
        <field name="arch" type="xml">
            <form string="Multicolor Backend Theme">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="is_theme_active"/>
                    </group>
                    <group string="Colors" col="3">
                        <field name="theme_main_color" widget="color"/>
                        <field name="theme_font_color" widget="color"/>
                        <field name="view_font_color" widget="color"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_theme_config_search" model="ir.ui.view">
        <field name="name">theme.config.search</field>
        <field name="model">theme.config</field>
        <field name="arch" type="xml">
            <search string="Multicolor Backend Themes">
                <field name="name"/>
                <filter name="filter_active_theme" string="Active" domain="[('is_theme_active', '=', True)]"/>
            </search>
        </field>
    </record>

    <record id="action_theme_config" model="ir.actions.act_window">
        <field name="name">Multicolor Themes</field>
        <field name="res_model">theme.config</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_theme_config_search"/>
    </record>

    <record id="menu_multicolor_backend_theme_root" model="ir.ui.menu">
        <field name="name">Multicolor</field>
        <field name="parent_id" ref="base.menu_administration"/>
        <field name="action" ref="base.action_res_users_my"/>
        <field name="sequence">96</field>
        <field name="groups_id" eval="[(6, 0, [ref('multicolor_backend_theme.multicolor_theme_manager_access')])]"/>
        <field name="web_icon" eval="False"/>
    </record>

    <record id="menu_multicolor_backend_theme_preferences" model="ir.ui.menu">
        <field name="parent_id" ref="multicolor_backend_theme.menu_multicolor_backend_theme_root"/>
        <field name="action" ref="base.action_res_users_my"/>
        <field name="sequence">5</field>
        <field name="groups_id" eval="[(6, 0, [ref('base.group_no_one')])]"/>
        <field name="web_icon" eval="False"/>
    </record>

    <record id="menu_theme_config" model="ir.ui.menu">
        <field name="name">Multicolor Themes</field>
        <field name="parent_id" ref="multicolor_backend_theme.menu_multicolor_backend_theme_root"/>
        <field name="action" ref="multicolor_backend_theme.action_theme_config"/>
        <field name="sequence">10</field>
        <field name="groups_id" eval="[(6, 0, [ref('multicolor_backend_theme.multicolor_theme_manager_access')])]"/>
        <field name="web_icon" eval="False"/>
    </record>
</odoo>
