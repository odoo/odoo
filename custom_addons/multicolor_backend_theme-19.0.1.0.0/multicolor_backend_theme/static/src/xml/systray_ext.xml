<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <!--    Systray view-->
    <t t-inherit="web.NavBar" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[hasclass('o_menu_systray')]//t[@t-foreach='systrayItems']" position="before">
            <Dropdown t-if="this.isThemeManager">
                <button title="Themes">
                    <i class="fa fa-paint-brush" role="img" aria-label="Themes Configuration"/>
                </button>
                <t t-set-slot="content">
                    <div class="themes_selector dropdown-menu-right" role="menu">
                    <div class="row">
                        <div class="themes_list">
                            <div class="row theme_obj">
                                <select class="theme_select form-control" t-on-change="onChangeTheme">
                                    <t t-foreach="themeState.theme_data"
                                       t-as="theme_data_id" t-key="theme_data_id.id">
                                        <option t-att-id="theme_data_id.id" t-att-value="theme_data_id.id"
                                                t-att-selected="themeState.selected_theme and theme_data_id.id === themeState.selected_theme.id">
                                            <span t-esc="theme_data_id.name"/>
                                        </option>
                                    </t>
                                </select>
                            </div>
                        </div>
                        <div class="theme_data" t-if="themeState.selected_theme">
                            <div class="row name">
                                <div class="cell">
                                    <p>Name</p>
                                </div>
                                <div class="cell">
                                    <input type="text"
                                           id="themeName"
                                           readonly="readonly"
                                           t-att-value="themeState.selected_theme.name"/>
                                    <i id="editIcon" class="fa fa-pencil" t-on-click="onEditName"/>
                                </div>
                            </div>
                            <div class="theme_extra">
                                <div id="active_theme" class="theme-active">
                                    <p>Active</p>
                                </div>
                            </div>
                            <!--            Color selector -->
                            <div class="color_selector">
                                <div class="row theme_main_color">
                                    <div class="cell">
                                        <p>Base Color
                                        </p>
                                    </div>
                                    <div class="cell">
                                        <div class="color" id="theme_main_color" t-on-click="onClickBaseColor"
                                             t-att-style="'background-color:'+themeState.selected_theme.theme_main_color">
                                        </div>
                                    </div>
                                </div>
                                <div class="row theme_font_color">
                                    <div class="cell">
                                        <p>Font Color</p>
                                    </div>
                                    <div class="cell">
                                        <div class="color" id="theme_font_color" t-on-click="onClickBaseColor"
                                             t-att-style="'background-color:'+themeState.selected_theme.theme_font_color"/>
                                    </div>
                                </div>
                                <div class="row view_font_color">
                                    <div class="cell">
                                        <p>View Font Color</p>
                                    </div>
                                    <div class="cell">
                                        <div class="color" id="view_font_color" t-on-click="onClickBaseColor"
                                             t-att-style="'background-color:'+themeState.selected_theme.view_font_color"/>
                                    </div>
                                </div>
                                <div class="row login_background_color">
                                    <div class="cell">
                                        <p>Login Background</p>
                                    </div>
                                    <div class="cell">
                                        <div class="color" id="login_background_color" t-on-click="onClickBaseColor"
                                             t-att-style="'background-color:'+(themeState.selected_theme.login_background_color || '#f1f4f5')"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="theme_data" t-else="">
                            <p>No themes available. Click create to add one.</p>
                        </div>
                    </div>
                    <!--View for Theme create, remove and apply buttons-->
                    <div class="header_buttons row" style="position: absolute; bottom: 0;">
                        <div class="button-create cell">
                            <p t-on-click="onClickCreate">Create</p>
                        </div>
                        <div class="button-create cell">
                            <p t-on-click="onClickRemove">Remove</p>
                        </div>
                        <div class="button-create cell">
                            <p t-on-click="onClickApply"><i class="fa fa-check"/>Apply</p>
                        </div>
                    </div>
                </div>
                </t>
            </Dropdown>
        </xpath>
    </t>
</templates>
