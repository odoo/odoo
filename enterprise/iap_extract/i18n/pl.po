#. module: iap_extract
#: model:mail.template,body_html:iap_extract.iap_extract_no_credit
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"    <p>Dear,<br/></p>\n"
"    <p>There are no more credits on your IAP OCR account.<br/>\n"
"    You can charge your IAP OCR account in the settings page.</p>\n"
"    <p>Best regards,<br/></p>\n"
"    <p>Odoo S.A.</p>\n"
"</div>"
msgstr ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"    <p>Dzień dobry,<br/></p>\n"
"    <p>Na Twoim koncie nie ma już żadnych kredytów IAP OCR.<br/>\n"
"    Możesz doładować swoje konto IAP OCR nas stronie ustawień.</p>\n"
"    <p>Z pozdrowieniami,<br/></p>\n"
"    <p>Odoo S.A.</p>\n"
"</div>"

