#. module: iap_extract
#: model:mail.template,body_html:iap_extract.iap_extract_no_credit
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"    <p>Dear,<br/></p>\n"
"    <p>There are no more credits on your IAP OCR account.<br/>\n"
"    You can charge your IAP OCR account in the settings page.</p>\n"
"    <p>Best regards,<br/></p>\n"
"    <p>Odoo S.A.</p>\n"
"</div>"
msgstr ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"    <p>Hej<br/></p>\n"
"   <p> Der er ikke flere kreditter på din IAP OCR-konto.<br/>\n"
"    Du kan fylde din IAP OCR-konto op på indstillingssiden.</p>\n"
"    <p>Med venlig hilsen<br/></p>\n"
"   <p> Odoo S.A.</p>\n"
"</div>"

