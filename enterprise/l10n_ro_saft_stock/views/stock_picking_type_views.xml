<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record model="ir.ui.view" id="view_picking_type_form_l10n_ro_saft_stock">
        <field name="name">stock.picking.type.form.l10n_ro_saft_stock</field>
        <field name="model">stock.picking.type</field>
        <field name="inherit_id" ref="stock.view_picking_type_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='code']" position="after">
                <field name="l10n_ro_stock_movement_type" invisible="country_code != 'RO'" required="country_code == 'RO'"/>
            </xpath>
        </field>
    </record>

</odoo>
