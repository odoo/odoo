#. module: documents_hr
#: model:mail.template,body_html:documents_hr.mail_template_document_folder_link
msgid ""
"<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"width:100%; "
"margin:0px auto;\"><tbody>\n"
"        <tr><td valign=\"top\" style=\"text-align: left; font-size: 14px;"
"\">\n"
"            Dear <t t-esc=\"object.name\"/>, your personal documents access "
"link is available for you.<br/><br/>\n"
"            You'll find all your personal HR documents in this folder.<br/"
"><br/>\n"
"            Please keep this link secure.<br/><br/>\n"
"            <div style=\"text-align: center; padding: 16px 0px 16px 0px; "
"font-size: 14px;\">\n"
"                <a t-attf-href=\"{{ object._get_documents_link_url() }}\" "
"target=\"_blank\" style=\"background-color: #875A7B; padding: 8px 16px 8px "
"16px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;"
"\">\n"
"                    Your Documents\n"
"                </a>\n"
"            </div>\n"
"            Have a nice day,<br/>\n"
"            The HR Team\n"
"        </td></tr>\n"
"    </tbody></table>\n"
"                "
msgstr ""
"<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"width:100%; "
"margin:0px auto;\"><tbody>\n"
"        <tr><td valign=\"top\" style=\"text-align: left; font-size: 14px;"
"\">\n"
"            Pozdravljeni <t t-esc=\"object.name\"/>, povezava za dostop do "
"vaših osebnih dokumentov je na voljo.<br/><br/>\n"
"            V tej mapi boste našli vse svoje osebne dokumente s področja "
"kadrovske službe.<br/><br/>\n"
"            Prosim, hranite to povezavo varno.<br/><br/>\n"
"            <div style=\"text-align: center; padding: 16px 0px 16px 0px; "
"font-size: 14px;\">\n"
"                <a t-attf-href=\"{{ object._get_documents_link_url() }}\" "
"target=\"_blank\" style=\"background-color: #875A7B; padding: 8px 16px 8px "
"16px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;"
"\">\n"
"                    Vaši dokumenti\n"
"                </a>\n"
"            </div>\n"
"            Lep dan še naprej,<br/>\n"
"            Kadrovska ekipa\n"
"        </td></tr>\n"
"    </tbody></table>\n"
"                "

