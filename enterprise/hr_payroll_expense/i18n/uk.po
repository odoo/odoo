#. module: hr_payroll_expense
#: model_terms:ir.ui.view,arch_db:hr_payroll_expense.view_account_payment_register_form_inherit_hr_payroll_expense
msgid ""
"<span class=\"fw-bold\">\n"
"                            The expenses will already be reimbursed in a "
"payslip. Make sure this payment is intended.\n"
"                        </span>"
msgstr ""
"<span class=\"fw-bold\">\n"
"                            Витрати вже будуть відшкодовані у платіжній "
"відомості. Переконайтеся, що цей платіж призначений.\n"
"                        </span>"

#. module: hr_payroll_expense
#: model_terms:ir.ui.view,arch_db:hr_payroll_expense.hr_expense_sheet_view_form_inherit_payroll
msgid "<span class=\"o_stat_text\">Payslip</span>"
msgstr "<span class=\"o_stat_text\">Зарплатний листок</span>"

#. module: hr_payroll_expense
#: model:ir.model,name:hr_payroll_expense.model_hr_expense_sheet
msgid "Expense Report"
msgstr "Звіт про витрати"

#. module: hr_payroll_expense
#. odoo-python
#: code:addons/hr_payroll_expense/models/hr_expense_sheet.py:0
msgid ""
"Expense reimbursement rule needs to be configured to add expenses to "
"payslips.\n"
"Please create one salary rule with the \"%(code)s\" code on the relevant "
"salary structures."
msgstr ""
"Правило відшкодування витрат потрібно налаштувати, щоб додавати витрати до "
"розрахункового листка.\n"
"Будь ласка, створіть одне правило зарплати з кодом \"%(code)s\" щодо "
"відповідних структур заробітної плати."

#. module: hr_payroll_expense
#. odoo-python
#: code:addons/hr_payroll_expense/models/hr_expense_sheet.py:0
msgid "Expense report (\"%(name)s\") was removed from the next payslip."
msgstr ""
"Звіт витрат (\"%(name)s\") було видалено з наступного розрахункового листка."

#. module: hr_payroll_expense
#. odoo-python
#: code:addons/hr_payroll_expense/models/hr_expense_sheet.py:0
msgid "Expense report (\"%(name)s\") will be added to the next payslip."
msgstr ""
"Звіт витрат (\"%(name)s\") буде додано до наступного розрахункового листка."

#. module: hr_payroll_expense
#: model:ir.model.fields,field_description:hr_payroll_expense.field_hr_payslip__expense_sheet_ids
#: model_terms:ir.ui.view,arch_db:hr_payroll_expense.hr_payslip_view_form_inherit_expense
msgid "Expenses"
msgstr "Витрати"

#. module: hr_payroll_expense
#: model:ir.model.fields,field_description:hr_payroll_expense.field_hr_payslip__expenses_count
msgid "Expenses Count"
msgstr "Підрахунок витрат"

#. module: hr_payroll_expense
#: model:hr.salary.rule,name:hr_payroll_expense.hr_salary_rule_expense_refund
msgid "Expenses Reimbursement"
msgstr "Відшкодування витрат"

#. module: hr_payroll_expense
#: model:ir.model.fields,help:hr_payroll_expense.field_hr_payslip__expense_sheet_ids
msgid "Expenses to reimburse to employee."
msgstr "Витрати для відшкодування співробітнику."

#. module: hr_payroll_expense
#: model:ir.model,name:hr_payroll_expense.model_hr_payslip_employees
msgid "Generate payslips for all selected employees"
msgstr "Створити розрахункові листи для всіх обраних співробітників"

#. module: hr_payroll_expense
#. odoo-python
#: code:addons/hr_payroll_expense/models/hr_expense_sheet.py:0
msgid "Go to salary rules"
msgstr "Перейти до правил зарплати"

#. module: hr_payroll_expense
#: model:ir.model.fields,field_description:hr_payroll_expense.field_account_payment_register__is_already_paid_through_a_payslip
msgid "Is Already Paid Through A Payslip"
msgstr "Вже оплачено через платіжну відомість"

#. module: hr_payroll_expense
#: model:ir.model,name:hr_payroll_expense.model_account_move
msgid "Journal Entry"
msgstr "Запис у журналі"

#. module: hr_payroll_expense
#. odoo-python
#: code:addons/hr_payroll_expense/models/hr_payroll_structure.py:0
msgid ""
"No debit account found in the '%(rule_name)s' payslip salary rule. Please "
"add a payable debit account to be able to create an accounting entry for the "
"expense reports linked to this payslip."
msgstr ""
"Не знайдено дебетовий рахунок в '%(rule_name)s' правилі зарплати. Будь "
"ласка, додайте дебетовий рахунок до сплати, щоб мати змогу створити "
"бухгалтерський запис для звітів про витрати, пов'язаних з цією платіжною "
"відомостю."

#. module: hr_payroll_expense
#. odoo-python
#: code:addons/hr_payroll_expense/models/hr_payslip.py:0
msgid ""
"No salary rule was found to handle expenses in structure '%"
"(structure_name)s'."
msgstr ""
"Не знайдено жодного правила зарплати для обробки витрат у структурі '%"
"(structure_name)s'."

#. module: hr_payroll_expense
#. odoo-python
#: code:addons/hr_payroll_expense/models/hr_expense_sheet.py:0
msgid ""
"Only approved expense reports that were paid by an employee can be "
"reimbursed in a payslip."
msgstr ""
"У платіжній відомості можуть бути відшкодовані лише затверджені звіти про "
"витрати, оплачені працівником."

#. module: hr_payroll_expense
#: model:ir.model,name:hr_payroll_expense.model_account_payment_register
msgid "Pay"
msgstr "Оплатити"

#. module: hr_payroll_expense
#: model:ir.model,name:hr_payroll_expense.model_hr_payslip
msgid "Pay Slip"
msgstr "Розрахунковий лист"

#. module: hr_payroll_expense
#. odoo-python
#: code:addons/hr_payroll_expense/models/hr_expense_sheet.py:0
#: model:ir.model.fields,field_description:hr_payroll_expense.field_hr_expense_sheet__payslip_id
msgid "Payslip"
msgstr "Розрахунковий лист"

#. module: hr_payroll_expense
#: model:ir.model.fields,field_description:hr_payroll_expense.field_hr_expense_sheet__refund_in_payslip
msgid "Reimburse In Next Payslip"
msgstr "Відшкодувати у наступному розрахунковому листі"

#. module: hr_payroll_expense
#. odoo-python
#: code:addons/hr_payroll_expense/models/hr_payslip.py:0
msgid "Reimbursed Expenses"
msgstr "Відшкодовані витрати"

#. module: hr_payroll_expense
#: model_terms:ir.ui.view,arch_db:hr_payroll_expense.hr_expense_sheet_view_form_inherit_payroll
msgid "Remove from Payslip"
msgstr "Вилучити з розрахункового листа"

#. module: hr_payroll_expense
#: model:ir.actions.server,name:hr_payroll_expense.hr_expense_add_to_payslip_action_server
#: model_terms:ir.ui.view,arch_db:hr_payroll_expense.hr_expense_sheet_view_form_inherit_payroll
msgid "Report in Next Payslip"
msgstr "Включити у наступний розрахунковий лист"

#. module: hr_payroll_expense
#: model:ir.model,name:hr_payroll_expense.model_hr_payroll_structure
msgid "Salary Structure"
msgstr "Структура зарплати"

#. module: hr_payroll_expense
#. odoo-python
#: code:addons/hr_payroll_expense/models/hr_payroll_structure.py:0
msgid ""
"The '%(account_name)s' account for the salary rule '%(rule_name)s' must be "
"of type 'Payable'."
msgstr ""
"Рахунок '%(account_name)s' для правила зарплати '%(rule_name)s' має бути з "
"типом 'Кредитор'."

#. module: hr_payroll_expense
#. odoo-python
#: code:addons/hr_payroll_expense/models/hr_payslip.py:0
msgid ""
"The salary rules with the code 'EXPENSES' must have a debit account set to "
"be able to properly reimburse the linked expenses. This must be an account "
"of type 'Payable'."
msgstr ""
"Правила оплати праці з кодом «ВИТРАТИ» повинні мати налаштований дебетовий "
"рахунок для належного відшкодування пов’язаних витрат. Це має бути рахунок "
"типу «Кредитор»."

#. module: hr_payroll_expense
#. odoo-python
#: code:addons/hr_payroll_expense/models/hr_expense_sheet.py:0
msgid ""
"The state of the accounting entries linked to this expense report do not "
"allow it to be reimbursed through a payslip."
msgstr ""
"Стан бухгалтерських записів, пов'язаних із цим звітом про витрати, не "
"дозволяє відшкодувати його через платіжну відомість."

#. module: hr_payroll_expense
#. odoo-python
#: code:addons/hr_payroll_expense/models/hr_expense_sheet.py:0
msgid "There are no valid expense sheets selected."
msgstr "Не вибрано жодного дійсного авансового звіту."

#. module: hr_payroll_expense
#. odoo-python
#: code:addons/hr_payroll_expense/models/hr_expense_sheet.py:0
msgid ""
"You cannot remove an expense from a payslip that has already been "
"validated.\n"
"Expenses can only be removed from draft or canceled payslips."
msgstr ""
"Ви не можете видалити витрати з платіжної відомості, яка вже була "
"підтверджена.\n"
"Витрати можна видалити лише з чернеток або скасованих платіжних відомостей."

#. module: hr_payroll_expense
#. odoo-python
#: code:addons/hr_payroll_expense/models/hr_payslip.py:0
msgid ""
"You don't have the access rights to link an expense report to a payslip. You "
"need to be a payroll officer to do that."
msgstr ""
"У вас немає прав доступу, щоб прив’язати звіт про витрати до платіжної "
"відомості. Для цього вам потрібно бути спеціалістом із нарахування "
"заробітної плати."

#. module: hr_payroll_expense
#. odoo-python
#: code:addons/hr_payroll_expense/models/account_move.py:0
msgid "You don't have the access rights to post an invoice."
msgstr "У вас немає прав публікувати рахунок."
