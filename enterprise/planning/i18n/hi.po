"                    <br/>\n"
"                    <p t-if=\"ctx.get('start_datetime') and "
"ctx.get('end_datetime')\">\n"
"                        Your upcoming shifts from <t t-"
"out=\"format_date(ctx['start_datetime'])\">05-05-2021</t>\n"
