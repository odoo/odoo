"value=\"(object.event_id.appointment_booker_id.upcoming_appointment_ids - "
"object.event_id).sorted('start')\"/>\n"
"    <div t-if=\"target_customer and upcoming_appointments\">\n"
"        <t t-set=\"appointment_booker_id\" t-"
"value=\"object.event_id.appointment_booker_id.id\"/>\n"
"        <p><strong>Prossimi appuntamenti</strong></p>\n"
"        <ul>\n"
"            <li t-foreach=\"upcoming_appointments\" t-"
"as=\"upcoming_appointment\">\n"
"                <span style=\"display: flex; font-size: small;\">\n"
"                    <span style=\"margin-right: 4px\" t-"
"out=\"upcoming_appointment.appointment_type_id.name or ''\">Dimostrazione "
"tecnica</span>\n"
