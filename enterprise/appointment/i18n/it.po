"                    Risorse\n"
"                    <ul>\n"
"                        <li t-"
"foreach=\"object.event_id.appointment_resource_ids\" t-as=\"resource\">\n"
"                            <span style=\"margin-left:5px\" t-"
"out=\"resource.name or ''\">Tavolo 1</span>\n"
"                        </li>\n"
"                    </ul>\n"
"                </li>\n"
"                <li t-if=\"object.event_id.videocall_redirection\">\n"
