msgid ""
"\n"
"                The new period is not valid for some products of your cart.\n"
"                Your changes on the rental period are not taken into "
"account.\n"
"            "
msgstr ""

#. module: website_sale_renting
#. odoo-python
#: code:addons/website_sale_renting/models/sale_order.py:0
msgid ""
"\n"
"                Your rental duration was too short. Unfortunately, we do not "
"process\n"
"                rentals that last less than %(duration)s %(unit)s.\n"
"            "
msgstr ""
"\n"
"                Doba prenájmu bola príliš krátka. Bohužiaľ, neakceptujeme\n"
"                prenájmy, ktoré trvajú menej ako %(duration)s %(unit)s.\n"
"            "

#. module: website_sale_renting
#. odoo-python
#: code:addons/website_sale_renting/models/sale_order.py:0
msgid ""
"\n"
"                Your rental product had invalid date of pickup (%"
"(start_date)s).\n"
"                Unfortunately, we do not process pickups on that weekday.\n"
"            "
msgstr ""
"\n"
"                Váš prenajatý produkt mal neplatný dátum vyzdvihnutia (%"
"(start_date)s).\n"
"                Bohužiaľ, v tento deň v týždni vyzdvihnutia neprebiehajú.\n"
"            "

#. module: website_sale_renting
#. odoo-python
#: code:addons/website_sale_renting/models/sale_order.py:0
msgid ""
"\n"
"                Your rental product had invalid date of return (%"
"(end_date)s).\n"
"                Unfortunately, we do not process returns on that weekday.\n"
"            "
msgstr ""
"\n"
"                Váš prenajatý produkt mal neplatný dátum vrátenia (%"
"(end_date)s).\n"
"                Bohužiaľ, v tento deň v týždni vrátenia neprijímame.\n"
"            "

#. module: website_sale_renting
#. odoo-python
#: code:addons/website_sale_renting/models/sale_order.py:0
msgid ""
"\n"
"                Your rental product had invalid dates of pickup (%"
"(start_date)s) and\n"
"                return (%(end_date)s). Unfortunately, we do not process "
"pickups nor\n"
"                returns on those weekdays.\n"
"            "
msgstr ""
"\n"
"                Váš prenajatý produkt mal neplatné dátumy vyzdvihnutia (%"
"(start_date)s) a\n"
"                vrátenia (%(end_date)s). Bohužiaľ, v týchto dňoch "
"neprevádzame vyzdvihnutia \n"
"                ani vrátenia.\n"
"            "

#. module: website_sale_renting
#. odoo-python
#: code:addons/website_sale_renting/models/sale_order.py:0
msgid ""
"\n"
"            Some of your rental products (%(product)s) cannot be rented "
"during the\n"
"            selected period and your cart must be updated. We're sorry for "
"the\n"
"            inconvenience.\n"
"        "
msgstr ""
"\n"
"            Niektoré z vašich produktov určených na prenájom (%(product)s) "
"nie je možné prenajať počas\n"
"            vybraného obdobia a je potrebné aktualizovať váš košík. "
"Ospravedlňujeme sa za\n"
"            nepríjemnosti.\n"
"        "

