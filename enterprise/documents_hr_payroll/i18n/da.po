"<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"width:100%; "
"margin:0px auto;\"><tbody>\n"
"        <tr><td valign=\"top\" style=\"text-align: left; font-size: 14px;"
"\">\n"
"            Hej <t t-esc=\"object.name\"/>. En ny fil til din selvangivelse "
"ligger klar til dig.<br/><br/>\n"
"            Du finder PDFfilen i din medarbejderportal.<br/><br/>\n"
"            Vi ønsker dig en god dag.<br/>\n"
"            HR\n"
"        </td></tr>\n"
"    </tbody></table>\n"
"                "

