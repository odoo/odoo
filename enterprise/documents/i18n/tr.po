"                                            <br/><br/>\n"
"                                            <t t-"
"out=\"object.create_uid.name or ''\">OdooBot</t> (<t t-"
"out=\"object.create_uid.email or ''\">odoobot@example.com</t>) asks you to "
"provide the following document:\n"
"                                            <br/><br/>\n"
"                                            <center>\n"
"                                                <div>\n"
"                                                    <t t-"
"if=\"object.name\">\n"
"                                                        <b t-"
"out=\"object.name or ''\">Inbox Financial</b>\n"
"                                                    </t>\n"
"                                                </div>\n"
"                                                <div>\n"
"                                                    <t t-"
"if=\"object.request_activity_id.note\">\n"
"                                                        <i t-"
"out=\"object.request_activity_id.note or ''\">Example of a note.</i>\n"
"                                                    </t>\n"
"                                                </div>\n"
"                                                <br/>\n"
"                                                <div style=\"margin: 16px "
"0px 16px 0px;\">\n"
"                                                    <a t-att-"
"href=\"object.access_url\" style=\"background-color: #875A7B; padding: 20px "
"30px 20px 30px; text-decoration: none; color: #fff; border-radius: 5px; font-"
"size:13px;\">\n"
"                                                        Upload the requested "
"document\n"
"                                                    </a>\n"
"                                                </div>\n"
"                                            </center><br/>\n"
"                                            Please provide us with the "
"missing document before <t t-"
"out=\"object.request_activity_id.date_deadline\">2021-05-17</t>.\n"
"                                            <t t-if=\"user and "
"user.signature\" data-o-mail-quote-container=\"1\">\n"
"                                                <br/>\n"
"                                                <t t-out=\"user.signature or "
"''\" data-o-mail-quote=\"1\">--<br data-o-mail-quote=\"1\"/>Mitchell Admin</"
"t>\n"
"                                                <br data-o-mail-quote=\"1\"/"
