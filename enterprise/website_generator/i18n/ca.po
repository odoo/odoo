#. module: website_generator
#: model:mail.template,body_html:website_generator.email_template_website_scrapped
msgid ""
"<div>\n"
"            <p><b>Great news!</b> Your website conversion is complete and "
"your new integrated Odoo website is now live.</p>\n"
"            <p>Check out your new website here: <a t-att-"
"href=\"ctx.get('website_url')\"><t t-out=\"ctx.get('website_url')\"/></a></"
"p>\n"
"            <p>Thank you for choosing Odoo for your web integration!</p>\n"
"            <p>Best regards,</p>\n"
"            <br/>\n"
"            <p>Odoo - The best open source website builder.</p>\n"
"            </div>\n"
"            "
msgstr ""
"<div>\n"
"            <p><b>Bones notícies!</b> El teu lloc web ja s'ha completat i la "
"nova versió integrada amb Odoo ja està activa.</p>\n"
"            <p>Pots visitar el teu nou lloc web aquí: <a t-att-"
"href=\"ctx.get('website_url')\"><t t-out=\"ctx.get('website_url')\"/></a></"
"p>\n"
"            <p>Gràcies per confiar en Odoo per a la teva integració web!</"
"p>\n"
"            <p>Salutacions cordials,</p>\n"
"            <br/>\n"
"            <p>Odoo - El millor creador de llocs web codi obert.</p>\n"
"            </div>\n"
"            "

