"                <table style=\"width:600px;margin:5px auto;\">\n"
"                    <tbody>\n"
"                        <tr><td t-if=\"not "
"object.company_id.uses_default_logo\">\n"
"                            <a href=\"/\"><img t-attf-src=\"/logo.png?"
