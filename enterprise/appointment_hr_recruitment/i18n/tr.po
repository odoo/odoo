msgid ""
"Can we plan an interview together for your {{ (object.job_id.name + ' ') if "
"object.job_id else '' }}application?"
msgstr ""
"{{ (object.job_id.name + ' ') if object.job_id else '' }}başvurunuza "
"istinaden birlikte bir görüşme planlayabilir miyiz?"

