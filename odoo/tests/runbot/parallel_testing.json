{
    "name": "Parallel testing",
    "vars": {
        "module_filter": "*,-hw_*,-*l10n_*,-theme_*,-account_bacs,-account_reports_cash_basis,-auth_ldap,-base_gengo,-document_ftp,-iot_drivers,-note_pad,-odoo_referral,-odoo_referral_portal,-pad,-pad_project,-pos_blackbox_be,-pos_cache,-pos_six,-social_demo,-website_gengo,-website_instantclick,test_l10n_be_hr_payroll_account,test_l10n_us_hr_payroll_account,-test_translation_mode"
    },
    "steps": [
        {
            "name": "Create at install",
            "job_type": "create_build",
            "children": [
                {
                    "name": "Test at install",
                    "steps":[{
                        "name": "Start at install",
                        "job_type": "odoo",
                        "install_modules": "{{module_filter}},-test_lint",
                        "test_tags": "-post_install,-/test_lint"
                        }]
                },
                {
                    "name": "Test pylint",
                    "steps":[{
                        "name": "Start test lint",
                        "job_type": "odoo",
                        "install_modules": "test_lint",
                        "test_tags": "-post_install,/test_lint"
                    }]
                }
            ]
        },
        {
            "name": "Install all",
            "db_name": "all",
            "job_type": "odoo",
            "install_modules": "{{module_filter}}"
        },
        {
            "name": "Create post install",
            "job_type": "create_build",
            "for_each_vars": [

                {"test_module_filter": "-> !account_accountant"},
                {"test_module_filter": "account_accountant -> !account_reports"},
                {"test_module_filter": "account_reports -> !crm"},
                {"test_module_filter": "crm -> !hr_holidays"},
                {"test_module_filter": "hr_holidays -> !html_editor"},
                {"test_module_filter": "html_editor -> !l10n_be_hr_payroll"},
                {"test_module_filter": "l10n_be_hr_payroll -> !mail"},
                {"test_module_filter": "mail -> !mrp"},
                {"test_module_filter": "mrp -> !point_of_sale"},
                {"test_module_filter": "point_of_sale -> !pos_account_tax_python"},
                {"test_module_filter": "pos_account_tax_python -> !pos_restaurant"},
                {"test_module_filter": "pos_restaurant -> !pos_stock"},
                {"test_module_filter": "pos_stock -> !sale"},
                {"test_module_filter": "sale -> !sale_subscription"},
                {"test_module_filter": "sale_subscription -> !stock_barcode"},
                {"test_module_filter": "stock_barcode -> !test_l10n_be_hr_payroll_account"},
                {"test_module_filter": "test_l10n_be_hr_payroll_account -> !test_sale_product_configurators"},
                {"test_module_filter": "test_sale_product_configurators -> !web"},
                {"test_module_filter": "web -> web"},
                {"test_module_filter": "!web -> !website"},
                {"test_module_filter": "website -> website"},
                {"test_module_filter": "!website -> !website_sale_stock"},
                {"test_module_filter": "website_sale_stock ->"}
            ],
            "children": [{
                "name": "Test Post Install",
                "description": "Post install tests for **{{test_module_filter}}**",
                "steps": [
                    {"name": "restore", "job_type": "restore", "db_name": "all"},
                    {
                        "name": "Start post install tests",
                        "job_type": "odoo",
                        "test_tags": "-at_install,{{test_module_filter|filter_all_modules|make_module_test_tags}}",
                        "db_name": "all"
                    }
                ]
            }]
        }
    ]
}
