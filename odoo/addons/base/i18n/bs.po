"Allows users to send documents by post\n"
"=====================================================\n"
msgstr ""
"\n"
"Omogućava korisnicima slanje dokumenata poštom\n"
"=======================================================\n"

#. module: base
#: model:ir.module.module,description:base.module_snailmail_account
msgid ""
"\n"
"Allows users to send invoices by post\n"
"=====================================================\n"
msgstr ""
"\n"
