#. module: base
#. odoo-python
#: code:addons/base/models/ir_module.py:0
msgid "The method _button_immediate_install cannot be called on init or non loaded registries. Please use button_install instead."
msgstr ""
"ວິທີການ _button_immediate_install ບໍ່ສາມາດເອີ້ນໃຊ້ໃນຂະນະເລີ່ມຕົ້ນ ຫຼື ຖານຂໍ້ມູນທີ່ຍັງບໍ່ທັນໂຫຼດໄດ້. ກ"
"ະລຸນາໃຊ້ button_install ແທນ."

#. module: base
#. odoo-python
#: code:addons/base/models/ir_model.py:0
