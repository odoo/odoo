<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Group's sections -->
        <record id="view_res_groups_privilege_search" model="ir.ui.view">
            <field name="name">res.groups.privilege.search</field>
            <field name="model">res.groups.privilege</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" string="Scope"/>
                    <field name="group_ids"/>
                    <filter string="Category" name="category" context="{'group_by':'category_id'}"/>
                </search>
            </field>
        </record>
        <record id="view_res_groups_privilege_list" model="ir.ui.view">
            <field name="name">res.groups.privilege.list</field>
            <field name="model">res.groups.privilege</field>
            <field name="arch" type="xml">
                <list default_group_by="category_id">
                    <field name="name"/>
                    <field name="group_ids" widget="many2many_tags" context="{'short_display_name': True}"/>
                </list>
            </field>
        </record>
        <record id="view_res_groups_privilege_form" model="ir.ui.view">
            <field name="name">res.groups.privilege.form</field>
            <field name="model">res.groups.privilege</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <h1><field name="name" placeholder="Privilege Name"/></h1>
                        <group>
                            <group>
                                <field name="sequence" groups="base.group_no_one"/>
                                <field name="category_id" invisible="'default_category_id' in context"/>
                                <field name="placeholder"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Groups" name="groups">
                                <field name="group_ids" widget="many2many" domain="[('privilege_id', '=', False)]" context="{'default_privilege_id': id}">
                                    <list string="Groups">
                                        <field name="sequence" widget="handle"/>
                                        <field name="name"/>
                                        <field name="comment" optional="show"/>
                                        <field name="implied_ids" widget="many2many_tags" optional="hide"/>
                                        <field name="implied_by_ids" widget="many2many_tags" optional="hide"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Notes" name="notes">
                                <field name="description" placeholder="Keep track of what this scope does and why it exists..."/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_res_groups_privilege_kanban" model="ir.ui.view">
            <field name="name">res.groups.privilege.kanban</field>
            <field name="model">res.groups.privilege</field>
            <field name="arch" type="xml">
                <kanban>
                    <templates>
                        <t t-name="card" class="row">
                            <field name="category_id" class="text-muted"/>
                            <field name="name" class="fw-bolder"/>
                            <field name="group_ids" widget="many2many_tags"/>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
        <record id="action_res_groups_privilege" model="ir.actions.act_window">
            <field name="name">Scopes</field>
            <field name="res_model">res.groups.privilege</field>
            <field name="view_mode">list,kanban,form</field>
        </record>

        <!-- res.groups -->
        <record id="view_groups_search" model="ir.ui.view">
            <field name="name">res.groups.search</field>
            <field name="model">res.groups</field>
            <field name="arch" type="xml">
                <search string="Groups">
                    <field name="full_name" string="Group"/>
                    <field name="privilege_id" filter_domain="[('privilege_id.name','ilike',self)]" string="Scope"/>
                    <field name="implied_by_ids" filter_domain="[('implied_by_ids.full_name','ilike',self)]" string="Implying Group"/>
                    <field name="implied_ids" filter_domain="[('implied_ids.full_name','ilike',self)]" string="Implied Group"/>
                    <separator orientation="vertical"/>
                    <group>
                        <filter string="Scope" name="groupby_scope" context="{'group_by': 'privilege_id'}"/>
                    </group>
                </search>
            </field>
        </record>
        <record id="view_groups_list" model="ir.ui.view">
            <field name="name">res.groups.list</field>
            <field name="model">res.groups</field>
            <field name="arch" type="xml">
                <list string="Implied groups" default_order="privilege_id,name">
                    <field name="privilege_id"/>
                    <field name="name"/>
                    <field name="comment" optional="hide"/>
                    <field name="implied_ids" widget="many2many_tags" optional="hide"/>
                    <field name="implied_by_ids" widget="many2many_tags" optional="hide"/>
                </list>
            </field>
        </record>
        <record id="view_groups_form" model="ir.ui.view">
            <field name="name">res.groups.form</field>
            <field name="model">res.groups</field>
            <field name="arch" type="xml">
                <form string="Groups">
                  <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_view_implied_ids"
                            class="oe_stat_button" icon="oi-arrow-down">
                            <field name="implied_count" widget="statinfo" string="Implied Groups"/>
                        </button>
                        <button type="object" name="action_view_implied_by_ids"
                            class="oe_stat_button" icon="oi-arrow-up">
                            <field name="implied_by_count" widget="statinfo" string="Implying Groups"/>
                        </button>
                        <button type="object" name="action_view_access_ids"
                            class="oe_stat_button" icon="fa-lock">
                            <field name="access_count" widget="statinfo" string="Access Rights"/>
                        </button>
                    </div>

                    <h1>
                        <field name="name" placeholder="Group Name" required="1"/>
                    </h1>
                    <group>
                        <group>
                            <field name="comment" nolabel="1" placeholder="Keep track of what this groups does and why it exists..."/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Users" name="user_ids">
                            <field name="user_ids" context="{'search_default_filter_no_share':1}"/>
                        </page>
                        <page string="Dependencies" name="inherit_groups">
                            <group>
                                <field name="implied_ids" widget="many2many_tags" options="{'on_tag_click': 'open_form'}"/>
                                <field name="implied_by_ids" widget="many2many_tags" options="{'on_tag_click': 'open_form'}"/>
                                <field name="disjoint_ids" widget="many2many_tags" options="{'on_tag_click': 'open_form'}"/>
                            </group>
                        </page>
                        <page string="Access Rights" name="access_rights">
                            <field name="access_ids">
                                <list string="Access Rights">
                                    <field name="name" width="200px"/>
                                    <field name="model_id" width="200px"/>
                                    <field name="for_create"/>
                                    <field name="for_read"/>
                                    <field name="for_write"/>
                                    <field name="for_unlink"/>
                                    <field name="domain"/>
                                    <field name="kind" widget="label_selection" string="Type"
                                        options="{
                                            'classes': {
                                                'permission': 'success',
                                                'restriction': 'danger',
                                            }
                                        }"
                                        help="A restriction is an access rights without group that is globally applied
                                            and that cannot be bypassed. A permission is an access right associated with a group
                                            that is constrained by their domain and the restrictions"/>
                                </list>
                            </field>
                        </page>
                        <page string="Menus" name="menus">
                            <field name="menu_access"/>
                        </page>
                        <page string="Views" name="views">
                            <field name="view_access" groups="base.group_system">
                                <list>
                                    <field name="name" string="Name"/>
                                    <field name="type"/>
                                    <field name="model_id" string="Model"/>
                                </list>
                            </field>
                        </page>
                        <page string="Settings" name="settings">
                             <div class="row mt16 o_settings_container">
                                <setting help="Sets in which scope this group appears on the users access rights page">
                                    <field name="privilege_id" placeholder="No scope"/>
                                    <div>
                                        <button type="action" name="base.action_res_groups_privilege" string="Manage Scopes" icon="oi-arrow-right" class="oe_link"/>
                                    </div>
                                </setting>
                                <setting help="Defines the number of days the API keys will be alive for users in this group">
                                    <field name="api_key_duration" class="oe_inline o_input_5ch"/><span> days</span>
                                </setting>
                            </div>
                        </page>
                    </notebook>
                  </sheet>
                </form>
            </field>
        </record>
        <record id="view_groups_kanban" model="ir.ui.view">
            <field name="name">res.groups.kanban</field>
            <field name="model">res.groups</field>
            <field name="arch" type="xml">
                <kanban>
                    <templates>
                        <t t-name="card" class="row">
                            <field name="privilege_id" class="text-muted"/>
                            <field name="name" class="fw-bolder"/>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
        <record id="action_res_groups" model="ir.actions.act_window">
            <field name="name">Groups</field>
            <field name="res_model">res.groups</field>
            <field name="view_mode">list,kanban,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No groups found. Let's create one!
                </p>
                <p>
                    Groups allow centralize and manage user access rights.<br/>
                    Define which models, menus and views the users can interact with,
                    or enforce strict record-level security rules.
                </p>
            </field>
        </record>

        <record id="view_default_groups_form" model="ir.ui.view">
            <field name="name">res.groups default groups form</field>
            <field name="model">res.groups</field>
            <field name="priority">100</field>
            <field name="arch" type="xml">
                <form string="Groups">
                  <sheet>
                    <group>
                        <field name="implied_ids" widget="res_user_group_ids" nolabel="1" colspan="2"/>
                    </group>
                  </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
