[options]
; Example only. The real local runtime file is generated by:
;   make prod-config
; Fill `.env` first, then generate `deploy/odoo/kodoo.prod.local.conf`.

admin_passwd = change-me-in-.env

db_host = db
db_port = 5432
db_user = kodoo
db_password = change-me-in-.env

addons_path = /usr/lib/python3/dist-packages/odoo/addons,/mnt/extra-addons,/mnt/custom-addons,/mnt/custom-addons/public_sector,/mnt/custom-addons/knowledge,/mnt/custom-addons/om_account_accountant-19.0.1.0.3

proxy_mode = True
list_db = True
dbfilter = ^%d$

http_port = 8069
http_interface = 0.0.0.0
gevent_port = 8072

; Tune according to your server resources.
workers = 2
max_cron_threads = 1
limit_time_cpu = 600
limit_time_real = 1200
limit_memory_hard = 2684354560
limit_memory_soft = 2147483648

log_level = info
