[options]
; Example only. The real local runtime file is generated by:
;   make dev-host-config
; Fill `.env.make` first, then generate `deploy/odoo/kodoo.dev-host.local.conf`.

admin_passwd = change-me-in-.env.make

db_host = 127.0.0.1
db_port = 5432
db_user = kodoo
db_password = change-me-in-.env.make

addons_path = addons,custom_addons,custom_addons/public_sector,custom_addons/knowledge,custom_addons/om_account_accountant-19.0.1.0.3

proxy_mode = False
list_db = True

http_port = 8069
http_interface = 127.0.0.1

; Keep local dev simple and avoid extra worker/gevent processes.
workers = 0
max_cron_threads = 1

log_level = info
