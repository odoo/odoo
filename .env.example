# --- Odoo ---
ODOO_ADMIN_PASSWD=change_me
ODOO_LOG_LEVEL=info
ODOO_PROXY_MODE=False

# Domain (production via Traefik)
ODOO_DOMAIN=odoo.example.com

# Ports
ODOO_HTTP_PORT=8069
ODOO_LONGPOLLING_PORT=8072

# Production tuning (workers)
ODOO_WORKERS=2
ODOO_MAX_CRON_THREADS=1

# Resource limits
ODOO_LIMIT_TIME_CPU=60
ODOO_LIMIT_TIME_REAL=120
ODOO_LIMIT_MEMORY_SOFT=2147483648
ODOO_LIMIT_MEMORY_HARD=2684354560

# Traefik / Let's Encrypt
TRAEFIK_ACME_EMAIL=admin@example.com

# --- Postgres (used by Odoo) ---
DB_HOST=db
DB_PORT=5432
DB_USER=odoo
DB_PASSWORD=odoo
DB_NAME=postgres

# --- Postgres container init (compose) ---
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo
POSTGRES_DB=postgres

# --- Docker image ---
# Example: yourdockerhubuser/odoo-community:19.0
ODOO_IMAGE=yourdockerhubuser/odoo-community:19.0
