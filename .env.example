# Kodoo local/deploy environment template
# Copy to .env and fill the required secrets.

DOMAIN=kodoo.online
EMAIL=
CLOUDFLARED_TOKEN=

PROD_DB_NAME=kodoo
PROD_DB_USER=kodoo
PROD_DB_PASSWORD=
PROD_ADMIN_PASSWORD=
PROD_LIST_DB=True
# Recommended tenant-per-subdomain routing:
# kodoo.online -> database "kodoo"
# example-corp.kodoo.online -> database "example-corp"
PROD_DBFILTER=^%d$

DEV_HOST_HTTP_PORT=8070
DEV_HOST_DB=kodoo
DEV_HOST_TEST_DB=ktest
DEV_HOST_ADMIN_PASSWORD=

DEV_PROJECT_HTTP_PORT=8071
DEV_PROJECT_DB=ktest
DEV_PROJECT_ADMIN_PASSWORD=

PG_LOCAL_HOST=127.0.0.1
PG_LOCAL_PORT=5432
PG_LOCAL_USER=kodoo
PG_LOCAL_PASSWORD=

DOCKER_DB_BIND_HOST=127.0.0.1
DOCKER_DB_HOST_PORT=5433
DOCKER_DB_REPLICA_BIND_HOST=127.0.0.1
DOCKER_DB_REPLICA_HOST_PORT=5434
DB_REPLICA_USER=replicator
# Optional: defaults to PROD_DB_PASSWORD when empty.
DB_REPLICA_PASSWORD=
DB_REPLICA_SLOT=kodoo_replica
DB_REPLICA_MAX_WAL_SENDERS=10
DB_REPLICA_MAX_SLOTS=10
# Keep localhost for same-machine access only.
# Use 0.0.0.0 when you need the tunnel/local nginx endpoint reachable from another PC on the LAN.
LOCAL_BIND_HOST=127.0.0.1
LOCAL_HTTP_PORT=8069

OLLAMA_MODEL=qwen3.5:0.8b
TUI_REFRESH_SECONDS=3
TUI_LOG_LINES=20
SMOKE_PUBLIC=1
